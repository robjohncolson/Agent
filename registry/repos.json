    "purpose": "Original DOGE grid trading bot",
    "deploy": null,
    "depends_on": [],
    "entry_points": [],
    "domain": "trading"
  },
  "grid-bot-v3": {
    "remote": "git@github.com:robjohncolson/grid-bot-v3.git",
    "purpose": "Kraken DOGE grid trading bot with R/Shiny dashboard and Haskell state machine",
    "deploy": "railway",
    "depends_on": [],
    "entry_points": ["bot.py", "app.R", "StateMachine.hs"],
    "domain": "trading"
  },
  "cmd-line-tools": {
    "remote": "git@github.com:robjohncolson/cmd-line-tools.git",
    "purpose": "Personal CLI utilities",
    "deploy": null,
    "depends_on": [],
    "entry_points": [],
    "domain": "tools"
  },
  "agent": {
    "remote": "ssh://git@github.com/robjohncolson/Agent.git",
