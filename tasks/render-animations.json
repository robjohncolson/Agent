{
  "$schema": "../schema/task.schema.json",
  "id": "render-animations",
  "name": "Render Manim animations",
  "type": "node-script",
  "worker": "scripts/render-animations.mjs",
  "inputs": {
    "unit": "{{unit}}",
    "lesson": "{{lesson}}",
    "quality": "m"
  },
  "outputs": {
    "registry_key": "animations"
  },
  "preconditions": {
    "registry_status": { "key": "animations", "not": "done" }
  },
  "on_failure": {
    "strategy": "skip"
  },
  "timeout_minutes": 10
}
