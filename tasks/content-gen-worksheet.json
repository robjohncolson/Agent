{
  "$schema": "../schema/task.schema.json",
  "id": "content-gen-worksheet",
  "name": "Generate worksheet + grading prompts via Codex",
  "type": "node-script",
  "worker": "scripts/workers/codex-content-gen.mjs",
  "inputs": {
    "task": "worksheet",
    "unit": "{{unit}}",
    "lesson": "{{lesson}}"
  },
  "outputs": {
    "files": "u{{unit}}_lesson{{lesson}}_live.html",
    "registry_key": "worksheet"
  },
  "preconditions": {
    "registry_status": { "key": "worksheet", "not": "done" }
  },
  "on_failure": {
    "strategy": "fail"
  },
  "timeout_minutes": 15
}
