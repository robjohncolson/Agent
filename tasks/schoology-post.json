{
  "$schema": "../schema/task.schema.json",
  "id": "schoology-post",
  "name": "Post lesson materials to Schoology",
  "type": "cdp-browser",
  "worker": "scripts/post-to-schoology.mjs",
  "inputs": {
    "unit": "{{unit}}",
    "lesson": "{{lesson}}",
    "blooket": "{{blooket}}",
    "auto-urls": true,
    "with-videos": true,
    "no-prompt": true,
    "folder-path": "{{folder_path}}",
    "create-folder": "{{folder_title}}",
    "folder-desc": "{{folder_desc}}",
    "target-folder": "{{schoologyFolder}}",
    "courses": "{{courses}}"
  },
  "outputs": {
    "registry_key": "schoology"
  },
  "preconditions": {
    "requires_cdp": true,
    "registry_status": { "key": "schoology", "not": "done" }
  },
  "on_failure": {
    "strategy": "skip"
  },
  "timeout_minutes": 15
}
