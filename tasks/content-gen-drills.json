{
  "$schema": "../schema/task.schema.json",
  "id": "content-gen-drills",
  "name": "Generate drill cartridge definitions via Codex",
  "type": "node-script",
  "worker": "scripts/workers/codex-content-gen.mjs",
  "inputs": {
    "task": "drills",
    "unit": "{{unit}}",
    "lesson": "{{lesson}}"
  },
  "outputs": {
    "registry_key": "drills"
  },
  "preconditions": {
    "registry_status": { "key": "drills", "not": "done" }
  },
  "on_failure": {
    "strategy": "fail"
  },
  "timeout_minutes": 15
}
