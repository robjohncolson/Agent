{
  "$schema": "../schema/task.schema.json",
  "id": "upload-animations",
  "name": "Upload rendered animations to Supabase",
  "type": "node-script",
  "worker": "scripts/upload-animations.mjs",
  "inputs": {
    "unit": "{{unit}}",
    "lesson": "{{lesson}}"
  },
  "outputs": {
    "registry_key": "animationUpload"
  },
  "preconditions": {
    "registry_status": { "key": "animationUpload", "not": "done" }
  },
  "on_failure": {
    "strategy": "skip"
  },
  "timeout_minutes": 10
}
