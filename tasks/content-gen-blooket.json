{
  "$schema": "../schema/task.schema.json",
  "id": "content-gen-blooket",
  "name": "Generate Blooket quiz CSV via Codex",
  "type": "codex-agent",
  "worker": "codex",
  "inputs": {
    "unit": "{{unit}}",
    "lesson": "{{lesson}}",
    "video_context_dir": "u{{unit}}"
  },
  "outputs": {
    "files": "u{{unit}}_l{{lesson}}_blooket.csv",
    "registry_key": "blooketCsv"
  },
  "preconditions": {
    "registry_status": { "key": "blooketCsv", "not": "done" }
  },
  "on_failure": {
    "strategy": "fail"
  },
  "timeout_minutes": 15
}
