{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Parallel Codex Runner Manifest",
  "description": "Declarative plan for Phase 5 branch-per-agent Codex execution.",
  "type": "object",
  "required": ["version", "batch_name", "target_branch", "agents"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "batch_name": {
      "type": "string",
      "minLength": 1
    },
    "target_branch": {
      "type": "string",
      "minLength": 1
    },
    "base_ref": {
      "type": "string",
      "description": "Git ref all agent branches are created from."
    },
    "codex_approval_mode": {
      "type": "string",
      "default": "suggest"
    },
    "verify_commands": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence_observations": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1}
    },
    "cc_merge_order": {
      "type": "array",
      "items": {"type": "string"}
    },
    "contracts": {
      "type": "array",
      "items": {"$ref": "#/$defs/contract"}
    },
    "merge": {
      "$ref": "#/$defs/merge"
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/agent"}
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": ["name", "prompt_file", "owned_paths"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "prompt_file": {"type": "string", "minLength": 1},
        "branch": {"type": "string"},
        "depends_on": {
          "type": "array",
          "items": {"type": "string"}
        },
        "owned_paths": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "verify_commands": {
          "type": "array",
          "items": {"type": "string"}
        },
        "allow_no_changes": {"type": "boolean"},
        "merge_enabled": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "contract_language": {
      "type": "object",
      "required": ["agent", "path", "symbol", "json_shape"],
      "properties": {
        "agent": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "symbol": {"type": "string", "minLength": 1},
        "json_shape": {}
      },
      "additionalProperties": true
    },
    "contract": {
      "type": "object",
      "required": ["name", "producer_agent", "consumer_agents", "python", "r"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "producer_agent": {"type": "string", "minLength": 1},
        "consumer_agents": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "python": {"$ref": "#/$defs/contract_language"},
        "r": {"$ref": "#/$defs/contract_language"}
      },
      "additionalProperties": true
    },
    "merge": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "branch": {"type": "string"},
        "commit_prefix": {"type": "string"},
        "verify_commands": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    }
  }
}
