{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project State",
  "description": "Per-project checkpoint state used to restore implementation and deployment context.",
  "type": "object",
  "required": [
    "state_version",
    "project_name",
    "status",
    "last_updated",
    "commits",
    "deployment",
    "open_issues"
  ],
  "properties": {
    "state_version": {
      "type": "integer",
      "minimum": 1
    },
    "project_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["planning", "implementing", "deploying", "running", "paused"]
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "hash"],
        "properties": {
          "label": {"type": "string"},
          "hash": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    },
    "deployment": {
      "type": "object",
      "required": ["platform", "status"],
      "properties": {
        "platform": {"type": "string"},
        "status": {"type": "string"},
        "last_verified_at": {
          "type": "string",
          "format": "date-time"
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "status"],
            "properties": {
              "name": {"type": "string"},
              "status": {"type": "string"},
              "notes": {"type": "string"}
            }
          }
        }
      }
    },
    "open_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "status": {"type": "string", "enum": ["open", "in_progress", "blocked"]},
          "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "notes": {"type": "string"},
          "source_observations": {
            "type": "array",
            "items": {"type": "integer"}
          }
        }
      }
    }
  }
}
