      resize: vertical;\n   131→        }\n   132→        .exit-ticket {\n   133→            border: 2px solid #003366;\n   134→            border-radius: 6px;\n   135→            padding: 12px;\n   136→            background: #f0f4ff;\n   137→            margin-top: 18px;\n   138→        }\n   139→\n   140→        /* Formula box */\n   141→        .formula-box {\n   142→            border: 2px solid #667eea;\n   143→            border-radius: 8px;\n   144→            padding: 15px;\n   145→            background: #f8f9ff;\n   146→            margin: 15px 0;\n   147→            text-align: center;\n   148→        }\n   149→        .formula-box h4 {\n   150→            margin: 0 0 10px 0;\n   151→            color: #667eea;\n   152→        }\n   153→        .formula {\n   154→            font-size: 1.2em;\n   155→            font-family: 'Times New Roman', serif;\n   156→            margin: 8px 0;\n   157→        }\n   158→\n   159→        /* Data table */\n   160→        .data-table {\n   161→            width: 100%;\n   162→            border-collapse: collapse;\n   163→            margin: 10px 0;\n   164→            font-size: 0.95em;\n   165→        }\n   166→        .data-table th, .data-table td {\n   167→            border: 1px solid #ccc;\n   168→            padding: 8px;\n   169→            text-align: center;\n   170→        }\n   171→        .data-table th {\n   172→            background: #003366;\n   173→            color: white;\n   174→        }\n   175→        .data-table td input {\n   176→            width: 60px;\n   177→            text-align: center;\n   178→        }\n   179→\n   180→        /* Control buttons */\n   181→        .controls {\n   182→            display: flex;\n   183→            gap: 10px;\n   184→            margin: 20px 0;\n   185→            flex-wrap: wrap;\n   186→        }\n   187→        .controls button {\n   188→            padding: 8px 16px;\n   189→            border: none;\n   190→            border-radius: 4px;\n   19