{ font-size: 0.8em; color: #666; margin-top: 4px; }\n   291→\n   292→        /* Score display */\n   293→        #scoreDisplay {\n   294→            display: none;\n   295→            padding: 10px 15px;\n   296→            background: #e8f5e9;\n   297→            border: 1px solid #4caf50;\n   298→            border-radius: 4px;\n   299→            margin: 10px 0;\n   300→            font-weight: bold;\n   301→        }\n   302→        #scoreDisplay.visible {\n   303→            display: inline-block;\n   304→        }\n   305→\n   306→        /* Aggregate drawer & buttons */\n   307→        .aggregate-trigger {\n   308→            background: #e3f2fd;\n   309→            border: 1px solid #90caf9;\n   310→            color: #1565c0;\n   311→            padding: 3px 8px;\n   312→            border-radius: 4px;\n   313→            cursor: pointer;\n   314→            font-size: 0.85em;\n   315→            margin-left: 10px;\n   316→        }\n   317→        .aggregate-trigger:hover {\n   318→            background: #bbdefb;\n   319→        }\n   320→        .aggregate-drawer {\n   321→            position: fixed;\n   322→            top: 0;\n   323→            right: -380px;\n   324→            width: 360px;\n   325→            height: 100vh;\n   326→            background: #fff;\n   327→            box-shadow: -2px 0 10px rgba(0,0,0,0.15);\n   328→            transition: right 0.25s ease;\n   329→            z-index: 1000;\n   330→            overflow-y: auto;\n   331→            padding: 20px;\n   332→        }\n   333→        .aggregate-drawer.open {\n   334→            right: 0;\n   335→        }\n   336→        .drawer-header {\n   337→            display: flex;\n   338→            justify-content: space-between;\n   339→            align-items: center;\n   340→            border-bottom: 1px solid #ccc;\n   341→            padding-bottom: 10px;\n   342→            margin-bottom: 15px;\n   343→        }\n   344→        .drawer-header h3 { margin: 0; color: #003366; }\n   345→        .drawer-close {\n   346→            background: none;\n   347→            border: none;\n   348→            font-size: 1.5em;\n   349→            cursor: pointer;\n   350→            color: #666;\n   351→        }\n   352→        .drawer-content { font-size: 0.95em; }\n   353→        .bar-chart { margin: 10px 0; }\n   354→        .bar-row {\n   355→            display: flex;\n   356→            align-items: center;\n   357→            margin: 4px 0;\n   358→        }\n   359→        .bar-label {\n   360→            width: 100px;\n   361→            font-size: 0.85em;\n   362→            overflow: hidden;\n   363→            text-overflow: ellipsis;\n   364→            white-space: nowrap;\n   365→        }\n   366→        .bar-container {\n   367→            flex: 1;\n   368→            height: 18px;\n   369→            background: #eee;\n   370→            border-radius: 3px;\n   371→            overflow: hidden;\n   372→            margin: 0 8px;\n   373→        }\n   374→        .bar-fill {\n   375→            height: 100%;\n   376→            background: linear-gradient(90deg, #667eea, #764ba2);\n   377→            border-radius: 3px;\n   378→            transition: width 0.3s ease;\n   379→        }\n   380→        .bar-count {\n   381→            width: 35px;\n   382→            text-align: right;\n   383→            font-size: 0.85em;\n   384→            color: #666;\n   385→        }\n   386→\n   387→        /* Save indicator */\n   388→        .save-indicator {\n   389→            font-size: 0.8em;\n   390→            color: #28a745;\n   391→            margin-left: 8px;\n   392→            opacity: 0;\n   393→            transition: opacity 0.2s ease;\n   394→        }\n   395→        .save-indicator.visible {\n   396→            opacity: 1;\n   397→        }\n   398→\n   399→        /* Upload particle */\n   400→        .upload-particle {\n   401→            position: absolute;\n   402→            font-size: 0.9em;\n   403→            color: #667eea;\n   404→            pointer-events: none;\n   405→            animation: floatUp 0.9s ease-out forwards;\n   406→        }\n   407→        @keyframes floatUp {\n   408→            0% { opacity: 1; transform: translateY(0); }\n   409→            100% { opacity: 0; transform: translateY(-16px); }\n   410→        }\n   411→\n   412→        /* Print styles */\n   413→        @media print {\n   414→            .controls, .aggregate-trigger, .aggregate-drawer, .save-indicator,\n   415→            .appeal-section, .ai-feedback, .btn-ai { display: none !important; }\n   416→            .blank { border-bottom: 1px solid #000 !important; background: transparent !important; }\n   417→            body { background: white; }\n   418→            .section { page-break-inside: avoid; }\n   419→            .exit-ticket { page-break-before: auto; }\n   420→        }\n   421→    </style>\n   422→</head>\n   423→<body>\n   424→\n   425→    <div class=\"header\">\n   426→        <span class=\"header-left\">AP Statistics</span>\n   427→        <span class=\"header-center\">Unit 5</span>\n   428→        <span class=\"header-right\">Sampling Distributions</span>\n   429→    </div>\n   430→\n   431→    <h1>Topic 5.4: Biased and Unbiased Point Estimates</h1>\n   432→    <div class=\"subtitle\">When Does a Sample Statistic \"Hit the Target\" on Average?</div>\n   433→    <div class=\"worksheet-label\">Video Follow-Along Worksheet</div>\n   434→\n   435→    <div class=\"student-info\">\n   436→        <div><label>Name:</label> <input type=\"text\" id=\"worksheetName\" style=\"width:160px;\"></div>\n   437→        <div><label>Period:</label> <input type=\"text\" id=\"worksheetPeriod\" style=\"width:40px;\"></div>\n   438→        <div><label>Username:</label> <input type=\"text\" id=\"worksheetUsername\" style=\"width:120px;\" placeholder=\"for class sync\"></div>\n   439→    </div>\n   440→\n   441→    <div class=\"controls\">\n   442→        <button class=\"btn-check\" onclick=\"checkAnswers()\">&#10003; Check Answers</button>\n   443→        <button class=\"btn-show\" onclick=\"showAnswers()\">&#128065; Show Answers</button>\n   444→        <button class=\"btn-reset\" onclick=\"resetAnswers()\">&#8634; Reset</button>\n   445→        <button class=\"btn-print\" onclick=\"window.print()\">&#128424; Print</button>\n   446→        <button class=\"btn-ai\" onclick=\"gradeAllReflections()\">&#129302; Grade My Reflections</button>\n   447→        <span id=\"scoreDisplay\"></span>\n   448→    </div>\n   449→\n   450→    <div class=\"objective-box\">\n   451→        <strong>Learning Objectives:</strong>\n   452→        <ul style=\"margin: 8px 0 0 0; padding-left: 20px;\">\n   453→            <li><strong>UNC-3.I:</strong> Explain why an estimator is or is not unbiased.</li>\n   454→            <li><strong>UNC-3.J:</strong> Calculate estimates for a population parameter.</li>\n   455→        </ul>\n   456→        <strong style=\"margin-top: 10px; display: block;\">Essential Knowledge:</strong>\n   457→        <ul style=\"margin: 8px 0 0 0; padding-left: 20px;\">\n   458→            <li>An estimator is unbiased if, on average, it equals the population parameter.</li>\n   459→            <li>A sample statistic is a point estimator of the corresponding population parameter.</li>\n   460→            <li>An estimator exhibits variability that can be modeled using probability.</li>\n   461→        </ul>\n   462→    </div>\n   463→\n   464→    <div class=\"vocab-box\">\n   465→        <h3>Key Vocabulary</h3>\n   466→        <table class=\"vocab-table\">\n   467→            <tr>\n   468→                <td>Point Estimator</td>\n   469→                <td>The sample statistic used to estimate a population parameter (e.g., <span style=\"text-decoration: overline;\">x</span> estimates &mu;)</td>\n   470→            </tr>\n   471→            <tr>\n   472→                <td>Point Estimate</td>\n   473→                <td>The specific numerical value of the statistic from a particular sample (e.g., <span style=\"text-decoration: overline;\">x</span> = 2.3)</td>\n   474→            </tr>\n   475→            <tr>\n   476→                <td>Unbiased Estimator</td>\n   477→                <td>A statistic whose sampling distribution is centered at the true parameter &mdash; on average, it equals the parameter</td>\n   478→            </tr>\n   479→            <tr>\n   480→                <td>Biased Estimator</td>\n   481→                <td>A statistic whose sampling distribution is <em>not</em> centered at the true parameter &mdash; it systematically over- or under-estimates</td>\n   482→            </tr>\n   483→            <tr>\n   484→                <td>Sampling Variability</td>\n   485→                <td>The natural variation in a statistic from sample to sample; can be modeled using probability</td>\n   486→            </tr>\n   487→        </table>\n   488→    </div>\n   489→\n   490→    <!-- ============================================================ -->\n   491→    <!-- SECTION 1: Sample Mean as an Unbiased Estimator               -->\n   492→    <!-- ============================================================ -->\n   493→    <div class=\"section\">\n   494→        <div class=\"section-header\">\n   495→            <h2>Part 1: The Sample Mean &mdash; An Unbiased Estimator</h2>\n   496→            <span class=\"timestamp\">[0:00 &ndash; 2:40]</span>\n   497→        </div>\n   498→\n   499→        <div class=\"note-box\">\n   500→            <strong>Setup &mdash; Weimaraner Dogs:</strong>\n   501→            <span class=\"ts\">[0:19]</span>\n   502→            A breeder has 5 dogs with ages: <strong>0, 2, 5, 8, 10</strong>. This is the entire population. Population mean &mu; = 5. We randomly select samples of 3 dogs.\n   503→        </div>\n   504→\n   505→        <div class=\"question\">\n   506→            <span class=\"question-number\">1.</span>\n   507→            <span class=\"ts\">[1:21]</span>\n   508→            One sample gives ages {0, 2, 5} with <span style=\"text-decoration: overline;\">x</span> = 2.3. The <em>statistic</em> <span style=\"text-decoration: overline;\">x</span> is called the <input type=\"text\" class=\"blank\" data-answer=\"point estimator\" style=\"width:130px;\">, and the specific value 2.3 is called the <input type=\"text\" class=\"blank\" data-answer=\"point estimate\" style=\"width:120px;\">.\n   509→        </div>\n   510→\n   511→        <div class=\"question\">\n   512→            <span class=\"question-number\">2.</span>\n   513→            <span class=\"ts\">[1:35]</span>\n   514→            This single sample gave <span style=\"text-decoration: overline;\">x</span> = 2.3, which is <em>not</em> equal to &mu; = 5. Does this one \"miss\" make <span style=\"text-decoration: overline;\">x</span> a bad estimator? <input type=\"text\" class=\"blank\" data-answer=\"no\" style=\"width:35px;\">\n   515→            <span class=\"hint\">Think about what \"on average\" means.</span>\n   516→        </div>\n   517→\n   518→        <div class=\"question\">\n   519→            <span class=\"question-number\">3.</span>\n   520→            <span class=\"ts\">[1:47]</span>\n   521→            The video lists <strong>all possible</strong> samples of size 3 and their means. The mean of all those sample means turns out to be <input type=\"text\" class=\"blank\" data-answer=\"5\" style=\"width:35px;\">, which equals the population mean &mu;.\n   522→        </div>\n   523→\n   524→        <div class=\"question\">\n   525→            <span class=\"question-number\">4.</span>\n   526→            <span class=\"ts\">[2:27]</span>\n   527→            Because the average value of <span style=\"text-decoration: overline;\">x</span> across all possible samples equals &mu;, we say <span style=\"text-decoration: overline;\">x</span> is an <input type=\"text\" class=\"blank\" data-answer=\"unbiased\" style=\"width:90px;\"> estimator of &mu;.\n   528→        </div>\n   529→\n   530→        <div class=\"model-box\">\n   531→            <strong>Key Idea:</strong>\n   532→            <span class=\"ts\">[2:18]</span>\n   533→            Individual sample means <em>vary</em> around &mu; &mdash; some are too high, some too low. But the sampling distribution is <input type=\"text\" class=\"blank\" data-answer=\"centered|centered at\" style=\"width:90px;\"> at the population mean. That's what \"unbiased\" means: no systematic tendency to miss in one direction.\n   534→        </div>\n   535→    </div>\n   536→\n   537→    <!-- ============================================================ -->\n   538→    <!-- SECTION 2: Sample Range as a Biased Estimator                 -->\n   539→    <!-- ============================================================ -->\n   540→    <div class=\"section\">\n   541→        <div class=\"section-header\">\n   542→            <h2>Part 2: The Sample Range &mdash; A Biased Estimator</h2>\n   543→            <span class=\"timestamp\">[2:41 &ndash; 4:05]</span>\n   544→        </div>\n   545→\n   546→        <div class=\"question\">\n   547→            <span class=\"question-number\">5.</span>\n   548→            <span class=\"ts\">[2:41]</span>\n   549→            The population range is 10 &minus; 0 = <input type=\"text\" class=\"blank\" data-answer=\"10\" style=\"width:35px;\">. The sample {0, 2, 5} has a range of <input type=\"text\" class=\"blank\" data-answer=\"5\" style=\"width:35px;\">.\n   550→        </div>\n   551→\n   552→        <div class=\"question\">\n   553→            <span class=\"question-number\">6.</span>\n   554→            <span class=\"ts\">[3:17]</span>\n   555→            After computing the range for <strong>all possible</strong> samples of size 3, the mean of all sample ranges is <input type=\"text\" class=\"blank\" data-answer=\"7.8\" style=\"width:40px;\">. Since this does <strong>not</strong> equal the population range (10), the sample range is a <input type=\"text\" class=\"blank\" data-answer=\"biased\" style=\"width:70px;\"> estimator.\n   556→        </div>\n   557→\n   558→        <div class=\"question\">\n   559→            <span class=\"question-number\">7.</span>\n   560→            <span class=\"ts\">[3:27]</span>\n   561→            On the dot plot of all sample ranges, the values cluster to the <input type=\"text\" class=\"blank\" data-answer=\"left\" style=\"width:50px;\"> of the population range. This means the sample range systematically <input type=\"text\" class=\"blank\" data-answer=\"underestimates\" style=\"width:130px;\"> the population range.\n   562→        </div>\n   563→\n   564→        <div class=\"question\">\n   565→            <span class=\"question-number\">8.</span>\n   566→            <span class=\"ts\">[3:27]</span>\n   567→            <strong>Why is this bias predictable?</strong> A sample of 3 dogs drawn from a population of 5 can never include <em>both</em> the youngest and oldest dog every time. So the sample range can never be <input type=\"text\" class=\"blank\" data-answer=\"larger|greater|bigger\" style=\"width:70px;\"> than the population range &mdash; it can only equal it or fall short.\n   568→        </div>\n   569→    </div>\n   570→\n   571→    <!-- ============================================================ -->\n   572→    <!-- SECTION 3: Key Takeaways                                      -->\n   573→    <!-- ============================================================ -->\n   574→    <div class=\"section\">\n   575→        <div class=\"section-header\">\n   576→            <h2>Part 3: Key Takeaways</h2>\n   577→            <span class=\"timestamp\">[4:05 &ndash; 4:32]</span>\n   578→        </div>\n   579→\n   580→        <div class=\"model-box\">\n   581→            <span class=\"ts\">[4:07]</span>\n   582→            <ol style=\"margin: 5px 0; padding-left: 20px;\">\n   583→                <li>A sample statistic is a <input type=\"text\" class=\"blank\" data-answer=\"point estimator\" style=\"width:120px;\"> of the corresponding population parameter.</li>\n   584→                <li>Estimators exhibit <input type=\"text\" class=\"blank\" data-answer=\"variability\" style=\"width:90px;\"> that can be modeled using probability.</li>\n   585→                <li>An estimator is unbiased if, <input type=\"text\" class=\"blank\" data-answer=\"on average\" style=\"width:90px;\">, it equals the population parameter.</li>\n   586→            </ol>\n   587→        </div>\n   588→    </div>\n   589→\n   590→    <!-- ============================================================ -->\n   591→    <!-- REFLECTION SECTION                                            -->\n   592→    <!-- ============================================================ -->\n   593→    <div class=\"section\">\n   594→        <div class=\"section-header\">\n   595→            <h2>Reflection Questions</h2>\n   596→            <span class=\"timestamp\">[AI-Graded]</span>\n   597→        </div>\n   598→\n   599→        <div class=\"question\">"}]},"uuid":"05cd1e6e-f43c-457c-9e22-59ad7d132f82","timestamp":"2026-03-05T02:44:46.955Z","toolUseResult":{"type":"text","file":{"filePath":"C:\\Users\\ColsonR\\apstats-live-worksheet\\u5_lesson4_live.html","content":"            background: #003366;\n            color: #fff;\n        }\n        .btn-show {\n            background: #6c757d;\n            color: #fff;\n        }\n        .btn-reset {\n            background: #dc3545;\n            color: #fff;\n        }\n        .btn-print {\n            background: #28a745;\n            color: #fff;\n        }\n        .btn-ai {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: #fff;\n        }\n\n        /* AI Feedback Styles */\n        .ai-feedback {\n            margin-top: 8px;\n            padding: 10px;\n            background: #f8f9ff;\n            border: 1px solid #d0d7ff;\n            border-radius: 4px;\n            font-size: 0.9em;\n        }\n        .ai-feedback-header {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            margin-bottom: 6px;\n        }\n        .score-badge {\n            padding: 2px 8px;\n            border-radius: 4px;\n            font-weight: bold;\n            font-size: 0.85em;\n        }\n        .score-badge.score-E { background: #d4edda; color: #155724; }\n        .score-badge.score-P { background: #fff3cd; color: #856404; }\n        .score-badge.score-I { background: #f8d7da; color: #721c24; }\n\n        .ai-feedback-body { color: #444; }\n        .ai-feedback-matched { color: #155724; margin-top: 4px; }\n        .ai-feedback-missing { color: #856404; margin-top: 4px; }\n        .ai-feedback-suggestion { color: #004085; margin-top: 4px; font-style: italic; }\n\n        textarea.graded-E { border-color: #28a745; background: #f8fff9; }\n        textarea.graded-P { border-color: #ffc107; background: #fffef5; }\n        textarea.graded-I { border-color: #dc3545; background: #fff8f8; }\n\n        /* Appeal system styles */\n        .appeal-section { margin-top: 8px; }\n        .appeal-btn {\n            background: none;\n            border: 1px solid #6c757d;\n            color: #6c757d;\n            padding: 4px 10px;\n            border-radius: 4px;\n            cursor: pointer;\n            font-size: 0.85em;\n        }\n        .appeal-btn:hover { background: #f0f0f0; }\n        .appeal-form {\n            display: none;\n            margin-top: 8px;\n            padding: 10px;\n            background: #fff;\n            border: 1px solid #ccc;\n            border-radius: 4px;\n        }\n        .appeal-form.visible { display: block; }\n        .appeal-form textarea {\n            min-height: 60px;\n            margin-bottom: 8px;\n        }\n        .appeal-form button {\n            margin-right: 8px;\n        }\n        .appeal-result {\n            margin-top: 8px;\n            padding: 8px;\n            border-radius: 4px;\n            font-size: 0.9em;\n        }\n        .appeal-result.upgraded { background: #d4edda; color: #155724; }\n        .appeal-result.maintained { background: #fff3cd; color: #856404; }\n        .appeal-count { font-size: 0.8em; color: #666; margin-top: 4px; }\n\n        /* Score display */\n        #scoreDisplay {\n            display: none;\n            padding: 10px 15px;\n            background: #e8f5e9;\n            border: 1px solid #4caf50;\n            border-radius: 4px;\n            margin: 10px 0;\n            font-weight: bold;\n        }\n        #scoreDisplay.visible {\n            display: inline-block;\n        }\n\n        /* Aggregate drawer & buttons */\n        .aggregate-trigger {\n            background: #e3f2fd;\n            border: 1px solid #90caf9;\n            color: #1565c0;\n            padding: 3px 8px;\n            border-radius: 4px;\n            cursor: pointer;\n            font-size: 0.85em;\n            margin-left: 10px;\n        }\n        .aggregate-trigger:hover {\n            background: #bbdefb;\n        }\n        .aggregate-drawer {\n            position: fixed;\n            top: 0;\n            right: -380px;\n            width: 360px;\n            height: 100vh;\n            background: #fff;\n            box-shadow: -2px 0 10px rgba(0,0,0,0.15);\n            transition: right 0.25s ease;\n            z-index: 1000;\n            overflow-y: auto;\n            padding: 20px;\n        }\n        .aggregate-drawer.open {\n            right: 0;\n        }\n        .drawer-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            border-bottom: 1px solid #ccc;\n            padding-bottom: 10px;\n            margin-bottom: 15px;\n        }\n        .drawer-header h3 { margin: 0; color: #003366; }\n        .drawer-close {\n            background: none;\n            border: none;\n            font-size: 1.5em;\n            cursor: pointer;\n            color: #666;\n        }\n        .drawer-content { font-size: 0.95em; }\n        .bar-chart { margin: 10px 0; }\n        .bar-row {\n            display: flex;\n            align-items: center;\n            margin: 4px 0;\n        }\n        .bar-label {\n            width: 100px;\n            font-size: 0.85em;\n            overflow: hidden;\n            text-overflow: ellipsis;\n            white-space: nowrap;\n        }\n        .bar-container {\n            flex: 1;\n            height: 18px;\n            background: #eee;\n            border-radius: 3px;\n            overflow: hidden;\n            margin: 0 8px;\n        }\n        .bar-fill {\n            height: 100%;\n            background: linear-gradient(90deg, #667eea, #764ba2);\n            border-radius: 3px;\n            transition: width 0.3s ease;\n        }\n        .bar-count {\n            width: 35px;\n            text-align: right;\n            font-size: 0.85em;\n            color: #666;\n        }\n\n        /* Save indicator */\n        .save-indicator {\n            font-size: 0.8em;\n            color: #28a745;\n            margin-left: 8px;\n            opacity: 0;\n            transition: opacity 0.2s ease;\n        }\n        .save-indicator.visible {\n            opacity: 1;\n        }\n\n        /* Upload particle */\n        .upload-particle {\n            position: absolute;\n            font-size: 0.9em;\n            color: #667eea;\n            pointer-events: none;\n            animation: floatUp 0.9s ease-out forwards;\n        }\n        @keyframes floatUp {\n            0% { opacity: 1; transform: translateY(0); }\n            100% { opacity: 0; transform: translateY(-16px); }\n        }\n\n        /* Print styles */\n        @media print {\n            .controls, .aggregate-trigger, .aggregate-drawer, .save-indicator,\n            .appeal-section, .ai-feedback, .btn-ai { display: none !important; }\n            .blank { border-bottom: 1px solid #000 !important; background: transparent !important; }\n            body { background: white; }\n            .section { page-break-inside: avoid; }\n            .exit-ticket { page-break-before: auto; }\n        }\n    </style>\n</head>\n<body>\n\n    <div class=\"header\">\n        <span class=\"header-left\">AP Statistics</span>\n        <span class=\"header-center\">Unit 5</span>\n        <span class=\"header-right\">Sampling Distributions</span>\n    </div>\n\n    <h1>Topic 5.4: Biased and Unbiased Point Estimates</h1>\n    <div class=\"subtitle\">When Does a Sample Statistic \"Hit the Target\" on Average?</div>\n    <div class=\"worksheet-label\">Video Follow-Along Worksheet</div>\n\n    <div class=\"student-info\">\n        <div><label>Name:</label> <input type=\"text\" id=\"worksheetName\" style=\"width:160px;\"></div>\n        <div><label>Period:</label> <input type=\"text\" id=\"worksheetPeriod\" style=\"width:40px;\"></div>\n        <div><label>Username:</label> <input type=\"text\" id=\"worksheetUsername\" style=\"width:120px;\" placeholder=\"for class sync\"></div>\n    </div>\n\n    <div class=\"controls\">\n        <button class=\"btn-check\" onclick=\"checkAnswers()\">&#10003; Check Answers</button>\n        <button class=\"btn-show\" onclick=\"showAnswers()\">&#128065; Show Answers</button>\n        <button class=\"btn-reset\" onclick=\"resetAnswers()\">&#8634; Reset</button>\n        <button class=\"btn-print\" onclick=\"window.print()\">&#128424; Print</button>\n        <button class=\"btn-ai\" onclick=\"gradeAllReflections()\">&#129302; Grade My Reflections</button>\n        <span id=\"scoreDisplay\"></span>\n    </div>\n\n    <div class=\"objective-box\">\n        <strong>Learning Objectives:</strong>\n        <ul style=\"margin: 8px 0 0 0; padding-left: 20px;\">\n            <li><strong>UNC-3.I:</strong> Explain why an estimator is or is not unbiased.</li>\n            <li><strong>UNC-3.J:</strong> Calculate estimates for a population parameter.</li>\n        </ul>\n        <strong style=\"margin-top: 10px; display: block;\">Essential Knowledge:</strong>\n        <ul style=\"margin: 8px 0 0 0; padding-left: 20px;\">\n            <li>An estimator is unbiased if, on average, it equals the population parameter.</li>\n            <li>A sample statistic is a point estimator of the corresponding population parameter.</li>\n            <li>An estimator exhibits variability that can be modeled using probability.</li>\n        </ul>\n    </div>\n\n    <div class=\"vocab-box\">\n        <h3>Key Vocabulary</h3>\n        <table class=\"vocab-table\">\n            <tr>\n                <td>Point Estimator</td>\n                <td>The sample statistic used to estimate a population parameter (e.g., <span style=\"text-decoration: overline;\">x</span> estimates &mu;)</td>\n            </tr>\n            <tr>\n                <td>Point Estimate</td>\n                <td>The specific numerical value of the statistic from a particular sample (e.g., <span style=\"text-decoration: overline;\">x</span> = 2.3)</td>\n            </tr>\n            <tr>\n                <td>Unbiased Estimator</td>\n                <td>A statistic whose sampling distribution is centered at the true parameter &mdash; on average, it equals the parameter</td>\n            </tr>\n            <tr>\n                <td>Biased Estimator</td>\n                <td>A statistic whose sampling distribution is <em>not</em> centered at the true parameter &mdash; it systematically over- or under-estimates</td>\n            </tr>\n            <tr>\n                <td>Sampling Variability</td>\n                <td>The natural variation in a statistic from sample to sample; can be modeled using probability</td>\n            </tr>\n        </table>\n    </div>\n\n    <!-- ============================================================ -->\n    <!-- SECTION 1: Sample Mean as an Unbiased Estimator               -->\n    <!-- ============================================================ -->\n    <div class=\"section\">\n        <div class=\"section-header\">\n            <h2>Part 1: The Sample Mean &mdash; An Unbiased Estimator</h2>\n            <span class=\"timestamp\">[0:00 &ndash; 2:40]</span>\n        </div>\n\n        <div class=\"note-box\">\n            <strong>Setup &mdash; Weimaraner Dogs:</strong>\n            <span class=\"ts\">[0:19]</span>\n            A breeder has 5 dogs with ages: <strong>0, 2, 5, 8, 10</strong>. This is the entire population. Population mean &mu; = 5. We randomly select samples of 3 dogs.\n        </div>\n\n        <div class=\"question\">\n            <span class=\"question-number\">1.</span>\n            <span class=\"ts\">[1:21]</span>\n            One sample gives ages {0, 2, 5} with <span style=\"text-decoration: overline;\">x</span> = 2.3. The <em>statistic</em> <span style=\"text-decoration: overline;\">x</span> is called the <input type=\"text\" class=\"blank\" data-answer=\"point estimator\" style=\"width:130px;\">, and the specific value 2.3 is called the <input type=\"text\" class=\"blank\" data-answer=\"point estimate\" style=\"width:120px;\">.\n        </div>\n\n        <div class=\"question\">\n            <span class=\"question-number\">2.</span>\n            <span class=\"ts\">[1:35]</span>\n            This single sample gave <span style=\"text-decoration: overline;\">x</span> = 2.3, which is <em>not</em> equal to &mu; = 5. Does this one \"miss\" make <span style=\"text-decoration: overline;\">x</span> a bad estimator? <input type=\"text\" class=\"blank\" data-answer=\"no\" style=\"width:35px;\">\n            <span class=\"hint\">Think about what \"on average\" means.</span>\n        </div>\n\n        <div class=\"question\">\n            <span class=\"question-number\">3.</span>\n            <span class=\"ts\">[1:47]</span>\n            The video lists <strong>all possible</strong> samples of size 3 and their means. The mean of all those sample means turns out to be <input type=\"text\" class=\"blank\" data-answer=\"5\" style=\"width:35px;\">, which equals the population mean &mu;.\n        </div>\n\n        <div class=\"question\">\n            <span class=\"question-number\">4.</span>\n            <span class=\"ts\">[2:27]</span>\n            Because the average value of <span style=\"text-decoration: overline;\">x</span> across all possible samples equals &mu;, we say <span style=\"text-decoration: overline;\">x</span> is an <input type=\"text\" class=\"blank\" data-answer=\"unbiased\" style=\"width:90px;\"> estimator of &mu;.\n        </div>\n\n        <div class=\"model-box\">\n            <strong>Key Idea:</strong>\n            <span class=\"ts\">[2:18]</span>\n            Individual sample means <em>vary</em> around &mu; &mdash; some are too high, some too low. But the sampling distribution is <input type=\"text\" class=\"blank\" data-answer=\"centered|centered at\" style=\"width:90px;\"> at the population mean. That's what \"unbiased\" means: no systematic tendency to miss in one direction.\n        </div>\n    </div>\n\n    <!-- ============================================================ -->\n    <!-- SECTION 2: Sample Range as a Biased Estimator                 -->\n    <!-- ============================================================ -->\n    <div class=\"section\">\n        <div class=\"section-header\">\n            <h2>Part 2: The Sample Range &mdash; A Biased Estimator</h2>\n            <span class=\"timestamp\">[2:41 &ndash; 4:05]</span>\n        </div>\n\n        <div class=\"question\">\n            <span class=\"question-number\">5.</span>\n            <span class=\"ts\">[2:41]</span>\n            The population range is 10 &minus; 0 = <input type=\"text\" class=\"blank\" data-answer=\"10\" style=\"width:35px;\">. The sample {0, 2, 5} has a range of <input type=\"text\" class=\"blank\" data-answer=\"5\" style=\"width:35px;\">.\n        </div>\n\n        <div class=\"question\">\n            <span class=\"question-number\">6.</span>\n            <span class=\"ts\">[3:17]</span>\n            After computing the range for <strong>all possible</strong> samples of size 3, the mean of all sample ranges is <input type=\"text\" class=\"blank\" data-answer=\"7.8\" style=\"width:40px;\">. Since this does <strong>not</strong> equal the population range (10), the sample range is a <input type=\"text\" class=\"blank\" data-answer=\"biased\" style=\"width:70px;\"> estimator.\n        </div>\n\n        <div class=\"question\">\n            <span class=\"question-number\">7.</span>\n            <span class=\"ts\">[3:27]</span>\n            On the dot plot of all sample ranges, the values cluster to the <input type=\"text\" class=\"blank\" data-answer=\"left\" style=\"width:50px;\"> of the population range. This means the sample range systematically <input type=\"text\" class=\"blank\" data-answer=\"underestimates\" style=\"width:130px;\"> the population range.\n        </div>\n\n        <div class=\"question\">\n            <span class=\"question-number\">8.</span>\n            <span class=\"ts\">[3:27]</span>\n            <strong>Why is this bias predictable?</strong> A sample of 3 dogs drawn from a population of 5 can never include <em>both</em> the youngest and oldest dog every time. So the sample range can never be <input type=\"text\" class=\"blank\" data-answer=\"larger|greater|bigger\" style=\"width:70px;\"> than the population range &mdash; it can only equal it or fall short.\n        </div>\n    </div>\n\n    <!-- ============================================================ -->\n    <!-- SECTION 3: Key Takeaways                                      -->\n    <!-- ============================================================ -->\n    <div class=\"section\">\n        <div class=\"section-header\">\n            <h2>Part 3: Key Takeaways</h2>\n            <span class=\"timestamp\">[4:05 &ndash; 4:32]</span>\n        </div>\n\n        <div class=\"model-box\">\n            <span class=\"ts\">[4:07]</span>\n            <ol style=\"margin: 5px 0; padding-left: 20px;\">\n                <li>A sample statistic is a <input type=\"text\" class=\"blank\" data-answer=\"point estimator\" style=\"width:120px;\"> of the corresponding population parameter.</li>\n                <li>Estimators exhibit <input type=\"text\" class=\"blank\" data-answer=\"variability\" style=\"width:90px;\"> that can be modeled using probability.</li>\n                <li>An estimator is unbiased if, <input type=\"text\" class=\"blank\" data-answer=\"on average\" style=\"width:90px;\">, it equals the population parameter.</li>\n            </ol>\n        </div>\n    </div>\n\n    <!-- ============================================================ -->\n    <!-- REFLECTION SECTION                                            -->\n    <!-- ============================================================ -->\n    <div class=\"section\">\n        <div class=\"section-header\">\n            <h2>Reflection Questions</h2>\n            <span class=\"timestamp\">[AI-Graded]</span>\n        </div>\n\n        <div class=\"question\">","numLines":400,"startLine":200,"totalLines":1203}},"sourceToolAssistantUUID":"481e8112-c6ae-4d0d-8ada-47957348319a"}
