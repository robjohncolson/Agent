+          "-vn",
+          "-ar",
+          "16000",
+          "-ac",
+          "1",
+          "-c:a",
+          "libmp3lame",
+          "-b:a",
+          "48k",
+          outputPath,
+          "-y",
+        ]
+      : [
+          "-hide_banner",
+          "-loglevel",
+          "error",
+          "-i",
+          videoPath,
+          "-vn",
+          "-ar",
+          "16000",
+          "-ac",
+          "1",
+          "-c:a",
+          "pcm_s16le",
