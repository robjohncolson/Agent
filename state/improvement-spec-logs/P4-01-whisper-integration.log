+    const timeLine = lines[timeIndex];
+    const match = timeLine?.match(
+      /(\d{2}):(\d{2}):(\d{2})[,.:](\d{3})\s*-->\s*(\d{2}):(\d{2}):(\d{2})[,.:](\d{3})/
+    );
