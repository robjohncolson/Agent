}

async function main() {
  const options = parseArgs(process.argv);

  if (options.help) {
    console.log(usageText());
    return;
  }

  if (options.generateSlides) {
    console.warn(
      "Slide description generation is not implemented in video-ingest-whisper.mjs yet. Continuing with transcripts only."
    );
  }

