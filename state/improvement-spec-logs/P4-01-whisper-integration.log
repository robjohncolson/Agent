+  basename_spec="$(basename "$spec")"
+  if [[ "$basename_spec" != *.bin ]]; then
+    if [[ "$basename_spec" == ggml-* ]]; then
+      basename_spec="${basename_spec}.bin"
+    else
+      basename_spec="ggml-${basename_spec}.bin"
