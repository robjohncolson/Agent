+  return {
+    help,
+    unit,
+    lesson,
+    part,
+    videos,
+    outputDir,
+    engine,
+    whisperModel,
+    apiModel,
+    whisperBin,
+    whisperCppDir,
+    force,
+    generateSlides,
+    useWrapper,
+  };
+}
+
+export function usageText() {
