  console.log(`Engine: ${options.engine}`);
  console.log(`Output: ${finalOutputDir}`);

  for (let index = 0; index < options.videos.length; index++) {
    const currentPart = options.part ?? index + 1;
    const currentVideo = options.videos[index];

