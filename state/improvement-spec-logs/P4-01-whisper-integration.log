+
+function resolveCommand(binaryName) {
+  const locator = process.platform === "win32" ? "where" : "which";
+
+  try {
+    const result = spawnSync(locator, [binaryName], {
+      encoding: "utf8",
+      stdio: ["ignore", "pipe", "ignore"],
+    });
+
+    if (result.status !== 0) return null;
