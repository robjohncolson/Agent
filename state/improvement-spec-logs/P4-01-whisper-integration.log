+  if (!existingSource) return false;
+
+  const content = readFileSync(existingSource, "utf8").trimEnd();
+  writeIfNeeded(fileSet.transcriptPath, content, false);
+  writeIfNeeded(fileSet.transcriptionPath, content, false);
