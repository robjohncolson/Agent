+  return (
+    existsSync(fileSet.transcriptPath) &&
+    statSync(fileSet.transcriptPath).size > 0 &&
+    existsSync(fileSet.transcriptionPath) &&
+    statSync(fileSet.transcriptionPath).size > 0
