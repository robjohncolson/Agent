+  position_x INT DEFAULT 10,
+  position_y INT DEFAULT 10,
+  health INT DEFAULT 100,
+  largest_cluster INTEGER DEFAULT 0,
+  last_answer_at TIMESTAMPTZ,
+  active_buffs JSONB DEFAULT '{}'::jsonb,
+  lifetime_earned INTEGER DEFAULT 0,
