+-- LRSL-Driller shared-instance schema.
+-- Keep the legacy tables the Railway server already uses, then expose
+-- prefixed drill_* namespace views on top.
+
+CREATE TABLE IF NOT EXISTS public.lsrl_progress (
+  id SERIAL PRIMARY KEY,
+  username TEXT NOT NULL REFERENCES public.users(username) ON DELETE CASCADE,
+  scenario_topic TEXT NOT NULL,
+  slope_score TEXT CHECK (slope_score IN ('E', 'P', 'I')),
+  intercept_score TEXT CHECK (intercept_score IN ('E', 'P', 'I')),
+  correlation_score TEXT CHECK (correlation_score IN ('E', 'P', 'I')),
+  hints_used INTEGER DEFAULT 0 CHECK (hints_used >= 0 AND hints_used <= 3),
+  star_type TEXT CHECK (star_type IN ('gold', 'silver', 'bronze', 'tin') OR star_type IS NULL),
+  all_correct BOOLEAN DEFAULT FALSE,
+  grading_mode TEXT CHECK (grading_mode IN ('keywords', 'ai', 'both')),
+  ai_provider TEXT CHECK (ai_provider IN ('gemini', 'groq') OR ai_provider IS NULL),
+  completed_at TIMESTAMPTZ DEFAULT NOW(),
+  cartridge_id TEXT,
+  mode_id TEXT,
+  level_index INTEGER,
+  total_levels INTEGER,
+  level_multiplier DECIMAL(3,2) DEFAULT 1.0,
+  weighted_points DECIMAL(10,2) DEFAULT 0
+);
+
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS cartridge_id TEXT;
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS mode_id TEXT;
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS level_index INTEGER;
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS total_levels INTEGER;
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS level_multiplier DECIMAL(3,2) DEFAULT 1.0;
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS weighted_points DECIMAL(10,2) DEFAULT 0;
+
+CREATE INDEX IF NOT EXISTS idx_progress_username ON public.lsrl_progress(username);
+CREATE INDEX IF NOT EXISTS idx_progress_completed ON public.lsrl_progress(completed_at DESC);
+CREATE INDEX IF NOT EXISTS idx_progress_star ON public.lsrl_progress(star_type) WHERE star_type IS NOT NULL;
+CREATE INDEX IF NOT EXISTS idx_lsrl_progress_cartridge ON public.lsrl_progress(cartridge_id, mode_id);
+CREATE INDEX IF NOT EXISTS idx_lsrl_progress_weighted ON public.lsrl_progress(username, weighted_points);
+
+UPDATE public.lsrl_progress
+SET weighted_points = CASE star_type
+  WHEN 'gold' THEN 4.0
+  WHEN 'silver' THEN 3.0
+  WHEN 'bronze' THEN 2.0
+  WHEN 'tin' THEN 1.0
+  ELSE 0
+END,
+level_multiplier = COALESCE(level_multiplier, 1.0)
+WHERE weighted_points IS NULL OR weighted_points = 0;
+
+CREATE TABLE IF NOT EXISTS public.user_progress (
+  id SERIAL PRIMARY KEY,
+  username VARCHAR(50) NOT NULL,
+  cartridge_id VARCHAR(100) NOT NULL,
+  gold_stars INTEGER DEFAULT 0,
+  silver_stars INTEGER DEFAULT 0,
+  bronze_stars INTEGER DEFAULT 0,
+  tin_stars INTEGER DEFAULT 0,
+  total_weighted_score DECIMAL(10,2) DEFAULT 0,
+  mode_progress JSONB DEFAULT '{}'::jsonb,
+  created_at TIMESTAMPTZ DEFAULT NOW(),
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(username, cartridge_id)
+);
+
+CREATE INDEX IF NOT EXISTS idx_user_progress_score ON public.user_progress(total_weighted_score DESC);
+CREATE INDEX IF NOT EXISTS idx_user_progress_cartridge ON public.user_progress(cartridge_id);
+CREATE INDEX IF NOT EXISTS idx_user_progress_username ON public.user_progress(username);
+
+DROP TRIGGER IF EXISTS user_progress_touch_updated_at ON public.user_progress;
+CREATE TRIGGER user_progress_touch_updated_at
+  BEFORE UPDATE ON public.user_progress
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.user_settings (
+  username TEXT PRIMARY KEY REFERENCES public.users(username) ON DELETE CASCADE,
+  gemini_key TEXT,
+  groq_key TEXT,
+  preferred_provider TEXT DEFAULT 'groq' CHECK (preferred_provider IN ('gemini', 'groq', 'none')),
+  updated_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+DROP TRIGGER IF EXISTS user_settings_touch_updated_at ON public.user_settings;
+CREATE TRIGGER user_settings_touch_updated_at
+  BEFORE UPDATE ON public.user_settings
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.api_keys_pool (
+  id SERIAL PRIMARY KEY,
+  provider TEXT NOT NULL CHECK (provider IN ('gemini', 'groq')),
+  api_key TEXT NOT NULL,
+  contributed_by TEXT REFERENCES public.users(username) ON DELETE SET NULL,
+  is_active BOOLEAN DEFAULT TRUE,
+  last_used_at TIMESTAMPTZ,
+  rate_limited_until TIMESTAMPTZ,
+  total_uses INTEGER DEFAULT 0,
+  total_failures INTEGER DEFAULT 0,
+  created_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(provider, api_key)
+);
+
+CREATE INDEX IF NOT EXISTS idx_api_keys_available
+  ON public.api_keys_pool(provider, is_active, rate_limited_until)
+  WHERE is_active = TRUE;
+
+CREATE OR REPLACE FUNCTION public.increment_key_uses(key_id INTEGER)
+RETURNS void AS $$
+BEGIN
+  UPDATE public.api_keys_pool
+  SET total_uses = total_uses + 1,
+      last_used_at = NOW()
+  WHERE id = key_id;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE OR REPLACE FUNCTION public.increment_key_failures(key_id INTEGER, limit_until TIMESTAMPTZ)
+RETURNS void AS $$
+BEGIN
+  UPDATE public.api_keys_pool
+  SET total_failures = total_failures + 1,
+      rate_limited_until = limit_until
+  WHERE id = key_id;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE TABLE IF NOT EXISTS public.teacher_reviews (
+  id SERIAL PRIMARY KEY,
+  username TEXT NOT NULL REFERENCES public.users(username) ON DELETE CASCADE,
+  scenario_topic TEXT NOT NULL,
+  scenario_context JSONB,
+  student_answers JSONB NOT NULL,
+  expected_answers JSONB,
+  keyword_results JSONB,
+  teacher_grades JSONB,
+  teacher_feedback TEXT,
+  teacher_notes TEXT,
+  cartridge_id VARCHAR(100),
+  cartridge_name TEXT,
+  mode_id VARCHAR(100),
+  field_ids JSONB,
+  status TEXT DEFAULT 'pending' CHECK (status IN ('pending', 'reviewed', 'dismissed')),
+  submitted_at TIMESTAMPTZ DEFAULT NOW(),
+  reviewed_at TIMESTAMPTZ
+);
+
+ALTER TABLE public.teacher_reviews ADD COLUMN IF NOT EXISTS expected_answers JSONB;
+ALTER TABLE public.teacher_reviews ADD COLUMN IF NOT EXISTS cartridge_id VARCHAR(100);
+ALTER TABLE public.teacher_reviews ADD COLUMN IF NOT EXISTS cartridge_name TEXT;
+ALTER TABLE public.teacher_reviews ADD COLUMN IF NOT EXISTS mode_id VARCHAR(100);
+ALTER TABLE public.teacher_reviews ADD COLUMN IF NOT EXISTS field_ids JSONB;
+
+CREATE INDEX IF NOT EXISTS idx_teacher_reviews_status ON public.teacher_reviews(status);
+CREATE INDEX IF NOT EXISTS idx_teacher_reviews_username ON public.teacher_reviews(username);
+CREATE INDEX IF NOT EXISTS idx_teacher_reviews_submitted ON public.teacher_reviews(submitted_at DESC);
+
+CREATE TABLE IF NOT EXISTS public.time_sessions (
+  id BIGSERIAL PRIMARY KEY,
+  session_id TEXT UNIQUE NOT NULL,
+  username TEXT NOT NULL,
+  session_start TIMESTAMPTZ NOT NULL,
+  active_time_ms BIGINT DEFAULT 0,
+  total_time_ms BIGINT DEFAULT 0,
+  last_sync TIMESTAMPTZ DEFAULT NOW(),
+  is_complete BOOLEAN DEFAULT FALSE,
+  created_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+CREATE INDEX IF NOT EXISTS idx_time_sessions_username ON public.time_sessions(username);
+CREATE INDEX IF NOT EXISTS idx_time_sessions_start ON public.time_sessions(session_start);
+
+CREATE TABLE IF NOT EXISTS public.time_problems (
+  id BIGSERIAL PRIMARY KEY,
+  session_id TEXT NOT NULL,
+  username TEXT NOT NULL,
+  problem_id TEXT,
+  cartridge_id TEXT,
+  mode_id TEXT,
+  active_time_ms BIGINT DEFAULT 0,
+  total_time_ms BIGINT DEFAULT 0,
+  completed BOOLEAN DEFAULT FALSE,
+  result JSONB,
+  completed_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+CREATE INDEX IF NOT EXISTS idx_time_problems_username ON public.time_problems(username);
+CREATE INDEX IF NOT EXISTS idx_time_problems_session ON public.time_problems(session_id);
+CREATE INDEX IF NOT EXISTS idx_time_problems_completed_at ON public.time_problems(completed_at);
+
+CREATE TABLE IF NOT EXISTS public.point_events (
+  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
+  game_id TEXT NOT NULL DEFAULT 'default',
+  player_id TEXT NOT NULL,
+  delta INTEGER NOT NULL,
+  reason TEXT NOT NULL,
+  cartridge_id TEXT,
+  metadata JSONB DEFAULT '{}'::jsonb,
+  created_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+CREATE INDEX IF NOT EXISTS idx_point_events_player_time
+  ON public.point_events(game_id, player_id, created_at DESC);
+CREATE INDEX IF NOT EXISTS idx_point_events_recent
+  ON public.point_events(created_at DESC)
+  WHERE created_at > NOW() - INTERVAL '1 hour';
+CREATE INDEX IF NOT EXISTS idx_point_events_cleanup ON public.point_events(created_at);
+
+CREATE TABLE IF NOT EXISTS public.progression_overrides (
+  id SERIAL PRIMARY KEY,
+  game_id VARCHAR(100) NOT NULL DEFAULT 'default',
+  cartridge_id VARCHAR(100) NOT NULL,
+  mode_id VARCHAR(100) NOT NULL,
+  gold_required INTEGER NOT NULL CHECK (gold_required >= 1 AND gold_required <= 10),
+  updated_by VARCHAR(100),
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(game_id, cartridge_id, mode_id)
+);
+
+CREATE INDEX IF NOT EXISTS idx_progression_overrides_lookup
+  ON public.progression_overrides(game_id, cartridge_id);
+
+DROP TRIGGER IF EXISTS progression_overrides_touch_updated_at ON public.progression_overrides;
+CREATE TRIGGER progression_overrides_touch_updated_at
+  BEFORE UPDATE ON public.progression_overrides
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.ghost_profiles (
+  id SERIAL PRIMARY KEY,
+  username TEXT NOT NULL,
+  cartridge_id TEXT NOT NULL,
+  weights JSONB NOT NULL,
+  buffer JSONB,
+  total_interactions INTEGER DEFAULT 0,
+  proficiency_score FLOAT DEFAULT 0,
+  color TEXT DEFAULT 'white',
+  opacity FLOAT DEFAULT 0.1,
+  version INTEGER DEFAULT 1,
+  created_at TIMESTAMPTZ DEFAULT NOW(),
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(username, cartridge_id)
+);
+
+CREATE INDEX IF NOT EXISTS idx_ghost_profiles_cartridge_proficiency
+  ON public.ghost_profiles(cartridge_id, proficiency_score DESC);
+CREATE INDEX IF NOT EXISTS idx_ghost_profiles_username ON public.ghost_profiles(username);
+
+DROP TRIGGER IF EXISTS ghost_profiles_touch_updated_at ON public.ghost_profiles;
+CREATE TRIGGER ghost_profiles_touch_updated_at
+  BEFORE UPDATE ON public.ghost_profiles
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.ghost_ratings (
+  id SERIAL PRIMARY KEY,
+  username VARCHAR(50) NOT NULL,
+  cartridge_id VARCHAR(100) NOT NULL,
+  rating INTEGER DEFAULT 1200,
+  battles_fought INTEGER DEFAULT 0,
+  wins INTEGER DEFAULT 0,
+  losses INTEGER DEFAULT 0,
+  draws INTEGER DEFAULT 0,
+  current_streak INTEGER DEFAULT 0,
+  best_streak INTEGER DEFAULT 0,
+  last_battle_at TIMESTAMPTZ,
+  created_at TIMESTAMPTZ DEFAULT NOW(),
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(username, cartridge_id)
+);
+
+CREATE INDEX IF NOT EXISTS idx_ghost_ratings_leaderboard
+  ON public.ghost_ratings(cartridge_id, rating DESC);
+CREATE INDEX IF NOT EXISTS idx_ghost_ratings_username ON public.ghost_ratings(username);
+
+DROP TRIGGER IF EXISTS ghost_ratings_touch_updated_at ON public.ghost_ratings;
+CREATE TRIGGER ghost_ratings_touch_updated_at
+  BEFORE UPDATE ON public.ghost_ratings
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE OR REPLACE FUNCTION public.get_or_create_ghost_rating(
+  p_username VARCHAR(50),
+  p_cartridge_id VARCHAR(100)
+)
+RETURNS public.ghost_ratings AS $$
+DECLARE
+  v_rating public.ghost_ratings;
+BEGIN
+  SELECT * INTO v_rating
+  FROM public.ghost_ratings
+  WHERE username = p_username AND cartridge_id = p_cartridge_id;
+
+  IF v_rating IS NULL THEN
+    INSERT INTO public.ghost_ratings (username, cartridge_id, rating)
+    VALUES (p_username, p_cartridge_id, 1200)
+    RETURNING * INTO v_rating;
+  END IF;
+
+  RETURN v_rating;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE TABLE IF NOT EXISTS public.ghost_battles (
+  id SERIAL PRIMARY KEY,
+  cartridge_id VARCHAR(100) NOT NULL,
+  challenger_username VARCHAR(50) NOT NULL,
+  defender_username VARCHAR(50) NOT NULL,
+  challenge_type VARCHAR(20) NOT NULL CHECK (challenge_type IN ('random', 'specific', 'rematch', 'leaderboard')),
+  seed BIGINT NOT NULL,
+  winner VARCHAR(50),
+  winner_side INTEGER NOT NULL CHECK (winner_side IN (0, 1, 2)),
+  challenger_time FLOAT NOT NULL,
+  challenger_correct INTEGER NOT NULL,
+  defender_time FLOAT NOT NULL,
+  defender_correct INTEGER NOT NULL,
+  margin FLOAT NOT NULL,
+  challenger_rating_before INTEGER NOT NULL,
+  defender_rating_before INTEGER NOT NULL,
+  challenger_rating_after INTEGER NOT NULL,
+  defender_rating_after INTEGER NOT NULL,
+  battle_log JSONB NOT NULL,
+  created_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+CREATE INDEX IF NOT EXISTS idx_ghost_battles_cartridge ON public.ghost_battles(cartridge_id);
+CREATE INDEX IF NOT EXISTS idx_ghost_battles_challenger ON public.ghost_battles(challenger_username);
+CREATE INDEX IF NOT EXISTS idx_ghost_battles_defender ON public.ghost_battles(defender_username);
+CREATE INDEX IF NOT EXISTS idx_ghost_battles_created ON public.ghost_battles(created_at DESC);
+
+CREATE TABLE IF NOT EXISTS public.ghost_orbits_sessions (
+  id SERIAL PRIMARY KEY,
+  cartridge_id VARCHAR(100) NOT NULL,
+  period_id VARCHAR(50),
+  started_at TIMESTAMPTZ DEFAULT NOW(),
+  ended_at TIMESTAMPTZ,
+  round_number INTEGER DEFAULT 1,
+  round_duration_ms INTEGER,
+  winner_username VARCHAR(50),
+  final_rankings JSONB,
+  total_players INTEGER,
+  total_eliminations INTEGER
+);
+
+CREATE TABLE IF NOT EXISTS public.ghost_orbits_stats (
+  id SERIAL PRIMARY KEY,
+  username VARCHAR(50) NOT NULL,
+  cartridge_id VARCHAR(100) NOT NULL,
+  games_played INTEGER DEFAULT 0,
+  total_territory_percent DECIMAL(10,4) DEFAULT 0,
+  total_eliminations INTEGER DEFAULT 0,
+  times_eliminated INTEGER DEFAULT 0,
+  wins INTEGER DEFAULT 0,
+  best_territory_percent DECIMAL(5,2),
+  longest_survival_ms INTEGER,
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(username, cartridge_id)
+);
+
+CREATE INDEX IF NOT EXISTS idx_orbits_sessions_cartridge ON public.ghost_orbits_sessions(cartridge_id);
+CREATE INDEX IF NOT EXISTS idx_orbits_sessions_period ON public.ghost_orbits_sessions(period_id);
+CREATE INDEX IF NOT EXISTS idx_orbits_sessions_started ON public.ghost_orbits_sessions(started_at DESC);
+CREATE INDEX IF NOT EXISTS idx_orbits_stats_user ON public.ghost_orbits_stats(username);
+CREATE INDEX IF NOT EXISTS idx_orbits_stats_cartridge_wins ON public.ghost_orbits_stats(cartridge_id, wins DESC);
+
+DROP TRIGGER IF EXISTS ghost_orbits_stats_touch_updated_at ON public.ghost_orbits_stats;
+CREATE TRIGGER ghost_orbits_stats_touch_updated_at
+  BEFORE UPDATE ON public.ghost_orbits_stats
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE OR REPLACE FUNCTION public.get_or_create_orbits_stats(
+  p_username VARCHAR(50),
+  p_cartridge_id VARCHAR(100)
+)
+RETURNS public.ghost_orbits_stats AS $$
+DECLARE
+  v_stats public.ghost_orbits_stats;
+BEGIN
+  SELECT * INTO v_stats
+  FROM public.ghost_orbits_stats
+  WHERE username = p_username AND cartridge_id = p_cartridge_id;
+
+  IF v_stats IS NULL THEN
+    INSERT INTO public.ghost_orbits_stats (username, cartridge_id)
+    VALUES (p_username, p_cartridge_id)
+    RETURNING * INTO v_stats;
+  END IF;
+
+  RETURN v_stats;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE OR REPLACE FUNCTION public.update_orbits_stats(
+  p_username VARCHAR(50),
+  p_cartridge_id VARCHAR(100),
+  p_territory_percent DECIMAL(5,2),
+  p_eliminations INTEGER,
+  p_was_eliminated BOOLEAN,
+  p_won BOOLEAN,
+  p_survival_ms INTEGER
+)
+RETURNS public.ghost_orbits_stats AS $$
+DECLARE
+  v_stats public.ghost_orbits_stats;
+BEGIN
+  PERFORM public.get_or_create_orbits_stats(p_username, p_cartridge_id);
+
+  UPDATE public.ghost_orbits_stats
+  SET
+    games_played = games_played + 1,
+    total_territory_percent = total_territory_percent + p_territory_percent,
+    total_eliminations = total_eliminations + p_eliminations,
+    times_eliminated = times_eliminated + CASE WHEN p_was_eliminated THEN 1 ELSE 0 END,
+    wins = wins + CASE WHEN p_won THEN 1 ELSE 0 END,
+    best_territory_percent = GREATEST(COALESCE(best_territory_percent, 0), p_territory_percent),
+    longest_survival_ms = GREATEST(COALESCE(longest_survival_ms, 0), p_survival_ms)
+  WHERE username = p_username AND cartridge_id = p_cartridge_id
+  RETURNING * INTO v_stats;
+
+  RETURN v_stats;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE TABLE IF NOT EXISTS public.grid_wars_games (
+  id SERIAL PRIMARY KEY,
+  game_id TEXT UNIQUE NOT NULL,
+  status TEXT DEFAULT 'active' CHECK (status IN ('active', 'paused', 'completed')),
+  map_size INT DEFAULT 20,
+  wave_number INT DEFAULT 0,
+  center_hp INT DEFAULT 100,
+  class_goal_target INTEGER DEFAULT 200,
+  class_goal_current INTEGER DEFAULT 0,
+  surge_cell_x INTEGER CHECK (surge_cell_x IS NULL OR (surge_cell_x >= 0 AND surge_cell_x < 20)),
+  surge_cell_y INTEGER CHECK (surge_cell_y IS NULL OR (surge_cell_y >= 0 AND surge_cell_y < 20)),
+  surge_expires TIMESTAMPTZ,
+  rounds_enabled BOOLEAN DEFAULT FALSE,
+  round_number INTEGER DEFAULT 1,
+  round_started_at TIMESTAMPTZ,
+  round_ends_at TIMESTAMPTZ,
+  round_status TEXT DEFAULT 'active',
+  victory_config JSONB DEFAULT '{"type":"manual"}'::jsonb,
+  legacy_bonus_winner INTEGER DEFAULT 5,
+  legacy_bonus_top3 INTEGER DEFAULT 3,
+  duels_enabled BOOLEAN NOT NULL DEFAULT TRUE,
+  created_at TIMESTAMPTZ DEFAULT NOW(),
+  updated_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+DROP TRIGGER IF EXISTS grid_wars_games_touch_updated_at ON public.grid_wars_games;
+CREATE TRIGGER grid_wars_games_touch_updated_at
+  BEFORE UPDATE ON public.grid_wars_games
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.grid_wars_territories (
+  id SERIAL PRIMARY KEY,
+  game_id TEXT NOT NULL REFERENCES public.grid_wars_games(game_id) ON DELETE CASCADE,
+  x INT NOT NULL CHECK (x >= 0 AND x < 20),
+  y INT NOT NULL CHECK (y >= 0 AND y < 20),
+  owner TEXT REFERENCES public.users(username) ON DELETE SET NULL,
+  claimed_at TIMESTAMPTZ DEFAULT NOW(),
+  health INT DEFAULT 100,
+  strength INTEGER DEFAULT 3,
+  contested_by TEXT REFERENCES public.users(username) ON DELETE SET NULL,
+  contested_since TIMESTAMPTZ,
+  node_type TEXT CHECK (node_type IN ('amplifier', 'beacon', 'anchor')),
+  address VARCHAR(32),
+  parent_address VARCHAR(32),
+  is_developed BOOLEAN DEFAULT FALSE,
+  cell_level INTEGER DEFAULT 0,
+  parent_x INTEGER,
+  parent_y INTEGER,
+  UNIQUE(game_id, x, y)
+);
+
+CREATE TABLE IF NOT EXISTS public.grid_wars_structures (
+  id SERIAL PRIMARY KEY,
+  game_id TEXT NOT NULL REFERENCES public.grid_wars_games(game_id) ON DELETE CASCADE,
+  x INT NOT NULL CHECK (x >= 0 AND x < 20),
+  y INT NOT NULL CHECK (y >= 0 AND y < 20),
+  structure_type TEXT NOT NULL CHECK (structure_type IN ('tower', 'farm', 'wall', 'castle')),
+  owner TEXT NOT NULL REFERENCES public.users(username) ON DELETE CASCADE,
+  health INT DEFAULT 100,
+  built_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(game_id, x, y)
+);
+
+CREATE TABLE IF NOT EXISTS public.grid_wars_players (
+  id SERIAL PRIMARY KEY,
+  game_id TEXT NOT NULL REFERENCES public.grid_wars_games(game_id) ON DELETE CASCADE,
+  username TEXT NOT NULL REFERENCES public.users(username) ON DELETE CASCADE,
+  action_points INT DEFAULT 0,
+  territories_count INT DEFAULT 0,
+  structures_count INT DEFAULT 0,
+  avatar_format TEXT DEFAULT 'A' CHECK (avatar_format IN ('A', 'B')),
+  position_x INT DEFAULT 10,
+  position_y INT DEFAULT 10,
+  health INT DEFAULT 100,
+  largest_cluster INTEGER DEFAULT 0,
+  last_answer_at TIMESTAMPTZ,
+  active_buffs JSONB DEFAULT '{}'::jsonb,
+  lifetime_earned INTEGER DEFAULT 0,
+  pending_legacy_bonus INTEGER DEFAULT 0,
+  color VARCHAR(20),
+  challenge_tokens INTEGER NOT NULL DEFAULT 2,
+  total_rent_earned INTEGER NOT NULL DEFAULT 0,
+  last_token_grant_rent INTEGER NOT NULL DEFAULT 0,
+  recent_correct_count INTEGER NOT NULL DEFAULT 0,
+  recent_correct_window_start TIMESTAMPTZ,
+  correct_answer_count INTEGER NOT NULL DEFAULT 0,
+  last_token_grant_count INTEGER NOT NULL DEFAULT 0,
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(game_id, username)
+);
+
+DROP TRIGGER IF EXISTS grid_wars_players_touch_updated_at ON public.grid_wars_players;
+CREATE TRIGGER grid_wars_players_touch_updated_at
+  BEFORE UPDATE ON public.grid_wars_players
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.grid_wars_gifts (
+  id SERIAL PRIMARY KEY,
+  game_id VARCHAR(100) NOT NULL,
+  from_username VARCHAR(50) NOT NULL,
+  to_username VARCHAR(50) NOT NULL,
+  address VARCHAR(32) NOT NULL,
+  gifted_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+CREATE TABLE IF NOT EXISTS public.round_history (
+  id SERIAL PRIMARY KEY,
+  game_id TEXT NOT NULL,
+  round_number INTEGER NOT NULL,
+  started_at TIMESTAMPTZ,
+  ended_at TIMESTAMPTZ DEFAULT NOW(),
+  victory_condition TEXT NOT NULL CHECK (victory_condition IN ('domination', 'timed', 'collaborative', 'manual')),
+  winner_id TEXT,
+  winner_name TEXT,
+  winner_score INTEGER,
+  runner_up_id TEXT,
+  runner_up_name TEXT,
+  runner_up_score INTEGER,
+  third_place_id TEXT,
+  third_place_name TEXT,
+  third_place_score INTEGER,
+  total_players INTEGER DEFAULT 0,
+  total_cells_claimed INTEGER DEFAULT 0,
+  class_goal_reached BOOLEAN DEFAULT FALSE,
+  metadata JSONB DEFAULT '{}'::jsonb,
+  UNIQUE(game_id, round_number)
+);
+
+CREATE INDEX IF NOT EXISTS idx_orbits_sessions_cartridge ON public.ghost_orbits_sessions(cartridge_id);
+CREATE INDEX IF NOT EXISTS idx_orbits_sessions_period ON public.ghost_orbits_sessions(period_id);
+CREATE INDEX IF NOT EXISTS idx_orbits_sessions_started ON public.ghost_orbits_sessions(started_at DESC);
+CREATE INDEX IF NOT EXISTS idx_orbits_stats_user ON public.ghost_orbits_stats(username);
+CREATE INDEX IF NOT EXISTS idx_orbits_stats_cartridge_wins ON public.ghost_orbits_stats(cartridge_id, wins DESC);
+CREATE INDEX IF NOT EXISTS idx_gw_games_status ON public.grid_wars_games(status);
+CREATE INDEX IF NOT EXISTS idx_gw_territories_game ON public.grid_wars_territories(game_id);
+CREATE INDEX IF NOT EXISTS idx_gw_territories_owner ON public.grid_wars_territories(owner);
+CREATE INDEX IF NOT EXISTS idx_gw_territories_contested
+  ON public.grid_wars_territories(contested_by)
+  WHERE contested_by IS NOT NULL;
+CREATE INDEX IF NOT EXISTS idx_gw_structures_game ON public.grid_wars_structures(game_id);
+CREATE INDEX IF NOT EXISTS idx_gw_structures_owner ON public.grid_wars_structures(owner);
+CREATE INDEX IF NOT EXISTS idx_gw_players_game ON public.grid_wars_players(game_id);
+CREATE INDEX IF NOT EXISTS idx_gw_players_username ON public.grid_wars_players(username);
+CREATE INDEX IF NOT EXISTS idx_gw_players_position ON public.grid_wars_players(game_id, position_x, position_y);
+CREATE INDEX IF NOT EXISTS idx_gw_players_lifetime ON public.grid_wars_players(lifetime_earned DESC);
+CREATE INDEX IF NOT EXISTS idx_gw_players_last_answer
+  ON public.grid_wars_players(last_answer_at)
+  WHERE last_answer_at IS NOT NULL;
+CREATE INDEX IF NOT EXISTS idx_grid_wars_players_correct_count
+  ON public.grid_wars_players(game_id, username, correct_answer_count);
+CREATE INDEX IF NOT EXISTS idx_gifts_game ON public.grid_wars_gifts(game_id);
+CREATE INDEX IF NOT EXISTS idx_gifts_from ON public.grid_wars_gifts(from_username);
+CREATE INDEX IF NOT EXISTS idx_gifts_to ON public.grid_wars_gifts(to_username);
+CREATE INDEX IF NOT EXISTS idx_gifts_timestamp ON public.grid_wars_gifts(gifted_at);
+CREATE INDEX IF NOT EXISTS idx_round_history_game ON public.round_history(game_id);
+CREATE INDEX IF NOT EXISTS idx_round_history_ended ON public.round_history(ended_at DESC);
+CREATE INDEX IF NOT EXISTS idx_round_history_winner ON public.round_history(winner_id);
+
+CREATE OR REPLACE FUNCTION public.get_spawn_position(p_game_id TEXT, p_map_size INT DEFAULT 20)
+RETURNS TABLE(spawn_x INT, spawn_y INT) AS $$
+DECLARE
+  margin INT := 3;
+  best_x INT;
+  best_y INT;
+  best_distance FLOAT := 0;
+  test_x INT;
+  test_y INT;
+  min_dist FLOAT;
+  dist FLOAT;
+  player RECORD;
+BEGIN
+  FOR test_x IN margin..(p_map_size - margin - 1) LOOP
+    FOR test_y IN margin..(p_map_size - margin - 1) LOOP
+      min_dist := 999999;
+      FOR player IN
+        SELECT position_x, position_y
+        FROM public.grid_wars_players
+        WHERE game_id = p_game_id AND position_x IS NOT NULL
+      LOOP
+        dist := sqrt(power(test_x - player.position_x, 2) + power(test_y - player.position_y, 2));
+        IF dist < min_dist THEN
+          min_dist := dist;
+        END IF;
+      END LOOP;
+      IF min_dist > best_distance THEN
+        best_distance := min_dist;
+        best_x := test_x;
+        best_y := test_y;
+      END IF;
+    END LOOP;
+  END LOOP;
+  IF best_x IS NULL THEN
+    best_x := p_map_size / 2;
+    best_y := p_map_size / 2;
+  END IF;
+  spawn_x := best_x;
+  spawn_y := best_y;
+  RETURN NEXT;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE OR REPLACE FUNCTION public.init_resource_nodes(p_game_id TEXT)
+RETURNS VOID AS $$
+BEGIN
+  INSERT INTO public.grid_wars_territories (game_id, x, y, owner, node_type, strength)
+  VALUES
+    (p_game_id, 10, 10, NULL, 'amplifier', 3),
+    (p_game_id, 4, 4, NULL, 'beacon', 3),
+    (p_game_id, 15, 15, NULL, 'anchor', 3)
+  ON CONFLICT (game_id, x, y) DO UPDATE
+  SET node_type = EXCLUDED.node_type;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE OR REPLACE VIEW public.grid_wars_active_contestations AS
+SELECT
+  t.game_id,
+  t.x,
+  t.y,
+  t.owner,
+  t.contested_by,
+  t.contested_since,
+  EXTRACT(EPOCH FROM (NOW() - t.contested_since)) AS seconds_contested,
+  p_owner.health AS owner_health,
+  p_contester.health AS contester_health,
+  p_contester.position_x AS contester_x,
+  p_contester.position_y AS contester_y
+FROM public.grid_wars_territories AS t
+JOIN public.grid_wars_players AS p_owner
+  ON t.game_id = p_owner.game_id AND t.owner = p_owner.username
+LEFT JOIN public.grid_wars_players AS p_contester
+  ON t.game_id = p_contester.game_id AND t.contested_by = p_contester.username
+WHERE t.contested_by IS NOT NULL;
+
+CREATE OR REPLACE VIEW public.leaderboard AS
+SELECT
+  u.username,
+  u.real_name,
+  COALESCE(SUM(CASE WHEN p.star_type = 'gold' THEN 1 ELSE 0 END), 0) AS gold,
+  COALESCE(SUM(CASE WHEN p.star_type = 'silver' THEN 1 ELSE 0 END), 0) AS silver,
+  COALESCE(SUM(CASE WHEN p.star_type = 'bronze' THEN 1 ELSE 0 END), 0) AS bronze,
+  COALESCE(SUM(CASE WHEN p.star_type = 'tin' THEN 1 ELSE 0 END), 0) AS tin,
+  COALESCE(
+    SUM(CASE WHEN p.star_type = 'gold' THEN 4 ELSE 0 END) +
+    SUM(CASE WHEN p.star_type = 'silver' THEN 3 ELSE 0 END) +
+    SUM(CASE WHEN p.star_type = 'bronze' THEN 2 ELSE 0 END) +
+    SUM(CASE WHEN p.star_type = 'tin' THEN 1 ELSE 0 END),
+    0
+  ) AS weighted_score,
+  COUNT(p.id) AS total_attempts,
+  COALESCE(SUM(CASE WHEN p.all_correct THEN 1 ELSE 0 END), 0) AS perfect_runs,
+  MAX(p.completed_at) AS last_active
+FROM public.users AS u
+LEFT JOIN public.lsrl_progress AS p
+  ON u.username = p.username
+WHERE u.user_type = 'student'
+GROUP BY u.username, u.real_name
+ORDER BY weighted_score DESC, perfect_runs DESC;
+
+CREATE OR REPLACE VIEW public.class_roster AS
+SELECT
+  username,
+  real_name,
+  class_period,
+  created_at,
+  last_seen
+FROM public.users
+WHERE user_type = 'student';
+
+CREATE OR REPLACE VIEW public.ghost_orbits_leaderboard AS
+SELECT
+  username,
+  SUM(wins) AS total_wins,
+  SUM(games_played) AS total_games,
+  ROUND(SUM(wins)::DECIMAL / NULLIF(SUM(games_played), 0) * 100, 1) AS win_rate,
+  MAX(best_territory_percent) AS best_territory
+FROM public.ghost_orbits_stats
+GROUP BY username
+ORDER BY total_wins DESC;
+
+CREATE OR REPLACE VIEW public.drill_progress AS
+SELECT
+  up.username AS student_id,
+  up.cartridge_id,
+  mode_progress.key AS mode_id,
+  mode_progress.value AS stars,
+  up.updated_at AS completed_at
+FROM public.user_progress AS up
+CROSS JOIN LATERAL jsonb_each(COALESCE(up.mode_progress, '{}'::jsonb)) AS mode_progress(key, value);
+
+CREATE OR REPLACE VIEW public.drill_leaderboard AS
+SELECT
+  up.username AS student_id,
+  up.cartridge_id,
+  up.total_weighted_score AS total_points,
+  DENSE_RANK() OVER (
+    PARTITION BY up.cartridge_id
+    ORDER BY up.total_weighted_score DESC, up.username ASC
+  ) AS rank,
+  up.updated_at
+FROM public.user_progress AS up;
+
+CREATE OR REPLACE VIEW public.drill_time_tracking AS
+SELECT
+  ts.username AS student_id,
+  ts.session_id,
+  ts.session_start,
+  CASE WHEN ts.is_complete THEN ts.last_sync ELSE NULL END AS session_end,
+  ts.total_time_ms AS duration_ms,
+  ts.active_time_ms,
+  ts.is_complete,
+  ts.last_sync AS updated_at
+FROM public.time_sessions AS ts;
+
+CREATE OR REPLACE VIEW public.drill_avatar_system AS
+SELECT
+  gp.username AS student_id,
+  jsonb_build_object(
+    'format', gp.avatar_format,
+    'position', jsonb_build_object('x', gp.position_x, 'y', gp.position_y),
+    'health', gp.health,
+    'color', gp.color
+  ) AS avatar_config,
+  gp.updated_at
+FROM public.grid_wars_players AS gp;
+
+CREATE OR REPLACE VIEW public.drill_user_progress AS SELECT * FROM public.user_progress;
+CREATE OR REPLACE VIEW public.drill_user_settings AS SELECT * FROM public.user_settings;
+CREATE OR REPLACE VIEW public.drill_teacher_reviews AS SELECT * FROM public.teacher_reviews;
+CREATE OR REPLACE VIEW public.drill_progression_overrides AS SELECT * FROM public.progression_overrides;
+CREATE OR REPLACE VIEW public.drill_ghost_profiles AS SELECT * FROM public.ghost_profiles;
+CREATE OR REPLACE VIEW public.drill_ghost_ratings AS SELECT * FROM public.ghost_ratings;
+CREATE OR REPLACE VIEW public.drill_ghost_battles AS SELECT * FROM public.ghost_battles;
+CREATE OR REPLACE VIEW public.drill_ghost_orbits_sessions AS SELECT * FROM public.ghost_orbits_sessions;
+CREATE OR REPLACE VIEW public.drill_ghost_orbits_stats AS SELECT * FROM public.ghost_orbits_stats;
+CREATE OR REPLACE VIEW public.drill_ghost_orbits_leaderboard AS SELECT * FROM public.ghost_orbits_leaderboard;
+CREATE OR REPLACE VIEW public.drill_grid_wars_games AS SELECT * FROM public.grid_wars_games;
+CREATE OR REPLACE VIEW public.drill_grid_wars_territories AS SELECT * FROM public.grid_wars_territories;
+CREATE OR REPLACE VIEW public.drill_grid_wars_structures AS SELECT * FROM public.grid_wars_structures;
+CREATE OR REPLACE VIEW public.drill_grid_wars_players AS SELECT * FROM public.grid_wars_players;
+CREATE OR REPLACE VIEW public.drill_grid_wars_gifts AS SELECT * FROM public.grid_wars_gifts;
+CREATE OR REPLACE VIEW public.drill_round_history AS SELECT * FROM public.round_history;
+CREATE OR REPLACE VIEW public.drill_class_roster AS SELECT * FROM public.class_roster;
+CREATE OR REPLACE VIEW public.drill_point_events AS SELECT * FROM public.point_events;
+
+DO $$
+DECLARE
+  optional_table TEXT;
+BEGIN
+  FOREACH optional_table IN ARRAY ARRAY[
+    'pong_stats',
+    'pong_duels',
+    'pong_matches',
+    'pong_duel_log',
+    'ctf_games',
+    'ctf_players',
+    'ctf_tiebreaker_matches',
+    'game_mode_settings',
+    'koth_games',
+    'koth_players',
+    'koth_point_events',
+    'tiebreaker_matches',
+    'tiebreaker_champions'
+  ]
+  LOOP
+    IF to_regclass('public.' || optional_table) IS NOT NULL THEN
+      EXECUTE format(
+        'CREATE OR REPLACE VIEW public.%I AS SELECT * FROM public.%I',
+        'drill_' || optional_table,
+        optional_table
+      );
+    END IF;
+  END LOOP;
+END;
+$$;
+
+DO $$
+DECLARE
+  table_name TEXT;
+BEGIN
+  FOREACH table_name IN ARRAY ARRAY[
+    'lsrl_progress',
+    'user_progress',
+    'user_settings',
+    'api_keys_pool',
+    'teacher_reviews',
+    'time_sessions',
+    'time_problems',
+    'point_events',
+    'progression_overrides',
+    'ghost_profiles',
+    'ghost_ratings',
+    'ghost_battles',
+    'ghost_orbits_sessions',
+    'ghost_orbits_stats',
+    'grid_wars_games',
+    'grid_wars_territories',
+    'grid_wars_structures',
+    'grid_wars_players',
+    'grid_wars_gifts',
+    'round_history'
+  ]
+  LOOP
+    EXECUTE format('ALTER TABLE public.%I ENABLE ROW LEVEL SECURITY', table_name);
+    EXECUTE format('REVOKE ALL ON TABLE public.%I FROM anon, authenticated', table_name);
+  END LOOP;
+END;
+$$;
+
+DO $$
+DECLARE
+  view_name TEXT;
+BEGIN
+  FOREACH view_name IN ARRAY ARRAY[
+    'leaderboard',
+    'class_roster',
+    'ghost_orbits_leaderboard',
+    'grid_wars_active_contestations',
+    'drill_progress',
+    'drill_leaderboard',
+    'drill_time_tracking',
+    'drill_avatar_system',
+    'drill_user_progress',
+    'drill_user_settings',
+    'drill_teacher_reviews',
+    'drill_progression_overrides',
+    'drill_ghost_profiles',
+    'drill_ghost_ratings',
+    'drill_ghost_battles',
+    'drill_ghost_orbits_sessions',
+    'drill_ghost_orbits_stats',
+    'drill_ghost_orbits_leaderboard',
+    'drill_grid_wars_games',
+    'drill_grid_wars_territories',
+    'drill_grid_wars_structures',
+    'drill_grid_wars_players',
+    'drill_grid_wars_gifts',
+    'drill_round_history',
+    'drill_class_roster',
+    'drill_point_events'
+  ]
+  LOOP
+    IF to_regclass('public.' || view_name) IS NOT NULL THEN
+      EXECUTE format('REVOKE ALL ON TABLE public.%I FROM anon, authenticated', view_name);
+    END IF;
+  END LOOP;
+END;
+$$;
+
+GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO service_role;
+GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA public TO service_role;
