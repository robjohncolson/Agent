@@ -0,0 +1,322 @@
+-- Shared Supabase base objects for curriculum_render + lrsl-driller.
+-- Compatibility strategy:
+--   1. Keep public.users as the legacy compatibility table because lrsl-driller
+--      foreign keys point at it today.
+--   2. Introduce public.shared_users as the shared auth namespace.
+--   3. Mirror users <-> shared_users so both legacy and namespaced access work.
+--   4. Keep shared_grading_log service-role only until the proxy writes to it.
+
+CREATE EXTENSION IF NOT EXISTS pgcrypto;
+
+CREATE OR REPLACE FUNCTION public.touch_updated_at()
+RETURNS trigger AS $$
+BEGIN
+  NEW.updated_at = NOW();
+  RETURN NEW;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE TABLE IF NOT EXISTS public.users (
+  username TEXT PRIMARY KEY,
+  real_name TEXT,
+  password TEXT,
+  user_type TEXT NOT NULL DEFAULT 'student' CHECK (user_type IN ('student', 'teacher')),
+  class_period VARCHAR(1),
+  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  last_seen TIMESTAMPTZ
+);
+
+ALTER TABLE public.users ADD COLUMN IF NOT EXISTS real_name TEXT;
+ALTER TABLE public.users ADD COLUMN IF NOT EXISTS password TEXT;
+ALTER TABLE public.users ADD COLUMN IF NOT EXISTS user_type TEXT;
+ALTER TABLE public.users ADD COLUMN IF NOT EXISTS class_period VARCHAR(1);
+ALTER TABLE public.users ADD COLUMN IF NOT EXISTS created_at TIMESTAMPTZ DEFAULT NOW();
+ALTER TABLE public.users ADD COLUMN IF NOT EXISTS updated_at TIMESTAMPTZ DEFAULT NOW();
+ALTER TABLE public.users ADD COLUMN IF NOT EXISTS last_seen TIMESTAMPTZ;
+ALTER TABLE public.users ALTER COLUMN user_type SET DEFAULT 'student';
+ALTER TABLE public.users ALTER COLUMN created_at SET DEFAULT NOW();
+ALTER TABLE public.users ALTER COLUMN updated_at SET DEFAULT NOW();
+
+CREATE INDEX IF NOT EXISTS idx_users_real_name ON public.users(real_name);
+CREATE INDEX IF NOT EXISTS idx_users_user_type ON public.users(user_type);
+CREATE INDEX IF NOT EXISTS idx_users_class_period ON public.users(class_period);
+
+DROP TRIGGER IF EXISTS users_touch_updated_at ON public.users;
+CREATE TRIGGER users_touch_updated_at
+  BEFORE UPDATE ON public.users
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.shared_users (
+  student_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
+  username TEXT NOT NULL UNIQUE,
+  real_name TEXT,
+  password TEXT,
+  user_type TEXT NOT NULL DEFAULT 'student' CHECK (user_type IN ('student', 'teacher')),
+  class_period VARCHAR(1),
+  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  last_seen TIMESTAMPTZ
+);
+
+ALTER TABLE public.shared_users ADD COLUMN IF NOT EXISTS student_id UUID DEFAULT gen_random_uuid();
+ALTER TABLE public.shared_users ADD COLUMN IF NOT EXISTS username TEXT;
+ALTER TABLE public.shared_users ADD COLUMN IF NOT EXISTS real_name TEXT;
+ALTER TABLE public.shared_users ADD COLUMN IF NOT EXISTS password TEXT;
+ALTER TABLE public.shared_users ADD COLUMN IF NOT EXISTS user_type TEXT;
+ALTER TABLE public.shared_users ADD COLUMN IF NOT EXISTS class_period VARCHAR(1);
+ALTER TABLE public.shared_users ADD COLUMN IF NOT EXISTS created_at TIMESTAMPTZ DEFAULT NOW();
+ALTER TABLE public.shared_users ADD COLUMN IF NOT EXISTS updated_at TIMESTAMPTZ DEFAULT NOW();
+ALTER TABLE public.shared_users ADD COLUMN IF NOT EXISTS last_seen TIMESTAMPTZ;
+ALTER TABLE public.shared_users ALTER COLUMN user_type SET DEFAULT 'student';
+ALTER TABLE public.shared_users ALTER COLUMN created_at SET DEFAULT NOW();
+ALTER TABLE public.shared_users ALTER COLUMN updated_at SET DEFAULT NOW();
+
+CREATE UNIQUE INDEX IF NOT EXISTS idx_shared_users_username_unique ON public.shared_users(username);
+CREATE INDEX IF NOT EXISTS idx_shared_users_user_type ON public.shared_users(user_type);
+CREATE INDEX IF NOT EXISTS idx_shared_users_class_period ON public.shared_users(class_period);
+
+DROP TRIGGER IF EXISTS shared_users_touch_updated_at ON public.shared_users;
+CREATE TRIGGER shared_users_touch_updated_at
+  BEFORE UPDATE ON public.shared_users
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+INSERT INTO public.shared_users (
+  username,
+  real_name,
+  password,
+  user_type,
+  class_period,
+  created_at,
+  updated_at,
+  last_seen
+)
+SELECT
+  u.username,
+  u.real_name,
+  u.password,
+  COALESCE(u.user_type, 'student'),
+  u.class_period,
+  COALESCE(u.created_at, NOW()),
+  COALESCE(u.updated_at, NOW()),
+  u.last_seen
+FROM public.users AS u
+ON CONFLICT (username) DO UPDATE
+SET
+  real_name = EXCLUDED.real_name,
+  password = EXCLUDED.password,
+  user_type = EXCLUDED.user_type,
+  class_period = EXCLUDED.class_period,
+  created_at = LEAST(public.shared_users.created_at, EXCLUDED.created_at),
+  updated_at = GREATEST(public.shared_users.updated_at, EXCLUDED.updated_at),
+  last_seen = GREATEST(
+    COALESCE(public.shared_users.last_seen, EXCLUDED.last_seen),
+    COALESCE(EXCLUDED.last_seen, public.shared_users.last_seen)
+  );
+
+INSERT INTO public.users (
+  username,
+  real_name,
+  password,
+  user_type,
+  class_period,
+  created_at,
+  updated_at,
+  last_seen
+)
+SELECT
+  su.username,
+  su.real_name,
+  su.password,
+  COALESCE(su.user_type, 'student'),
+  su.class_period,
+  COALESCE(su.created_at, NOW()),
+  COALESCE(su.updated_at, NOW()),
+  su.last_seen
+FROM public.shared_users AS su
+ON CONFLICT (username) DO UPDATE
+SET
+  real_name = EXCLUDED.real_name,
+  password = EXCLUDED.password,
+  user_type = EXCLUDED.user_type,
+  class_period = EXCLUDED.class_period,
+  created_at = LEAST(public.users.created_at, EXCLUDED.created_at),
+  updated_at = GREATEST(public.users.updated_at, EXCLUDED.updated_at),
+  last_seen = GREATEST(
+    COALESCE(public.users.last_seen, EXCLUDED.last_seen),
+    COALESCE(EXCLUDED.last_seen, public.users.last_seen)
+  );
+
+CREATE OR REPLACE FUNCTION public.sync_users_to_shared_users()
+RETURNS trigger AS $$
+BEGIN
+  IF pg_trigger_depth() > 1 THEN
+    RETURN COALESCE(NEW, OLD);
+  END IF;
+
+  IF TG_OP = 'DELETE' THEN
+    DELETE FROM public.shared_users WHERE username = OLD.username;
+    RETURN OLD;
+  END IF;
+
+  INSERT INTO public.shared_users (
+    username,
+    real_name,
+    password,
+    user_type,
+    class_period,
+    created_at,
+    updated_at,
+    last_seen
+  )
+  VALUES (
+    NEW.username,
+    NEW.real_name,
+    NEW.password,
+    COALESCE(NEW.user_type, 'student'),
+    NEW.class_period,
+    COALESCE(NEW.created_at, NOW()),
+    COALESCE(NEW.updated_at, NOW()),
+    NEW.last_seen
+  )
+  ON CONFLICT (username) DO UPDATE
+  SET
+    real_name = EXCLUDED.real_name,
+    password = EXCLUDED.password,
+    user_type = EXCLUDED.user_type,
+    class_period = EXCLUDED.class_period,
+    created_at = LEAST(public.shared_users.created_at, EXCLUDED.created_at),
+    updated_at = GREATEST(public.shared_users.updated_at, EXCLUDED.updated_at),
+    last_seen = GREATEST(
+      COALESCE(public.shared_users.last_seen, EXCLUDED.last_seen),
+      COALESCE(EXCLUDED.last_seen, public.shared_users.last_seen)
+    );
+
+  RETURN NEW;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE OR REPLACE FUNCTION public.sync_shared_users_to_users()
+RETURNS trigger AS $$
+BEGIN
+  IF pg_trigger_depth() > 1 THEN
+    RETURN COALESCE(NEW, OLD);
+  END IF;
+
+  IF TG_OP = 'DELETE' THEN
+    DELETE FROM public.users WHERE username = OLD.username;
+    RETURN OLD;
+  END IF;
+
+  INSERT INTO public.users (
+    username,
+    real_name,
+    password,
+    user_type,
+    class_period,
+    created_at,
+    updated_at,
+    last_seen
+  )
+  VALUES (
+    NEW.username,
+    NEW.real_name,
+    NEW.password,
+    COALESCE(NEW.user_type, 'student'),
+    NEW.class_period,
+    COALESCE(NEW.created_at, NOW()),
+    COALESCE(NEW.updated_at, NOW()),
+    NEW.last_seen
+  )
+  ON CONFLICT (username) DO UPDATE
+  SET
+    real_name = EXCLUDED.real_name,
+    password = EXCLUDED.password,
+    user_type = EXCLUDED.user_type,
+    class_period = EXCLUDED.class_period,
+    created_at = LEAST(public.users.created_at, EXCLUDED.created_at),
+    updated_at = GREATEST(public.users.updated_at, EXCLUDED.updated_at),
+    last_seen = GREATEST(
+      COALESCE(public.users.last_seen, EXCLUDED.last_seen),
+      COALESCE(EXCLUDED.last_seen, public.users.last_seen)
+    );
+
+  RETURN NEW;
+END;
+$$ LANGUAGE plpgsql;
+
+DROP TRIGGER IF EXISTS users_sync_to_shared_users ON public.users;
+CREATE TRIGGER users_sync_to_shared_users
+  AFTER INSERT OR UPDATE OR DELETE ON public.users
+  FOR EACH ROW
+  EXECUTE FUNCTION public.sync_users_to_shared_users();
+
+DROP TRIGGER IF EXISTS shared_users_sync_to_users ON public.shared_users;
+CREATE TRIGGER shared_users_sync_to_users
+  AFTER INSERT OR UPDATE OR DELETE ON public.shared_users
+  FOR EACH ROW
+  EXECUTE FUNCTION public.sync_shared_users_to_users();
+
+CREATE TABLE IF NOT EXISTS public.shared_grading_log (
+  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
+  source_app TEXT NOT NULL CHECK (source_app IN ('curriculum_render', 'lrsl-driller')),
+  question_id TEXT NOT NULL,
+  username TEXT NOT NULL,
+  score TEXT,
+  provider TEXT,
+  graded_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  metadata JSONB NOT NULL DEFAULT '{}'::jsonb
+);
+
+CREATE INDEX IF NOT EXISTS idx_shared_grading_log_question ON public.shared_grading_log(question_id);
+CREATE INDEX IF NOT EXISTS idx_shared_grading_log_username ON public.shared_grading_log(username);
+CREATE INDEX IF NOT EXISTS idx_shared_grading_log_source_app ON public.shared_grading_log(source_app, graded_at DESC);
+
+ALTER TABLE public.users ENABLE ROW LEVEL SECURITY;
+ALTER TABLE public.shared_users ENABLE ROW LEVEL SECURITY;
+ALTER TABLE public.shared_grading_log ENABLE ROW LEVEL SECURITY;
+
+DROP POLICY IF EXISTS users_public_select ON public.users;
+DROP POLICY IF EXISTS users_public_insert ON public.users;
+DROP POLICY IF EXISTS users_public_update ON public.users;
+
+CREATE POLICY users_public_select
+  ON public.users
+  FOR SELECT
+  TO anon, authenticated
+  USING (true);
+
+CREATE POLICY users_public_insert
+  ON public.users
+  FOR INSERT
+  TO anon, authenticated
+  WITH CHECK (true);
+
+CREATE POLICY users_public_update
+  ON public.users
+  FOR UPDATE
+  TO anon, authenticated
+  USING (true)
+  WITH CHECK (true);
+
+DROP POLICY IF EXISTS shared_users_public_select ON public.shared_users;
+
+CREATE POLICY shared_users_public_select
+  ON public.shared_users
+  FOR SELECT
+  TO anon, authenticated
+  USING (true);
+
+REVOKE ALL ON TABLE public.users FROM anon, authenticated;
+REVOKE ALL ON TABLE public.shared_users FROM anon, authenticated;
+REVOKE ALL ON TABLE public.shared_grading_log FROM anon, authenticated;
+
+GRANT SELECT, INSERT, UPDATE ON TABLE public.users TO anon, authenticated;
+GRANT SELECT ON TABLE public.shared_users TO anon, authenticated;
+
+GRANT ALL PRIVILEGES ON TABLE public.users TO service_role;
+GRANT ALL PRIVILEGES ON TABLE public.shared_users TO service_role;
+GRANT ALL PRIVILEGES ON TABLE public.shared_grading_log TO service_role;
+GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA public TO anon, authenticated, service_role;
diff --git a/C:/Users/ColsonR/shared-grading-proxy/migrations/002_curriculum_render_namespace.sql b/C:/Users/ColsonR/shared-grading-proxy/migrations/002_curriculum_render_namespace.sql
