+-- Curriculum Render shared-instance schema.
+-- Compatibility strategy:
+--   1. Keep public.answers as the live legacy table because the browser does
+--      direct upserts and real-time subscriptions against it.
+--   2. Mirror answers <-> cr_answers so the new namespace exists immediately.
+--   3. Keep the remaining curriculum tables on their legacy names and expose
+--      prefixed views for the shared-instance namespace.
+
+CREATE TABLE IF NOT EXISTS public.answers (
+  username TEXT NOT NULL,
+  question_id TEXT NOT NULL,
+  answer_value TEXT NOT NULL,
+  timestamp BIGINT NOT NULL,
+  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  PRIMARY KEY (username, question_id)
+);
+
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS username TEXT;
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS question_id TEXT;
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS answer_value TEXT;
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS timestamp BIGINT;
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS created_at TIMESTAMPTZ DEFAULT NOW();
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS updated_at TIMESTAMPTZ DEFAULT NOW();
+ALTER TABLE public.answers ALTER COLUMN created_at SET DEFAULT NOW();
+ALTER TABLE public.answers ALTER COLUMN updated_at SET DEFAULT NOW();
+
+CREATE INDEX IF NOT EXISTS idx_answers_question_id ON public.answers(question_id);
+CREATE INDEX IF NOT EXISTS idx_answers_timestamp ON public.answers(timestamp DESC);
+CREATE INDEX IF NOT EXISTS idx_answers_username ON public.answers(username);
+
+DROP TRIGGER IF EXISTS answers_touch_updated_at ON public.answers;
+CREATE TRIGGER answers_touch_updated_at
+  BEFORE UPDATE ON public.answers
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.cr_answers (
+  question_id TEXT NOT NULL,
+  student_id TEXT NOT NULL,
+  value TEXT NOT NULL,
+  timestamp BIGINT NOT NULL,
+  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  PRIMARY KEY (question_id, student_id)
+);
+
+ALTER TABLE public.cr_answers ADD COLUMN IF NOT EXISTS question_id TEXT;
+ALTER TABLE public.cr_answers ADD COLUMN IF NOT EXISTS student_id TEXT;
+ALTER TABLE public.cr_answers ADD COLUMN IF NOT EXISTS value TEXT;
+ALTER TABLE public.cr_answers ADD COLUMN IF NOT EXISTS timestamp BIGINT;
+ALTER TABLE public.cr_answers ADD COLUMN IF NOT EXISTS created_at TIMESTAMPTZ DEFAULT NOW();
+ALTER TABLE public.cr_answers ADD COLUMN IF NOT EXISTS updated_at TIMESTAMPTZ DEFAULT NOW();
+ALTER TABLE public.cr_answers ALTER COLUMN created_at SET DEFAULT NOW();
+ALTER TABLE public.cr_answers ALTER COLUMN updated_at SET DEFAULT NOW();
+
+CREATE INDEX IF NOT EXISTS idx_cr_answers_student ON public.cr_answers(student_id);
+CREATE INDEX IF NOT EXISTS idx_cr_answers_timestamp ON public.cr_answers(timestamp DESC);
+
+DROP TRIGGER IF EXISTS cr_answers_touch_updated_at ON public.cr_answers;
+CREATE TRIGGER cr_answers_touch_updated_at
+  BEFORE UPDATE ON public.cr_answers
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+INSERT INTO public.cr_answers (
+  question_id,
+  student_id,
+  value,
+  timestamp,
+  created_at,
+  updated_at
+)
+SELECT
+  a.question_id,
+  a.username,
+  a.answer_value,
+  a.timestamp,
+  COALESCE(a.created_at, NOW()),
+  COALESCE(a.updated_at, NOW())
+FROM public.answers AS a
+ON CONFLICT (question_id, student_id) DO UPDATE
+SET
+  value = EXCLUDED.value,
+  timestamp = EXCLUDED.timestamp,
+  created_at = LEAST(public.cr_answers.created_at, EXCLUDED.created_at),
+  updated_at = GREATEST(public.cr_answers.updated_at, EXCLUDED.updated_at);
+
+INSERT INTO public.answers (
+  username,
+  question_id,
+  answer_value,
+  timestamp,
+  created_at,
+  updated_at
+)
+SELECT
+  ca.student_id,
+  ca.question_id,
+  ca.value,
+  ca.timestamp,
+  COALESCE(ca.created_at, NOW()),
+  COALESCE(ca.updated_at, NOW())
+FROM public.cr_answers AS ca
+ON CONFLICT (username, question_id) DO UPDATE
+SET
+  answer_value = EXCLUDED.answer_value,
+  timestamp = EXCLUDED.timestamp,
+  created_at = LEAST(public.answers.created_at, EXCLUDED.created_at),
+  updated_at = GREATEST(public.answers.updated_at, EXCLUDED.updated_at);
+
+CREATE OR REPLACE FUNCTION public.sync_answers_to_cr_answers()
+RETURNS trigger AS $$
+BEGIN
+  IF pg_trigger_depth() > 1 THEN
+    RETURN COALESCE(NEW, OLD);
+  END IF;
+
+  IF TG_OP = 'DELETE' THEN
+    DELETE FROM public.cr_answers
+    WHERE question_id = OLD.question_id AND student_id = OLD.username;
+    RETURN OLD;
+  END IF;
+
+  INSERT INTO public.cr_answers (
+    question_id,
+    student_id,
+    value,
+    timestamp,
+    created_at,
+    updated_at
+  )
+  VALUES (
+    NEW.question_id,
+    NEW.username,
+    NEW.answer_value,
+    NEW.timestamp,
+    COALESCE(NEW.created_at, NOW()),
+    COALESCE(NEW.updated_at, NOW())
+  )
+  ON CONFLICT (question_id, student_id) DO UPDATE
+  SET
+    value = EXCLUDED.value,
+    timestamp = EXCLUDED.timestamp,
+    created_at = LEAST(public.cr_answers.created_at, EXCLUDED.created_at),
+    updated_at = GREATEST(public.cr_answers.updated_at, EXCLUDED.updated_at);
+
+  RETURN NEW;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE OR REPLACE FUNCTION public.sync_cr_answers_to_answers()
+RETURNS trigger AS $$
+BEGIN
+  IF pg_trigger_depth() > 1 THEN
+    RETURN COALESCE(NEW, OLD);
+  END IF;
+
+  IF TG_OP = 'DELETE' THEN
+    DELETE FROM public.answers
+    WHERE username = OLD.student_id AND question_id = OLD.question_id;
+    RETURN OLD;
+  END IF;
+
+  INSERT INTO public.answers (
+    username,
+    question_id,
+    answer_value,
+    timestamp,
+    created_at,
+    updated_at
+  )
+  VALUES (
+    NEW.student_id,
+    NEW.question_id,
+    NEW.value,
+    NEW.timestamp,
+    COALESCE(NEW.created_at, NOW()),
+    COALESCE(NEW.updated_at, NOW())
+  )
+  ON CONFLICT (username, question_id) DO UPDATE
+  SET
+    answer_value = EXCLUDED.answer_value,
+    timestamp = EXCLUDED.timestamp,
+    created_at = LEAST(public.answers.created_at, EXCLUDED.created_at),
+    updated_at = GREATEST(public.answers.updated_at, EXCLUDED.updated_at);
+
+  RETURN NEW;
+END;
+$$ LANGUAGE plpgsql;
+
+DROP TRIGGER IF EXISTS answers_sync_to_cr_answers ON public.answers;
+CREATE TRIGGER answers_sync_to_cr_answers
+  AFTER INSERT OR UPDATE OR DELETE ON public.answers
+  FOR EACH ROW
+  EXECUTE FUNCTION public.sync_answers_to_cr_answers();
+
+DROP TRIGGER IF EXISTS cr_answers_sync_to_answers ON public.cr_answers;
+CREATE TRIGGER cr_answers_sync_to_answers
+  AFTER INSERT OR UPDATE OR DELETE ON public.cr_answers
+  FOR EACH ROW
+  EXECUTE FUNCTION public.sync_cr_answers_to_answers();
+
+CREATE TABLE IF NOT EXISTS public.badges (
+  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
+  username TEXT NOT NULL,
+  badge_type TEXT NOT NULL,
+  earned_date BIGINT NOT NULL,
+  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
