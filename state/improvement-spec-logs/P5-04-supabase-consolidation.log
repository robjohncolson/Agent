+-- Curriculum Render shared-instance schema.
+-- Compatibility strategy:
+--   1. Keep public.answers as the live legacy table because the browser does
+--      direct upserts and real-time subscriptions against it.
+--   2. Mirror answers <-> cr_answers so the new namespace exists immediately.
+--   3. Keep the remaining curriculum tables on their legacy names and expose
+--      prefixed views for the shared-instance namespace.
+
+CREATE TABLE IF NOT EXISTS public.answers (
+  username TEXT NOT NULL,
+  question_id TEXT NOT NULL,
+  answer_value TEXT NOT NULL,
+  timestamp BIGINT NOT NULL,
+  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  PRIMARY KEY (username, question_id)
+);
+
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS username TEXT;
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS question_id TEXT;
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS answer_value TEXT;
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS timestamp BIGINT;
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS created_at TIMESTAMPTZ DEFAULT NOW();
+ALTER TABLE public.answers ADD COLUMN IF NOT EXISTS updated_at TIMESTAMPTZ DEFAULT NOW();
+ALTER TABLE public.answers ALTER COLUMN created_at SET DEFAULT NOW();
+ALTER TABLE public.answers ALTER COLUMN updated_at SET DEFAULT NOW();
+
+CREATE INDEX IF NOT EXISTS idx_answers_question_id ON public.answers(question_id);
+CREATE INDEX IF NOT EXISTS idx_answers_timestamp ON public.answers(timestamp DESC);
+CREATE INDEX IF NOT EXISTS idx_answers_username ON public.answers(username);
+
+DROP TRIGGER IF EXISTS answers_touch_updated_at ON public.answers;
+CREATE TRIGGER answers_touch_updated_at
+  BEFORE UPDATE ON public.answers
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.cr_answers (
+  question_id TEXT NOT NULL,
+  student_id TEXT NOT NULL,
+  value TEXT NOT NULL,
+  timestamp BIGINT NOT NULL,
+  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
+  PRIMARY KEY (question_id, student_id)
+);
