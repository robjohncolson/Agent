+
+CREATE OR REPLACE VIEW public.cr_peer_data AS
+SELECT
+  ca.question_id,
+  jsonb_object_agg(
+    ca.student_id,
+    jsonb_build_object('value', ca.value, 'timestamp', ca.timestamp)
+  ) AS aggregated_data,
+  TO_TIMESTAMP(MAX(ca.timestamp) / 1000.0) AS updated_at
+FROM public.cr_answers AS ca
+GROUP BY ca.question_id;
+
+CREATE OR REPLACE VIEW public.cr_votes AS
+SELECT
+  v.question_id,
+  v.voter_username AS student_id,
