+CREATE INDEX IF NOT EXISTS idx_gw_games_status ON public.grid_wars_games(status);
+CREATE INDEX IF NOT EXISTS idx_gw_territories_game ON public.grid_wars_territories(game_id);
+CREATE INDEX IF NOT EXISTS idx_gw_territories_owner ON public.grid_wars_territories(owner);
+CREATE INDEX IF NOT EXISTS idx_gw_territories_contested
+  ON public.grid_wars_territories(contested_by)
+  WHERE contested_by IS NOT NULL;
+CREATE INDEX IF NOT EXISTS idx_gw_structures_game ON public.grid_wars_structures(game_id);
+CREATE INDEX IF NOT EXISTS idx_gw_structures_owner ON public.grid_wars_structures(owner);
+CREATE INDEX IF NOT EXISTS idx_gw_players_game ON public.grid_wars_players(game_id);
+CREATE INDEX IF NOT EXISTS idx_gw_players_username ON public.grid_wars_players(username);
+CREATE INDEX IF NOT EXISTS idx_gw_players_position ON public.grid_wars_players(game_id, position_x, position_y);
+CREATE INDEX IF NOT EXISTS idx_gw_players_lifetime ON public.grid_wars_players(lifetime_earned DESC);
+CREATE INDEX IF NOT EXISTS idx_gw_players_last_answer
+  ON public.grid_wars_players(last_answer_at)
+  WHERE last_answer_at IS NOT NULL;
+CREATE INDEX IF NOT EXISTS idx_grid_wars_players_correct_count
+  ON public.grid_wars_players(game_id, username, correct_answer_count);
+CREATE INDEX IF NOT EXISTS idx_gifts_game ON public.grid_wars_gifts(game_id);
+CREATE INDEX IF NOT EXISTS idx_gifts_from ON public.grid_wars_gifts(from_username);
+CREATE INDEX IF NOT EXISTS idx_gifts_to ON public.grid_wars_gifts(to_username);
+CREATE INDEX IF NOT EXISTS idx_gifts_timestamp ON public.grid_wars_gifts(gifted_at);
+CREATE INDEX IF NOT EXISTS idx_round_history_game ON public.round_history(game_id);
+CREATE INDEX IF NOT EXISTS idx_round_history_ended ON public.round_history(ended_at DESC);
+CREATE INDEX IF NOT EXISTS idx_round_history_winner ON public.round_history(winner_id);
+
+CREATE OR REPLACE FUNCTION public.get_spawn_position(p_game_id TEXT, p_map_size INT DEFAULT 20)
+RETURNS TABLE(spawn_x INT, spawn_y INT) AS $$
+DECLARE
+  margin INT := 3;
+  best_x INT;
+  best_y INT;
+  best_distance FLOAT := 0;
+  test_x INT;
+  test_y INT;
+  min_dist FLOAT;
+  dist FLOAT;
+  player RECORD;
+BEGIN
+  FOR test_x IN margin..(p_map_size - margin - 1) LOOP
+    FOR test_y IN margin..(p_map_size - margin - 1) LOOP
+      min_dist := 999999;
+      FOR player IN
+        SELECT position_x, position_y
+        FROM public.grid_wars_players
+        WHERE game_id = p_game_id AND position_x IS NOT NULL
+      LOOP
+        dist := sqrt(power(test_x - player.position_x, 2) + power(test_y - player.position_y, 2));
+        IF dist < min_dist THEN
+          min_dist := dist;
+        END IF;
+      END LOOP;
+      IF min_dist > best_distance THEN
+        best_distance := min_dist;
+        best_x := test_x;
+        best_y := test_y;
+      END IF;
+    END LOOP;
+  END LOOP;
+  IF best_x IS NULL THEN
+    best_x := p_map_size / 2;
+    best_y := p_map_size / 2;
+  END IF;
+  spawn_x := best_x;
+  spawn_y := best_y;
+  RETURN NEXT;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE OR REPLACE FUNCTION public.init_resource_nodes(p_game_id TEXT)
+RETURNS VOID AS $$
+BEGIN
+  INSERT INTO public.grid_wars_territories (game_id, x, y, owner, node_type, strength)
+  VALUES
+    (p_game_id, 10, 10, NULL, 'amplifier', 3),
+    (p_game_id, 4, 4, NULL, 'beacon', 3),
+    (p_game_id, 15, 15, NULL, 'anchor', 3)
+  ON CONFLICT (game_id, x, y) DO UPDATE
+  SET node_type = EXCLUDED.node_type;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE OR REPLACE VIEW public.grid_wars_active_contestations AS
+SELECT
+  t.game_id,
+  t.x,
+  t.y,
+  t.owner,
+  t.contested_by,
+  t.contested_since,
+  EXTRACT(EPOCH FROM (NOW() - t.contested_since)) AS seconds_contested,
+  p_owner.health AS owner_health,
+  p_contester.health AS contester_health,
+  p_contester.position_x AS contester_x,
+  p_contester.position_y AS contester_y
+FROM public.grid_wars_territories AS t
+JOIN public.grid_wars_players AS p_owner
+  ON t.game_id = p_owner.game_id AND t.owner = p_owner.username
+LEFT JOIN public.grid_wars_players AS p_contester
+  ON t.game_id = p_contester.game_id AND t.contested_by = p_contester.username
+WHERE t.contested_by IS NOT NULL;
+
+CREATE OR REPLACE VIEW public.leaderboard AS
+SELECT
+  u.username,
+  u.real_name,
+  COALESCE(SUM(CASE WHEN p.star_type = 'gold' THEN 1 ELSE 0 END), 0) AS gold,
+  COALESCE(SUM(CASE WHEN p.star_type = 'silver' THEN 1 ELSE 0 END), 0) AS silver,
+  COALESCE(SUM(CASE WHEN p.star_type = 'bronze' THEN 1 ELSE 0 END), 0) AS bronze,
+  COALESCE(SUM(CASE WHEN p.star_type = 'tin' THEN 1 ELSE 0 END), 0) AS tin,
+  COALESCE(
+    SUM(CASE WHEN p.star_type = 'gold' THEN 4 ELSE 0 END) +
+    SUM(CASE WHEN p.star_type = 'silver' THEN 3 ELSE 0 END) +
+    SUM(CASE WHEN p.star_type = 'bronze' THEN 2 ELSE 0 END) +
+    SUM(CASE WHEN p.star_type = 'tin' THEN 1 ELSE 0 END),
+    0
+  ) AS weighted_score,
+  COUNT(p.id) AS total_attempts,
+  COALESCE(SUM(CASE WHEN p.all_correct THEN 1 ELSE 0 END), 0) AS perfect_runs,
+  MAX(p.completed_at) AS last_active
+FROM public.users AS u
+LEFT JOIN public.lsrl_progress AS p
+  ON u.username = p.username
+WHERE u.user_type = 'student'
+GROUP BY u.username, u.real_name
+ORDER BY weighted_score DESC, perfect_runs DESC;
+
+CREATE OR REPLACE VIEW public.class_roster AS
+SELECT
+  username,
+  real_name,
+  class_period,
+  created_at,
+  last_seen
+FROM public.users
+WHERE user_type = 'student';
+
+CREATE OR REPLACE VIEW public.ghost_orbits_leaderboard AS
+SELECT
+  username,
+  SUM(wins) AS total_wins,
+  SUM(games_played) AS total_games,
+  ROUND(SUM(wins)::DECIMAL / NULLIF(SUM(games_played), 0) * 100, 1) AS win_rate,
+  MAX(best_territory_percent) AS best_territory
+FROM public.ghost_orbits_stats
+GROUP BY username
+ORDER BY total_wins DESC;
+
+CREATE OR REPLACE VIEW public.drill_progress AS
+SELECT
+  up.username AS student_id,
+  up.cartridge_id,
+  mode_progress.key AS mode_id,
+  mode_progress.value AS stars,
+  up.updated_at AS completed_at
+FROM public.user_progress AS up
+CROSS JOIN LATERAL jsonb_each(COALESCE(up.mode_progress, '{}'::jsonb)) AS mode_progress(key, value);
+
+CREATE OR REPLACE VIEW public.drill_leaderboard AS
+SELECT
+  up.username AS student_id,
+  up.cartridge_id,
+  up.total_weighted_score AS total_points,
+  DENSE_RANK() OVER (
+    PARTITION BY up.cartridge_id
+    ORDER BY up.total_weighted_score DESC, up.username ASC
+  ) AS rank,
+  up.updated_at
+FROM public.user_progress AS up;
+
+CREATE OR REPLACE VIEW public.drill_time_tracking AS
+SELECT
+  ts.username AS student_id,
+  ts.session_id,
+  ts.session_start,
+  CASE WHEN ts.is_complete THEN ts.last_sync ELSE NULL END AS session_end,
+  ts.total_time_ms AS duration_ms,
+  ts.active_time_ms,
+  ts.is_complete,
+  ts.last_sync AS updated_at
+FROM public.time_sessions AS ts;
+
+CREATE OR REPLACE VIEW public.drill_avatar_system AS
+SELECT
+  gp.username AS student_id,
+  jsonb_build_object(
+    'format', gp.avatar_format,
+    'position', jsonb_build_object('x', gp.position_x, 'y', gp.position_y),
+    'health', gp.health,
+    'color', gp.color
+  ) AS avatar_config,
+  gp.updated_at
+FROM public.grid_wars_players AS gp;
+
+CREATE OR REPLACE VIEW public.drill_user_progress AS SELECT * FROM public.user_progress;
+CREATE OR REPLACE VIEW public.drill_user_settings AS SELECT * FROM public.user_settings;
+CREATE OR REPLACE VIEW public.drill_teacher_reviews AS SELECT * FROM public.teacher_reviews;
+CREATE OR REPLACE VIEW public.drill_progression_overrides AS SELECT * FROM public.progression_overrides;
+CREATE OR REPLACE VIEW public.drill_ghost_profiles AS SELECT * FROM public.ghost_profiles;
+CREATE OR REPLACE VIEW public.drill_ghost_ratings AS SELECT * FROM public.ghost_ratings;
+CREATE OR REPLACE VIEW public.drill_ghost_battles AS SELECT * FROM public.ghost_battles;
+CREATE OR REPLACE VIEW public.drill_ghost_orbits_sessions AS SELECT * FROM public.ghost_orbits_sessions;
+CREATE OR REPLACE VIEW public.drill_ghost_orbits_stats AS SELECT * FROM public.ghost_orbits_stats;
+CREATE OR REPLACE VIEW public.drill_ghost_orbits_leaderboard AS SELECT * FROM public.ghost_orbits_leaderboard;
+CREATE OR REPLACE VIEW public.drill_grid_wars_games AS SELECT * FROM public.grid_wars_games;
+CREATE OR REPLACE VIEW public.drill_grid_wars_territories AS SELECT * FROM public.grid_wars_territories;
+CREATE OR REPLACE VIEW public.drill_grid_wars_structures AS SELECT * FROM public.grid_wars_structures;
+CREATE OR REPLACE VIEW public.drill_grid_wars_players AS SELECT * FROM public.grid_wars_players;
+CREATE OR REPLACE VIEW public.drill_grid_wars_gifts AS SELECT * FROM public.grid_wars_gifts;
+CREATE OR REPLACE VIEW public.drill_round_history AS SELECT * FROM public.round_history;
+CREATE OR REPLACE VIEW public.drill_class_roster AS SELECT * FROM public.class_roster;
+CREATE OR REPLACE VIEW public.drill_point_events AS SELECT * FROM public.point_events;
+
+DO $$
+DECLARE
+  optional_table TEXT;
+BEGIN
+  FOREACH optional_table IN ARRAY ARRAY[
+    'pong_stats',
+    'pong_duels',
+    'pong_matches',
+    'pong_duel_log',
+    'ctf_games',
+    'ctf_players',
+    'ctf_tiebreaker_matches',
+    'game_mode_settings',
+    'koth_games',
+    'koth_players',
+    'koth_point_events',
+    'tiebreaker_matches',
+    'tiebreaker_champions'
+  ]
+  LOOP
+    IF to_regclass('public.' || optional_table) IS NOT NULL THEN
+      EXECUTE format(
+        'CREATE OR REPLACE VIEW public.%I AS SELECT * FROM public.%I',
+        'drill_' || optional_table,
+        optional_table
+      );
+    END IF;
+  END LOOP;
+END;
+$$;
+
+DO $$
+DECLARE
+  table_name TEXT;
+BEGIN
+  FOREACH table_name IN ARRAY ARRAY[
+    'lsrl_progress',
+    'user_progress',
+    'user_settings',
+    'api_keys_pool',
+    'teacher_reviews',
+    'time_sessions',
+    'time_problems',
+    'point_events',
+    'progression_overrides',
+    'ghost_profiles',
+    'ghost_ratings',
+    'ghost_battles',
+    'ghost_orbits_sessions',
+    'ghost_orbits_stats',
+    'grid_wars_games',
+    'grid_wars_territories',
+    'grid_wars_structures',
+    'grid_wars_players',
+    'grid_wars_gifts',
+    'round_history'
+  ]
+  LOOP
+    EXECUTE format('ALTER TABLE public.%I ENABLE ROW LEVEL SECURITY', table_name);
+    EXECUTE format('REVOKE ALL ON TABLE public.%I FROM anon, authenticated', table_name);
+  END LOOP;
+END;
+$$;
+
+DO $$
+DECLARE
+  view_name TEXT;
+BEGIN
+  FOREACH view_name IN ARRAY ARRAY[
+    'leaderboard',
+    'class_roster',
+    'ghost_orbits_leaderboard',
+    'grid_wars_active_contestations',
+    'drill_progress',
+    'drill_leaderboard',
+    'drill_time_tracking',
+    'drill_avatar_system',
+    'drill_user_progress',
+    'drill_user_settings',
+    'drill_teacher_reviews',
+    'drill_progression_overrides',
+    'drill_ghost_profiles',
+    'drill_ghost_ratings',
+    'drill_ghost_battles',
+    'drill_ghost_orbits_sessions',
+    'drill_ghost_orbits_stats',
+    'drill_ghost_orbits_leaderboard',
+    'drill_grid_wars_games',
+    'drill_grid_wars_territories',
+    'drill_grid_wars_structures',
+    'drill_grid_wars_players',
+    'drill_grid_wars_gifts',
+    'drill_round_history',
+    'drill_class_roster',
+    'drill_point_events'
+  ]
+  LOOP
+    IF to_regclass('public.' || view_name) IS NOT NULL THEN
+      EXECUTE format('REVOKE ALL ON TABLE public.%I FROM anon, authenticated', view_name);
+    END IF;
+  END LOOP;
+END;
+$$;
+
+GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO service_role;
+GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA public TO service_role;
