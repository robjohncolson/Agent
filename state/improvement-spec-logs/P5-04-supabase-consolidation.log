+  FOR INSERT
+  TO anon, authenticated
+  WITH CHECK (true);
+
+CREATE POLICY votes_public_update
+  ON public.votes
+  FOR UPDATE
+  TO anon, authenticated
+  USING (true)
+  WITH CHECK (true);
+
+CREATE POLICY identity_claims_public_select
+  ON public.identity_claims
+  FOR SELECT
+  TO anon, authenticated
+  USING (true);
+
+CREATE POLICY identity_claims_public_insert
+  ON public.identity_claims
+  FOR INSERT
+  TO anon, authenticated
+  WITH CHECK (true);
+
+CREATE POLICY identity_claims_public_update
+  ON public.identity_claims
+  FOR UPDATE
+  TO anon, authenticated
+  USING (true)
+  WITH CHECK (true);
+
+CREATE POLICY teacher_notifications_public_select
+  ON public.teacher_notifications
+  FOR SELECT
+  TO anon, authenticated
+  USING (true);
+
+CREATE POLICY teacher_notifications_public_insert
+  ON public.teacher_notifications
+  FOR INSERT
+  TO anon, authenticated
+  WITH CHECK (true);
+
+CREATE POLICY teacher_notifications_public_update
+  ON public.teacher_notifications
+  FOR UPDATE
+  TO anon, authenticated
+  USING (true)
+  WITH CHECK (true);
+
+CREATE POLICY badges_public_select
