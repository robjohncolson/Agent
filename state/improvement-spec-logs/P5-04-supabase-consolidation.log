+-- LRSL-Driller shared-instance schema.
+-- Keep the legacy tables the Railway server already uses, then expose
+-- prefixed drill_* namespace views on top.
+
+CREATE TABLE IF NOT EXISTS public.lsrl_progress (
+  id SERIAL PRIMARY KEY,
+  username TEXT NOT NULL REFERENCES public.users(username) ON DELETE CASCADE,
+  scenario_topic TEXT NOT NULL,
+  slope_score TEXT CHECK (slope_score IN ('E', 'P', 'I')),
+  intercept_score TEXT CHECK (intercept_score IN ('E', 'P', 'I')),
+  correlation_score TEXT CHECK (correlation_score IN ('E', 'P', 'I')),
+  hints_used INTEGER DEFAULT 0 CHECK (hints_used >= 0 AND hints_used <= 3),
+  star_type TEXT CHECK (star_type IN ('gold', 'silver', 'bronze', 'tin') OR star_type IS NULL),
+  all_correct BOOLEAN DEFAULT FALSE,
+  grading_mode TEXT CHECK (grading_mode IN ('keywords', 'ai', 'both')),
+  ai_provider TEXT CHECK (ai_provider IN ('gemini', 'groq') OR ai_provider IS NULL),
+  completed_at TIMESTAMPTZ DEFAULT NOW(),
+  cartridge_id TEXT,
+  mode_id TEXT,
+  level_index INTEGER,
+  total_levels INTEGER,
+  level_multiplier DECIMAL(3,2) DEFAULT 1.0,
+  weighted_points DECIMAL(10,2) DEFAULT 0
+);
+
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS cartridge_id TEXT;
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS mode_id TEXT;
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS level_index INTEGER;
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS total_levels INTEGER;
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS level_multiplier DECIMAL(3,2) DEFAULT 1.0;
+ALTER TABLE public.lsrl_progress ADD COLUMN IF NOT EXISTS weighted_points DECIMAL(10,2) DEFAULT 0;
+
+CREATE INDEX IF NOT EXISTS idx_progress_username ON public.lsrl_progress(username);
+CREATE INDEX IF NOT EXISTS idx_progress_completed ON public.lsrl_progress(completed_at DESC);
+CREATE INDEX IF NOT EXISTS idx_progress_star ON public.lsrl_progress(star_type) WHERE star_type IS NOT NULL;
+CREATE INDEX IF NOT EXISTS idx_lsrl_progress_cartridge ON public.lsrl_progress(cartridge_id, mode_id);
+CREATE INDEX IF NOT EXISTS idx_lsrl_progress_weighted ON public.lsrl_progress(username, weighted_points);
+
+UPDATE public.lsrl_progress
+SET weighted_points = CASE star_type
+  WHEN 'gold' THEN 4.0
+  WHEN 'silver' THEN 3.0
+  WHEN 'bronze' THEN 2.0
+  WHEN 'tin' THEN 1.0
+  ELSE 0
+END,
+level_multiplier = COALESCE(level_multiplier, 1.0)
+WHERE weighted_points IS NULL OR weighted_points = 0;
+
+CREATE TABLE IF NOT EXISTS public.user_progress (
+  id SERIAL PRIMARY KEY,
+  username VARCHAR(50) NOT NULL,
+  cartridge_id VARCHAR(100) NOT NULL,
+  gold_stars INTEGER DEFAULT 0,
+  silver_stars INTEGER DEFAULT 0,
+  bronze_stars INTEGER DEFAULT 0,
+  tin_stars INTEGER DEFAULT 0,
+  total_weighted_score DECIMAL(10,2) DEFAULT 0,
+  mode_progress JSONB DEFAULT '{}'::jsonb,
+  created_at TIMESTAMPTZ DEFAULT NOW(),
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(username, cartridge_id)
+);
+
+CREATE INDEX IF NOT EXISTS idx_user_progress_score ON public.user_progress(total_weighted_score DESC);
+CREATE INDEX IF NOT EXISTS idx_user_progress_cartridge ON public.user_progress(cartridge_id);
+CREATE INDEX IF NOT EXISTS idx_user_progress_username ON public.user_progress(username);
+
+DROP TRIGGER IF EXISTS user_progress_touch_updated_at ON public.user_progress;
+CREATE TRIGGER user_progress_touch_updated_at
+  BEFORE UPDATE ON public.user_progress
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.user_settings (
+  username TEXT PRIMARY KEY REFERENCES public.users(username) ON DELETE CASCADE,
+  gemini_key TEXT,
+  groq_key TEXT,
+  preferred_provider TEXT DEFAULT 'groq' CHECK (preferred_provider IN ('gemini', 'groq', 'none')),
+  updated_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+DROP TRIGGER IF EXISTS user_settings_touch_updated_at ON public.user_settings;
+CREATE TRIGGER user_settings_touch_updated_at
+  BEFORE UPDATE ON public.user_settings
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.api_keys_pool (
+  id SERIAL PRIMARY KEY,
+  provider TEXT NOT NULL CHECK (provider IN ('gemini', 'groq')),
+  api_key TEXT NOT NULL,
+  contributed_by TEXT REFERENCES public.users(username) ON DELETE SET NULL,
+  is_active BOOLEAN DEFAULT TRUE,
+  last_used_at TIMESTAMPTZ,
+  rate_limited_until TIMESTAMPTZ,
+  total_uses INTEGER DEFAULT 0,
+  total_failures INTEGER DEFAULT 0,
+  created_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(provider, api_key)
+);
+
+CREATE INDEX IF NOT EXISTS idx_api_keys_available
+  ON public.api_keys_pool(provider, is_active, rate_limited_until)
+  WHERE is_active = TRUE;
+
+CREATE OR REPLACE FUNCTION public.increment_key_uses(key_id INTEGER)
+RETURNS void AS $$
+BEGIN
+  UPDATE public.api_keys_pool
+  SET total_uses = total_uses + 1,
+      last_used_at = NOW()
+  WHERE id = key_id;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE OR REPLACE FUNCTION public.increment_key_failures(key_id INTEGER, limit_until TIMESTAMPTZ)
+RETURNS void AS $$
+BEGIN
+  UPDATE public.api_keys_pool
+  SET total_failures = total_failures + 1,
+      rate_limited_until = limit_until
+  WHERE id = key_id;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE TABLE IF NOT EXISTS public.teacher_reviews (
+  id SERIAL PRIMARY KEY,
+  username TEXT NOT NULL REFERENCES public.users(username) ON DELETE CASCADE,
+  scenario_topic TEXT NOT NULL,
+  scenario_context JSONB,
+  student_answers JSONB NOT NULL,
+  expected_answers JSONB,
+  keyword_results JSONB,
+  teacher_grades JSONB,
+  teacher_feedback TEXT,
+  teacher_notes TEXT,
+  cartridge_id VARCHAR(100),
+  cartridge_name TEXT,
+  mode_id VARCHAR(100),
+  field_ids JSONB,
+  status TEXT DEFAULT 'pending' CHECK (status IN ('pending', 'reviewed', 'dismissed')),
+  submitted_at TIMESTAMPTZ DEFAULT NOW(),
+  reviewed_at TIMESTAMPTZ
+);
+
+ALTER TABLE public.teacher_reviews ADD COLUMN IF NOT EXISTS expected_answers JSONB;
+ALTER TABLE public.teacher_reviews ADD COLUMN IF NOT EXISTS cartridge_id VARCHAR(100);
+ALTER TABLE public.teacher_reviews ADD COLUMN IF NOT EXISTS cartridge_name TEXT;
+ALTER TABLE public.teacher_reviews ADD COLUMN IF NOT EXISTS mode_id VARCHAR(100);
+ALTER TABLE public.teacher_reviews ADD COLUMN IF NOT EXISTS field_ids JSONB;
+
+CREATE INDEX IF NOT EXISTS idx_teacher_reviews_status ON public.teacher_reviews(status);
+CREATE INDEX IF NOT EXISTS idx_teacher_reviews_username ON public.teacher_reviews(username);
+CREATE INDEX IF NOT EXISTS idx_teacher_reviews_submitted ON public.teacher_reviews(submitted_at DESC);
+
+CREATE TABLE IF NOT EXISTS public.time_sessions (
+  id BIGSERIAL PRIMARY KEY,
+  session_id TEXT UNIQUE NOT NULL,
+  username TEXT NOT NULL,
+  session_start TIMESTAMPTZ NOT NULL,
+  active_time_ms BIGINT DEFAULT 0,
+  total_time_ms BIGINT DEFAULT 0,
+  last_sync TIMESTAMPTZ DEFAULT NOW(),
+  is_complete BOOLEAN DEFAULT FALSE,
+  created_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+CREATE INDEX IF NOT EXISTS idx_time_sessions_username ON public.time_sessions(username);
+CREATE INDEX IF NOT EXISTS idx_time_sessions_start ON public.time_sessions(session_start);
+
+CREATE TABLE IF NOT EXISTS public.time_problems (
+  id BIGSERIAL PRIMARY KEY,
+  session_id TEXT NOT NULL,
+  username TEXT NOT NULL,
+  problem_id TEXT,
+  cartridge_id TEXT,
+  mode_id TEXT,
+  active_time_ms BIGINT DEFAULT 0,
+  total_time_ms BIGINT DEFAULT 0,
+  completed BOOLEAN DEFAULT FALSE,
+  result JSONB,
+  completed_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+CREATE INDEX IF NOT EXISTS idx_time_problems_username ON public.time_problems(username);
+CREATE INDEX IF NOT EXISTS idx_time_problems_session ON public.time_problems(session_id);
+CREATE INDEX IF NOT EXISTS idx_time_problems_completed_at ON public.time_problems(completed_at);
+
+CREATE TABLE IF NOT EXISTS public.point_events (
+  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
+  game_id TEXT NOT NULL DEFAULT 'default',
+  player_id TEXT NOT NULL,
+  delta INTEGER NOT NULL,
+  reason TEXT NOT NULL,
+  cartridge_id TEXT,
+  metadata JSONB DEFAULT '{}'::jsonb,
+  created_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+CREATE INDEX IF NOT EXISTS idx_point_events_player_time
+  ON public.point_events(game_id, player_id, created_at DESC);
+CREATE INDEX IF NOT EXISTS idx_point_events_recent
+  ON public.point_events(created_at DESC)
+  WHERE created_at > NOW() - INTERVAL '1 hour';
+CREATE INDEX IF NOT EXISTS idx_point_events_cleanup ON public.point_events(created_at);
+
+CREATE TABLE IF NOT EXISTS public.progression_overrides (
+  id SERIAL PRIMARY KEY,
+  game_id VARCHAR(100) NOT NULL DEFAULT 'default',
+  cartridge_id VARCHAR(100) NOT NULL,
+  mode_id VARCHAR(100) NOT NULL,
+  gold_required INTEGER NOT NULL CHECK (gold_required >= 1 AND gold_required <= 10),
+  updated_by VARCHAR(100),
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(game_id, cartridge_id, mode_id)
+);
+
+CREATE INDEX IF NOT EXISTS idx_progression_overrides_lookup
+  ON public.progression_overrides(game_id, cartridge_id);
+
+DROP TRIGGER IF EXISTS progression_overrides_touch_updated_at ON public.progression_overrides;
+CREATE TRIGGER progression_overrides_touch_updated_at
+  BEFORE UPDATE ON public.progression_overrides
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.ghost_profiles (
+  id SERIAL PRIMARY KEY,
+  username TEXT NOT NULL,
+  cartridge_id TEXT NOT NULL,
+  weights JSONB NOT NULL,
+  buffer JSONB,
+  total_interactions INTEGER DEFAULT 0,
+  proficiency_score FLOAT DEFAULT 0,
+  color TEXT DEFAULT 'white',
+  opacity FLOAT DEFAULT 0.1,
+  version INTEGER DEFAULT 1,
+  created_at TIMESTAMPTZ DEFAULT NOW(),
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(username, cartridge_id)
+);
+
+CREATE INDEX IF NOT EXISTS idx_ghost_profiles_cartridge_proficiency
+  ON public.ghost_profiles(cartridge_id, proficiency_score DESC);
+CREATE INDEX IF NOT EXISTS idx_ghost_profiles_username ON public.ghost_profiles(username);
+
+DROP TRIGGER IF EXISTS ghost_profiles_touch_updated_at ON public.ghost_profiles;
+CREATE TRIGGER ghost_profiles_touch_updated_at
+  BEFORE UPDATE ON public.ghost_profiles
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE TABLE IF NOT EXISTS public.ghost_ratings (
+  id SERIAL PRIMARY KEY,
+  username VARCHAR(50) NOT NULL,
+  cartridge_id VARCHAR(100) NOT NULL,
+  rating INTEGER DEFAULT 1200,
+  battles_fought INTEGER DEFAULT 0,
+  wins INTEGER DEFAULT 0,
+  losses INTEGER DEFAULT 0,
+  draws INTEGER DEFAULT 0,
+  current_streak INTEGER DEFAULT 0,
+  best_streak INTEGER DEFAULT 0,
+  last_battle_at TIMESTAMPTZ,
+  created_at TIMESTAMPTZ DEFAULT NOW(),
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
+  UNIQUE(username, cartridge_id)
+);
+
+CREATE INDEX IF NOT EXISTS idx_ghost_ratings_leaderboard
+  ON public.ghost_ratings(cartridge_id, rating DESC);
+CREATE INDEX IF NOT EXISTS idx_ghost_ratings_username ON public.ghost_ratings(username);
+
+DROP TRIGGER IF EXISTS ghost_ratings_touch_updated_at ON public.ghost_ratings;
+CREATE TRIGGER ghost_ratings_touch_updated_at
+  BEFORE UPDATE ON public.ghost_ratings
+  FOR EACH ROW
+  EXECUTE FUNCTION public.touch_updated_at();
+
+CREATE OR REPLACE FUNCTION public.get_or_create_ghost_rating(
+  p_username VARCHAR(50),
+  p_cartridge_id VARCHAR(100)
+)
+RETURNS public.ghost_ratings AS $$
+DECLARE
+  v_rating public.ghost_ratings;
+BEGIN
+  SELECT * INTO v_rating
+  FROM public.ghost_ratings
+  WHERE username = p_username AND cartridge_id = p_cartridge_id;
+
+  IF v_rating IS NULL THEN
+    INSERT INTO public.ghost_ratings (username, cartridge_id, rating)
+    VALUES (p_username, p_cartridge_id, 1200)
+    RETURNING * INTO v_rating;
+  END IF;
+
+  RETURN v_rating;
+END;
+$$ LANGUAGE plpgsql;
+
+CREATE TABLE IF NOT EXISTS public.ghost_battles (
+  id SERIAL PRIMARY KEY,
+  cartridge_id VARCHAR(100) NOT NULL,
+  challenger_username VARCHAR(50) NOT NULL,
+  defender_username VARCHAR(50) NOT NULL,
+  challenge_type VARCHAR(20) NOT NULL CHECK (challenge_type IN ('random', 'specific', 'rematch', 'leaderboard')),
+  seed BIGINT NOT NULL,
+  winner VARCHAR(50),
+  winner_side INTEGER NOT NULL CHECK (winner_side IN (0, 1, 2)),
+  challenger_time FLOAT NOT NULL,
+  challenger_correct INTEGER NOT NULL,
+  defender_time FLOAT NOT NULL,
+  defender_correct INTEGER NOT NULL,
+  margin FLOAT NOT NULL,
+  challenger_rating_before INTEGER NOT NULL,
+  defender_rating_before INTEGER NOT NULL,
+  challenger_rating_after INTEGER NOT NULL,
+  defender_rating_after INTEGER NOT NULL,
+  battle_log JSONB NOT NULL,
+  created_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+CREATE INDEX IF NOT EXISTS idx_ghost_battles_cartridge ON public.ghost_battles(cartridge_id);
+CREATE INDEX IF NOT EXISTS idx_ghost_battles_challenger ON public.ghost_battles(challenger_username);
+CREATE INDEX IF NOT EXISTS idx_ghost_battles_defender ON public.ghost_battles(defender_username);
+CREATE INDEX IF NOT EXISTS idx_ghost_battles_created ON public.ghost_battles(created_at DESC);
+
+CREATE TABLE IF NOT EXISTS public.ghost_orbits_sessions (
+  id SERIAL PRIMARY KEY,
+  cartridge_id VARCHAR(100) NOT NULL,
+  period_id VARCHAR(50),
+  started_at TIMESTAMPTZ DEFAULT NOW(),
+  ended_at TIMESTAMPTZ,
+  round_number INTEGER DEFAULT 1,
+  round_duration_ms INTEGER,
+  winner_username VARCHAR(50),
+  final_rankings JSONB,
+  total_players INTEGER,
+  total_eliminations INTEGER
+);
+
+CREATE TABLE IF NOT EXISTS public.ghost_orbits_stats (
+  id SERIAL PRIMARY KEY,
+  username VARCHAR(50) NOT NULL,
+  cartridge_id VARCHAR(100) NOT NULL,
+  games_played INTEGER DEFAULT 0,
+  total_territory_percent DECIMAL(10,4) DEFAULT 0,
+  total_eliminations INTEGER DEFAULT 0,
+  times_eliminated INTEGER DEFAULT 0,
+  wins INTEGER DEFAULT 0,
+  best_territory_percent DECIMAL(5,2),
+  longest_survival_ms INTEGER,
+  updated_at TIMESTAMPTZ DEFAULT NOW(),
