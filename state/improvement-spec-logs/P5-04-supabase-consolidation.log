CREATE OR REPLACE FUNCTION public.sync_answers_to_cr_answers()
RETURNS trigger AS $$
BEGIN
  IF pg_trigger_depth() > 1 THEN
    RETURN COALESCE(NEW, OLD);
  END IF;

  IF TG_OP = 'DELETE' THEN
    DELETE FROM public.cr_answers
    WHERE question_id = OLD.question_id AND student_id = OLD.username;
    RETURN OLD;
  END IF;

  INSERT INTO public.cr_answers (
    question_id,
    student_id,
    value,
    timestamp,
    created_at,
    updated_at
  )
  VALUES (
    NEW.question_id,
    NEW.username,
    NEW.answer_value,
    NEW.timestamp,
    COALESCE(NEW.created_at, NOW()),
    COALESCE(NEW.updated_at, NOW())
  )
  ON CONFLICT (question_id, student_id) DO UPDATE
  SET
    value = EXCLUDED.value,
    timestamp = EXCLUDED.timestamp,
    created_at = LEAST(public.cr_answers.created_at, EXCLUDED.created_at),
    updated_at = GREATEST(public.cr_answers.updated_at, EXCLUDED.updated_at);

  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION public.sync_cr_answers_to_answers()
RETURNS trigger AS $$
BEGIN
  IF pg_trigger_depth() > 1 THEN
    RETURN COALESCE(NEW, OLD);
  END IF;

  IF TG_OP = 'DELETE' THEN
    DELETE FROM public.answers
    WHERE username = OLD.student_id AND question_id = OLD.question_id;
    RETURN OLD;
  END IF;

  INSERT INTO public.answers (
    username,
    question_id,
    answer_value,
    timestamp,
    created_at,
    updated_at
  )
  VALUES (
    NEW.student_id,
    NEW.question_id,
    NEW.value,
    NEW.timestamp,
    COALESCE(NEW.created_at, NOW()),
    COALESCE(NEW.updated_at, NOW())
  )
  ON CONFLICT (username, question_id) DO UPDATE
  SET
    answer_value = EXCLUDED.answer_value,
    timestamp = EXCLUDED.timestamp,
    created_at = LEAST(public.answers.created_at, EXCLUDED.created_at),
    updated_at = GREATEST(public.answers.updated_at, EXCLUDED.updated_at);

  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

