+    real_name,
+    password,
+    user_type,
+    class_period,
+    created_at,
+    updated_at,
+    last_seen
+  )
+  VALUES (
+    NEW.username,
+    NEW.real_name,
+    NEW.password,
+    COALESCE(NEW.user_type, 'student'),
+    NEW.class_period,
+    COALESCE(NEW.created_at, NOW()),
+    COALESCE(NEW.updated_at, NOW()),
+    NEW.last_seen
+  )
