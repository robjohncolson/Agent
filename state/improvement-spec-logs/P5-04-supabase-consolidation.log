+INSERT INTO public.shared_users (
+  username,
+  real_name,
+  password,
+  user_type,
+  class_period,
+  created_at,
+  updated_at,
+  last_seen
+)
+SELECT
+  u.username,
+  u.real_name,
+  u.password,
+  COALESCE(u.user_type, 'student'),
+  u.class_period,
+  COALESCE(u.created_at, NOW()),
+  COALESCE(u.updated_at, NOW()),
+  u.last_seen
+FROM public.users AS u
