class TestFillsInDegradedMode:
    def test_buy_fill_in_long_only_transitions_correctly(self) -> None:
        state, cfg = _degraded_s0_long_only()
        entry = state.orders[0]

        new_state, actions = transition(
            state,
            _fill_for_order(entry, timestamp=state.now + 1.0, fee_pct=cfg.maker_fee_pct),
            cfg,
            2.0,
        )

        assert derive_phase(new_state) == "S1b"
        assert new_state.long_only is True
        assert new_state.short_only is False
        assert _single_order_signature(new_state) == ("sell", "exit", "B")
        assert _action_types(actions) == {PlaceOrderAction}
        assert check_invariants(new_state) == []

    def test_sell_fill_in_short_only_transitions_correctly(self) -> None:
        state, cfg = _degraded_s0_short_only()
        entry = state.orders[0]

        new_state, actions = transition(
            state,
            _fill_for_order(entry, timestamp=state.now + 1.0, fee_pct=cfg.maker_fee_pct),
            cfg,
            2.0,
        )

        assert derive_phase(new_state) == "S1a"
        assert new_state.long_only is False
        assert new_state.short_only is True
        assert _single_order_signature(new_state) == ("buy", "exit", "A")
        assert _action_types(actions) == {PlaceOrderAction}
        assert check_invariants(new_state) == []

    @pytest.mark.parametrize(
        ("builder", "expected_side", "expected_trade_id"),
        [
            (_degraded_s1b_long_only, "buy", "B"),
            (_degraded_s1a_short_only, "sell", "A"),
        ],
    )
    def test_exit_fill_in_degraded_books_profit(
        self,
        builder: object,
        expected_side: str,
        expected_trade_id: str,
    ) -> None:
        state, cfg = builder()
        exit_order = state.orders[0]

        new_state, actions = transition(
            state,
            _fill_for_order(exit_order, timestamp=state.now + 10.0, fee_pct=cfg.maker_fee_pct),
            cfg,
            2.0,
        )

        book_actions = [action for action in actions if isinstance(action, BookCycleAction)]
        entry_actions = [action for action in actions if isinstance(action, PlaceOrderAction)]

        assert len(book_actions) == 1
        assert len(entry_actions) == 1
        assert book_actions[0].trade_id == expected_trade_id
        assert book_actions[0].net_profit > 0
        assert entry_actions[0].side == expected_side
        assert entry_actions[0].trade_id == expected_trade_id
        assert derive_phase(new_state) == "S0"
        assert check_invariants(new_state) == []


