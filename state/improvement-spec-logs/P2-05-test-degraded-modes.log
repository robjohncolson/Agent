+        role="entry",
+        price=0.08982,
+        volume=22.0,
+        trade_id="B",
+        cycle=1,
+        placed_at=1_000.0,
+    )
+    state = _make_pair_state(
+        orders=(order,),
+        next_order_id=2,
+        long_only=True,
+        short_only=False,
+        mode_source="regime",
+    )
+    return state, cfg
+
+
+def _degraded_s0_short_only() -> tuple[PairState, EngineConfig]:
