from __future__ import annotations

from dataclasses import replace

import pytest

from bot_types import (
    BookCycleAction,
    FillEvent,
    GovernorActions,
    OrphanOrderAction,
    PlaceOrderAction,
    RecoveryFillEvent,
    SlotAccount,
    SlotRuntime,
)
from slot_engine import SlotEngine
from state_machine import (
    EngineConfig,
    OrderState,
    PairState,
    TimerTick,
    bootstrap_orders,
    check_invariants,
    derive_phase,
    transition,
)


def _make_engine_config(**overrides: object) -> EngineConfig:
    defaults = dict(
        entry_pct=0.20,
        profit_pct=1.0,
        refresh_pct=1.0,
        order_size_usd=2.0,
        price_decimals=6,
        volume_decimals=0,
        min_volume=13.0,
        maker_fee_pct=0.25,
        stale_price_max_age_sec=60.0,
        s1_orphan_after_sec=60.0,
        s2_orphan_after_sec=1800.0,
        max_recovery_slots=2,
        sticky_mode_enabled=False,
    )
    defaults.update(overrides)
    return EngineConfig(**defaults)


def _make_pair_state(**overrides: object) -> PairState:
    defaults = dict(
        market_price=0.09000,
        now=1_000.0,
        last_price_update_at=1_000.0,
    )
    defaults.update(overrides)
    return PairState(**defaults)


def _make_slot(*, state: PairState, sticky: bool = False, slot_id: int = 1) -> SlotRuntime:
    return SlotRuntime(
        slot_id=slot_id,
        state=state,
        sticky=sticky,
        alias=f"Slot {slot_id}",
        account=SlotAccount(slot_id=slot_id),
        created_at=state.now,
    )


def _bootstrap_full_s0(*, sticky: bool = False) -> tuple[PairState, EngineConfig]:
    cfg = _make_engine_config(sticky_mode_enabled=sticky)
    state = _make_pair_state()
    state, _, orders = bootstrap_orders(state, cfg, 2.0)
    return replace(state, orders=orders), cfg


def _degraded_s0_long_only() -> tuple[PairState, EngineConfig]:
    cfg = _make_engine_config()
    order = OrderState(
        local_id=1,
        side="buy",
        role="entry",
        price=0.08982,
        volume=22.0,
        trade_id="B",
        cycle=1,
        placed_at=1_000.0,
    )
    state = _make_pair_state(
        orders=(order,),
        next_order_id=2,
        long_only=True,
        short_only=False,
        mode_source="regime",
    )
    return state, cfg


def _degraded_s0_short_only() -> tuple[PairState, EngineConfig]:
    cfg = _make_engine_config()
    order = OrderState(
        local_id=1,
        side="sell",
        role="entry",
        price=0.09018,
        volume=22.0,
        trade_id="A",
        cycle=1,
        placed_at=1_000.0,
    )
    state = _make_pair_state(
        orders=(order,),
        next_order_id=2,
        long_only=False,
        short_only=True,
        mode_source="regime",
    )
    return state, cfg


def _fill_for_order(order: OrderState, *, timestamp: float, fee_pct: float) -> FillEvent:
    fee = order.price * order.volume * fee_pct / 100.0
    return FillEvent(
        order_local_id=order.local_id,
        txid=f"FILL-{order.trade_id}-{order.local_id}",
        side=order.side,
        price=order.price,
        volume=order.volume,
        fee=fee,
        timestamp=timestamp,
    )


def _degraded_s1b_long_only() -> tuple[PairState, EngineConfig]:
    state, cfg = _degraded_s0_long_only()
    entry = state.orders[0]
    state, _ = transition(
        state,
        _fill_for_order(entry, timestamp=state.now + 1.0, fee_pct=cfg.maker_fee_pct),
        cfg,
        2.0,
    )
    return state, cfg


def _degraded_s1a_short_only() -> tuple[PairState, EngineConfig]:
    state, cfg = _degraded_s0_short_only()
    entry = state.orders[0]
    state, _ = transition(
        state,
        _fill_for_order(entry, timestamp=state.now + 1.0, fee_pct=cfg.maker_fee_pct),
        cfg,
        2.0,
    )
    return state, cfg


def _action_types(actions: list[object]) -> set[type]:
    return {type(action) for action in actions}


def _single_order_signature(state: PairState) -> tuple[str, str, str]:
    assert len(state.orders) == 1
    order = state.orders[0]
    return (order.side, order.role, order.trade_id)


