@@ -0,0 +1,28 @@
+import test from 'node:test';
+import assert from 'node:assert/strict';
+
+import { extractJSON } from '../json-extractor.js';
+
+test('extractJSON parses valid JSON directly', () => {
+  const parsed = extractJSON('{"score":"E","feedback":"Correct","matched":["a"],"missing":[]}');
+  assert.equal(parsed.score, 'E');
+  assert.equal(parsed.feedback, 'Correct');
+});
+
+test('extractJSON repairs smart quotes and trailing commas', () => {
+  const parsed = extractJSON('{“score”: “P”, “feedback”: “Almost there”,}');
+  assert.equal(parsed.score, 'P');
+  assert.equal(parsed.feedback, 'Almost there');
+});
+
+test('extractJSON pulls JSON out of prose-wrapped responses', () => {
+  const parsed = extractJSON('Here is the result:\n{"score":"I","feedback":"Missing evidence","matched":[],"missing":["context"]}\nThanks.');
+  assert.equal(parsed.score, 'I');
+  assert.deepEqual(parsed.missing, ['context']);
+});
+
+test('extractJSON falls back to score and feedback regex extraction', () => {
+  const parsed = extractJSON('score: "P", feedback: "Need more detail"');
+  assert.equal(parsed.score, 'P');
+  assert.equal(parsed.feedback, 'Need more detail');
+});
