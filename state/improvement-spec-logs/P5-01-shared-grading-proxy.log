@@ -0,0 +1,48 @@
+const SCORE_ORDER = { I: 0, P: 1, E: 2 };
+
+export function normalizeScore(score) {
+  const normalized = String(score ?? 'I').trim().toUpperCase();
+  return SCORE_ORDER[normalized] == null ? 'I' : normalized;
+}
+
+export function validateAppealScore(currentScore, proposedScore) {
+  const normalizedCurrent = normalizeScore(currentScore);
+  const normalizedProposed = normalizeScore(proposedScore);
+
+  return SCORE_ORDER[normalizedProposed] >= SCORE_ORDER[normalizedCurrent]
+    ? normalizedProposed
+    : normalizedCurrent;
+}
+
+export function isUpgrade(currentScore, nextScore) {
+  return SCORE_ORDER[normalizeScore(nextScore)] > SCORE_ORDER[normalizeScore(currentScore)];
+}
+
+export async function handleAppeal({ payload, aiGrader }) {
+  const currentScore = normalizeScore(payload.currentScore);
+
+  try {
+    const aiResult = await aiGrader.appeal(payload);
+    const score = validateAppealScore(currentScore, aiResult.score);
+    const upgraded = isUpgrade(currentScore, score);
+
+    return {
+      score,
+      feedback: aiResult.feedback || (upgraded ? 'Appeal granted.' : 'Appeal denied.'),
+      upgraded,
+      appealResponse: aiResult.appealResponse || aiResult.feedback || '',
+      provider: aiResult.provider || null,
+      model: aiResult.model || null
+    };
+  } catch (error) {
+    return {
+      score: currentScore,
+      feedback: 'Appeal service unavailable. Keeping current score.',
+      upgraded: false,
+      appealResponse: '',
+      provider: 'fallback',
+      model: null,
+      error: error.message
+    };
+  }
+}
