@@ -0,0 +1,76 @@
+import test from 'node:test';
+import assert from 'node:assert/strict';
+
+import { GradingQueue } from '../grading-queue.js';
+
+test('GradingQueue drains tasks in order and respects minimum interval', async () => {
+  const queue = new GradingQueue({
+    maxRequestsPerMinute: 50,
+    minDelayBetweenRequests: 25,
+    taskTimeoutMs: 500
+  });
+
+  const callTimes = [];
+
+  const results = await Promise.all([
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 'first';
+    }),
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 'second';
+    }),
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 'third';
+    })
+  ]);
+
+  assert.deepEqual(results, ['first', 'second', 'third']);
+  assert.ok(callTimes[1] - callTimes[0] >= 20);
+  assert.ok(callTimes[2] - callTimes[1] >= 20);
+});
+
+test('GradingQueue enforces the per-minute request window', async () => {
+  const queue = new GradingQueue({
+    maxRequestsPerMinute: 2,
+    minDelayBetweenRequests: 0,
+    minuteWindowMs: 40,
+    rateLimitBackoffMs: 1,
+    taskTimeoutMs: 500
+  });
+
+  const callTimes = [];
+
+  await Promise.all([
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 1;
+    }),
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 2;
+    }),
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 3;
+    })
+  ]);
+
+  assert.equal(callTimes.length, 3);
+  assert.ok(callTimes[2] - callTimes[1] >= 35);
+});
+
+test('GradingQueue rejects tasks that exceed the timeout', async () => {
+  const queue = new GradingQueue({
+    maxRequestsPerMinute: 25,
+    minDelayBetweenRequests: 0,
+    taskTimeoutMs: 20
+  });
+
+  await assert.rejects(
+    queue.add(() => new Promise((resolve) => setTimeout(resolve, 100))),
+    /timed out/i
+  );
+});
