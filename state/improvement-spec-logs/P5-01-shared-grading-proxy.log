@@ -0,0 +1,167 @@
+const DEFAULT_MAX_REQUESTS_PER_MINUTE = 25;
+const DEFAULT_MIN_DELAY_BETWEEN_REQUESTS_MS = 2500;
+const DEFAULT_TASK_TIMEOUT_MS = 30000;
+const DEFAULT_RATE_LIMIT_BACKOFF_MS = 30000;
+const DEFAULT_MINUTE_WINDOW_MS = 60000;
+
+export class GradingQueue {
+  constructor({
+    maxRequestsPerMinute = DEFAULT_MAX_REQUESTS_PER_MINUTE,
+    minDelayBetweenRequests = DEFAULT_MIN_DELAY_BETWEEN_REQUESTS_MS,
+    taskTimeoutMs = DEFAULT_TASK_TIMEOUT_MS,
+    rateLimitBackoffMs = DEFAULT_RATE_LIMIT_BACKOFF_MS,
+    minuteWindowMs = DEFAULT_MINUTE_WINDOW_MS
+  } = {}) {
+    this.maxRequestsPerMinute = maxRequestsPerMinute;
+    this.minInterval = minDelayBetweenRequests;
+    this.taskTimeoutMs = taskTimeoutMs;
+    this.rateLimitBackoffMs = rateLimitBackoffMs;
+    this.minuteWindowMs = minuteWindowMs;
+
+    this.queue = [];
+    this.processing = false;
+    this.lastRequestTime = 0;
+    this.requestsThisMinute = 0;
+    this.minuteStart = Date.now();
+  }
+
+  async add(task, options = {}) {
+    return new Promise((resolve, reject) => {
+      this.queue.push({
+        task,
+        resolve,
+        reject,
+        timeoutMs: options.timeoutMs ?? this.taskTimeoutMs
+      });
+      this.process();
+    });
+  }
+
+  async enqueue(task, options = {}) {
+    return this.add(task, options);
+  }
+
+  async process() {
+    if (this.processing || this.queue.length === 0) {
+      return;
+    }
+
+    this.processing = true;
+
+    try {
+      while (this.queue.length > 0) {
+        const next = this.queue.shift();
+        const { task, resolve, reject, timeoutMs } = next;
+
+        try {
+          const now = Date.now();
+          if (now - this.minuteStart > this.minuteWindowMs) {
+            this.requestsThisMinute = 0;
+            this.minuteStart = now;
+          }
+
+          if (this.requestsThisMinute >= this.maxRequestsPerMinute) {
+            const waitTime = Math.max(
+              this.minuteWindowMs - (now - this.minuteStart) + 1,
+              0
+            );
+            await this.delay(waitTime);
+            this.requestsThisMinute = 0;
+            this.minuteStart = Date.now();
+          }
+
+          const timeSinceLastRequest = Date.now() - this.lastRequestTime;
+          if (timeSinceLastRequest < this.minInterval) {
+            await this.delay(this.minInterval - timeSinceLastRequest);
+          }
+
+          this.lastRequestTime = Date.now();
+          this.requestsThisMinute += 1;
+
+          const result = await this.runTask(task, timeoutMs);
+          resolve(result);
+        } catch (error) {
+          if (this.isRateLimitError(error)) {
+            await this.delay(this.rateLimitBackoffMs);
+            this.queue.unshift(next);
+          } else {
+            reject(error);
+          }
+        }
+      }
+    } finally {
+      this.processing = false;
+      if (this.queue.length > 0) {
+        this.process();
+      }
+    }
+  }
+
+  async runTask(task, timeoutMs) {
+    if (!timeoutMs || timeoutMs <= 0) {
+      return Promise.resolve().then(task);
+    }
+
+    return new Promise((resolve, reject) => {
+      let settled = false;
+
+      const timer = setTimeout(() => {
+        settled = true;
+        reject(this.createTimeoutError(timeoutMs));
+      }, timeoutMs);
+
+      Promise.resolve()
+        .then(task)
+        .then((result) => {
+          if (settled) {
+            return;
+          }
+          settled = true;
+          clearTimeout(timer);
+          resolve(result);
+        })
+        .catch((error) => {
+          if (settled) {
+            return;
+          }
+          settled = true;
+          clearTimeout(timer);
+          reject(error);
+        });
+    });
+  }
+
+  createTimeoutError(timeoutMs) {
+    const error = new Error(`Queued grading task timed out after ${timeoutMs}ms`);
+    error.code = 'TASK_TIMEOUT';
+    error.statusCode = 504;
+    return error;
+  }
+
+  isRateLimitError(error) {
+    const message = error?.message?.toLowerCase?.() || '';
+    return message.includes('429') || message.includes('rate limit');
+  }
+
+  delay(ms) {
+    return new Promise((resolve) => setTimeout(resolve, ms));
+  }
+
+  getQueueLength() {
+    return this.queue.length;
+  }
+
+  getStats() {
+    return {
+      queueLength: this.queue.length,
+      requestsThisMinute: this.requestsThisMinute,
+      processing: this.processing
+    };
+  }
+}
+
+export const DEFAULT_QUEUE_OPTIONS = {
+  maxRequestsPerMinute: DEFAULT_MAX_REQUESTS_PER_MINUTE,
+  minDelayBetweenRequests: DEFAULT_MIN_DELAY_BETWEEN_REQUESTS_MS,
+  taskTimeoutMs: DEFAULT_TASK_TIMEOUT_MS
+};
