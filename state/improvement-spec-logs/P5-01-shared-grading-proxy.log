+import { buildFrameworkContext, getFrameworkForQuestion } from './framework-context.js';
+import { DEFAULT_QUEUE_OPTIONS, GradingQueue } from './grading-queue.js';
+import {
+  extractJSON,
+  isValidGradingResponse,
+  normalizeGradingResponse
+} from './json-extractor.js';
+
+export const GROQ_PROVIDER = 'groq';
+export const GROQ_MODEL = 'llama-3.3-70b-versatile';
+export const GROQ_TIMEOUT_MS = 30000;
+export const GROQ_TEMPERATURE = 0.1;
+
+export function createAIGrader({
+  apiKey = process.env.GROQ_API_KEY,
+  model = GROQ_MODEL,
+  temperature = GROQ_TEMPERATURE,
+  timeoutMs = GROQ_TIMEOUT_MS,
+  fetchImpl = globalThis.fetch,
+  queue = new GradingQueue({
+    ...DEFAULT_QUEUE_OPTIONS,
+    taskTimeoutMs: timeoutMs
+  })
+} = {}) {
+  if (typeof fetchImpl !== 'function') {
+    throw new Error('Global fetch is not available in this runtime');
+  }
+
+  async function callGroq(prompt) {
+    if (!apiKey) {
+      const error = new Error('GROQ_API_KEY not configured');
+      error.statusCode = 503;
+      throw error;
+    }
+
+    const controller = new AbortController();
+    const timeoutId = setTimeout(() => controller.abort(), timeoutMs);
+
+    try {
+      const response = await fetchImpl('https://api.groq.com/openai/v1/chat/completions', {
+        method: 'POST',
+        headers: {
+          Authorization: `Bearer ${apiKey}`,
+          'Content-Type': 'application/json'
+        },
+        signal: controller.signal,
+        body: JSON.stringify({
+          model,
+          messages: [
+            {
+              role: 'system',
+              content: 'You are an AP Statistics teacher grading student responses. Always respond with valid JSON only.'
+            },
+            {
+              role: 'user',
+              content: prompt
+            }
+          ],
+          temperature,
+          max_tokens: 1500,
+          response_format: { type: 'json_object' }
+        })
+      });
+
+      if (!response.ok) {
+        const errorText = await response.text();
+        throw new Error(`Groq API error ${response.status}: ${errorText}`);
+      }
+
+      const data = await response.json();
+      const content = data.choices?.[0]?.message?.content;
+
+      if (!content) {
+        throw new Error('Empty response from Groq');
+      }
+
+      const parsed = extractJSON(content);
+      if (!isValidGradingResponse(parsed)) {
+        throw new Error('Failed to parse Groq response as a valid grading payload');
+      }
+
+      return normalizeGradingResponse(parsed);
+    } catch (error) {
+      if (error?.name === 'AbortError') {
+        const timeoutError = new Error('Groq API request timed out');
+        timeoutError.statusCode = 504;
+        throw timeoutError;
+      }
+      throw error;
+    } finally {
+      clearTimeout(timeoutId);
+    }
+  }
+
+  async function grade(payload) {
+    const prompt = buildGradePrompt(payload);
+    const result = await queue.add(() => callGroq(prompt), { timeoutMs });
+    return {
+      ...result,
+      provider: GROQ_PROVIDER,
+      model
+    };
+  }
+
+  async function appeal(payload) {
+    const prompt = buildAppealPrompt(payload);
+    const result = await queue.add(() => callGroq(prompt), { timeoutMs });
+    return {
+      ...result,
+      provider: GROQ_PROVIDER,
+      model
+    };
+  }
+
+  return {
+    grade,
+    appeal,
+    queue,
+    isAvailable() {
+      return Boolean(apiKey);
+    }
+  };
+}
+
+export function buildGradePrompt({
+  questionId,
+  questionType,
+  studentAnswer,
+  correctAnswer,
+  rubric,
+  frameworkContext
+}) {
+  const contextText = resolveFrameworkContext(questionId, frameworkContext);
+  const expectedElements = formatExpectedElements(rubric);
+  const normalizedQuestionType = questionType || 'frq';
+
+  return `You are an AP Statistics teacher grading a student's response.
+
+${contextText ? `${contextText}\n` : ''}## Question Context
+Question ID: ${questionId || 'unknown'}
+Question Type: ${normalizedQuestionType}
+Correct Answer: ${correctAnswer || 'not provided'}
+
+## Expected Elements
+${expectedElements}
+
+## Student Answer
+"${String(studentAnswer ?? '')}"
+
+## Grading Rules
+- Grade using only these scores: E, P, I
+- E: all key elements are present and correct
+- P: some key elements are present, with omissions or minor errors
+- I: most key elements are missing or incorrect
+- For multiple-choice questions, a wrong answer cannot receive E
+- Keep feedback concise and student-facing
+
+Respond with ONLY valid JSON:
+{
+  "score": "E" or "P" or "I",
+  "feedback": "Brief explanation of the score",
+  "matched": ["list of correct elements"],
+  "missing": ["list of missing elements"]
+}`;
+}
+
+export function buildAppealPrompt({
+  questionId,
+  questionType,
+  studentAnswer,
+  currentScore,
+  reasoning,
+  correctAnswer,
+  rubric,
+  frameworkContext
+}) {
+  const contextText = resolveFrameworkContext(questionId, frameworkContext);
+  const expectedElements = formatExpectedElements(rubric);
+
+  return `You are an AP Statistics teacher reviewing a student's grade appeal.
+
+${contextText ? `${contextText}\n` : ''}## Question Context
+Question ID: ${questionId || 'unknown'}
+Question Type: ${questionType || 'frq'}
+Current Score: ${currentScore || 'I'}
+Correct Answer: ${correctAnswer || 'not provided'}
+
+## Expected Elements
+${expectedElements}
+
+## Student Answer
+"${String(studentAnswer ?? '')}"
+
+## Student Appeal
+"${String(reasoning ?? '')}"
+
+## Appeal Rules
+- You may upgrade the score if the appeal shows valid understanding
+- You must not downgrade the score
+- For multiple-choice questions, a wrong answer cannot receive E
+- Keep feedback concise and student-facing
+- Explain your decision in plain language
+
+Respond with ONLY valid JSON:
+{
+  "score": "E" or "P" or "I",
+  "feedback": "Explanation of the decision",
+  "appealGranted": true or false,
+  "appealResponse": "Direct message to the student"
+}`;
+}
+
+function resolveFrameworkContext(questionId, explicitFrameworkContext) {
+  if (explicitFrameworkContext) {
+    return explicitFrameworkContext;
+  }
+
+  const framework = getFrameworkForQuestion(questionId);
+  return framework ? buildFrameworkContext(framework) : '';
+}
+
+function formatExpectedElements(rubric) {
+  if (!rubric) {
+    return 'Use standard AP Statistics grading judgment.';
+  }
+
+  const elements =
+    rubric.expectedElements ||
+    rubric.rubric ||
+    rubric.required ||
+    (Array.isArray(rubric) ? rubric : []);
+
+  if (!Array.isArray(elements) || elements.length === 0) {
+    return 'Use standard AP Statistics grading judgment.';
+  }
+
+  return elements
+    .map((item, index) => {
+      if (typeof item === 'string') {
+        return `${index + 1}. ${item}`;
+      }
+
+      return `${index + 1}. ${item.description || item.id || item.pattern || 'Rubric element'}`;
+    })
+    .join('\n');
+}
diff --git a/C:/Users/ColsonR/shared-grading-proxy/appeal-handler.js b/C:/Users/ColsonR/shared-grading-proxy/appeal-handler.js
new file mode 100644
index 0000000000000000000000000000000000000000..4a97ca422081a938efb1f012f508f21cacb02abf
--- /dev/null
+++ b/C:/Users/ColsonR/shared-grading-proxy/appeal-handler.js
@@ -0,0 +1,48 @@
+const SCORE_ORDER = { I: 0, P: 1, E: 2 };
+
+export function normalizeScore(score) {
+  const normalized = String(score ?? 'I').trim().toUpperCase();
+  return SCORE_ORDER[normalized] == null ? 'I' : normalized;
+}
+
+export function validateAppealScore(currentScore, proposedScore) {
+  const normalizedCurrent = normalizeScore(currentScore);
+  const normalizedProposed = normalizeScore(proposedScore);
+
+  return SCORE_ORDER[normalizedProposed] >= SCORE_ORDER[normalizedCurrent]
+    ? normalizedProposed
+    : normalizedCurrent;
+}
+
+export function isUpgrade(currentScore, nextScore) {
+  return SCORE_ORDER[normalizeScore(nextScore)] > SCORE_ORDER[normalizeScore(currentScore)];
+}
+
+export async function handleAppeal({ payload, aiGrader }) {
+  const currentScore = normalizeScore(payload.currentScore);
+
+  try {
+    const aiResult = await aiGrader.appeal(payload);
+    const score = validateAppealScore(currentScore, aiResult.score);
+    const upgraded = isUpgrade(currentScore, score);
+
+    return {
+      score,
+      feedback: aiResult.feedback || (upgraded ? 'Appeal granted.' : 'Appeal denied.'),
+      upgraded,
+      appealResponse: aiResult.appealResponse || aiResult.feedback || '',
+      provider: aiResult.provider || null,
+      model: aiResult.model || null
+    };
+  } catch (error) {
+    return {
+      score: currentScore,
+      feedback: 'Appeal service unavailable. Keeping current score.',
+      upgraded: false,
+      appealResponse: '',
+      provider: 'fallback',
+      model: null,
+      error: error.message
+    };
+  }
+}
diff --git a/C:/Users/ColsonR/shared-grading-proxy/grading-queue.js b/C:/Users/ColsonR/shared-grading-proxy/grading-queue.js
new file mode 100644
index 0000000000000000000000000000000000000000..9467820046ade1fd96ea8ada267d9397abd00422
--- /dev/null
+++ b/C:/Users/ColsonR/shared-grading-proxy/grading-queue.js
@@ -0,0 +1,167 @@
+const DEFAULT_MAX_REQUESTS_PER_MINUTE = 25;
+const DEFAULT_MIN_DELAY_BETWEEN_REQUESTS_MS = 2500;
+const DEFAULT_TASK_TIMEOUT_MS = 30000;
+const DEFAULT_RATE_LIMIT_BACKOFF_MS = 30000;
+const DEFAULT_MINUTE_WINDOW_MS = 60000;
+
+export class GradingQueue {
+  constructor({
+    maxRequestsPerMinute = DEFAULT_MAX_REQUESTS_PER_MINUTE,
+    minDelayBetweenRequests = DEFAULT_MIN_DELAY_BETWEEN_REQUESTS_MS,
+    taskTimeoutMs = DEFAULT_TASK_TIMEOUT_MS,
+    rateLimitBackoffMs = DEFAULT_RATE_LIMIT_BACKOFF_MS,
+    minuteWindowMs = DEFAULT_MINUTE_WINDOW_MS
+  } = {}) {
+    this.maxRequestsPerMinute = maxRequestsPerMinute;
+    this.minInterval = minDelayBetweenRequests;
+    this.taskTimeoutMs = taskTimeoutMs;
+    this.rateLimitBackoffMs = rateLimitBackoffMs;
+    this.minuteWindowMs = minuteWindowMs;
+
+    this.queue = [];
+    this.processing = false;
+    this.lastRequestTime = 0;
+    this.requestsThisMinute = 0;
+    this.minuteStart = Date.now();
+  }
+
+  async add(task, options = {}) {
+    return new Promise((resolve, reject) => {
+      this.queue.push({
+        task,
+        resolve,
+        reject,
+        timeoutMs: options.timeoutMs ?? this.taskTimeoutMs
+      });
+      this.process();
+    });
+  }
+
+  async enqueue(task, options = {}) {
+    return this.add(task, options);
+  }
+
+  async process() {
+    if (this.processing || this.queue.length === 0) {
+      return;
+    }
+
+    this.processing = true;
+
+    try {
+      while (this.queue.length > 0) {
+        const next = this.queue.shift();
+        const { task, resolve, reject, timeoutMs } = next;
+
+        try {
+          const now = Date.now();
+          if (now - this.minuteStart > this.minuteWindowMs) {
+            this.requestsThisMinute = 0;
+            this.minuteStart = now;
+          }
+
+          if (this.requestsThisMinute >= this.maxRequestsPerMinute) {
+            const waitTime = Math.max(
+              this.minuteWindowMs - (now - this.minuteStart) + 1,
+              0
+            );
+            await this.delay(waitTime);
+            this.requestsThisMinute = 0;
+            this.minuteStart = Date.now();
+          }
+
+          const timeSinceLastRequest = Date.now() - this.lastRequestTime;
+          if (timeSinceLastRequest < this.minInterval) {
+            await this.delay(this.minInterval - timeSinceLastRequest);
+          }
+
+          this.lastRequestTime = Date.now();
+          this.requestsThisMinute += 1;
+
+          const result = await this.runTask(task, timeoutMs);
+          resolve(result);
+        } catch (error) {
+          if (this.isRateLimitError(error)) {
+            await this.delay(this.rateLimitBackoffMs);
+            this.queue.unshift(next);
+          } else {
+            reject(error);
+          }
+        }
+      }
+    } finally {
+      this.processing = false;
+      if (this.queue.length > 0) {
+        this.process();
+      }
+    }
+  }
+
+  async runTask(task, timeoutMs) {
+    if (!timeoutMs || timeoutMs <= 0) {
+      return Promise.resolve().then(task);
+    }
+
+    return new Promise((resolve, reject) => {
+      let settled = false;
+
+      const timer = setTimeout(() => {
+        settled = true;
+        reject(this.createTimeoutError(timeoutMs));
+      }, timeoutMs);
+
+      Promise.resolve()
+        .then(task)
+        .then((result) => {
+          if (settled) {
+            return;
+          }
+          settled = true;
+          clearTimeout(timer);
+          resolve(result);
+        })
+        .catch((error) => {
+          if (settled) {
+            return;
+          }
+          settled = true;
+          clearTimeout(timer);
+          reject(error);
+        });
+    });
+  }
+
+  createTimeoutError(timeoutMs) {
+    const error = new Error(`Queued grading task timed out after ${timeoutMs}ms`);
+    error.code = 'TASK_TIMEOUT';
+    error.statusCode = 504;
+    return error;
+  }
+
+  isRateLimitError(error) {
+    const message = error?.message?.toLowerCase?.() || '';
+    return message.includes('429') || message.includes('rate limit');
+  }
+
+  delay(ms) {
+    return new Promise((resolve) => setTimeout(resolve, ms));
+  }
+
+  getQueueLength() {
+    return this.queue.length;
+  }
+
+  getStats() {
+    return {
+      queueLength: this.queue.length,
+      requestsThisMinute: this.requestsThisMinute,
+      processing: this.processing
+    };
+  }
+}
+
+export const DEFAULT_QUEUE_OPTIONS = {
+  maxRequestsPerMinute: DEFAULT_MAX_REQUESTS_PER_MINUTE,
+  minDelayBetweenRequests: DEFAULT_MIN_DELAY_BETWEEN_REQUESTS_MS,
+  taskTimeoutMs: DEFAULT_TASK_TIMEOUT_MS
+};
diff --git a/C:/Users/ColsonR/shared-grading-proxy/json-extractor.js b/C:/Users/ColsonR/shared-grading-proxy/json-extractor.js
new file mode 100644
index 0000000000000000000000000000000000000000..a6fc8f2a248bc03ce36ae6d1b8b8c845aacd13d2
--- /dev/null
+++ b/C:/Users/ColsonR/shared-grading-proxy/json-extractor.js
@@ -0,0 +1,129 @@
+const SCORE_REGEX = /["']?score["']?\s*:\s*["']?([EPI])["']?/i;
+const FEEDBACK_REGEX = /["']?feedback["']?\s*:\s*["']([^"']*)["']/i;
+
+export function extractJSON(raw) {
+  if (raw && typeof raw === 'object') {
+    return raw;
+  }
+
+  const text = String(raw ?? '').trim();
+  if (!text) {
+    throw new Error('Failed to extract JSON from AI response');
+  }
+
+  try {
+    return JSON.parse(text);
+  } catch {
+    // Continue to repair strategy.
+  }
+
+  try {
+    return JSON.parse(repairJSON(text));
+  } catch {
+    // Continue to extraction strategy.
+  }
+
+  const jsonMatch =
+    text.match(/\{[\s\S]*?"score"\s*:\s*"[EPIepi]"[\s\S]*?\}/) ||
+    text.match(/\{[\s\S]*\}/);
+
+  if (jsonMatch) {
+    const extracted = jsonMatch[0];
+
+    try {
+      return JSON.parse(extracted);
+    } catch {
+      try {
+        return JSON.parse(repairJSON(extracted));
+      } catch {
+        // Continue to last-resort field extraction.
+      }
+    }
+  }
+
+  const scoreMatch = text.match(SCORE_REGEX);
+  if (scoreMatch) {
+    return {
+      score: scoreMatch[1].toUpperCase(),
+      feedback: text.match(FEEDBACK_REGEX)?.[1] || ''
+    };
+  }
+
+  throw new Error('Failed to extract JSON from AI response');
+}
+
+export function repairJSON(text) {
+  return String(text)
+    .replace(/^\s*```(?:json)?\s*/i, '')
+    .replace(/\s*```\s*$/i, '')
+    .replace(/[\u201C\u201D]/g, '"')
+    .replace(/[\u2018\u2019]/g, "'")
+    .replace(/,(\s*[}\]])/g, '$1')
+    .replace(/([{,]\s*)([A-Za-z_][A-Za-z0-9_]*)(\s*:)/g, '$1"$2"$3');
+}
+
+export function isValidGradingResponse(parsed) {
+  if (!parsed || typeof parsed !== 'object') {
+    return false;
+  }
+
+  if ('score' in parsed) {
+    return ['E', 'P', 'I'].includes(String(parsed.score).toUpperCase());
+  }
+
+  for (const [key, value] of Object.entries(parsed)) {
+    if (key.startsWith('_')) {
+      continue;
+    }
+    if (value && typeof value === 'object' && 'score' in value) {
+      return ['E', 'P', 'I'].includes(String(value.score).toUpperCase());
+    }
+  }
+
+  return false;
+}
+
+export function normalizeGradingResponse(parsed) {
+  if (!parsed || typeof parsed !== 'object') {
+    return {
+      score: 'I',
+      feedback: 'Unable to parse AI response',
+      matched: [],
+      missing: []
+    };
+  }
+
+  if ('score' in parsed && ['E', 'P', 'I'].includes(String(parsed.score).toUpperCase())) {
+    return {
+      score: String(parsed.score).toUpperCase(),
+      feedback: parsed.feedback || '',
+      matched: Array.isArray(parsed.matched) ? parsed.matched : [],
+      missing: Array.isArray(parsed.missing) ? parsed.missing : [],
+      appealGranted: Boolean(parsed.appealGranted),
+      appealResponse: parsed.appealResponse || ''
+    };
+  }
+
+  for (const [key, value] of Object.entries(parsed)) {
+    if (key.startsWith('_') || !value || typeof value !== 'object' || !value.score) {
+      continue;
+    }
+
+    return {
+      score: String(value.score).toUpperCase(),
+      feedback: value.feedback || '',
+      matched: Array.isArray(value.matched) ? value.matched : [],
+      missing: Array.isArray(value.missing) ? value.missing : [],
+      appealGranted: Boolean(value.appealGranted),
+      appealResponse: value.appealResponse || '',
+      fieldId: key
+    };
+  }
+
+  return {
+    score: 'I',
+    feedback: 'Unable to determine score from AI response',
+    matched: [],
+    missing: []
+  };
+}
diff --git a/C:/Users/ColsonR/shared-grading-proxy/keyword-grader.js b/C:/Users/ColsonR/shared-grading-proxy/keyword-grader.js
new file mode 100644
index 0000000000000000000000000000000000000000..a039721541505237af56c215e351795acee4e48c
--- /dev/null
+++ b/C:/Users/ColsonR/shared-grading-proxy/keyword-grader.js
@@ -0,0 +1,300 @@
+const SCORE_ORDER = { I: 0, P: 1, E: 2 };
+
+export function gradeByKeywords(studentAnswer, correctAnswer, rubric, context = {}) {
+  const answerText = String(studentAnswer ?? '');
+  const normalizedRubric = normalizeRubric(rubric);
+
+  if (!normalizedRubric) {
+    return gradeExact(answerText, correctAnswer);
+  }
+
+  const text = answerText.toLowerCase();
+  const results = {
+    required: {},
+    forbidden: [],
+    matched: [],
+    missing: [],
+    score: 'E'
+  };
+
+  let matchedCount = 0;
+  let totalRequired = 0;
+
+  for (const [index, item] of normalizedRubric.rubric.entries()) {
+    if (!item || typeof item !== 'object') {
+      continue;
+    }
+
+    if (typeof item.contextCondition === 'function' && !item.contextCondition(context)) {
+      continue;
+    }
+
+    const label = item.id || item.description || `item-${index + 1}`;
+    const required = item.required !== false;
+
+    if (required) {
+      totalRequired += 1;
+    }
+
+    const matched = testRubricItem(item, text, context);
+    results.required[label] = matched;
+
+    if (matched) {
+      results.matched.push(label);
+      if (required) {
+        matchedCount += 1;
+      }
+    } else if (required) {
+      results.missing.push(label);
+    }
+  }
+
+  for (const forbiddenItem of normalizedRubric.forbidden) {
+    const regex = toRegExp(forbiddenItem, context);
+    if (regex && regex.test(text)) {
+      results.forbidden.push(formatLabel(forbiddenItem));
+    }
+  }
+
+  const missingCount = results.missing.length;
+  const scoring = normalizedRubric.scoring || {};
+  const eMinRequired = scoring.E?.minRequired ?? totalRequired;
+  const eMaxMissing = scoring.E?.maxMissing;
+  const pMinRequired = scoring.P?.minRequired ?? Math.ceil(totalRequired * 0.5);
+  const pMaxMissing = scoring.P?.maxMissing;
+
+  if (results.forbidden.length > 0) {
+    results.score = 'I';
+    results.feedback = `Avoid using "${results.forbidden[0]}" - it may imply something incorrect.`;
+  } else if (totalRequired === 0) {
+    results.score = 'E';
+    results.feedback = 'Correct!';
+  } else if (
+    matchedCount >= eMinRequired &&
+    (typeof eMaxMissing !== 'number' || missingCount <= eMaxMissing)
+  ) {
+    results.score = 'E';
+    results.feedback = 'Excellent! All key elements included.';
+  } else if (
+    matchedCount >= pMinRequired &&
+    (typeof pMaxMissing !== 'number' || missingCount <= pMaxMissing)
+  ) {
+    results.score = 'P';
+    const missingItems = results.missing.slice(0, 3);
+    results.feedback = missingItems.length > 0
+      ? `Good, but consider including: ${missingItems.join(', ')}.`
+      : 'Good work. Some key elements are present.';
+  } else {
+    results.score = 'I';
+    results.feedback = 'Missing key elements. Review the rubric requirements.';
+  }
+
+  results.correct = results.score === 'E';
+  results.matchedCount = matchedCount;
+  results.totalRequired = totalRequired;
+  results.scoreValue = SCORE_ORDER[results.score];
+
+  return results;
+}
+
+export function gradeExact(studentAnswer, correctAnswer) {
+  const actual = normalizeText(studentAnswer);
+  const acceptableAnswers = normalizeAcceptableAnswers(correctAnswer);
+  const match = acceptableAnswers.find((candidate) => normalizeText(candidate) === actual);
+  const correct = Boolean(match) && actual.length > 0;
+
+  return {
+    score: correct ? 'E' : 'I',
+    feedback: correct ? 'Correct' : 'Incorrect',
+    matched: correct && match ? [match] : [],
+    missing: correct ? [] : acceptableAnswers.slice(0, 1),
+    correct,
+    matchedCount: correct ? 1 : 0,
+    totalRequired: acceptableAnswers.length || 1,
+    scoreValue: correct ? SCORE_ORDER.E : SCORE_ORDER.I
+  };
+}
+
+export function compareScores(left, right) {
+  return (SCORE_ORDER[left] || 0) - (SCORE_ORDER[right] || 0);
+}
+
+function normalizeRubric(rubric) {
+  if (!rubric) {
+    return null;
+  }
+
+  if (Array.isArray(rubric)) {
+    return {
+      rubric,
+      scoring: null,
+      forbidden: []
+    };
+  }
+
+  if (Array.isArray(rubric.rubric)) {
+    return {
+      rubric: rubric.rubric,
+      scoring: rubric.scoring || null,
+      forbidden: Array.isArray(rubric.forbidden) ? rubric.forbidden : []
+    };
+  }
+
+  if (Array.isArray(rubric.required)) {
+    return {
+      rubric: rubric.required,
+      scoring: rubric.scoring || null,
+      forbidden: Array.isArray(rubric.forbidden) ? rubric.forbidden : []
+    };
+  }
+
+  if (Array.isArray(rubric.expectedElements)) {
+    return {
+      rubric: rubric.expectedElements.map((element, index) => normalizeExpectedElement(element, index)),
+      scoring: rubric.scoring || null,
+      forbidden: Array.isArray(rubric.forbidden) ? rubric.forbidden : []
+    };
+  }
+
+  return null;
+}
+
+function normalizeExpectedElement(element, index) {
+  if (typeof element === 'string') {
+    return {
+      id: `element-${index + 1}`,
+      description: element,
+      required: true,
+      pattern: element
+    };
+  }
+
+  return {
+    id: element.id || `element-${index + 1}`,
+    description: element.description || element.id || `element-${index + 1}`,
+    required: element.required !== false,
+    pattern: element.pattern ?? element.description,
+    patterns: element.patterns
+  };
+}
+
+function testRubricItem(item, text, context) {
+  const patterns = resolvePatterns(item, context);
+  if (patterns.length === 0) {
+    return false;
+  }
+
+  for (const pattern of patterns) {
+    const regex = toRegExp(pattern, context);
+    if (!regex) {
+      continue;
+    }
+
+    const match = text.match(regex);
+    if (!match) {
+      continue;
+    }
+
+    if (typeof item.validate === 'function') {
+      if (item.validate(match, context)) {
+        return true;
+      }
+      continue;
+    }
+
+    return true;
+  }
+
+  return false;
+}
+
+function resolvePatterns(item, context) {
+  let pattern = item.pattern;
+
+  if (typeof item.contextPattern === 'function') {
+    pattern = item.contextPattern(context);
+  }
+
+  if (Array.isArray(item.patterns)) {
+    pattern = item.patterns;
+  }
+
+  if (pattern == null) {
+    return [];
+  }
+
+  return Array.isArray(pattern) ? pattern : [pattern];
+}
+
+function toRegExp(pattern, context) {
+  if (!pattern) {
+    return null;
+  }
+
+  if (pattern instanceof RegExp) {
+    return pattern;
+  }
+
+  if (typeof pattern === 'function') {
+    return toRegExp(pattern(context), context);
+  }
+
+  if (typeof pattern === 'object') {
+    if (typeof pattern.source === 'string') {
+      return new RegExp(pattern.source, pattern.flags || 'i');
+    }
+
+    const signKey = Number(context.sign) >= 0 ? 'positive' : 'negative';
+    const contextual = pattern[signKey] ?? Object.values(pattern)[0];
+    return toRegExp(contextual, context);
+  }
+
+  if (typeof pattern === 'string') {
+    const interpolated = interpolate(pattern, context);
+    const regexString = interpolated.match(/^\/([\s\S]+)\/([dgimsuvy]*)$/);
+    if (regexString) {
+      return new RegExp(regexString[1], regexString[2] || 'i');
+    }
+    return new RegExp(interpolated, 'i');
+  }
+
+  return null;
+}
+
+function interpolate(template, context) {
+  return String(template).replace(/\{\{\s*([A-Za-z0-9_]+)\s*\}\}/g, (_, key) => {
+    return context[key] == null ? '' : String(context[key]);
+  });
+}
+
+function normalizeAcceptableAnswers(correctAnswer) {
+  if (Array.isArray(correctAnswer)) {
+    return correctAnswer.map((value) => String(value).trim()).filter(Boolean);
+  }
+
+  if (correctAnswer == null) {
+    return [];
+  }
+
+  return String(correctAnswer)
+    .split('|')
+    .map((value) => value.trim())
+    .filter(Boolean);
+}
+
+function normalizeText(value) {
+  return String(value ?? '').trim().toLowerCase();
+}
+
+function formatLabel(value) {
+  if (typeof value === 'string') {
+    return value;
+  }
+  if (value instanceof RegExp) {
+    return value.source;
+  }
+  if (value && typeof value === 'object' && typeof value.source === 'string') {
+    return value.source;
+  }
+  return String(value);
+}
diff --git a/C:/Users/ColsonR/shared-grading-proxy/mcq-enforcer.js b/C:/Users/ColsonR/shared-grading-proxy/mcq-enforcer.js
new file mode 100644
index 0000000000000000000000000000000000000000..7c6bea4fe7cf4e651f23ba8679f0676a7874bc0a
--- /dev/null
+++ b/C:/Users/ColsonR/shared-grading-proxy/mcq-enforcer.js
@@ -0,0 +1,60 @@
+const MCQ_TYPES = new Set([
+  'mcq',
+  'multiple-choice',
+  'multiple choice',
+  'multiple_choice'
+]);
+
+export function isMCQQuestionType(questionType) {
+  return MCQ_TYPES.has(String(questionType ?? '').trim().toLowerCase());
+}
+
+export function normalizeAnswer(answer) {
+  return String(answer ?? '').trim().toLowerCase();
+}
+
+export function enforceMCQ(questionType, studentAnswer, correctAnswer, aiScore) {
+  if (!isMCQQuestionType(questionType)) {
+    return aiScore;
+  }
+
+  if (!correctAnswer) {
+    return aiScore;
+  }
+
+  const isCorrect = normalizeAnswer(studentAnswer) === normalizeAnswer(correctAnswer);
+  if (!isCorrect && aiScore === 'E') {
+    return 'P';
+  }
+
+  return aiScore;
+}
+
+export function applyMCQEnforcement({ questionType, studentAnswer, correctAnswer, result }) {
+  if (!result) {
+    return result;
+  }
+
+  const cappedScore = enforceMCQ(questionType, studentAnswer, correctAnswer, result.score);
+  if (cappedScore === result.score) {
+    return result;
+  }
+
+  return {
+    ...result,
+    score: cappedScore,
+    feedback: appendCapNote(result.feedback),
+    _scoreCapped: true
+  };
+}
+
+function appendCapNote(feedback) {
+  const note = '[Note: Maximum score for incorrect MCQ answers is P]';
+  if (!feedback) {
+    return note;
+  }
+  if (feedback.includes(note)) {
+    return feedback;
+  }
+  return `${feedback} ${note}`;
+}
