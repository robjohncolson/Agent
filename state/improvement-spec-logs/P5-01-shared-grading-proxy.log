index 0000000000000000000000000000000000000000..a039721541505237af56c215e351795acee4e48c
--- /dev/null
+++ b/C:/Users/ColsonR/shared-grading-proxy/keyword-grader.js
@@ -0,0 +1,300 @@
+const SCORE_ORDER = { I: 0, P: 1, E: 2 };
+
+export function gradeByKeywords(studentAnswer, correctAnswer, rubric, context = {}) {
+  const answerText = String(studentAnswer ?? '');
+  const normalizedRubric = normalizeRubric(rubric);
+
+  if (!normalizedRubric) {
+    return gradeExact(answerText, correctAnswer);
+  }
+
+  const text = answerText.toLowerCase();
+  const results = {
+    required: {},
+    forbidden: [],
+    matched: [],
+    missing: [],
+    score: 'E'
+  };
+
+  let matchedCount = 0;
+  let totalRequired = 0;
+
+  for (const [index, item] of normalizedRubric.rubric.entries()) {
+    if (!item || typeof item !== 'object') {
+      continue;
+    }
+
+    if (typeof item.contextCondition === 'function' && !item.contextCondition(context)) {
+      continue;
+    }
+
+    const label = item.id || item.description || `item-${index + 1}`;
+    const required = item.required !== false;
+
+    if (required) {
+      totalRequired += 1;
+    }
+
+    const matched = testRubricItem(item, text, context);
+    results.required[label] = matched;
+
+    if (matched) {
+      results.matched.push(label);
+      if (required) {
+        matchedCount += 1;
+      }
+    } else if (required) {
+      results.missing.push(label);
+    }
+  }
+
+  for (const forbiddenItem of normalizedRubric.forbidden) {
+    const regex = toRegExp(forbiddenItem, context);
+    if (regex && regex.test(text)) {
+      results.forbidden.push(formatLabel(forbiddenItem));
+    }
+  }
+
+  const missingCount = results.missing.length;
+  const scoring = normalizedRubric.scoring || {};
+  const eMinRequired = scoring.E?.minRequired ?? totalRequired;
+  const eMaxMissing = scoring.E?.maxMissing;
+  const pMinRequired = scoring.P?.minRequired ?? Math.ceil(totalRequired * 0.5);
+  const pMaxMissing = scoring.P?.maxMissing;
+
+  if (results.forbidden.length > 0) {
+    results.score = 'I';
+    results.feedback = `Avoid using "${results.forbidden[0]}" - it may imply something incorrect.`;
+  } else if (totalRequired === 0) {
+    results.score = 'E';
+    results.feedback = 'Correct!';
+  } else if (
+    matchedCount >= eMinRequired &&
+    (typeof eMaxMissing !== 'number' || missingCount <= eMaxMissing)
+  ) {
+    results.score = 'E';
+    results.feedback = 'Excellent! All key elements included.';
+  } else if (
+    matchedCount >= pMinRequired &&
+    (typeof pMaxMissing !== 'number' || missingCount <= pMaxMissing)
+  ) {
+    results.score = 'P';
+    const missingItems = results.missing.slice(0, 3);
+    results.feedback = missingItems.length > 0
+      ? `Good, but consider including: ${missingItems.join(', ')}.`
+      : 'Good work. Some key elements are present.';
+  } else {
+    results.score = 'I';
+    results.feedback = 'Missing key elements. Review the rubric requirements.';
+  }
+
+  results.correct = results.score === 'E';
+  results.matchedCount = matchedCount;
+  results.totalRequired = totalRequired;
+  results.scoreValue = SCORE_ORDER[results.score];
+
+  return results;
+}
+
+export function gradeExact(studentAnswer, correctAnswer) {
+  const actual = normalizeText(studentAnswer);
+  const acceptableAnswers = normalizeAcceptableAnswers(correctAnswer);
+  const match = acceptableAnswers.find((candidate) => normalizeText(candidate) === actual);
+  const correct = Boolean(match) && actual.length > 0;
+
+  return {
+    score: correct ? 'E' : 'I',
+    feedback: correct ? 'Correct' : 'Incorrect',
+    matched: correct && match ? [match] : [],
+    missing: correct ? [] : acceptableAnswers.slice(0, 1),
+    correct,
+    matchedCount: correct ? 1 : 0,
+    totalRequired: acceptableAnswers.length || 1,
+    scoreValue: correct ? SCORE_ORDER.E : SCORE_ORDER.I
+  };
+}
+
+export function compareScores(left, right) {
+  return (SCORE_ORDER[left] || 0) - (SCORE_ORDER[right] || 0);
+}
+
+function normalizeRubric(rubric) {
+  if (!rubric) {
+    return null;
+  }
+
+  if (Array.isArray(rubric)) {
+    return {
+      rubric,
+      scoring: null,
+      forbidden: []
+    };
+  }
+
+  if (Array.isArray(rubric.rubric)) {
+    return {
+      rubric: rubric.rubric,
+      scoring: rubric.scoring || null,
+      forbidden: Array.isArray(rubric.forbidden) ? rubric.forbidden : []
+    };
+  }
+
+  if (Array.isArray(rubric.required)) {
+    return {
+      rubric: rubric.required,
+      scoring: rubric.scoring || null,
+      forbidden: Array.isArray(rubric.forbidden) ? rubric.forbidden : []
+    };
+  }
+
+  if (Array.isArray(rubric.expectedElements)) {
+    return {
+      rubric: rubric.expectedElements.map((element, index) => normalizeExpectedElement(element, index)),
+      scoring: rubric.scoring || null,
+      forbidden: Array.isArray(rubric.forbidden) ? rubric.forbidden : []
+    };
+  }
+
+  return null;
+}
+
+function normalizeExpectedElement(element, index) {
+  if (typeof element === 'string') {
+    return {
+      id: `element-${index + 1}`,
+      description: element,
+      required: true,
+      pattern: element
+    };
+  }
+
+  return {
+    id: element.id || `element-${index + 1}`,
+    description: element.description || element.id || `element-${index + 1}`,
+    required: element.required !== false,
+    pattern: element.pattern ?? element.description,
+    patterns: element.patterns
+  };
+}
+
+function testRubricItem(item, text, context) {
+  const patterns = resolvePatterns(item, context);
+  if (patterns.length === 0) {
+    return false;
+  }
+
+  for (const pattern of patterns) {
+    const regex = toRegExp(pattern, context);
+    if (!regex) {
+      continue;
+    }
+
+    const match = text.match(regex);
+    if (!match) {
+      continue;
+    }
+
+    if (typeof item.validate === 'function') {
+      if (item.validate(match, context)) {
+        return true;
+      }
+      continue;
+    }
+
+    return true;
+  }
+
+  return false;
+}
+
+function resolvePatterns(item, context) {
+  let pattern = item.pattern;
+
+  if (typeof item.contextPattern === 'function') {
+    pattern = item.contextPattern(context);
+  }
+
+  if (Array.isArray(item.patterns)) {
+    pattern = item.patterns;
+  }
+
+  if (pattern == null) {
+    return [];
+  }
+
+  return Array.isArray(pattern) ? pattern : [pattern];
+}
+
+function toRegExp(pattern, context) {
+  if (!pattern) {
+    return null;
+  }
+
+  if (pattern instanceof RegExp) {
+    return pattern;
+  }
+
+  if (typeof pattern === 'function') {
+    return toRegExp(pattern(context), context);
+  }
+
+  if (typeof pattern === 'object') {
+    if (typeof pattern.source === 'string') {
+      return new RegExp(pattern.source, pattern.flags || 'i');
+    }
+
+    const signKey = Number(context.sign) >= 0 ? 'positive' : 'negative';
+    const contextual = pattern[signKey] ?? Object.values(pattern)[0];
+    return toRegExp(contextual, context);
+  }
+
+  if (typeof pattern === 'string') {
+    const interpolated = interpolate(pattern, context);
+    const regexString = interpolated.match(/^\/([\s\S]+)\/([dgimsuvy]*)$/);
+    if (regexString) {
+      return new RegExp(regexString[1], regexString[2] || 'i');
+    }
+    return new RegExp(interpolated, 'i');
+  }
+
+  return null;
+}
+
+function interpolate(template, context) {
+  return String(template).replace(/\{\{\s*([A-Za-z0-9_]+)\s*\}\}/g, (_, key) => {
+    return context[key] == null ? '' : String(context[key]);
+  });
+}
+
+function normalizeAcceptableAnswers(correctAnswer) {
+  if (Array.isArray(correctAnswer)) {
+    return correctAnswer.map((value) => String(value).trim()).filter(Boolean);
+  }
+
+  if (correctAnswer == null) {
+    return [];
+  }
+
+  return String(correctAnswer)
+    .split('|')
+    .map((value) => value.trim())
+    .filter(Boolean);
+}
+
+function normalizeText(value) {
+  return String(value ?? '').trim().toLowerCase();
+}
+
+function formatLabel(value) {
+  if (typeof value === 'string') {
+    return value;
+  }
+  if (value instanceof RegExp) {
+    return value.source;
+  }
+  if (value && typeof value === 'object' && typeof value.source === 'string') {
+    return value.source;
+  }
+  return String(value);
+}
diff --git a/C:/Users/ColsonR/shared-grading-proxy/mcq-enforcer.js b/C:/Users/ColsonR/shared-grading-proxy/mcq-enforcer.js
new file mode 100644
index 0000000000000000000000000000000000000000..7c6bea4fe7cf4e651f23ba8679f0676a7874bc0a
--- /dev/null
+++ b/C:/Users/ColsonR/shared-grading-proxy/mcq-enforcer.js
@@ -0,0 +1,60 @@
+const MCQ_TYPES = new Set([
+  'mcq',
+  'multiple-choice',
+  'multiple choice',
+  'multiple_choice'
+]);
+
+export function isMCQQuestionType(questionType) {
+  return MCQ_TYPES.has(String(questionType ?? '').trim().toLowerCase());
+}
+
+export function normalizeAnswer(answer) {
+  return String(answer ?? '').trim().toLowerCase();
+}
+
+export function enforceMCQ(questionType, studentAnswer, correctAnswer, aiScore) {
+  if (!isMCQQuestionType(questionType)) {
+    return aiScore;
+  }
+
+  if (!correctAnswer) {
+    return aiScore;
+  }
+
+  const isCorrect = normalizeAnswer(studentAnswer) === normalizeAnswer(correctAnswer);
+  if (!isCorrect && aiScore === 'E') {
+    return 'P';
+  }
+
+  return aiScore;
+}
+
+export function applyMCQEnforcement({ questionType, studentAnswer, correctAnswer, result }) {
+  if (!result) {
+    return result;
+  }
+
+  const cappedScore = enforceMCQ(questionType, studentAnswer, correctAnswer, result.score);
+  if (cappedScore === result.score) {
+    return result;
+  }
+
+  return {
+    ...result,
+    score: cappedScore,
+    feedback: appendCapNote(result.feedback),
+    _scoreCapped: true
+  };
+}
+
+function appendCapNote(feedback) {
+  const note = '[Note: Maximum score for incorrect MCQ answers is P]';
+  if (!feedback) {
+    return note;
+  }
+  if (feedback.includes(note)) {
+    return feedback;
+  }
+  return `${feedback} ${note}`;
+}
diff --git a/C:/Users/ColsonR/shared-grading-proxy/package.json b/C:/Users/ColsonR/shared-grading-proxy/package.json
