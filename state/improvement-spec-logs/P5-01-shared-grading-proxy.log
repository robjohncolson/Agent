+    rateLimitBackoffMs: 1,
+    taskTimeoutMs: 500
+  });
+
+  const callTimes = [];
+
+  await Promise.all([
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 1;
+    }),
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 2;
+    }),
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 3;
