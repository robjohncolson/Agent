diff --git a/C:/Users/ColsonR/shared-grading-proxy/ai-grader.js b/C:/Users/ColsonR/shared-grading-proxy/ai-grader.js
new file mode 100644
index 0000000000000000000000000000000000000000..9bd2a93f8aad57d5ed3947ed7ef2a40842c41f98
--- /dev/null
+++ b/C:/Users/ColsonR/shared-grading-proxy/ai-grader.js
@@ -0,0 +1,246 @@
+import { buildFrameworkContext, getFrameworkForQuestion } from './framework-context.js';
+import { DEFAULT_QUEUE_OPTIONS, GradingQueue } from './grading-queue.js';
+import {
+  extractJSON,
+  isValidGradingResponse,
+  normalizeGradingResponse
+} from './json-extractor.js';
+
+export const GROQ_PROVIDER = 'groq';
+export const GROQ_MODEL = 'llama-3.3-70b-versatile';
+export const GROQ_TIMEOUT_MS = 30000;
+export const GROQ_TEMPERATURE = 0.1;
+
+export function createAIGrader({
+  apiKey = process.env.GROQ_API_KEY,
+  model = GROQ_MODEL,
+  temperature = GROQ_TEMPERATURE,
+  timeoutMs = GROQ_TIMEOUT_MS,
+  fetchImpl = globalThis.fetch,
+  queue = new GradingQueue({
+    ...DEFAULT_QUEUE_OPTIONS,
+    taskTimeoutMs: timeoutMs
+  })
+} = {}) {
+  if (typeof fetchImpl !== 'function') {
+    throw new Error('Global fetch is not available in this runtime');
+  }
+
+  async function callGroq(prompt) {
+    if (!apiKey) {
+      const error = new Error('GROQ_API_KEY not configured');
+      error.statusCode = 503;
+      throw error;
+    }
+
+    const controller = new AbortController();
+    const timeoutId = setTimeout(() => controller.abort(), timeoutMs);
+
+    try {
+      const response = await fetchImpl('https://api.groq.com/openai/v1/chat/completions', {
+        method: 'POST',
+        headers: {
+          Authorization: `Bearer ${apiKey}`,
+          'Content-Type': 'application/json'
+        },
+        signal: controller.signal,
+        body: JSON.stringify({
+          model,
+          messages: [
+            {
+              role: 'system',
+              content: 'You are an AP Statistics teacher grading student responses. Always respond with valid JSON only.'
+            },
+            {
+              role: 'user',
+              content: prompt
+            }
+          ],
+          temperature,
+          max_tokens: 1500,
+          response_format: { type: 'json_object' }
+        })
+      });
+
+      if (!response.ok) {
+        const errorText = await response.text();
+        throw new Error(`Groq API error ${response.status}: ${errorText}`);
+      }
+
+      const data = await response.json();
+      const content = data.choices?.[0]?.message?.content;
+
+      if (!content) {
+        throw new Error('Empty response from Groq');
+      }
+
+      const parsed = extractJSON(content);
+      if (!isValidGradingResponse(parsed)) {
+        throw new Error('Failed to parse Groq response as a valid grading payload');
+      }
+
+      return normalizeGradingResponse(parsed);
+    } catch (error) {
+      if (error?.name === 'AbortError') {
+        const timeoutError = new Error('Groq API request timed out');
+        timeoutError.statusCode = 504;
+        throw timeoutError;
+      }
+      throw error;
+    } finally {
+      clearTimeout(timeoutId);
+    }
+  }
+
+  async function grade(payload) {
+    const prompt = buildGradePrompt(payload);
+    const result = await queue.add(() => callGroq(prompt), { timeoutMs });
+    return {
+      ...result,
+      provider: GROQ_PROVIDER,
+      model
+    };
+  }
+
+  async function appeal(payload) {
+    const prompt = buildAppealPrompt(payload);
+    const result = await queue.add(() => callGroq(prompt), { timeoutMs });
+    return {
+      ...result,
+      provider: GROQ_PROVIDER,
+      model
+    };
+  }
+
+  return {
+    grade,
+    appeal,
+    queue,
+    isAvailable() {
+      return Boolean(apiKey);
+    }
+  };
+}
+
+export function buildGradePrompt({
+  questionId,
+  questionType,
+  studentAnswer,
+  correctAnswer,
+  rubric,
+  frameworkContext
+}) {
+  const contextText = resolveFrameworkContext(questionId, frameworkContext);
+  const expectedElements = formatExpectedElements(rubric);
+  const normalizedQuestionType = questionType || 'frq';
+
+  return `You are an AP Statistics teacher grading a student's response.
+
+${contextText ? `${contextText}\n` : ''}## Question Context
+Question ID: ${questionId || 'unknown'}
+Question Type: ${normalizedQuestionType}
+Correct Answer: ${correctAnswer || 'not provided'}
+
+## Expected Elements
+${expectedElements}
+
+## Student Answer
+"${String(studentAnswer ?? '')}"
+
+## Grading Rules
+- Grade using only these scores: E, P, I
+- E: all key elements are present and correct
+- P: some key elements are present, with omissions or minor errors
+- I: most key elements are missing or incorrect
+- For multiple-choice questions, a wrong answer cannot receive E
+- Keep feedback concise and student-facing
+
+Respond with ONLY valid JSON:
+{
+  "score": "E" or "P" or "I",
+  "feedback": "Brief explanation of the score",
+  "matched": ["list of correct elements"],
+  "missing": ["list of missing elements"]
+}`;
+}
+
+export function buildAppealPrompt({
+  questionId,
+  questionType,
+  studentAnswer,
+  currentScore,
+  reasoning,
+  correctAnswer,
+  rubric,
+  frameworkContext
+}) {
+  const contextText = resolveFrameworkContext(questionId, frameworkContext);
+  const expectedElements = formatExpectedElements(rubric);
+
+  return `You are an AP Statistics teacher reviewing a student's grade appeal.
+
+${contextText ? `${contextText}\n` : ''}## Question Context
+Question ID: ${questionId || 'unknown'}
+Question Type: ${questionType || 'frq'}
+Current Score: ${currentScore || 'I'}
+Correct Answer: ${correctAnswer || 'not provided'}
+
+## Expected Elements
+${expectedElements}
+
+## Student Answer
+"${String(studentAnswer ?? '')}"
+
+## Student Appeal
+"${String(reasoning ?? '')}"
+
+## Appeal Rules
+- You may upgrade the score if the appeal shows valid understanding
+- You must not downgrade the score
+- For multiple-choice questions, a wrong answer cannot receive E
+- Keep feedback concise and student-facing
+- Explain your decision in plain language
+
+Respond with ONLY valid JSON:
+{
+  "score": "E" or "P" or "I",
+  "feedback": "Explanation of the decision",
+  "appealGranted": true or false,
+  "appealResponse": "Direct message to the student"
+}`;
+}
+
+function resolveFrameworkContext(questionId, explicitFrameworkContext) {
+  if (explicitFrameworkContext) {
+    return explicitFrameworkContext;
+  }
+
+  const framework = getFrameworkForQuestion(questionId);
+  return framework ? buildFrameworkContext(framework) : '';
+}
+
+function formatExpectedElements(rubric) {
+  if (!rubric) {
+    return 'Use standard AP Statistics grading judgment.';
+  }
+
+  const elements =
+    rubric.expectedElements ||
+    rubric.rubric ||
+    rubric.required ||
+    (Array.isArray(rubric) ? rubric : []);
+
+  if (!Array.isArray(elements) || elements.length === 0) {
+    return 'Use standard AP Statistics grading judgment.';
+  }
+
+  return elements
+    .map((item, index) => {
+      if (typeof item === 'string') {
+        return `${index + 1}. ${item}`;
+      }
+
+      return `${index + 1}. ${item.description || item.id || item.pattern || 'Rubric element'}`;
+    })
+    .join('\n');
+}
diff --git a/C:/Users/ColsonR/shared-grading-proxy/appeal-handler.js b/C:/Users/ColsonR/shared-grading-proxy/appeal-handler.js
