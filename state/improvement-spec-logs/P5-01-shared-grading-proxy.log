@@ -0,0 +1,342 @@
+import assert from 'node:assert/strict';
+
+import { GradingQueue } from '../grading-queue.js';
+import { extractJSON } from '../json-extractor.js';
+import { enforceMCQ } from '../mcq-enforcer.js';
+
+const results = {
+  passed: 0,
+  failed: 0,
+  skipped: 0
+};
+
+async function run(name, fn) {
+  try {
+    const skipReason = await fn();
+    if (typeof skipReason === 'string' && skipReason.length > 0) {
+      results.skipped += 1;
+      console.log(`SKIP ${name}: ${skipReason}`);
+      return;
+    }
+
+    results.passed += 1;
+    console.log(`PASS ${name}`);
+  } catch (error) {
+    results.failed += 1;
+    console.error(`FAIL ${name}`);
+    console.error(error.stack || error.message || error);
+  }
+}
+
+await run('GradingQueue drains tasks in order and respects minimum interval', async () => {
+  const queue = new GradingQueue({
+    maxRequestsPerMinute: 50,
+    minDelayBetweenRequests: 25,
+    taskTimeoutMs: 500
+  });
+
+  const callTimes = [];
+
+  const outputs = await Promise.all([
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 'first';
+    }),
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 'second';
+    }),
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 'third';
+    })
+  ]);
+
+  assert.deepEqual(outputs, ['first', 'second', 'third']);
+  assert.ok(callTimes[1] - callTimes[0] >= 20);
+  assert.ok(callTimes[2] - callTimes[1] >= 20);
+});
+
+await run('GradingQueue enforces the per-minute request window', async () => {
+  const queue = new GradingQueue({
+    maxRequestsPerMinute: 2,
+    minDelayBetweenRequests: 0,
+    minuteWindowMs: 40,
+    rateLimitBackoffMs: 1,
+    taskTimeoutMs: 500
+  });
+
+  const callTimes = [];
+
+  await Promise.all([
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 1;
+    }),
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 2;
+    }),
+    queue.add(async () => {
+      callTimes.push(Date.now());
+      return 3;
+    })
+  ]);
+
+  assert.equal(callTimes.length, 3);
+  assert.ok(callTimes[2] - callTimes[1] >= 35);
+});
+
+await run('GradingQueue rejects tasks that exceed the timeout', async () => {
+  const queue = new GradingQueue({
+    maxRequestsPerMinute: 25,
+    minDelayBetweenRequests: 0,
+    taskTimeoutMs: 20
+  });
+
+  await assert.rejects(
+    queue.add(() => new Promise((resolve) => setTimeout(resolve, 100))),
+    /timed out/i
+  );
+});
+
+await run('extractJSON parses valid JSON directly', async () => {
+  const parsed = extractJSON('{"score":"E","feedback":"Correct","matched":["a"],"missing":[]}');
+  assert.equal(parsed.score, 'E');
+  assert.equal(parsed.feedback, 'Correct');
+});
+
+await run('extractJSON repairs smart quotes and trailing commas', async () => {
+  const parsed = extractJSON('{“score”: “P”, “feedback”: “Almost there”,}');
+  assert.equal(parsed.score, 'P');
+  assert.equal(parsed.feedback, 'Almost there');
+});
+
+await run('extractJSON pulls JSON out of prose-wrapped responses', async () => {
+  const parsed = extractJSON('Here is the result:\n{"score":"I","feedback":"Missing evidence","matched":[],"missing":["context"]}\nThanks.');
+  assert.equal(parsed.score, 'I');
+  assert.deepEqual(parsed.missing, ['context']);
+});
+
+await run('extractJSON falls back to score and feedback regex extraction', async () => {
+  const parsed = extractJSON('score: "P", feedback: "Need more detail"');
+  assert.equal(parsed.score, 'P');
+  assert.equal(parsed.feedback, 'Need more detail');
+});
+
+await run('enforceMCQ caps incorrect MCQ answers at P', async () => {
+  assert.equal(enforceMCQ('mcq', 'B', 'A', 'E'), 'P');
+  assert.equal(enforceMCQ('multiple-choice', 'B', 'A', 'P'), 'P');
+});
+
+await run('enforceMCQ keeps E for correct MCQ answers', async () => {
+  assert.equal(enforceMCQ('mcq', 'A', 'A', 'E'), 'E');
+});
+
+await run('enforceMCQ does nothing for non-MCQ questions', async () => {
+  assert.equal(enforceMCQ('frq', 'anything', 'anything else', 'E'), 'E');
+});
+
+const serverModule = await loadServerModule();
+
+await run('GET /health returns service status', async () => {
+  if (!serverModule) {
+    return 'express/cors dependencies are not installed';
+  }
+
+  const app = serverModule.createApp({
+    aiGrader: {
+      isAvailable: () => false
+    }
+  });
+  const server = await startApp(app);
+
+  try {
+    const response = await fetch(`http://127.0.0.1:${server.address().port}/health`);
+    const body = await response.json();
+
+    assert.equal(response.status, 200);
+    assert.equal(body.status, 'ok');
+    assert.equal(body.groqAvailable, false);
+  } finally {
+    server.close();
+  }
+});
+
+await run('POST /grade falls back to keyword grading when AI is unavailable', async () => {
+  if (!serverModule) {
+    return 'express/cors dependencies are not installed';
+  }
+
+  const app = serverModule.createApp({
+    aiGrader: {
+      isAvailable: () => false
+    }
+  });
+  const server = await startApp(app);
+
+  try {
+    const response = await requestJson(server, '/grade', {
+      questionId: 'test',
+      questionType: 'frq',
+      studentAnswer: 'variation across samples due to random selection',
+      correctAnswer: 'variation across samples due to random selection'
+    });
+
+    assert.equal(response.status, 200);
+    assert.equal(response.body.score, 'E');
+    assert.equal(response.body.provider, 'keyword');
+  } finally {
+    server.close();
+  }
+});
+
+await run('POST /grade keeps the stronger keyword score when AI would downgrade', async () => {
+  if (!serverModule) {
+    return 'express/cors dependencies are not installed';
+  }
+
+  const app = serverModule.createApp({
+    aiGrader: {
+      isAvailable: () => true,
+      grade: async () => ({
+        score: 'I',
+        feedback: 'AI downgrade',
+        matched: [],
+        missing: ['context'],
+        provider: 'groq',
+        model: 'test-model'
+      })
+    }
+  });
+  const server = await startApp(app);
+
+  try {
+    const response = await requestJson(server, '/grade', {
+      questionId: 'test',
+      questionType: 'frq',
+      studentAnswer: 'sampling variability means samples differ',
+      correctAnswer: 'sampling variability means samples differ'
+    });
+
+    assert.equal(response.status, 200);
+    assert.equal(response.body.score, 'E');
+    assert.equal(response.body.provider, 'keyword');
+  } finally {
+    server.close();
+  }
+});
+
+await run('POST /grade caps incorrect MCQ answers at P even if AI returns E', async () => {
+  if (!serverModule) {
+    return 'express/cors dependencies are not installed';
+  }
+
+  const app = serverModule.createApp({
+    aiGrader: {
+      isAvailable: () => true,
+      grade: async () => ({
+        score: 'E',
+        feedback: 'AI says correct',
+        matched: ['reasoning'],
+        missing: [],
+        provider: 'groq',
+        model: 'test-model'
+      })
+    }
+  });
+  const server = await startApp(app);
+
+  try {
+    const response = await requestJson(server, '/grade', {
+      questionId: 'test',
+      questionType: 'mcq',
+      studentAnswer: 'B',
+      correctAnswer: 'A'
+    });
+
+    assert.equal(response.status, 200);
+    assert.equal(response.body.score, 'P');
+    assert.equal(response.body.provider, 'groq');
+  } finally {
+    server.close();
+  }
+});
+
+await run('POST /appeal enforces the upgrade-only invariant', async () => {
+  if (!serverModule) {
+    return 'express/cors dependencies are not installed';
+  }
+
+  const app = serverModule.createApp({
+    aiGrader: {
+      isAvailable: () => true,
+      appeal: async () => ({
+        score: 'I',
+        feedback: 'Still incorrect',
+        provider: 'groq',
+        model: 'test-model'
+      })
+    }
+  });
+  const server = await startApp(app);
+
+  try {
+    const response = await requestJson(server, '/appeal', {
+      questionId: 'U4-L2-Q3',
+      studentAnswer: 'My answer',
+      currentScore: 'P',
+      reasoning: 'I think this deserves more credit.'
+    });
+
+    assert.equal(response.status, 200);
+    assert.equal(response.body.score, 'P');
+    assert.equal(response.body.upgraded, false);
+  } finally {
+    server.close();
+  }
+});
+
+console.log(
+  `\nSummary: ${results.passed} passed, ${results.failed} failed, ${results.skipped} skipped`
+);
+
+if (results.failed > 0) {
+  process.exitCode = 1;
+}
+
+async function loadServerModule() {
+  try {
+    return await import('../server.js');
+  } catch (error) {
+    if (
+      error?.code === 'ERR_MODULE_NOT_FOUND' &&
+      (error.message.includes('express') || error.message.includes('cors'))
+    ) {
+      return null;
+    }
+    throw error;
+  }
+}
+
+async function startApp(app) {
+  return new Promise((resolve) => {
+    const server = app.listen(0, () => resolve(server));
+  });
+}
+
+async function requestJson(server, path, body) {
+  const address = server.address();
+  const response = await fetch(`http://127.0.0.1:${address.port}${path}`, {
+    method: 'POST',
+    headers: {
+      'Content-Type': 'application/json'
+    },
+    body: JSON.stringify(body)
+  });
+
+  return {
+    status: response.status,
+    body: await response.json()
+  };
+}
