+{
+  "name": "shared-grading-proxy",
+  "version": "1.0.0",
+  "description": "Standalone shared AI grading proxy for curriculum_render and lrsl-driller",
+  "type": "module",
+  "main": "server.js",
+  "scripts": {
+    "start": "node server.js",
+    "dev": "node --watch server.js",
+    "test": "node tests/run.js"
+  },
+  "engines": {
+    "node": ">=18.0.0"
+  },
+  "dependencies": {
+    "cors": "^2.8.5",
+    "dotenv": "^16.4.5",
+    "express": "^4.21.2"
+  }
+}
diff --git a/C:/Users/ColsonR/shared-grading-proxy/server.js b/C:/Users/ColsonR/shared-grading-proxy/server.js
new file mode 100644
index 0000000000000000000000000000000000000000..679adafb47069e9c12528c2b69d4ce78af611e9b
--- /dev/null
+++ b/C:/Users/ColsonR/shared-grading-proxy/server.js
@@ -0,0 +1,224 @@
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+
+import cors from 'cors';
+import dotenv from 'dotenv';
+import express from 'express';
+
+import { handleAppeal } from './appeal-handler.js';
+import { createAIGrader } from './ai-grader.js';
+import { compareScores, gradeByKeywords } from './keyword-grader.js';
+import { applyMCQEnforcement } from './mcq-enforcer.js';
+
+dotenv.config();
+
+const DEFAULT_ALLOWED_ORIGINS = [
+  'http://localhost:3000',
+  'http://localhost:3001',
+  'http://localhost:3002',
+  'http://localhost:5173',
+  'https://curriculumrender-production.up.railway.app',
+  'https://lrsl-driller.vercel.app',
+  'https://lrsl-driller-production.up.railway.app',
+  'https://lsrl-driller-railway-production.up.railway.app'
+];
+
+export function createApp({
+  aiGrader = createAIGrader(),
+  allowedOrigins = parseAllowedOrigins(process.env.ALLOWED_ORIGINS)
+} = {}) {
+  const app = express();
+  const startedAt = Date.now();
+  const allowedOriginSet = new Set(
+    (allowedOrigins.length > 0 ? allowedOrigins : DEFAULT_ALLOWED_ORIGINS).map((origin) => origin.trim())
+  );
+
+  app.use(
+    cors({
+      origin(origin, callback) {
+        if (!origin || allowedOriginSet.has(origin)) {
+          callback(null, true);
+          return;
+        }
+        callback(new Error('Origin not allowed by CORS'));
+      }
+    })
+  );
+  app.use(express.json({ limit: '1mb' }));
+
+  app.get('/health', (req, res) => {
+    res.json({
+      status: 'ok',
+      groqAvailable: aiGrader.isAvailable(),
+      uptime: (Date.now() - startedAt) / 1000
+    });
+  });
+
+  app.post('/grade', async (req, res) => {
+    const {
+      questionId,
+      questionType,
+      studentAnswer,
+      correctAnswer,
+      rubric,
+      frameworkContext
+    } = req.body || {};
+
+    if (studentAnswer == null || (correctAnswer == null && rubric == null)) {
+      res.status(400).json({
+        error: 'studentAnswer is required, and either correctAnswer or rubric must be provided'
+      });
+      return;
+    }
+
+    const keywordResult = gradeByKeywords(studentAnswer, correctAnswer, rubric, {
+      questionId,
+      questionType,
+      frameworkContext
+    });
+
+    if (!aiGrader.isAvailable()) {
+      res.json(toGradeResponse({ ...keywordResult, provider: 'keyword', model: null }));
+      return;
+    }
+
+    try {
+      const aiResult = await aiGrader.grade({
+        questionId,
+        questionType,
+        studentAnswer,
+        correctAnswer,
+        rubric,
+        frameworkContext
+      });
+
+      const selectedResult = selectBestGrade(keywordResult, aiResult);
+      const finalResult = applyMCQEnforcement({
+        questionType,
+        studentAnswer,
+        correctAnswer,
+        result: selectedResult
+      });
+
+      res.json(toGradeResponse(finalResult));
+    } catch (error) {
+      res.json(
+        toGradeResponse({
+          ...keywordResult,
+          provider: 'keyword',
+          model: null,
+          _fallbackReason: error.message
+        })
+      );
+    }
+  });
+
+  app.post('/appeal', async (req, res) => {
+    const {
+      questionId,
+      studentAnswer,
+      currentScore,
+      reasoning,
+      frameworkContext
+    } = req.body || {};
+
+    if (!studentAnswer || !currentScore || !reasoning || (!frameworkContext && !questionId)) {
+      res.status(400).json({
+        error: 'studentAnswer, currentScore, reasoning, and either frameworkContext or questionId are required'
+      });
+      return;
+    }
+
+    const result = await handleAppeal({
+      payload: req.body,
+      aiGrader
+    });
+
+    res.json({
+      score: result.score,
+      feedback: result.feedback,
+      upgraded: result.upgraded,
+      provider: result.provider,
+      model: result.model,
+      appealResponse: result.appealResponse
+    });
+  });
+
+  return app;
+}
+
+export function selectBestGrade(keywordResult, aiResult) {
+  if (!aiResult?.score) {
+    return {
+      ...keywordResult,
+      provider: 'keyword',
+      model: null
+    };
+  }
+
+  const comparison = compareScores(aiResult.score, keywordResult.score);
+
+  if (comparison > 0) {
+    return aiResult;
+  }
+
+  if (comparison < 0) {
+    return {
+      ...keywordResult,
+      provider: 'keyword',
+      model: null
+    };
+  }
+
+  return {
+    score: keywordResult.score,
+    feedback: aiResult.feedback || keywordResult.feedback,
+    matched: unique([
+      ...(keywordResult.matched || []),
+      ...(aiResult.matched || [])
+    ]),
+    missing:
+      Array.isArray(aiResult.missing) && aiResult.missing.length > 0
+        ? aiResult.missing
+        : keywordResult.missing || [],
+    provider: aiResult.provider,
+    model: aiResult.model
+  };
+}
+
+function toGradeResponse(result) {
+  return {
+    score: result.score,
+    feedback: result.feedback || '',
+    matched: Array.isArray(result.matched) ? result.matched : [],
+    missing: Array.isArray(result.missing) ? result.missing : [],
+    provider: result.provider || null,
+    model: result.model || null
+  };
+}
+
+function unique(values) {
+  return [...new Set(values)];
+}
+
+function parseAllowedOrigins(value) {
+  if (!value) {
+    return [];
+  }
+
+  return String(value)
+    .split(',')
+    .map((origin) => origin.trim())
+    .filter(Boolean);
+}
+
+const currentFile = fileURLToPath(import.meta.url);
+const entryFile = process.argv[1] ? path.resolve(process.argv[1]) : null;
+
+if (entryFile && currentFile === entryFile) {
+  const port = Number(process.env.PORT || 3000);
+  const app = createApp();
+  app.listen(port, () => {
+    console.log(`Shared grading proxy listening on port ${port}`);
+  });
+}
diff --git a/C:/Users/ColsonR/shared-grading-proxy/tests/grading-proxy.test.js b/C:/Users/ColsonR/shared-grading-proxy/tests/grading-proxy.test.js
new file mode 100644
index 0000000000000000000000000000000000000000..6a9669fbd115767c01ca3d4b3b9504750d6812f4
--- /dev/null
+++ b/C:/Users/ColsonR/shared-grading-proxy/tests/grading-proxy.test.js
@@ -0,0 +1,191 @@
+import test from 'node:test';
+import assert from 'node:assert/strict';
+
+async function loadServerModule() {
+  try {
+    return await import('../server.js');
+  } catch (error) {
+    if (
+      error?.code === 'ERR_MODULE_NOT_FOUND' &&
+      (error.message.includes('express') || error.message.includes('cors'))
+    ) {
+      return null;
+    }
+    throw error;
+  }
+}
+
+async function startApp(app) {
+  return new Promise((resolve) => {
+    const server = app.listen(0, () => resolve(server));
+  });
+}
+
+async function requestJson(server, path, body) {
+  const address = server.address();
+  const response = await fetch(`http://127.0.0.1:${address.port}${path}`, {
+    method: 'POST',
+    headers: {
+      'Content-Type': 'application/json'
+    },
+    body: JSON.stringify(body)
+  });
+
+  return {
+    status: response.status,
+    body: await response.json()
+  };
+}
+
+test('GET /health returns service status', async (t) => {
+  const mod = await loadServerModule();
+  if (!mod) {
+    t.skip('express/cors dependencies are not installed');
+    return;
+  }
+
+  const app = mod.createApp({
+    aiGrader: {
+      isAvailable: () => false
+    }
+  });
+  const server = await startApp(app);
+  t.after(() => server.close());
+
+  const response = await fetch(`http://127.0.0.1:${server.address().port}/health`);
+  const body = await response.json();
+
+  assert.equal(response.status, 200);
+  assert.equal(body.status, 'ok');
+  assert.equal(body.groqAvailable, false);
+});
+
+test('POST /grade falls back to keyword grading when AI is unavailable', async (t) => {
+  const mod = await loadServerModule();
+  if (!mod) {
+    t.skip('express/cors dependencies are not installed');
+    return;
+  }
+
+  const app = mod.createApp({
+    aiGrader: {
+      isAvailable: () => false
+    }
+  });
