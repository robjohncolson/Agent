+
+def to_forward_slashes(value: str) -> str:
+    return value.replace("\\", "/")
+
+
+def slugify(value: str) -> str:
+    slug = re.sub(r"[^a-zA-Z0-9]+", "-", value.strip().lower())
+    return slug.strip("-")
 
 
