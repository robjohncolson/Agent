import assert from 'node:assert/strict';
import { readFileSync } from 'node:fs';
import { GameEngine } from './platform/core/game-engine.js';
import { Platform } from './platform/platform.js';

const unit5Manifest = JSON.parse(readFileSync(new URL('./cartridges/apstats-u5-sampling-dist/manifest.json', import.meta.url), 'utf8'));
const lsrlManifest = JSON.parse(readFileSync(new URL('./cartridges/lsrl-interpretation/manifest.json', import.meta.url), 'utf8'));

const localStorageMock = (() => {
  let store = {};
  return {
    getItem(key) { return key in store ? store[key] : null; },
    setItem(key, value) { store[key] = value; },
    removeItem(key) { delete store[key]; },
    clear() { store = {}; }
  };
})();
Object.defineProperty(global, 'localStorage', { value: localStorageMock, configurable: true });

function createEngine() {
  return new GameEngine({
    onStreakUpdate: () => {},
    onStarEarned: () => {},
    onTierUnlocked: () => {}
  });
}

function getModeId(manifest, modeNumber) {
  return manifest.modes[modeNumber - 1]?.id ?? null;
}

function getModeNumberByPrefix(manifest, prefix) {
  const index = manifest.modes.findIndex((mode) => mode.name.startsWith(prefix));
  if (index < 0) throw new Error("'`Missing mode prefix ${prefix}`);
  return index + 1;
}

function getRequiredGoldForMode(manifest, modeNumber) {
  const mode = manifest.modes[modeNumber - 1];
  if (!mode || mode.unlockedBy === '"'default') return 0;
  return mode.unlockedBy?.gold ?? 1;
}

function setModeGold(engine, modeId, gold) {
  engine.starsPerMode[modeId] = { gold, silver: 0, bronze: 0, tin: 0 };
}

function buildCompletedModeNumbers(activeModeNumber) {
  return Array.from({ length: Math.max(0, activeModeNumber - 1) }, (_, index) => index + 1);
}

function persistProgress(manifest, { activeModeNumber = 1, completedModeNumbers = buildCompletedModeNumbers(activeModeNumber) } = {}) {
  const engine = createEngine();
  engine.loadCartridge(manifest);
  engine.starCounts = { gold: 0, silver: 0, bronze: 0, tin: 0 };

  for (const modeNumber of completedModeNumbers) {
    const modeId = getModeId(manifest, modeNumber);
    const gold = getRequiredGoldForMode(manifest, modeNumber + 1);
    setModeGold(engine, modeId, gold);
    engine.starCounts.gold += gold;
  }

  engine.unlockedTiers = [];
  engine.checkUnlocks(engine.unlockRules);
  engine.currentTier = getModeId(manifest, activeModeNumber);
  engine.saveState();
}

function createLoader(manifestsById) {
  let activeManifest = null;
  return {
    async load(cartridgeId) {
      activeManifest = manifestsById[cartridgeId];
      if ("'!activeManifest) throw new Error(`Unknown cartridge: ${cartridgeId}`);
      return {
        id: cartridgeId,
        manifest: activeManifest,
        gradingRules: { gradeField: () => ({ score: '"'E', feedback: 'Correct' }) }
      };
    },
    getModes() { return activeManifest?.modes ?? []; },
    getMode(modeId) { return activeManifest?.modes.find((mode) => mode.id === modeId); },
    async generateProblem(modeId) {
      return { context: { modeId }, answers: {}, scenario: "'`Problem for ${modeId}`, graphConfig: null };
    }
  };
}

function createPlatform(manifestsById) {
  const platform = new Platform();
  platform.cartridgeLoader = createLoader(manifestsById);
  platform.gameEngine.onStarEarned = () => {};
  platform.gameEngine.onTierUnlocked = () => {};
  platform.gameEngine.onStreakUpdate = () => {};
  return platform;
}

async function loadPlatformWithProgress(manifest, progress = {}) {
  persistProgress(manifest, progress);
  const platform = createPlatform({
    [unit5Manifest.meta.id]: unit5Manifest,
    [lsrlManifest.meta.id]: lsrlManifest
  });
  await platform.loadCartridge(manifest.meta.id);
  return platform;
}

function completeCurrentMode(platform, { penalties = 0 } = {}) {
  const completedModeId = platform.currentMode;
  const currentIndex = platform.gameEngine.getModeIndex(completedModeId);
  platform.gameEngine.resetHintsForNewProblem();
  for (let i = 0; i < penalties; i++) {
    platform.gameEngine.useHint(`hint-${i}`);
  }
  const result = platform.gameEngine.recordResult(`field-${completedModeId}`, '"'E', true);
  const state = platform.gameEngine.getState();
  const nextModeId = state.modeOrder[currentIndex + 1] ?? null;
  const didAdvance = nextModeId ? platform.setMode(nextModeId) : false;
  return { completedModeId, nextModeId, didAdvance, result, state };
}

async function run() {
  for (let modeNumber = 1; modeNumber <= 7; modeNumber++) {
    localStorageMock.clear();
    const platform = await loadPlatformWithProgress(unit5Manifest, { activeModeNumber: modeNumber });
    const completion = completeCurrentMode(platform);
    assert.equal(completion.didAdvance, true);
    assert.equal(completion.nextModeId, getModeId(unit5Manifest, modeNumber + 1));
    assert.equal(platform.currentMode, getModeId(unit5Manifest, modeNumber + 1));
  }

  localStorageMock.clear();
  const lastModeNumber = unit5Manifest.modes.length;
  let platform = await loadPlatformWithProgress(unit5Manifest, { activeModeNumber: lastModeNumber });
  let completion = completeCurrentMode(platform);
  assert.equal(completion.nextModeId, null);
  assert.equal(completion.didAdvance, false);
  assert.equal(platform.currentMode, getModeId(unit5Manifest, lastModeNumber));
  assert.notEqual(platform.currentMode, getModeId(unit5Manifest, 1));

  localStorageMock.clear();
  const topic57Capstone = getModeNumberByPrefix(unit5Manifest, '5.7 Cap');
  const topic58Start = getModeNumberByPrefix(unit5Manifest, '5.8a');
  const topic52Start = getModeNumberByPrefix(unit5Manifest, '5.2a');
  platform = await loadPlatformWithProgress(unit5Manifest, { activeModeNumber: topic57Capstone });
  completion = completeCurrentMode(platform);
  assert.equal(completion.didAdvance, true);
  assert.equal(completion.nextModeId, getModeId(unit5Manifest, topic58Start));
  assert.notEqual(completion.nextModeId, getModeId(unit5Manifest, topic52Start));
  assert.equal(platform.currentMode, getModeId(unit5Manifest, topic58Start));
  assert.notEqual(platform.currentMode, getModeId(unit5Manifest, topic52Start));

  localStorageMock.clear();
  let engine = createEngine();
  const mode1Id = getModeId(unit5Manifest, 1);
  const mode2Id = getModeId(unit5Manifest, 2);
  const mode3Id = getModeId(unit5Manifest, 3);
  const mode4Id = getModeId(unit5Manifest, 4);
  engine.loadCartridge(unit5Manifest);
  engine.recordResult("'`field-${mode1Id}`, '"'E', true);
  assert.equal(engine.isModeUnlocked(mode2Id), true);
  assert.equal(engine.setTier(mode2Id), true);
  engine.recordResult("'`field-${mode2Id}`, '"'E', true);
  assert.equal(engine.isModeUnlocked(mode3Id), true);
  assert.equal(engine.isModeUnlocked(mode4Id), false);

  localStorageMock.clear();
  platform = await loadPlatformWithProgress(unit5Manifest, { activeModeNumber: 1 });
  completion = completeCurrentMode(platform, { penalties: 3 });
  assert.equal(completion.result.isCorrect, true);
  assert.equal(completion.state.starsPerMode[completion.completedModeId].tin, 1);
  assert.equal(completion.state.starCounts.tin, 1);
  assert.equal(completion.didAdvance, false);
  assert.equal(platform.currentMode, getModeId(unit5Manifest, 1));
  assert.equal(completion.state.unlockedTiers.includes(getModeId(unit5Manifest, 2)), false);

  localStorageMock.clear();
  const topic57Start = getModeNumberByPrefix(unit5Manifest, '5.7a');
  platform = await loadPlatformWithProgress(unit5Manifest, { activeModeNumber: topic57Start });
  const firstCompletion = completeCurrentMode(platform);
  const secondCompletion = completeCurrentMode(platform);
  assert.equal(firstCompletion.didAdvance, true);
  assert.equal(firstCompletion.nextModeId, getModeId(unit5Manifest, topic57Start + 1));
  assert.equal(secondCompletion.didAdvance, true);
  assert.equal(secondCompletion.nextModeId, getModeId(unit5Manifest, topic57Start + 2));
  assert.equal(platform.currentMode, getModeId(unit5Manifest, topic57Start + 2));
  assert.equal(platform.gameEngine.getModeIndex(platform.currentMode), topic57Start + 1);

  localStorageMock.clear();
  persistProgress(unit5Manifest, { activeModeNumber: 5 });
  persistProgress(lsrlManifest, { activeModeNumber: 2 });
  engine = createEngine();
  engine.loadCartridge(unit5Manifest);
  assert.equal(engine.currentTier, getModeId(unit5Manifest, 5));
  assert.equal(engine.isModeUnlocked(getModeId(unit5Manifest, 5)), true);
  assert.equal(engine.getModeGoldStars(getModeId(unit5Manifest, 4)), 1);
  engine.loadCartridge(lsrlManifest);
  assert.equal(engine.currentTier, getModeId(lsrlManifest, 2));
  assert.equal(engine.isModeUnlocked(getModeId(lsrlManifest, 2)), true);
  assert.equal(engine.getModeGoldStars(getModeId(lsrlManifest, 1)), 1);
  engine.loadCartridge(unit5Manifest);
  assert.equal(engine.currentTier, getModeId(unit5Manifest, 5));
  assert.equal(engine.isModeUnlocked(getModeId(unit5Manifest, 5)), true);
  assert.equal(engine.getModeGoldStars(getModeId(unit5Manifest, 4)), 1);

  console.log('manual progression regression checks passed');
}

run().catch((error) => {
  console.error(error);
  process.exit(1);
});
