+class TestFeeEdgeCases:
+    """Small and unusual values should not produce impossible fee results."""
+
+    def test_zero_volume_order_has_zero_fee(self, make_engine_config):
+        cfg = make_engine_config(order_size_usd=2.0)
+        state = PairState(
+            market_price=0.09,
+            now=1_700_000_000.0,
+            orders=(
+                OrderState(
+                    local_id=7,
+                    side="sell",
+                    role="exit",
+                    price=0.091,
+                    volume=0.0,
+                    trade_id="B",
+                    cycle=1,
+                    entry_price=0.09,
+                    entry_fee=0.0,
+                    entry_filled_at=1_700_000_000.0,
+                ),
+            ),
+        )
+        next_state, actions = transition(
+            state,
+            FillEvent(
+                order_local_id=7,
+                txid="ZERO-VOL",
+                side="sell",
+                price=0.091,
+                volume=0.0,
+                fee=0.0,
+                timestamp=state.now + 1.0,
+            ),
+            cfg,
+            cfg.order_size_usd,
+        )
+        book = next(action for action in actions if isinstance(action, BookCycleAction))
+
+        assert book.fees == pytest.approx(0.0)
+        assert next_state.completed_cycles[-1].fees == pytest.approx(0.0)
+
+    def test_very_small_order_fee_not_negative(self, make_engine_config):
+        cfg = make_engine_config(maker_fee_pct=0.16, min_volume=0.0, volume_decimals=6)
+        state = PairState(
+            market_price=0.091237,
+            now=1_700_000_000.0,
+            orders=(
+                OrderState(
+                    local_id=8,
+                    side="sell",
+                    role="exit",
+                    price=0.09125,
+                    volume=0.000123,
+                    trade_id="B",
+                    cycle=1,
+                    entry_price=0.0912,
+                    entry_fee=0.0,
+                    entry_filled_at=1_700_000_000.0,
+                ),
+            ),
+        )
+        tiny_fee = _fee_from_pct(0.09125, 0.000123, cfg.maker_fee_pct)
+        _, actions = transition(
+            state,
+            FillEvent(
+                order_local_id=8,
+                txid="TINY-FEE",
+                side="sell",
+                price=0.09125,
+                volume=0.000123,
+                fee=tiny_fee,
+                timestamp=state.now + 1.0,
+            ),
+            cfg,
+            cfg.order_size_usd,
+        )
+        book = next(action for action in actions if isinstance(action, BookCycleAction))
+
+        assert tiny_fee >= 0.0
+        assert book.fees >= 0.0
+        assert book.net_profit <= book.gross_profit
+
+    def test_fee_with_different_price_decimals(self, make_engine_config):
+        cfg = make_engine_config(
+            maker_fee_pct=0.16,
+            profit_pct=1.7,
+            price_decimals=5,
+            volume_decimals=3,
+            min_volume=0.001,
+            order_size_usd=3.5,
+        )
+        result = _complete_trade_cycle(cfg, trade_id="B")
+        expected_entry_fee = _fee_from_pct(
+            result["entry_order"].price,
+            result["entry_order"].volume,
+            cfg.maker_fee_pct,
+        )
+        expected_exit_fee = _fee_from_pct(
+            result["exit_order"].price,
+            result["exit_order"].volume,
+            cfg.maker_fee_pct,
+        )
+
