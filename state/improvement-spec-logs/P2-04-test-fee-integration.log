def _is_price_stale(state: PairState, cfg: EngineConfig) -> bool:
    """True when market price age exceeds configured freshness threshold."""
    max_age = float(cfg.stale_price_max_age_sec)
    if max_age <= 0:
        return False
    last = state.last_price_update_at
    if last is None or last <= 0:
        # Treat unknown timestamp as usable to avoid blocking fresh boot paths.
        return False
    return (float(state.now) - float(last)) > max_age


def _entry_prices(market_price: float, entry_pct: float, cfg: EngineConfig) -> tuple[float, float]:
    p = entry_pct / 100.0
    buy = _round_price(market_price * (1 - p), cfg)
    sell = _round_price(market_price * (1 + p), cfg)
    return buy, sell
