+            ),
+            cfg,
+            cfg.order_size_usd,
+        )
+        book = next(action for action in actions if isinstance(action, BookCycleAction))
+
+        assert tiny_fee >= 0.0
+        assert book.fees >= 0.0
+        assert book.net_profit <= book.gross_profit
+
