+from dataclasses import replace
+from pathlib import Path
+
+import pytest
+
+import config
+from bot_types import (
+    BookCycleAction,
+    FillEvent,
+    GovernorActions,
+    OrderState,
+    PairState,
+    PlaceOrderAction,
+    RecoveryOrder,
+    WorkBank,
+    bootstrap_orders,
+    transition,
+)
+from ledger import Ledger
+from main import poll_fills, reconcile_recovery_orders
+from server import CommentatorEngine, build_status_payload
+from slot_engine import SlotEngine
+
+
+def _run(coro):
+    loop = asyncio.new_event_loop()
+    try:
+        return loop.run_until_complete(coro)
+    finally:
+        loop.close()
+
+
+def _fee_from_pct(price: float, volume: float, maker_fee_pct: float) -> float:
+    return float(price) * float(volume) * float(maker_fee_pct) / 100.0
+
+
+def _read_jsonl(path: Path) -> list[dict]:
+    if not path.exists():
+        return []
+    return [
+        json.loads(line)
+        for line in path.read_text(encoding="utf-8").splitlines()
+        if line.strip()
+    ]
+
+
+def _bootstrap_state(cfg, *, market_price: float = 0.09, now: float = 1_700_000_000.0) -> PairState:
+    state = PairState(market_price=market_price, now=now)
+    state, _, orders = bootstrap_orders(state, cfg, cfg.order_size_usd)
+    return replace(state, orders=orders)
+
+
+def _fill_tracked_order(
+    state: PairState,
+    *,
+    order: OrderState,
+    cfg,
+    fee: float,
+    timestamp: float,
+    price: float | None = None,
+    volume: float | None = None,
+):
+    return transition(
+        state,
+        FillEvent(
+            order_local_id=int(order.local_id),
+            txid=str(order.txid or f"FILL-{order.local_id}"),
+            side=str(order.side),
+            price=float(order.price if price is None else price),
+            volume=float(order.volume if volume is None else volume),
+            fee=float(fee),
+            timestamp=float(timestamp),
+        ),
+        cfg,
+        cfg.order_size_usd,
+    )
+
+
+def _prepare_trade_cycle(cfg, *, trade_id: str = "B") -> tuple[PairState, OrderState, OrderState, float]:
+    state = _bootstrap_state(cfg)
+    entry_order = next(
+        order
+        for order in state.orders
+        if order.role == "entry" and order.trade_id == trade_id
+    )
+    entry_fee = _fee_from_pct(entry_order.price, entry_order.volume, cfg.maker_fee_pct)
+    state, _ = _fill_tracked_order(
+        state,
+        order=entry_order,
+        cfg=cfg,
+        fee=entry_fee,
+        timestamp=state.now + 1.0,
+    )
+    exit_order = next(
+        order
+        for order in state.orders
+        if order.role == "exit" and order.trade_id == trade_id
+    )
+    return state, entry_order, exit_order, entry_fee
+
+
+def _complete_trade_cycle(cfg, *, trade_id: str = "B", exit_price: float | None = None):
+    state, entry_order, exit_order, entry_fee = _prepare_trade_cycle(cfg, trade_id=trade_id)
+    actual_exit_price = float(exit_order.price if exit_price is None else exit_price)
+    exit_fee = _fee_from_pct(actual_exit_price, exit_order.volume, cfg.maker_fee_pct)
+    next_state, actions = _fill_tracked_order(
+        state,
+        order=exit_order,
+        cfg=cfg,
+        fee=exit_fee,
+        timestamp=state.now + 1.0,
+        price=actual_exit_price,
+    )
+    book_action = next(action for action in actions if isinstance(action, BookCycleAction))
+    return {
+        "state": next_state,
+        "entry_order": entry_order,
+        "exit_order": exit_order,
+        "entry_fee": entry_fee,
+        "exit_fee": exit_fee,
+        "book_action": book_action,
+    }
+
+
+def _first_slot(engine: SlotEngine):
+    return next(iter(engine.all_slots().values()))
+
+
+def _find_order(slot, *, role: str, trade_id: str | None = None, side: str | None = None):
+    for order in slot.state.orders:
+        if order.role != role:
+            continue
+        if trade_id is not None and order.trade_id != trade_id:
+            continue
+        if side is not None and order.side != side:
+            continue
+        return order
+    raise AssertionError(
+        f"Missing order role={role!r} trade_id={trade_id!r} side={side!r}",
+    )
+
+
+def _place_live_orders(slot_engine: SlotEngine, adapter) -> None:
+    gov = GovernorActions()
+    for slot in slot_engine.all_slots().values():
+        actions = [
+            PlaceOrderAction(
+                local_id=order.local_id,
+                side=order.side,
+                role=order.role,
+                price=order.price,
+                volume=order.volume,
+                trade_id=order.trade_id,
+                cycle=order.cycle,
+                post_only=True,
+                reason="fee_test_bind",
+            )
+            for order in slot.state.orders
+            if not order.txid
+        ]
+        if not actions:
+            continue
+        _run(slot_engine.execute_actions(slot, actions, adapter, governor_actions=gov))
+
+
+def _build_live_env(root: Path, adapter, *, profit_pct_runtime: float | None = None):
+    root.mkdir(parents=True, exist_ok=True)
+    ledger = Ledger(ledger_file=str(root / "ledger.jsonl"))
+    engine = SlotEngine(initial_slots=1, initial_sticky_ratio=1.0)
+    engine.initialize(market_price=0.09, order_size_usd=2.0)
+    slot = _first_slot(engine)
+    if profit_pct_runtime is not None:
+        slot.state = replace(slot.state, profit_pct_runtime=float(profit_pct_runtime))
+    _place_live_orders(engine, adapter)
+    return {
+        "root": root,
+        "engine": engine,
+        "ledger": ledger,
+        "slot": slot,
+    }
+
+
+def _open_trade_b_exit(root: Path, adapter, *, entry_fee: float, profit_pct_runtime: float | None = None):
+    env = _build_live_env(root, adapter, profit_pct_runtime=profit_pct_runtime)
+    entry = _find_order(env["slot"], role="entry", trade_id="B", side="buy")
+    adapter.simulate_fill(
+        entry.txid,
+        price=entry.price,
+        volume=entry.volume,
+        fee=entry_fee,
+    )
+    had_fill = _run(
+        poll_fills(
+            adapter=adapter,
+            slot_engine=env["engine"],
+            ledger=env["ledger"],
+            commentator=CommentatorEngine(),
+            governor_actions=GovernorActions(),
+        ),
+    )
+    assert had_fill is True
+    env["entry"] = entry
+    env["exit"] = _find_order(env["slot"], role="exit", trade_id="B", side="sell")
+    return env
+
+
+def _save_and_restore(root: Path, engine: SlotEngine, ledger: Ledger):
+    root.mkdir(parents=True, exist_ok=True)
+    state_path = root / "state.json"
+    engine.save_to_file(str(state_path))
+    ledger.save()
+
+    restored_engine = SlotEngine(initial_slots=0)
+    assert restored_engine.load_from_file(str(state_path)) is True
+    restored_ledger = Ledger(ledger_file=str(root / "ledger.jsonl"))
+    restored_ledger.load()
+    for slot in restored_engine.all_slots().values():
+        slot.account = restored_ledger.get_slot_account(slot.slot_id)
+    return restored_engine, restored_ledger
+
+
+def _complete_live_exit(env: dict, adapter, *, exit_fee: float, exit_price: float | None = None):
+    slot = env["slot"]
+    exit_order = env["exit"]
+    fill_price = float(exit_order.price if exit_price is None else exit_price)
+    adapter.simulate_fill(
+        exit_order.txid,
+        price=fill_price,
+        volume=exit_order.volume,
+        fee=exit_fee,
+    )
+    had_fill = _run(
+        poll_fills(
+            adapter=adapter,
+            slot_engine=env["engine"],
+            ledger=env["ledger"],
+            commentator=CommentatorEngine(),
+            governor_actions=GovernorActions(),
+        ),
+    )
+    assert had_fill is True
+    slot.account = env["ledger"].get_slot_account(slot.slot_id)
+    return slot.state.completed_cycles[-1]
+
+
+def _build_recovery_env(root: Path, *, recovery: RecoveryOrder):
+    root.mkdir(parents=True, exist_ok=True)
+    ledger = Ledger(ledger_file=str(root / "ledger.jsonl"))
+    engine = SlotEngine(initial_slots=0)
+    slot = engine.add_slot(sticky=False)
+    assert slot is not None
+    slot.state = replace(
+        slot.state,
+        market_price=0.091,
+        orders=(),
+        recovery_orders=(recovery,),
+        next_recovery_id=recovery.recovery_id + 1,
+    )
+    return {
+        "root": root,
+        "engine": engine,
+        "ledger": ledger,
+        "slot": slot,
+        "recovery": recovery,
+    }
+
+
+def _build_status(env: dict) -> dict:
+    slot = env["slot"]
+    ledger = env["ledger"]
+    slot.account = ledger.get_slot_account(slot.slot_id)
+    return build_status_payload(
+        slots={slot.slot_id: slot},
+        governor_actions=GovernorActions(),
+        scanner_state={},
+        capacity=WorkBank(
+            effective_cap=16,
+            open_orders=len(slot.state.orders) + len(slot.state.recovery_orders),
+            headroom=16 - len(slot.state.orders) - len(slot.state.recovery_orders),
+            max_new_sticky=8,
+            max_new_cycle=4,
+        ),
+        ledger_payload=ledger.status_payload(),
+        commentator_messages=[],
+        price=slot.state.market_price,
+        start_time=max(0.0, slot.created_at),
+    )
+
+
+class TestFeeCalculation:
+    """Fee math invariants at the state-machine boundary."""
+
+    def test_cycle_fee_is_sum_of_entry_and_exit_maker_fees(self, make_engine_config):
+        cfg = make_engine_config(maker_fee_pct=0.16, profit_pct=1.7)
+        result = _complete_trade_cycle(cfg, trade_id="B")
+        expected = result["entry_fee"] + result["exit_fee"]
+
+        assert result["book_action"].fees == pytest.approx(expected)
+        assert result["state"].completed_cycles[-1].fees == pytest.approx(expected)
+
+    def test_net_profit_equals_gross_minus_fee(self, make_engine_config):
+        cfg = make_engine_config(maker_fee_pct=0.16, profit_pct=1.7)
+        result = _complete_trade_cycle(cfg, trade_id="A")
+        book = result["book_action"]
+
+        assert book.net_profit == pytest.approx(book.gross_profit - book.fees)
+        assert result["state"].completed_cycles[-1].net_profit == pytest.approx(
+            book.gross_profit - book.fees,
+        )
+
+    def test_negative_gross_still_deducts_fee(self, make_engine_config):
+        cfg = make_engine_config(maker_fee_pct=0.16, profit_pct=1.7)
+        prepared = _prepare_trade_cycle(cfg, trade_id="B")
+        state, entry_order, exit_order, _ = prepared
+        losing_exit_price = entry_order.price * 0.99
+        exit_fee = _fee_from_pct(losing_exit_price, exit_order.volume, cfg.maker_fee_pct)
+        next_state, actions = _fill_tracked_order(
+            state,
+            order=exit_order,
+            cfg=cfg,
+            fee=exit_fee,
+            timestamp=state.now + 1.0,
+            price=losing_exit_price,
+        )
+        book = next(action for action in actions if isinstance(action, BookCycleAction))
+
+        assert book.gross_profit < 0.0
+        assert book.fees > 0.0
+        assert book.net_profit < book.gross_profit
+        assert next_state.completed_cycles[-1].net_profit == pytest.approx(book.net_profit)
+
+
+class TestFeeConsistencyAcrossPaths:
+    """Regression tests for live, restart, and startup-only paths."""
+
+    def test_normal_poll_and_startup_restore_produce_same_fee_and_net(self, tmp_path, mock_adapter):
+        normal_adapter = type(mock_adapter)()
+        startup_adapter = type(mock_adapter)()
+
+        normal_env = _open_trade_b_exit(
+            tmp_path / "normal",
+            normal_adapter,
+            entry_fee=0.01,
+            profit_pct_runtime=1.7,
+        )
+        startup_live_env = _open_trade_b_exit(
+            tmp_path / "startup",
+            startup_adapter,
+            entry_fee=0.01,
+            profit_pct_runtime=1.7,
+        )
+        restored_engine, restored_ledger = _save_and_restore(
+            startup_live_env["root"],
+            startup_live_env["engine"],
+            startup_live_env["ledger"],
+        )
+        restored_slot = _first_slot(restored_engine)
+        restored_exit = _find_order(restored_slot, role="exit", trade_id="B", side="sell")
+        startup_env = {
+            "root": startup_live_env["root"],
+            "engine": restored_engine,
+            "ledger": restored_ledger,
+            "slot": restored_slot,
+            "exit": restored_exit,
+        }
+
+        normal_cycle = _complete_live_exit(normal_env, normal_adapter, exit_fee=0.02)
+        startup_cycle = _complete_live_exit(startup_env, startup_adapter, exit_fee=0.02)
+
+        assert restored_slot.state.profit_pct_runtime == pytest.approx(1.7)
+        assert restored_exit.price == pytest.approx(normal_env["exit"].price)
+        assert startup_cycle.fees == pytest.approx(normal_cycle.fees)
+        assert startup_cycle.net_profit == pytest.approx(normal_cycle.net_profit)
+
+    def test_recovery_fill_fee_matches_normal_fill_fee(self, tmp_path, mock_adapter):
+        recovery = RecoveryOrder(
+            recovery_id=17,
+            side="sell",
+            price=0.092,
+            volume=100.0,
+            trade_id="B",
+            cycle=3,
+            entry_price=0.09,
+            orphaned_at=time.time() - 300.0,
+            entry_fee=0.01,
+            entry_filled_at=time.time() - 600.0,
+            txid="REC-FEE-CONSISTENCY",
+        )
+        normal_adapter = type(mock_adapter)()
+        startup_adapter = type(mock_adapter)()
+
+        normal_env = _build_recovery_env(tmp_path / "normal-recovery", recovery=recovery)
+        startup_live_env = _build_recovery_env(tmp_path / "startup-recovery", recovery=recovery)
+        restored_engine, restored_ledger = _save_and_restore(
+            startup_live_env["root"],
+            startup_live_env["engine"],
+            startup_live_env["ledger"],
+        )
+        restored_slot = _first_slot(restored_engine)
+        startup_env = {
+            "root": startup_live_env["root"],
+            "engine": restored_engine,
+            "ledger": restored_ledger,
+            "slot": restored_slot,
+            "recovery": recovery,
+        }
+
+        status = {
+            "status": "closed",
+            "vol_exec": str(recovery.volume),
+            "price": str(recovery.price),
+            "fee": "0.02",
+        }
+        normal_adapter._closed_orders[recovery.txid] = dict(status)
+        startup_adapter._closed_orders[recovery.txid] = dict(status)
+
+        assert _run(
+            poll_fills(
+                adapter=normal_adapter,
+                slot_engine=normal_env["engine"],
+                ledger=normal_env["ledger"],
+                commentator=CommentatorEngine(),
+                governor_actions=GovernorActions(),
+            ),
+        ) is True
+        _run(
+            reconcile_recovery_orders(
+                adapter=startup_adapter,
+                slot_engine=startup_env["engine"],
+                ledger=startup_env["ledger"],
+                commentator=CommentatorEngine(),
+                governor_actions=GovernorActions(),
+            ),
+        )
+
+        normal_cycle = normal_env["slot"].state.completed_cycles[-1]
+        startup_cycle = startup_env["slot"].state.completed_cycles[-1]
+
+        assert normal_cycle.from_recovery is True
+        assert startup_cycle.from_recovery is True
+        assert startup_cycle.fees == pytest.approx(normal_cycle.fees)
+        assert startup_cycle.net_profit == pytest.approx(normal_cycle.net_profit)
+
+
+class TestFeeEndToEnd:
+    """Trace fee-related values through config, ledger persistence, and status payloads."""
+
+    def test_config_fee_propagates_to_cycle_action(self, monkeypatch):
+        monkeypatch.setattr(config, "MAKER_FEE_PCT", 0.16)
+        monkeypatch.setattr(config, "PAIR_PROFIT_PCT", 1.7)
+
+        engine = SlotEngine(initial_slots=0)
+        slot = engine.add_slot(sticky=True)
+        assert slot is not None
+        cfg = engine._build_default_config(slot)
+        result = _complete_trade_cycle(cfg, trade_id="B")
+        expected = _fee_from_pct(
+            result["entry_order"].price,
+            result["entry_order"].volume,
+            config.MAKER_FEE_PCT,
+        ) + _fee_from_pct(
+            result["exit_order"].price,
+            result["exit_order"].volume,
+            config.MAKER_FEE_PCT,
+        )
+
+        assert cfg.maker_fee_pct == pytest.approx(0.16)
+        assert result["book_action"].fees == pytest.approx(expected)
+
+    def test_cycle_fee_recorded_in_ledger(self, tmp_path, mock_adapter):
+        adapter = type(mock_adapter)()
+        env = _open_trade_b_exit(tmp_path / "ledger-record", adapter, entry_fee=0.01, profit_pct_runtime=1.7)
+        cycle = _complete_live_exit(env, adapter, exit_fee=0.02)
+
+        env["ledger"].save()
+        rows = _read_jsonl(env["root"] / "ledger.jsonl")
+
+        buy_entry = next(row for row in rows if row["entry_type"] == "BUY_ENTRY")
+        sell_exit = next(row for row in rows if row["entry_type"] == "SELL_EXIT")
+        cycle_profit = next(row for row in rows if row["entry_type"] == "CYCLE_PROFIT")
+
+        assert buy_entry["fee_usd"] == pytest.approx(0.01)
+        assert sell_exit["fee_usd"] == pytest.approx(0.02 * cycle.exit_price)
+        assert cycle_profit["credit_usd"] - cycle_profit["debit_usd"] == pytest.approx(
+            cycle.net_profit,
+        )
+
+    def test_ledger_totals_match_sum_of_persisted_fee_entries(self, tmp_path, mock_adapter):
+        adapter = type(mock_adapter)()
+        env = _open_trade_b_exit(tmp_path / "ledger-totals", adapter, entry_fee=0.01, profit_pct_runtime=1.7)
+        _complete_live_exit(env, adapter, exit_fee=0.02)
+
+        env["ledger"].save()
+        rows = _read_jsonl(env["root"] / "ledger.jsonl")
+        persisted_fee_total = sum(float(row["fee_usd"]) for row in rows)
+        ledger_payload = env["ledger"].status_payload()
+
+        assert ledger_payload["total_fees"] == pytest.approx(persisted_fee_total)
+        assert env["ledger"].get_slot_account(env["slot"].slot_id).total_fees_usd == pytest.approx(
+            persisted_fee_total,
+        )
+
+    def test_dashboard_payload_reflects_ledger_totals(self, tmp_path, mock_adapter):
+        adapter = type(mock_adapter)()
+        env = _open_trade_b_exit(tmp_path / "dashboard", adapter, entry_fee=0.01, profit_pct_runtime=1.7)
+        _complete_live_exit(env, adapter, exit_fee=0.02)
+
+        payload = _build_status(env)
+        ledger_payload = env["ledger"].status_payload()
+
+        assert payload["total_profit"] == pytest.approx(ledger_payload["total_profit"])
+        assert payload["total_fees"] == pytest.approx(ledger_payload["total_fees"])
+        assert payload["ledger"]["total_profit"] == pytest.approx(ledger_payload["total_profit"])
+        assert payload["ledger"]["total_fees"] == pytest.approx(ledger_payload["total_fees"])
+
