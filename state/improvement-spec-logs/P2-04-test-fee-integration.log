+        startup_adapter = type(mock_adapter)()
+
+        normal_env = _build_recovery_env(tmp_path / "normal-recovery", recovery=recovery)
+        startup_live_env = _build_recovery_env(tmp_path / "startup-recovery", recovery=recovery)
+        restored_engine, restored_ledger = _save_and_restore(
