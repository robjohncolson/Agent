  if (opts.dryRun) {
    return stepResult(label, "planned", {
      reason: "Blooket CSV missing; would generate from rubric",
      outputs: [blooketPath],
    });
  }

  let patternCsv;
  try {
    patternCsv = pickPatternArtifact(
      WORKING_DIRS.worksheet,
