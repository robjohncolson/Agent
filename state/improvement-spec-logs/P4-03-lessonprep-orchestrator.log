+#!/usr/bin/env node
+/**
+ * Dependency-aware lesson prep orchestrator.
+ *
+ * Pipeline:
+ * 1. Calendar check
+ * 2. Transcript (Whisper primary, AI Studio fallback)
+ * 3. Rubric generation
+ * 4a. Worksheet generation
+ * 4b. Blooket generation
+ * 5. Animation render/upload (non-blocking)
+ * 6. Report and optional commit/push
+ */
+
+import { spawn, spawnSync } from "node:child_process";
+import {
+  existsSync,
+  readFileSync,
+  readdirSync,
+  statSync,
+  unlinkSync,
+  writeFileSync,
+} from "node:fs";
+import { createRequire } from "node:module";
+import path from "node:path";
+import { createInterface } from "node:readline";
+import { readVideoContext } from "./lib/build-codex-prompts.mjs";
+import {
+  SCRIPTS,
+  WORKING_DIRS,
+  DRIVE_VIDEO_INDEX_PATH,
+  CALENDAR_DIR,
+  WORKSHEET_REPO,
+  DOWNSTREAM_REPOS,
+  CURRICULUM_REPO,
+} from "./lib/paths.mjs";
+
+const require = createRequire(import.meta.url);
+const CALENDAR_BASE_URL = "https://robjohncolson.github.io/apstats-live-worksheet";
+const WHISPER_SCRIPT = path.join(WORKSHEET_REPO, "video-ingest-whisper.mjs");
+const FRAMEWORKS_JS_PATH = path.join(CURRICULUM_REPO, "data", "frameworks.js");
+
+function usage() {
+  return (
+    "Usage: node scripts/lesson-prep.mjs <unit> <lesson> [options]\n" +
+    "       node scripts/lesson-prep.mjs --unit <U> --lesson <L> [options]\n" +
+    "       node scripts/lesson-prep.mjs --auto [options]\n\n" +
+    "Options:\n" +
+    "  -u, --unit <n>           Unit number\n" +
+    "  -l, --lesson <n>         Lesson number\n" +
+    "  --auto                   Detect unit/lesson from whats-tomorrow.mjs\n" +
+    "  --date YYYY-MM-DD        Date for calendar lookup\n" +
+    "  --drive-ids <ID...>      Google Drive IDs for AI Studio fallback\n" +
+    "  --files <path...>        Local video files for Whisper or AI Studio\n" +
+    "  --videos <path...>       Alias for --files\n" +
+    "  --dry-run                Check dependencies only\n" +
+    "  --skip-ingest            Do not generate missing transcripts\n" +
+    "  --skip-blooket           Skip Blooket generation\n" +
+    "  --skip-render            Skip animation rendering\n" +
+    "  --skip-upload            Skip animation upload\n" +
+    "  --auto-push              Commit and push without prompting\n"
+  );
+}
+
+function parseArgs(argv) {
+  const args = argv.slice(2);
+  const positional = [];
+  const driveIds = [];
+  const files = [];
+
+  let unit = null;
+  let lesson = null;
+  let auto = false;
+  let autoPush = false;
+  let targetDate = null;
+  let dryRun = false;
+  let skipIngest = false;
+  let skipBlooket = false;
+  let skipRender = false;
+  let skipUpload = false;
+
+  for (let i = 0; i < args.length; i++) {
+    const arg = args[i];
+    if (arg === "--auto") {
+      auto = true;
+    } else if (arg === "--auto-push") {
+      autoPush = true;
+    } else if (arg === "--date") {
+      targetDate = args[++i];
+    } else if (arg === "--dry-run") {
+      dryRun = true;
+    } else if (arg === "--skip-ingest" || arg === "--skip-transcript") {
+      skipIngest = true;
+    } else if (arg === "--skip-blooket") {
+      skipBlooket = true;
+    } else if (arg === "--skip-render") {
+      skipRender = true;
+    } else if (arg === "--skip-upload") {
+      skipUpload = true;
+    } else if ((arg === "--unit" || arg === "-u") && args[i + 1]) {
+      unit = Number(args[++i]);
+    } else if ((arg === "--lesson" || arg === "-l") && args[i + 1]) {
+      lesson = Number(args[++i]);
+    } else if (arg === "--drive-ids") {
+      i++;
+      while (i < args.length && !args[i].startsWith("-")) {
+        driveIds.push(args[i]);
+        i++;
+      }
+      i--;
+    } else if (arg === "--files" || arg === "--videos") {
+      i++;
+      while (i < args.length && !args[i].startsWith("-")) {
+        files.push(args[i]);
+        i++;
+      }
+      i--;
+    } else if (arg === "--help" || arg === "-h") {
+      console.log(usage());
+      process.exit(0);
+    } else if (arg.startsWith("-")) {
+      throw new Error(`Unknown option: ${arg}`);
+    } else {
+      positional.push(arg);
+    }
+  }
+
+  if (!unit && !lesson && positional.length >= 2) {
+    unit = Number(positional[0]);
+    lesson = Number(positional[1]);
+    files.push(...positional.slice(2));
+  } else if (positional.length > 0) {
+    files.push(...positional);
+  }
+
+  if (!auto && (!Number.isInteger(unit) || !Number.isInteger(lesson))) {
+    throw new Error(usage());
+  }
+
+  return {
+    unit,
+    lesson,
+    auto,
+    autoPush,
+    targetDate,
+    driveIds,
+    files,
+    dryRun,
+    skipIngest,
+    skipBlooket,
+    skipRender,
+    skipUpload,
+  };
+}
+
+function ask(question) {
+  const rl = createInterface({ input: process.stdin, output: process.stdout });
+  return new Promise((resolve) => {
+    rl.question(question, (answer) => {
+      rl.close();
+      resolve(answer.trim());
+    });
+  });
+}
+
+function stepResult(step, status, extra = {}) {
+  return {
+    step,
+    status,
+    outputs: [],
+    ...extra,
+  };
+}
+
+function commandFailureMessage(result, fallback = "command failed") {
+  const stderr = String(result?.stderr || "").trim();
+  const stdout = String(result?.stdout || "").trim();
+  return stderr || stdout || fallback;
+}
+
+function findCalendarUrl(targetDate, monthAbbr, dayNum) {
+  if (monthAbbr && dayNum) {
+    let d;
+    if (targetDate) {
+      const [y, m, day] = targetDate.split("-").map(Number);
+      d = new Date(y, m - 1, day);
+    } else {
+      d = new Date();
+      d.setDate(d.getDate() + 1);
+    }
+
+    const dow = d.getDay();
+    const monday = new Date(d);
+    monday.setDate(d.getDate() - (dow === 0 ? 6 : dow - 1));
+    const months = ["jan", "feb", "mar", "apr", "may", "jun", "jul", "aug", "sep", "oct", "nov", "dec"];
+    const filename = `week_${months[monday.getMonth()]}${monday.getDate()}_calendar.html`;
+    if (existsSync(path.join(CALENDAR_DIR, filename))) {
+      return `${CALENDAR_BASE_URL}/${filename}`;
+    }
+  }
+
+  try {
+    const candidates = readdirSync(CALENDAR_DIR)
+      .filter((name) => /^week.*calendar.*\.html$/i.test(name))
+      .sort()
+      .reverse();
+    if (candidates.length > 0) {
+      return `${CALENDAR_BASE_URL}/${candidates[0]}`;
+    }
+  } catch {
+    // Best effort.
+  }
+
+  return null;
+}
+
+function parseCalendarOutput(output, targetDate) {
+  const topicMatch = output.match(/Topic:\s+(\d+)\.(\d+)/);
+  if (!topicMatch) return null;
+
+  const headerMatch = output.match(/^(\w+),\s+(\w+)\s+(\d+)/m);
+  const topicDescMatch = output.match(/Topic:\s+[\d.]+\s+[—–-]\s+(.*)/);
+  const dueMatch = output.match(/Due:\s+(.*)/);
+  const assignMatch = output.match(/Assign:\s+(.*)/);
+
+  const unit = Number(topicMatch[1]);
+  const lesson = Number(topicMatch[2]);
+  const dayName = headerMatch?.[1] || null;
+  const monthAbbr = headerMatch?.[2] || null;
+  const dayNum = headerMatch ? Number(headerMatch[3]) : null;
+
+  const folderParts = [`${unit}.${lesson}${topicDescMatch?.[1] ? ` ${topicDescMatch[1]}` : ""}`];
+  if (dueMatch?.[1]) folderParts.push(`Due: ${dueMatch[1]}`);
+  if (assignMatch?.[1]) folderParts.push(`Assign: ${assignMatch[1]}`);
+
+  let folderTitle = null;
+  if (dayName && monthAbbr && dayNum) {
+    const monthMap = { Jan: 1, Feb: 2, Mar: 3, Apr: 4, May: 5, Jun: 6, Jul: 7, Aug: 8, Sep: 9, Oct: 10, Nov: 11, Dec: 12 };
+    const year = targetDate
+      ? Number(targetDate.split("-")[0]) % 100
+      : (() => {
+          const tomorrow = new Date();
+          tomorrow.setDate(tomorrow.getDate() + 1);
+          return tomorrow.getFullYear() % 100;
+        })();
+    folderTitle = `${dayName} ${monthMap[monthAbbr] || 0}/${dayNum}/${year}`;
+  }
+
+  return {
+    unit,
+    lesson,
+    topic: topicDescMatch?.[1] || `Topic ${unit}.${lesson}`,
+    date: headerMatch ? `${headerMatch[1]}, ${headerMatch[2]} ${headerMatch[3]}` : null,
+    folderTitle,
+    folderDesc: folderParts.join("\n"),
+    calendarUrl: findCalendarUrl(targetDate, monthAbbr, dayNum),
+  };
+}
+
+function step1Calendar(unit, lesson, opts) {
+  if (!existsSync(SCRIPTS.whatsTomorrow)) {
+    return stepResult("Calendar", "skipped", { reason: "whats-tomorrow.mjs not found" });
+  }
+
+  const args = [];
+  if (opts.targetDate) {
+    args.push("--date", opts.targetDate);
+  }
+
+  const result = spawnSync("node", [SCRIPTS.whatsTomorrow, ...args], {
+    encoding: "utf8",
+    cwd: WORKING_DIRS.worksheet,
+  });
+
+  if (result.status !== 0) {
+    return stepResult("Calendar", "failed", {
+      reason: commandFailureMessage(result, "calendar lookup failed"),
+    });
+  }
+
+  const parsed = parseCalendarOutput(result.stdout, opts.targetDate);
+  if (!parsed) {
+    return stepResult("Calendar", "failed", {
+      reason: "Could not parse calendar output",
+    });
+  }
+
+  const mismatch =
+    Number.isInteger(unit) &&
+    Number.isInteger(lesson) &&
+    (unit !== parsed.unit || lesson !== parsed.lesson);
+
+  return stepResult("Calendar", "created", {
+    output: result.stdout,
+    unit: parsed.unit,
+    lesson: parsed.lesson,
+    topic: parsed.topic,
+    date: parsed.date,
+    calendarContext: parsed,
+    reason: mismatch ? `Calendar says ${parsed.unit}.${parsed.lesson} but request was ${unit}.${lesson}` : null,
+  });
+}
+
+async function lookupDriveIds(unit, lesson) {
+  const topic = `${unit}.${lesson}`;
+  if (existsSync(DRIVE_VIDEO_INDEX_PATH)) {
+    try {
+      const index = JSON.parse(readFileSync(DRIVE_VIDEO_INDEX_PATH, "utf-8"));
+      const matches = (index.videos || [])
+        .filter((entry) => entry.topic === topic)
+        .sort((a, b) => (a.video_number || 0) - (b.video_number || 0));
+      if (matches.length > 0) {
+        return {
+          ids: matches.map((entry) => entry.file_id),
+          source: "index",
+        };
+      }
+    } catch {
+      // Fall through to prompt.
+    }
+  }
+
+  const answer = await ask(`Enter Drive IDs for Topic ${topic}, separated by spaces (or press Enter to skip): `);
+  const ids = answer.split(/\s+/).filter(Boolean);
+  return {
+    ids,
+    source: ids.length > 0 ? "manual" : "none",
+  };
+}
+
+function collectTranscriptArtifacts(unit, lesson) {
+  const lessonDir = path.join(WORKSHEET_REPO, `u${unit}`);
+  const result = {
+    lessonDir,
+    transcriptPaths: [],
+    transcriptionPaths: [],
+    slidePaths: [],
+    primaryTranscriptPaths: [],
+  };
+
+  if (!existsSync(lessonDir)) return result;
+
+  const pattern = new RegExp(`^apstat_${unit}-${lesson}(?:-(\\d+))?_(transcript|transcription|slides)\\.txt$`, "i");
+  const grouped = new Map();
+
+  for (const name of readdirSync(lessonDir)) {
+    const match = name.match(pattern);
+    if (!match) continue;
+    const part = Number(match[1] || 1);
+    const kind = match[2].toLowerCase();
+    const fullPath = path.join(lessonDir, name);
+    const entry = grouped.get(part) || { transcript: null, transcription: null, slides: null };
+    entry[kind] = fullPath;
+    grouped.set(part, entry);
+  }
+
+  for (const part of [...grouped.keys()].sort((a, b) => a - b)) {
+    const entry = grouped.get(part);
+    if (entry.transcript) result.transcriptPaths.push(entry.transcript);
+    if (entry.transcription) result.transcriptionPaths.push(entry.transcription);
+    if (entry.slides) result.slidePaths.push(entry.slides);
+    if (entry.transcript || entry.transcription) {
+      result.primaryTranscriptPaths.push(entry.transcript || entry.transcription);
+    }
+  }
+
+  return result;
+}
+
+function hasTranscriptArtifacts(artifacts) {
+  return artifacts.primaryTranscriptPaths.length > 0;
+}
+
+function pickPatternArtifact(dir, exactName, pattern, unit, lesson) {
+  const exactPath = path.join(dir, exactName);
+  if (existsSync(exactPath)) {
+    return {
+      name: exactName,
+      path: exactPath,
+      content: readFileSync(exactPath, "utf-8"),
+      isFallback: false,
+    };
+  }
+
+  const candidates = readdirSync(dir)
+    .map((name) => {
+      const match = name.match(pattern);
+      if (!match) return null;
+      return {
+        name,
+        path: path.join(dir, name),
+        unit: Number(match[1]),
+        lesson: Number(match[2]),
+      };
+    })
+    .filter(Boolean);
+
+  const candidate =
+    candidates.find((entry) => entry.unit === unit && entry.lesson === lesson - 1) ||
+    candidates
+      .filter((entry) => entry.unit === unit && entry.lesson < lesson)
+      .sort((a, b) => b.lesson - a.lesson)[0] ||
+    candidates.sort((a, b) => b.unit - a.unit || b.lesson - a.lesson)[0];
+
+  if (!candidate) {
+    throw new Error(`No pattern artifact found for ${exactName}`);
+  }
+
+  return {
+    ...candidate,
+    content: readFileSync(candidate.path, "utf-8"),
+    isFallback: true,
+  };
+}
+
+function takeCsvRows(csvText, rowCount) {
+  const normalized = csvText.replace(/\r\n/g, "\n");
+  const rows = [];
+  let current = "";
+  let inQuotes = false;
+
+  for (let i = 0; i < normalized.length; i++) {
+    const char = normalized[i];
+    if (char === '"') {
+      current += char;
+      if (inQuotes && normalized[i + 1] === '"') {
+        current += normalized[++i];
+      } else {
+        inQuotes = !inQuotes;
+      }
+      continue;
+    }
+    if (char === "\n" && !inQuotes) {
+      rows.push(current);
+      current = "";
+      if (rows.length === rowCount) break;
+      continue;
+    }
+    current += char;
+  }
+
+  if (rows.length < rowCount && current) {
+    rows.push(current);
+  }
+
+  return rows.join("\n").trim();
+}
+
+function loadLessonFramework(unit, lesson) {
+  if (!existsSync(FRAMEWORKS_JS_PATH)) return null;
+
+  try {
+    const { UNIT_FRAMEWORKS } = require(FRAMEWORKS_JS_PATH);
+    const unitFramework = UNIT_FRAMEWORKS?.[unit];
+    const lessonFramework = unitFramework?.lessons?.[lesson];
+    if (!unitFramework || !lessonFramework) return null;
+    return {
+      unit,
+      lesson,
+      unitTitle: unitFramework.title,
+      examWeight: unitFramework.examWeight,
+      topic: lessonFramework.topic,
+      skills: lessonFramework.skills || [],
+      learningObjectives: lessonFramework.learningObjectives || [],
+      keyConcepts: lessonFramework.keyConcepts || [],
+      commonMisconceptions: lessonFramework.commonMisconceptions || [],
+      keyFormulas: lessonFramework.keyFormulas || [],
+    };
+  } catch (error) {
+    return { error: error.message };
+  }
+}
+
+function buildFileBlock(filePath, contents) {
+  return `<file path="${filePath}">\n${contents}\n</file>`;
+}
+
+function buildTranscriptContext(videoContext, includeSlides = false) {
+  const sections = [`## Lesson Context`, `Topic: ${videoContext.topicTitle}`];
+  for (const video of videoContext.videos) {
+    sections.push(`### Video ${video.index} Transcript\n${video.transcription || "(missing)"}`);
+    if (includeSlides && video.slides) {
+      sections.push(`### Video ${video.index} Slides\n${video.slides}`);
+    }
+  }
+  return sections.join("\n\n");
+}
+
+function buildRubricPrompt(unit, lesson, videoContext, framework, patternFile) {
+  const frameworkBlock = framework
+    ? `## Framework\n\n\`\`\`json\n${JSON.stringify(framework, null, 2)}\n\`\`\``
+    : "## Framework\n\nNo framework data available.";
+
+  return `You are generating the AI grading configuration for an AP Statistics lesson.
+Create ONE file in the current directory:
+- \`ai-grading-prompts-u${unit}-l${lesson}.js\`
+
+## Pattern file
+${buildFileBlock(patternFile.name, patternFile.content)}
+
+${frameworkBlock}
+
+${buildTranscriptContext(videoContext, false)}
+
+## Requirements
+- Follow the exact runtime structure of the pattern file.
+- Define \`window.LESSON_CONTEXT_U${unit}L${lesson}\`.
+- Define \`window.RUBRICS_U${unit}L${lesson}\` with exactly \`reflect1\`, \`reflect2\`, and \`exitTicket\`.
+- Each rubric entry must include \`questionText\`, \`expectedElements\`, \`scoringGuide\`, \`commonMistakes\`, and \`contextFromVideo\`.
+- Use transcript timestamps in \`contextFromVideo\` when possible.
+- Keep browser-side helper functions so the worksheet can call this file at runtime.
+- Write browser JS only.
+
+Write the file directly to disk.`;
+}
+
+function buildWorksheetPrompt(unit, lesson, videoContext, worksheetPattern, rubricContents) {
+  return `You are generating an AP Statistics live worksheet.
+Create ONE file in the current directory:
+- \`u${unit}_lesson${lesson}_live.html\`
+
+## Worksheet pattern
+${buildFileBlock(worksheetPattern.name, worksheetPattern.content)}
+
+## Current rubric file
+${buildFileBlock(`ai-grading-prompts-u${unit}-l${lesson}.js`, rubricContents)}
+
+${buildTranscriptContext(videoContext, true)}
+
+## Requirements
+- Keep the CSS, JS infrastructure, buttons, and runtime wiring from the pattern file.
+- Update the title and identifiers for Topic ${unit}.${lesson}: ${videoContext.topicTitle}.
+- Reference \`ai-grading-prompts-u${unit}-l${lesson}.js\`.
+- Build one section per video and follow the transcript chronologically.
+- Include 15-25 fill-in-the-blank prompts total.
+- Reuse the rubric prompts for reflections and the exit ticket.
+- Do not rewrite the grading JS file.
+
+Write the HTML file directly to disk.`;
+}
+
+function buildBlooketPrompt(unit, lesson, patternCsv, rubricContents, framework) {
+  const frameworkBlock = framework
+    ? `## Framework Summary\n\n\`\`\`json\n${JSON.stringify({
+        topic: framework.topic,
+        skills: framework.skills,
+        learningObjectives: framework.learningObjectives,
+        keyConcepts: framework.keyConcepts,
+        commonMisconceptions: framework.commonMisconceptions,
+      }, null, 2)}\n\`\`\``
+    : "";
+
+  return `You are generating a Blooket CSV for AP Statistics Topic ${unit}.${lesson}.
+Create ONE file in the current directory:
+- \`u${unit}_l${lesson}_blooket.csv\`
+
+## CSV template
+${buildFileBlock(patternCsv.name, patternCsv.content)}
+
+## Rubric file
+${buildFileBlock(`ai-grading-prompts-u${unit}-l${lesson}.js`, rubricContents)}
+
+${frameworkBlock}
+
+## Requirements
+- Follow the exact Blooket import format.
+- Generate 25-35 multiple choice questions.
+- Cover vocabulary, procedures, reasoning, and common mistakes.
+- Use plausible distractors.
+- Randomize the correct answer position.
+- Keep the time limit at 20 seconds.
+- Output raw CSV only.
+
+Write the CSV file directly to disk.`;
+}
+
+function writeTempPromptFile(label, prompt, workingDir) {
+  const slug = label.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
+  const promptFile = path.join(
+    workingDir,
+    `.codex-prompt-${slug}-${process.pid}-${Date.now()}-${Math.random().toString(16).slice(2)}.md`
+  );
+  writeFileSync(promptFile, prompt, "utf-8");
+  return promptFile;
+}
+
+function cleanupTempPromptFile(promptFile) {
+  if (!promptFile || !existsSync(promptFile)) return;
+  try {
+    unlinkSync(promptFile);
+  } catch {
+    // Best effort.
+  }
+}
+
+function shouldRetryWithLegacyCodex(output) {
+  return /unknown command.*\bexec\b|invalid (sub)?command.*\bexec\b|unrecognized (sub)?command.*\bexec\b|no such command.*\bexec\b/i.test(
+    output
+  );
+}
+
+function launchCodexTask(label, promptFile, workingDir) {
+  return new Promise((resolve) => {
+    const promptContents = readFileSync(promptFile, "utf-8");
+    const isWindows = process.platform === "win32";
+    let settled = false;
+
+    const settle = (value) => {
+      if (settled) return;
+      settled = true;
+      cleanupTempPromptFile(promptFile);
+      resolve(value);
+    };
+
+    const runAttempt = (mode) => {
+      const spawnCommand = isWindows ? process.env.ComSpec || "cmd.exe" : "codex";
+      const spawnArgs = isWindows
+        ? ["/d", "/s", "/c", mode === "exec" ? "codex.cmd exec --full-auto -" : "codex.cmd --full-auto"]
+        : mode === "exec"
+          ? ["exec", "--full-auto", "-"]
+          : ["--full-auto"];
+
+      const proc = spawn(spawnCommand, spawnArgs, {
+        stdio: ["pipe", "pipe", "pipe"],
+        cwd: workingDir,
+      });
+
+      let output = "";
+
+      proc.stdout.on("data", (chunk) => {
+        const text = chunk.toString();
+        output += text;
+        process.stdout.write(text);
+      });
+
+      proc.stderr.on("data", (chunk) => {
+        const text = chunk.toString();
+        output += text;
+        process.stderr.write(text);
+      });
+
+      proc.stdin.write(promptContents);
+      proc.stdin.end();
+
+      proc.on("error", (error) => {
+        settle({ success: false, error: error.message, output });
+      });
+
+      proc.on("close", (code) => {
+        if (code === 0) {
+          settle({ success: true, output });
+          return;
+        }
+        if (mode === "exec" && shouldRetryWithLegacyCodex(output)) {
+          writeFileSync(promptFile, promptContents, "utf-8");
+          runAttempt("pipe");
+          return;
+        }
+        settle({ success: false, error: `exit code ${code}`, output });
+      });
+    };
+
+    runAttempt("exec");
+  });
+}
+
+function validateFileSize(filePath, minBytes) {
+  if (!existsSync(filePath)) {
+    return { ok: false, detail: `${path.basename(filePath)} missing` };
+  }
+  const size = statSync(filePath).size;
+  if (size < minBytes) {
+    return { ok: false, detail: `${path.basename(filePath)} too small (${size} bytes)` };
+  }
+  return { ok: true, detail: `${path.basename(filePath)} OK (${size} bytes)` };
+}
+
+function validateRubricFile(unit, lesson) {
+  const rubricPath = path.join(WORKING_DIRS.worksheet, `ai-grading-prompts-u${unit}-l${lesson}.js`);
+  const sizeValidation = validateFileSize(rubricPath, 1000);
+  if (!sizeValidation.ok) return sizeValidation;
+  const content = readFileSync(rubricPath, "utf-8");
+  if (!content.includes(`LESSON_CONTEXT_U${unit}L${lesson}`) || !content.includes(`RUBRICS_U${unit}L${lesson}`)) {
+    return { ok: false, detail: `${path.basename(rubricPath)} missing expected lesson globals` };
+  }
+  return { ok: true, detail: `${path.basename(rubricPath)} structure OK` };
+}
+
+function validateWorksheetFile(unit, lesson) {
+  const worksheetPath = path.join(WORKING_DIRS.worksheet, `u${unit}_lesson${lesson}_live.html`);
+  const sizeValidation = validateFileSize(worksheetPath, 10 * 1024);
+  if (!sizeValidation.ok) return sizeValidation;
+  const content = readFileSync(worksheetPath, "utf-8");
+  if (!content.includes(`ai-grading-prompts-u${unit}-l${lesson}.js`)) {
+    return { ok: false, detail: `${path.basename(worksheetPath)} missing grading script reference` };
+  }
+  return { ok: true, detail: `${path.basename(worksheetPath)} structure OK` };
+}
+
+function validateBlooketFile(unit, lesson) {
+  const blooketPath = path.join(WORKING_DIRS.worksheet, `u${unit}_l${lesson}_blooket.csv`);
+  const sizeValidation = validateFileSize(blooketPath, 500);
+  if (!sizeValidation.ok) return sizeValidation;
+  const content = readFileSync(blooketPath, "utf-8");
+  if (!content.startsWith(`"Blooket`)) {
+    return { ok: false, detail: `${path.basename(blooketPath)} missing Blooket header` };
+  }
+  return { ok: true, detail: `${path.basename(blooketPath)} structure OK` };
+}
+
+async function runCodexGenerationTask({ label, prompt, workingDir, validate, outputPath }) {
+  const promptFile = writeTempPromptFile(label, prompt, workingDir);
+  try {
+    const launchResult = await launchCodexTask(label, promptFile, workingDir);
+    if (!launchResult.success) {
+      return stepResult(label, "failed", { reason: launchResult.error || "Codex task failed" });
+    }
+    const validation = validate();
+    if (!validation.ok) {
+      return stepResult(label, "failed", { reason: validation.detail });
+    }
+    return stepResult(label, "created", { outputs: [outputPath], validation: validation.detail });
+  } finally {
+    cleanupTempPromptFile(promptFile);
+  }
+}
+
+async function step2Transcript(unit, lesson, opts) {
+  const artifacts = collectTranscriptArtifacts(unit, lesson);
+  if (hasTranscriptArtifacts(artifacts)) {
+    return stepResult("Transcript", "skipped", {
+      reason: "Transcript already exists",
+      outputs: artifacts.primaryTranscriptPaths,
+      method: "existing",
+    });
+  }
+
+  if (opts.skipIngest) {
+    return stepResult("Transcript", "failed", {
+      reason: "Transcript missing and --skip-ingest was set",
+    });
+  }
+
+  if (opts.dryRun) {
+    return stepResult("Transcript", "planned", {
+      reason: "Transcript missing; would run Whisper first, then AI Studio fallback",
+    });
+  }
+
+  let driveIds = [...opts.driveIds];
+  let driveSource = driveIds.length > 0 ? "args" : "none";
+
+  if (existsSync(WHISPER_SCRIPT) && opts.files.length > 0) {
+    const whisperArgs = ["--unit", String(unit), "--lesson", String(lesson)];
+    for (const filePath of opts.files) {
+      whisperArgs.push("--video", filePath);
+    }
+    const whisper = spawnSync("node", [WHISPER_SCRIPT, ...whisperArgs], {
+      encoding: "utf8",
+      cwd: WORKSHEET_REPO,
+      stdio: "inherit",
+    });
+    if (whisper.status === 0) {
+      const refreshed = collectTranscriptArtifacts(unit, lesson);
+      if (hasTranscriptArtifacts(refreshed)) {
+        return stepResult("Transcript", "created", {
+          outputs: refreshed.primaryTranscriptPaths,
+          method: "whisper",
+        });
+      }
+    }
+  }
+
+  if (!existsSync(SCRIPTS.aistudioIngest)) {
+    return stepResult("Transcript", "failed", {
+      reason: "No usable transcript generator is available",
+    });
+  }
+
+  if (driveIds.length === 0 && opts.files.length === 0) {
+    const lookup = await lookupDriveIds(unit, lesson);
+    driveIds = lookup.ids;
+    driveSource = lookup.source;
+  }
+
+  if (driveIds.length === 0 && opts.files.length === 0) {
+    return stepResult("Transcript", "failed", {
+      reason: "Transcript missing and no local video files or Drive IDs were provided",
+    });
+  }
+
+  const args = ["--unit", String(unit), "--lesson", String(lesson)];
+  if (opts.files.length > 0) {
+    args.push("--files", ...opts.files);
+  } else {
+    args.push("--drive-ids", ...driveIds);
+  }
+  const fallback = spawnSync("node", [SCRIPTS.aistudioIngest, ...args], {
+    encoding: "utf8",
+    cwd: WORKING_DIRS.worksheet,
+    stdio: "inherit",
+  });
+
+  if (fallback.status !== 0) {
+    return stepResult("Transcript", "failed", {
+      reason: "AI Studio fallback failed",
+      method: "aistudio",
+      driveSource,
+    });
+  }
+
+  const refreshed = collectTranscriptArtifacts(unit, lesson);
+  if (!hasTranscriptArtifacts(refreshed)) {
+    return stepResult("Transcript", "failed", {
+      reason: "Transcript generation completed but no transcript files were found",
+      method: "aistudio",
+      driveSource,
+    });
+  }
+
+  return stepResult("Transcript", "created", {
+    outputs: refreshed.primaryTranscriptPaths,
+    method: "aistudio",
+    driveSource,
+  });
+}
+
+async function step3Rubric(unit, lesson, transcriptResult, opts) {
+  const rubricPath = path.join(WORKING_DIRS.worksheet, `ai-grading-prompts-u${unit}-l${lesson}.js`);
+  if (existsSync(rubricPath)) {
+    return stepResult("Rubric", "skipped", { reason: "Rubric already exists", outputs: [rubricPath] });
+  }
+  if (transcriptResult.status === "failed") {
+    return stepResult("Rubric", "failed", { reason: "Transcript step failed" });
+  }
+  if (opts.dryRun) {
+    return stepResult("Rubric", "planned", { reason: "Rubric missing; would generate from transcript + framework", outputs: [rubricPath] });
+  }
+
+  let videoContext;
+  let patternFile;
+
+  try {
+    videoContext = readVideoContext(unit, lesson);
+    patternFile = pickPatternArtifact(
+      WORKING_DIRS.worksheet,
+      `ai-grading-prompts-u${unit}-l${lesson - 1}.js`,
+      /^ai-grading-prompts-u(\d+)-l(\d+)\.js$/,
+      unit,
+      lesson
+    );
+  } catch (error) {
+    return stepResult("Rubric", "failed", { reason: error.message });
+  }
+
+  const framework = loadLessonFramework(unit, lesson);
+  const prompt = buildRubricPrompt(unit, lesson, videoContext, framework, patternFile);
+
+  return runCodexGenerationTask({
+    label: "Rubric",
+    prompt,
+    workingDir: WORKING_DIRS.worksheet,
+    validate: () => validateRubricFile(unit, lesson),
+    outputPath: rubricPath,
+  });
+}
+
+async function step4Worksheet(unit, lesson, transcriptResult, rubricResult, opts) {
+  const worksheetPath = path.join(WORKING_DIRS.worksheet, `u${unit}_lesson${lesson}_live.html`);
+  if (existsSync(worksheetPath)) {
+    return stepResult("Worksheet", "skipped", { reason: "Worksheet already exists", outputs: [worksheetPath] });
+  }
+  if (transcriptResult.status === "failed" || rubricResult.status === "failed") {
+    return stepResult("Worksheet", "failed", { reason: "Transcript or rubric prerequisite failed" });
+  }
+  if (opts.dryRun) {
+    return stepResult("Worksheet", "planned", { reason: "Worksheet missing; would generate from transcript + rubric", outputs: [worksheetPath] });
+  }
+
+  let videoContext;
+  let worksheetPattern;
+  try {
+    videoContext = readVideoContext(unit, lesson);
+    worksheetPattern = pickPatternArtifact(
+      WORKING_DIRS.worksheet,
+      `u${unit}_lesson${lesson - 1}_live.html`,
+      /^u(\d+)_lesson(\d+)_live\.html$/,
+      unit,
+      lesson
+    );
+  } catch (error) {
+    return stepResult("Worksheet", "failed", { reason: error.message });
+  }
+
+  const rubricContents = readFileSync(
+    path.join(WORKING_DIRS.worksheet, `ai-grading-prompts-u${unit}-l${lesson}.js`),
+    "utf-8"
+  );
+
+  return runCodexGenerationTask({
+    label: "Worksheet",
+    prompt: buildWorksheetPrompt(unit, lesson, videoContext, worksheetPattern, rubricContents),
+    workingDir: WORKING_DIRS.worksheet,
+    validate: () => validateWorksheetFile(unit, lesson),
+    outputPath: worksheetPath,
+  });
+}
+
+async function step4Blooket(unit, lesson, rubricResult, opts) {
+  const blooketPath = path.join(WORKING_DIRS.worksheet, `u${unit}_l${lesson}_blooket.csv`);
+  if (opts.skipBlooket) {
+    return stepResult("Blooket", "skipped", { reason: "--skip-blooket was set" });
+  }
+  if (existsSync(blooketPath)) {
+    return stepResult("Blooket", "skipped", { reason: "Blooket CSV already exists", outputs: [blooketPath] });
+  }
+  if (rubricResult.status === "failed") {
+    return stepResult("Blooket", "failed", { reason: "Rubric prerequisite failed" });
+  }
+  if (opts.dryRun) {
+    return stepResult("Blooket", "planned", { reason: "Blooket CSV missing; would generate from rubric", outputs: [blooketPath] });
+  }
+
+  let patternCsv;
+  try {
+    patternCsv = pickPatternArtifact(
+      WORKING_DIRS.worksheet,
+      `u${unit}_l${lesson - 1}_blooket.csv`,
+      /^u(\d+)_l(\d+)_blooket\.csv$/,
+      unit,
+      lesson
+    );
+  } catch (error) {
+    return stepResult("Blooket", "failed", { reason: error.message });
+  }
+
+  const rubricContents = readFileSync(
+    path.join(WORKING_DIRS.worksheet, `ai-grading-prompts-u${unit}-l${lesson}.js`),
+    "utf-8"
+  );
+  const framework = loadLessonFramework(unit, lesson);
+
+  return runCodexGenerationTask({
+    label: "Blooket",
+    prompt: buildBlooketPrompt(
+      unit,
+      lesson,
+      { name: patternCsv.name, content: takeCsvRows(patternCsv.content, 10) },
+      rubricContents,
+      framework
+    ),
+    workingDir: WORKING_DIRS.worksheet,
+    validate: () => validateBlooketFile(unit, lesson),
+    outputPath: blooketPath,
+  });
+}
+
+function step5Animations(unit, lesson, rubricResult, opts) {
+  if (rubricResult.status === "failed") {
+    return stepResult("Animations", "skipped", { reason: "Rubric prerequisite failed" });
+  }
+  if (opts.skipRender && opts.skipUpload) {
+    return stepResult("Animations", "skipped", { reason: "--skip-render and --skip-upload were set" });
+  }
+  if (opts.dryRun) {
+    return stepResult("Animations", "planned", { reason: "Would render and/or upload animations" });
+  }
+
+  let renderOk = false;
+  let uploadOk = false;
+  let renderReason = null;
+  let uploadReason = null;
+  const outputs = [];
+
+  if (!opts.skipRender) {
+    if (!existsSync(SCRIPTS.renderAnimations)) {
+      renderReason = "render-animations.mjs not found";
+    } else {
+      const render = spawnSync("node", [SCRIPTS.renderAnimations, "--unit", String(unit), "--lesson", String(lesson)], {
+        encoding: "utf8",
+        cwd: WORKING_DIRS.driller,
+      });
+      if (render.stdout) process.stdout.write(render.stdout);
+      if (render.stderr) process.stderr.write(render.stderr);
+      renderOk = render.status === 0;
+      renderReason = renderOk ? null : commandFailureMessage(render, "animation render failed");
+    }
+  } else {
+    renderOk = true;
+    renderReason = "render skipped";
+  }
+
+  if (!opts.skipUpload) {
+    if (!existsSync(SCRIPTS.uploadAnimations)) {
+      uploadReason = "upload-animations.mjs not found";
+    } else {
+      const upload = spawnSync("node", [SCRIPTS.uploadAnimations, "--unit", String(unit), "--lesson", String(lesson)], {
+        encoding: "utf8",
+        cwd: WORKING_DIRS.driller,
+      });
+      if (upload.stdout) {
+        process.stdout.write(upload.stdout);
+        outputs.push(...[...upload.stdout.matchAll(/https?:\/\/\S+/g)].map((match) => match[0]));
+      }
+      if (upload.stderr) process.stderr.write(upload.stderr);
+      uploadOk = upload.status === 0;
+      uploadReason = uploadOk ? null : commandFailureMessage(upload, "animation upload failed");
+    }
+  } else {
+    uploadOk = true;
+    uploadReason = "upload skipped";
+  }
+
+  if (renderOk && uploadOk) {
+    return stepResult("Animations", "created", { outputs });
+  }
+
+  return stepResult("Animations", "failed", {
+    reason: [renderReason, uploadReason].filter(Boolean).join("; "),
+    outputs,
+    nonBlocking: true,
+  });
+}
+
+function printReport(unit, lesson, results) {
+  console.log("\n=== Lesson Prep Report ===\n");
+  console.log(`Lesson: Unit ${unit}, Lesson ${lesson}\n`);
+
+  for (const result of [results.calendar, results.transcript, results.rubric, results.worksheet, results.blooket, results.animations]) {
+    if (!result) continue;
+    console.log(`[${result.status.toUpperCase()}] ${result.step}`);
+    if (result.reason) console.log(`  ${result.reason}`);
+    if (result.method) console.log(`  Method: ${result.method}`);
+    for (const output of result.outputs || []) {
+      console.log(`  -> ${output}`);
+    }
+  }
+
+  const blockingFailures = [results.transcript, results.rubric, results.worksheet, results.blooket].filter(
+    (result) => result?.status === "failed"
+  );
+  const warnings = [results.animations].filter((result) => result?.status === "failed" && result.nonBlocking);
+
+  if (blockingFailures.length > 0) {
+    console.log("\nBlocking failures:");
+    for (const failure of blockingFailures) {
+      console.log(`  ${failure.step}: ${failure.reason}`);
+    }
+  }
+
+  if (warnings.length > 0) {
+    console.log("\nNon-blocking warnings:");
+    for (const warning of warnings) {
+      console.log(`  ${warning.step}: ${warning.reason}`);
+    }
+  }
+
+  console.log();
+}
+
+function commitAndPushRepos(unit, lesson) {
+  const repoResults = [];
+
+  for (const repo of DOWNSTREAM_REPOS) {
+    const status = spawnSync("git", ["status", "-s"], {
+      cwd: repo.path,
+      encoding: "utf8",
+    });
+
+    if (status.status !== 0) {
+      repoResults.push({ name: repo.name, action: "error", error: commandFailureMessage(status, "git status failed") });
+      continue;
+    }
+
+    if (!String(status.stdout || "").trim()) {
+      repoResults.push({ name: repo.name, action: "clean" });
+      continue;
+    }
+
+    for (const pattern of repo.patterns) {
+      spawnSync("git", ["add", pattern], {
+        cwd: repo.path,
+        encoding: "utf8",
+      });
+    }
+
+    const staged = spawnSync("git", ["diff", "--cached", "--name-only"], {
+      cwd: repo.path,
+      encoding: "utf8",
+    });
+    if (staged.status !== 0 || !String(staged.stdout || "").trim()) {
+      repoResults.push({ name: repo.name, action: "nothing-staged" });
+      continue;
+    }
+
+    const commitMessage = `pipeline: add U${unit} L${lesson} content`;
+    const commit = spawnSync("git", ["commit", "-m", commitMessage], {
+      cwd: repo.path,
+      encoding: "utf8",
+    });
+    if (commit.status !== 0) {
+      repoResults.push({ name: repo.name, action: "error", error: commandFailureMessage(commit, "git commit failed") });
+      continue;
+    }
+
+    const hashMatch = String(commit.stdout || "").match(/\[[\w/.-]+ ([a-f0-9]+)\]/);
+    const hash = hashMatch ? hashMatch[1] : "unknown";
+
+    const push = spawnSync("git", ["push"], {
+      cwd: repo.path,
+      encoding: "utf8",
+    });
+
+    if (push.status !== 0) {
+      repoResults.push({ name: repo.name, action: "committed", hash, pushError: commandFailureMessage(push, "git push failed") });
+      continue;
+    }
+
+    repoResults.push({ name: repo.name, action: "pushed", hash });
+  }
+
+  return repoResults;
+}
+
+function printCommitSummary(repoResults) {
+  if (!repoResults?.length) return;
+  console.log("Commit results:");
+  for (const repo of repoResults) {
+    if (repo.action === "pushed") {
+      console.log(`  ${repo.name}: pushed (${repo.hash})`);
+    } else if (repo.action === "committed") {
+      console.log(`  ${repo.name}: committed (${repo.hash}) but push failed: ${repo.pushError}`);
+    } else if (repo.action === "clean") {
+      console.log(`  ${repo.name}: no changes`);
+    } else if (repo.action === "nothing-staged") {
+      console.log(`  ${repo.name}: nothing matched staging patterns`);
+    } else if (repo.action === "error") {
+      console.log(`  ${repo.name}: ${repo.error}`);
+    }
+  }
+  console.log();
+}
+
+async function confirmCommit(opts) {
+  if (opts.dryRun) return false;
+  if (opts.autoPush) return true;
+  const answer = await ask("Review generated files above. Commit and push matching lesson changes now? [y/N] ");
+  return /^y(es)?$/i.test(answer);
+}
+
+async function main() {
+  const opts = parseArgs(process.argv);
+  let { unit, lesson } = opts;
+
+  let calendarResult;
+  let transcriptResult;
+
+  if (opts.auto) {
+    calendarResult = step1Calendar(unit, lesson, opts);
+    if (calendarResult.status === "failed") {
+      printReport(unit || "?", lesson || "?", {
+        calendar: calendarResult,
+        transcript: stepResult("Transcript", "skipped", { reason: "Calendar detection failed" }),
+      });
+      process.exit(1);
+    }
+    unit = calendarResult.unit;
+    lesson = calendarResult.lesson;
+    transcriptResult = await step2Transcript(unit, lesson, opts);
+  } else {
+    [calendarResult, transcriptResult] = await Promise.all([
+      Promise.resolve(step1Calendar(unit, lesson, opts)),
+      step2Transcript(unit, lesson, opts),
+    ]);
+  }
+
+  console.log(`\n=== Lesson Prep: Unit ${unit}, Lesson ${lesson} ===\n`);
+  if (calendarResult.output) {
+    process.stdout.write(calendarResult.output);
+    console.log();
+  }
+
+  const rubricResult = await step3Rubric(unit, lesson, transcriptResult, opts);
+  const [worksheetResult, blooketResult] = await Promise.all([
+    step4Worksheet(unit, lesson, transcriptResult, rubricResult, opts),
+    step4Blooket(unit, lesson, rubricResult, opts),
+  ]);
+  const animationsResult = step5Animations(unit, lesson, rubricResult, opts);
+
+  const results = {
+    calendar: calendarResult,
+    transcript: transcriptResult,
+    rubric: rubricResult,
+    worksheet: worksheetResult,
+    blooket: blooketResult,
+    animations: animationsResult,
+  };
+
+  printReport(unit, lesson, results);
+
+  const blockingFailures = [transcriptResult, rubricResult, worksheetResult, blooketResult].filter(
+    (result) => result?.status === "failed"
+  );
+  if (blockingFailures.length > 0) {
+    console.log("Commit skipped because one or more blocking steps failed.\n");
+    return;
+  }
+
+  if (!(await confirmCommit(opts))) {
+    console.log("Commit skipped.\n");
+    return;
+  }
+
+  const repoResults = commitAndPushRepos(unit, lesson);
+  printCommitSummary(repoResults);
+}
+
+main().catch((error) => {
+  console.error("Fatal error:", error);
+  process.exit(1);
+});
