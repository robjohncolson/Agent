function step5_animations(unit, lesson, rubricResult, opts) {
  const label = "Animations";

  if (rubricResult.status === "failed") {
    return stepResult(label, "skipped", {
      reason: "Rubric prerequisite failed",
    });
  }

  if (opts.skipRender && opts.skipUpload) {
    return stepResult(label, "skipped", {
      reason: "--skip-render and --skip-upload were set",
    });
  }

  if (opts.dryRun) {
    return stepResult(label, "planned", {
      reason: "Would render and/or upload animations",
    });
  }

  let renderOk = false;
  let uploadOk = false;
  let renderReason = null;
  let uploadReason = null;
  const outputs = [];

  if (!opts.skipRender) {
    if (!scriptExists(SCRIPTS.renderAnimations)) {
      renderReason = "render-animations.mjs not found";
    } else {
      const renderResult = spawnSync(
        "node",
        [SCRIPTS.renderAnimations, "--unit", String(unit), "--lesson", String(lesson)],
        { encoding: "utf8", cwd: WORKING_DIRS.driller }
      );
      if (typeof renderResult.stdout === "string" && renderResult.stdout) {
        process.stdout.write(renderResult.stdout);
      }
      if (typeof renderResult.stderr === "string" && renderResult.stderr) {
        process.stderr.write(renderResult.stderr);
      }
      renderOk = renderResult.status === 0;
      renderReason = renderOk ? null : commandFailureMessage(renderResult, "animation render failed");
    }
  } else {
    renderOk = true;
    renderReason = "render skipped";
  }

  if (!opts.skipUpload) {
    if (!scriptExists(SCRIPTS.uploadAnimations)) {
      uploadReason = "upload-animations.mjs not found";
    } else {
      const uploadResult = spawnSync(
        "node",
        [SCRIPTS.uploadAnimations, "--unit", String(unit), "--lesson", String(lesson)],
        { encoding: "utf8", cwd: WORKING_DIRS.driller }
      );
      if (typeof uploadResult.stdout === "string" && uploadResult.stdout) {
        process.stdout.write(uploadResult.stdout);
        outputs.push(
          ...[...uploadResult.stdout.matchAll(/https?:\/\/\S+/g)].map((match) => match[0])
        );
      }
      if (typeof uploadResult.stderr === "string" && uploadResult.stderr) {
        process.stderr.write(uploadResult.stderr);
      }
      uploadOk = uploadResult.status === 0;
      uploadReason = uploadOk ? null : commandFailureMessage(uploadResult, "animation upload failed");
    }
  } else {
    uploadOk = true;
    uploadReason = "upload skipped";
  }

  if (renderOk && uploadOk) {
    return stepResult(label, "created", {
      outputs,
    });
  }

  return stepResult(label, "failed", {
    reason: [renderReason, uploadReason].filter(Boolean).join("; "),
    outputs,
    nonBlocking: true,
  });
}

function printReport(unit, lesson, results) {
  console.log("\n=== Lesson Prep Report ===\n");
  console.log(`Lesson: Unit ${unit}, Lesson ${lesson}\n`);

  const ordered = [
    results.calendar,
    results.transcript,
    results.rubric,
    results.worksheet,
    results.blooket,
    results.animations,
  ];

  for (const result of ordered) {
    if (!result) continue;

    const status = result.status.toUpperCase();
    console.log(`[${status}] ${resultLabel(result)}`);
    if (result.reason) {
      console.log(`  ${result.reason}`);
    }
    if (result.method) {
      console.log(`  Method: ${result.method}`);
    }
    if (result.outputs?.length) {
      for (const output of result.outputs) {
        console.log(`  -> ${output}`);
      }
    }
  }

  const createdFiles = ordered.flatMap((result) =>
    result?.status === "created" || result?.status === "skipped" ? result.outputs || [] : []
  );

  if (createdFiles.length > 0) {
    console.log("\nArtifacts:");
    for (const filePath of createdFiles) {
      console.log(`  ${filePath}`);
    }
  }

  const failures = ordered.filter((result) => result?.status === "failed" && !result.nonBlocking);
  const warnings = ordered.filter((result) => result?.status === "failed" && result.nonBlocking);

  if (failures.length > 0) {
    console.log("\nBlocking failures:");
    for (const failure of failures) {
      console.log(`  ${resultLabel(failure)}: ${failure.reason}`);
    }
  }

  if (warnings.length > 0) {
    console.log("\nNon-blocking warnings:");
    for (const warning of warnings) {
      console.log(`  ${resultLabel(warning)}: ${warning.reason}`);
    }
  }

  console.log();
}

function commitAndPushRepos(unit, lesson) {
  const repoResults = [];

  for (const repo of DOWNSTREAM_REPOS) {
    try {
      const status = spawnSync("git", ["status", "-s"], {
        cwd: repo.path,
        encoding: "utf8",
      });

      if (status.status !== 0) {
        repoResults.push({
          name: repo.name,
          action: "error",
          error: commandFailureMessage(status, "git status failed"),
        });
        continue;
      }

      if (!String(status.stdout || "").trim()) {
        repoResults.push({
          name: repo.name,
          action: "clean",
        });
        continue;
      }

      for (const pattern of repo.patterns) {
        spawnSync("git", ["add", pattern], {
          cwd: repo.path,
          encoding: "utf8",
        });
      }

      const staged = spawnSync("git", ["diff", "--cached", "--name-only"], {
        cwd: repo.path,
        encoding: "utf8",
      });
      if (staged.status !== 0 || !String(staged.stdout || "").trim()) {
        repoResults.push({
          name: repo.name,
          action: "nothing-staged",
        });
        continue;
      }

      const commitMessage = `pipeline: add U${unit} L${lesson} content`;
      const commit = spawnSync("git", ["commit", "-m", commitMessage], {
        cwd: repo.path,
        encoding: "utf8",
      });
      if (commit.status !== 0) {
        repoResults.push({
          name: repo.name,
          action: "error",
          error: commandFailureMessage(commit, "git commit failed"),
        });
        continue;
      }

      const hashMatch = String(commit.stdout || "").match(/\[[\w/.-]+ ([a-f0-9]+)\]/);
      const hash = hashMatch ? hashMatch[1] : "unknown";

      const push = spawnSync("git", ["push"], {
        cwd: repo.path,
        encoding: "utf8",
      });
      if (push.status !== 0) {
        repoResults.push({
          name: repo.name,
          action: "committed",
          hash,
          pushError: commandFailureMessage(push, "git push failed"),
        });
        continue;
      }

      repoResults.push({
        name: repo.name,
        action: "pushed",
        hash,
      });
    } catch (error) {
      repoResults.push({
        name: repo.name,
        action: "error",
        error: error.message,
      });
    }
  }

  return repoResults;
}

function printCommitSummary(repoResults) {
  if (!repoResults || repoResults.length === 0) return;

  console.log("Commit results:");
  for (const repo of repoResults) {
    if (repo.action === "pushed") {
      console.log(`  ${repo.name}: pushed (${repo.hash})`);
    } else if (repo.action === "committed") {
      console.log(`  ${repo.name}: committed (${repo.hash}) but push failed: ${repo.pushError}`);
    } else if (repo.action === "clean") {
      console.log(`  ${repo.name}: no changes`);
    } else if (repo.action === "nothing-staged") {
      console.log(`  ${repo.name}: nothing matched staging patterns`);
    } else if (repo.action === "error") {
      console.log(`  ${repo.name}: ${repo.error}`);
    }
  }
  console.log();
}

async function confirmCommit(opts) {
  if (opts.dryRun) {
    return false;
  }

  if (opts.autoPush) {
    return true;
  }

  const answer = await ask("Review the generated files above. Commit and push matching lesson changes now? [y/N] ");
  return /^y(es)?$/i.test(answer);
}

async function main() {
  const opts = parseArgs(process.argv);
  let { unit, lesson } = opts;

  let calendarResult;
  let transcriptResult;

  if (opts.auto) {
    calendarResult = step1_calendarCheck(unit, lesson, opts);
    if (calendarResult.status === "failed") {
      printReport(unit || "?", lesson || "?", {
        calendar: calendarResult,
        transcript: stepResult("Transcript", "skipped", {
          reason: "Calendar detection failed",
        }),
      });
      process.exit(1);
    }

    unit = calendarResult.unit;
    lesson = calendarResult.lesson;
    transcriptResult = await step2_transcript(unit, lesson, opts);
  } else {
    [calendarResult, transcriptResult] = await Promise.all([
      Promise.resolve(step1_calendarCheck(unit, lesson, opts)),
      step2_transcript(unit, lesson, opts),
    ]);
  }

  console.log(`\n=== Lesson Prep: Unit ${unit}, Lesson ${lesson} ===\n`);

  if (calendarResult.output) {
    process.stdout.write(calendarResult.output);
    console.log();
  }

  const rubricResult = await step3_rubric(unit, lesson, transcriptResult, opts);

  const [worksheetResult, blooketResult] = await Promise.all([
    step4a_worksheet(unit, lesson, transcriptResult, rubricResult, opts),
    step4b_blooket(unit, lesson, rubricResult, opts),
  ]);

  const animationsResult = step5_animations(unit, lesson, rubricResult, opts);

  const results = {
    calendar: calendarResult,
    transcript: transcriptResult,
    rubric: rubricResult,
    worksheet: worksheetResult,
    blooket: blooketResult,
    animations: animationsResult,
  };

  printReport(unit, lesson, results);

  const blockingFailures = [transcriptResult, rubricResult, worksheetResult, blooketResult].filter(
    (result) => result?.status === "failed"
  );

  if (blockingFailures.length > 0) {
    console.log("Commit skipped because one or more blocking steps failed.\n");
    return;
  }

  if (!(await confirmCommit(opts))) {
    console.log("Commit skipped.\n");
    return;
  }

  const repoResults = commitAndPushRepos(unit, lesson);
  printCommitSummary(repoResults);
}

main().catch((error) => {
  console.error("Fatal error:", error);
  process.exit(1);
});
