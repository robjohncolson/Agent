+
+        new_state, actions = _orphan_on_timer(state, cfg)
+
+        assert not any(isinstance(action, OrphanOrderAction) for action in actions)
+        assert new_state.recovery_orders == ()
+        assert derive_phase(new_state) == "S1a"
+        assert any(order.local_id == exit_order.local_id for order in new_state.orders)
+
+    def test_s1b_exit_orphaned_after_timeout(self):
+        cfg = _make_engine_config()
