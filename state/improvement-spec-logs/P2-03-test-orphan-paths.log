+        timestamp=state.now + 1.0,
+    )
+    state, _ = transition(state, fill, cfg, ORDER_SIZE_USD)
+    return state
+
+
+def _advance_to_s1b(cfg: EngineConfig) -> PairState:
+    state = _make_bootstrapped_state(cfg)
+    buy_entry = next(
+        order for order in state.orders
+        if order.role == "entry" and order.trade_id == "B"
+    )
+    fill = FillEvent(
+        order_local_id=buy_entry.local_id,
+        txid="FILL-B",
+        side=buy_entry.side,
+        price=buy_entry.price,
+        volume=buy_entry.volume,
+        fee=_fill_fee(buy_entry.price, buy_entry.volume, cfg),
+        timestamp=state.now + 1.0,
+    )
+    state, _ = transition(state, fill, cfg, ORDER_SIZE_USD)
+    return state
+
+
+def _advance_to_s2(cfg: EngineConfig) -> PairState:
+    state = _make_bootstrapped_state(cfg)
+    for entry in tuple(order for order in state.orders if order.role == "entry"):
+        fill = FillEvent(
+            order_local_id=entry.local_id,
+            txid=f"FILL-{entry.trade_id}",
+            side=entry.side,
+            price=entry.price,
+            volume=entry.volume,
+            fee=_fill_fee(entry.price, entry.volume, cfg),
+            timestamp=state.now + 1.0,
+        )
+        state, _ = transition(state, fill, cfg, ORDER_SIZE_USD)
+    return state
+
+
+def _orphan_on_timer(state: PairState, cfg: EngineConfig, *, at: float = 1100.0):
+    return transition(state, TimerTick(timestamp=at), cfg, ORDER_SIZE_USD)
+
+
+def _only_action(actions: list, action_type):
+    matches = [action for action in actions if isinstance(action, action_type)]
+    assert len(matches) == 1
+    return matches[0]
+
+
+def _orphaned_s1a_state(cfg: EngineConfig, *, at: float = 1100.0) -> PairState:
+    state = _advance_to_s1a(cfg)
+    state, _ = _orphan_on_timer(state, cfg, at=at)
+    return state
+
+
+def _orphaned_s1b_state(cfg: EngineConfig, *, at: float = 1100.0) -> PairState:
+    state = _advance_to_s1b(cfg)
+    state, _ = _orphan_on_timer(state, cfg, at=at)
+    return state
+
+
+def _make_recovery_cancel_fixture():
+    cfg = _make_engine_config()
+    state = _orphaned_s1a_state(cfg)
+    recovery = replace(state.recovery_orders[0], txid="REC-CANCEL")
+    state = replace(
+        state,
+        market_price=0.095,
+        recovery_orders=(recovery,),
+    )
+    engine = SlotEngine(initial_slots=0)
+    slot = engine.add_slot(sticky=False)
+    assert slot is not None
+    slot.state = state
+    adapter = MockExchangeAdapter()
+    adapter._closed_orders[recovery.txid] = {
+        "status": "canceled",
+        "vol_exec": 0.0,
+        "price": recovery.price,
+        "fee": 0.0,
+    }
+    ledger = Ledger(
+        ledger_file=os.path.join(tempfile.mkdtemp(), "orphan_recovery_paths.jsonl")
+    )
+    return cfg, engine, slot, recovery, adapter, ledger
+
+
+class TestOrphanDetection:
+    """When does an exit get promoted into recovery tracking?"""
+
+    def test_s1a_exit_orphaned_after_timeout_and_price_moved(self):
+        cfg = _make_engine_config()
+        state = _advance_to_s1a(cfg)
+
+        new_state, actions = _orphan_on_timer(state, cfg)
+
+        orphan = _only_action(actions, OrphanOrderAction)
+        assert orphan.reason == "s1_timeout"
+        assert orphan.side == "buy"
+        assert len(new_state.recovery_orders) == 1
+        assert new_state.recovery_orders[0].trade_id == "A"
+
+    def test_s1a_exit_NOT_orphaned_if_price_still_near(self):
+        cfg = _make_engine_config()
+        state = _advance_to_s1a(cfg)
+        exit_order = next(order for order in state.orders if order.role == "exit")
+        state = replace(state, market_price=exit_order.price, last_price_update_at=1099.0)
+
+        new_state, actions = _orphan_on_timer(state, cfg)
+
+        assert not any(isinstance(action, OrphanOrderAction) for action in actions)
+        assert new_state.recovery_orders == ()
+        assert derive_phase(new_state) == "S1a"
+        assert any(order.local_id == exit_order.local_id for order in new_state.orders)
+
+    def test_s1b_exit_orphaned_after_timeout(self):
+        cfg = _make_engine_config()
+        state = _advance_to_s1b(cfg)
+
+        new_state, actions = _orphan_on_timer(state, cfg)
+
+        orphan = _only_action(actions, OrphanOrderAction)
+        assert orphan.reason == "s1_timeout"
+        assert orphan.side == "sell"
+        assert len(new_state.recovery_orders) == 1
+        assert new_state.recovery_orders[0].trade_id == "B"
+
+    def test_sticky_mode_disables_orphaning(self):
+        cfg = _make_engine_config(sticky_mode_enabled=True)
+        state = _advance_to_s1a(cfg)
+
+        new_state, actions = _orphan_on_timer(state, cfg)
+
+        assert actions == []
+        assert new_state.recovery_orders == ()
+        assert derive_phase(new_state) == "S1a"
+
+    def test_s2_orphans_worse_leg_by_distance(self):
+        cfg = _make_engine_config()
+        state = _advance_to_s2(cfg)
+        state, first_tick_actions = transition(
+            state, TimerTick(timestamp=1050.0), cfg, ORDER_SIZE_USD,
+        )
+        assert first_tick_actions == []
+
+        exits = [order for order in state.orders if order.role == "exit"]
+        assert len(exits) == 2
+        market_price = state.market_price
+        buy_exit = next(order for order in exits if order.side == "buy")
+        sell_exit = next(order for order in exits if order.side == "sell")
+        expected = buy_exit if (
+            abs(buy_exit.price - market_price) / market_price
+            > abs(sell_exit.price - market_price) / market_price
+        ) else sell_exit
+
+        new_state, actions = transition(
+            state, TimerTick(timestamp=1145.0), cfg, ORDER_SIZE_USD,
+        )
+
+        orphan = _only_action(actions, OrphanOrderAction)
+        assert orphan.local_id == expected.local_id
+        assert new_state.recovery_orders[0].trade_id == expected.trade_id
+        assert new_state.recovery_orders[0].reason == "s2_timeout"
+        assert new_state.s2_entered_at is None
+
+
+class TestOrphanActionExecution:
+    """What does orphaning do to active and recovery state?"""
+
+    def test_orphan_reclassifies_stale_exit_only_and_keeps_companion_entry(self):
+        cfg = _make_engine_config()
+        state = _advance_to_s1a(cfg)
+        companion_entry = next(
+            order for order in state.orders
+            if order.role == "entry" and order.trade_id == "B"
+        )
+        stale_exit = next(order for order in state.orders if order.role == "exit")
+
+        new_state, actions = _orphan_on_timer(state, cfg)
+
+        assert not any(isinstance(action, CancelOrderAction) for action in actions)
+        assert companion_entry in new_state.orders
+        assert not any(order.local_id == stale_exit.local_id for order in new_state.orders)
+        recovery = new_state.recovery_orders[0]
+        assert recovery.side == stale_exit.side
+        assert recovery.price == stale_exit.price
+        assert recovery.volume == stale_exit.volume
+        assert recovery.trade_id == stale_exit.trade_id
+        assert recovery.entry_price == stale_exit.entry_price
+
+    def test_orphan_promotes_live_exit_to_recovery_with_same_txid(self):
+        cfg = _make_engine_config()
+        state = _advance_to_s1b(cfg)
+        patched_orders = []
+        stale_exit = None
+        for order in state.orders:
+            if order.role == "exit":
+                stale_exit = replace(order, txid="EXIT-B-1")
+                patched_orders.append(stale_exit)
+            else:
+                patched_orders.append(order)
+        assert stale_exit is not None
+        state = replace(state, orders=tuple(patched_orders))
+
+        new_state, _ = _orphan_on_timer(state, cfg)
+
+        recovery = new_state.recovery_orders[0]
+        assert recovery.txid == "EXIT-B-1"
+        assert recovery.price == stale_exit.price
+        assert recovery.side == stale_exit.side
+        assert recovery.trade_id == stale_exit.trade_id
+
+    def test_orphan_transitions_back_to_s0_and_rebootstraps_missing_entry(self):
+        cfg = _make_engine_config()
+        state = _advance_to_s1a(cfg)
+
+        new_state, actions = _orphan_on_timer(state, cfg)
+
+        entry_action = _only_action(actions, PlaceOrderAction)
+        assert derive_phase(new_state) == "S0"
+        assert entry_action.role == "entry"
+        assert entry_action.side == "sell"
+        assert entry_action.trade_id == "A"
+        assert entry_action.reason == "orphan_A"
+        assert {order.trade_id for order in new_state.orders if order.role == "entry"} == {"A", "B"}
+
