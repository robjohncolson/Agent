    def initialize(self, market_price: float, order_size_usd: float) -> list:
        """Create initial slots and bootstrap their orders. Returns actions."""
        all_actions = []
        n_sticky = max(1, round(self._initial_slots * self._initial_sticky_ratio))
        for i in range(self._initial_slots):
            sticky = i < n_sticky
            slot = self._create_slot(sticky, market_price)
            cfg = self._build_default_config(slot)
            state, actions, orders = bootstrap_orders(
                slot.state, cfg, order_size_usd,
            )
            slot.state = replace(state, orders=orders)
            all_actions.extend(actions)
        return all_actions

