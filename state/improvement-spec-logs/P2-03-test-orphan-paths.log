+        assert len(new_state.recovery_orders) == 1
+        assert new_state.recovery_orders[0].trade_id == "B"
+
+    def test_sticky_mode_disables_orphaning(self):
+        cfg = _make_engine_config(sticky_mode_enabled=True)
+        state = _advance_to_s1a(cfg)
+
+        new_state, actions = _orphan_on_timer(state, cfg)
+
+        assert actions == []
+        assert new_state.recovery_orders == ()
+        assert derive_phase(new_state) == "S1a"
+
+    def test_s2_orphans_worse_leg_by_distance(self):
+        cfg = _make_engine_config()
+        state = _advance_to_s2(cfg)
+        state, first_tick_actions = transition(
+            state, TimerTick(timestamp=1050.0), cfg, ORDER_SIZE_USD,
+        )
+        assert first_tick_actions == []
+
+        exits = [order for order in state.orders if order.role == "exit"]
+        assert len(exits) == 2
