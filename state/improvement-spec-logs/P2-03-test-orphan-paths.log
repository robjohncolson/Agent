    def record_write_off(
        self, slot_id: int, trade_id: str, cycle: int,
        entry_price: float, market_price: float, volume: float,
    ) -> LedgerEntry:
        """Record a write-off for a stale exit."""
        # Loss = difference between entry and market at write-off time
        if trade_id == "A":
            # A-side: sold at entry_price, writing off buy-back at market
            loss = (market_price - entry_price) * volume
        else:
            # B-side: bought at entry_price, writing off sell at market
            loss = (entry_price - market_price) * volume

        loss = max(0.0, loss)  # Loss is always positive

        acct = self._ensure_slot_account(slot_id)
        acct.total_write_offs_usd += loss
        acct.open_position_usd = max(0.0, acct.open_position_usd - entry_price * volume)



