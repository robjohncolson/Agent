+        assert orphan.reason == "s1_timeout"
+        assert orphan.side == "buy"
+        assert len(new_state.recovery_orders) == 1
+        assert new_state.recovery_orders[0].trade_id == "A"
+
+    def test_s1a_exit_NOT_orphaned_if_price_still_near(self):
+        cfg = _make_engine_config()
