class TestRecoveryWriteOff:
    """External recovery cancels are written off in poll_fills()."""

    def test_write_off_cleans_up_slot_state(self):
        _, engine, slot, recovery, adapter, ledger = _make_recovery_cancel_fixture()

        had_fill = _run(
            poll_fills(
                adapter=adapter,
                slot_engine=engine,
                ledger=ledger,
                commentator=_CommentatorStub(),
                governor_actions=GovernorActions(),
                server=None,
            )
        )

        assert had_fill is False
        assert slot.state.recovery_orders == ()
        assert any(
            order.role == "entry" and order.trade_id == "A" and order.side == "sell"
            for order in slot.state.orders
        )
        assert recovery.trade_id == "A"

    def test_write_off_records_loss_in_ledger(self):
        _, engine, slot, recovery, adapter, ledger = _make_recovery_cancel_fixture()

        _run(
            poll_fills(
                adapter=adapter,
                slot_engine=engine,
                ledger=ledger,
                commentator=_CommentatorStub(),
                governor_actions=GovernorActions(),
                server=None,
            )
        )

        expected_loss = max(
            0.0,
            (slot.state.market_price - recovery.entry_price) * recovery.volume,
        )
        entries = ledger.recent_entries(limit=20)
        write_off = next(entry for entry in entries if entry.entry_type == "WRITE_OFF")
        account = ledger.get_slot_account(slot.slot_id)
        assert write_off.slot_id == slot.slot_id
        assert write_off.trade_id == recovery.trade_id
        assert write_off.debit_usd == pytest.approx(expected_loss, rel=1e-9)
        assert account.total_write_offs_usd == pytest.approx(expected_loss, rel=1e-9)
