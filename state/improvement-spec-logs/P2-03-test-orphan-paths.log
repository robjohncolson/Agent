+class TestRecoveryCancel:
+    """Exchange or runtime cancels recovery tracking."""
+
+    def test_recovery_cancel_drops_recovery_tracking_only(self):
+        cfg = _make_engine_config()
+        state = _orphaned_s1a_state(cfg)
+        before_orders = state.orders
+        recovery = state.recovery_orders[0]
+
+        new_state, actions = transition(
+            state,
+            RecoveryCancelEvent(
+                recovery_id=recovery.recovery_id,
+                txid="REC-CANCEL-A",
+                timestamp=1110.0,
+            ),
+            cfg,
+            ORDER_SIZE_USD,
+        )
+
+        assert actions == []
+        assert new_state.recovery_orders == ()
+        assert new_state.orders == before_orders
+
+    def test_recovery_cancel_does_not_book_profit_or_loss(self):
+        cfg = _make_engine_config()
+        state = _orphaned_s1b_state(cfg)
+        recovery = state.recovery_orders[0]
+
+        new_state, actions = transition(
+            state,
+            RecoveryCancelEvent(
+                recovery_id=recovery.recovery_id,
+                txid="REC-CANCEL-B",
+                timestamp=1110.0,
+            ),
+            cfg,
+            ORDER_SIZE_USD,
+        )
+
+        assert actions == []
+        assert new_state.total_profit == pytest.approx(state.total_profit, rel=1e-9)
+        assert new_state.completed_cycles == state.completed_cycles
+        assert len(new_state.recovery_orders) == 0
