+class TestRecoveryFill:
+    """Recovery order eventually fills."""
+
+    def test_recovery_fill_books_profit_correctly(self):
+        cfg = _make_engine_config()
+        state = _orphaned_s1a_state(cfg)
+        recovery = state.recovery_orders[0]
+        fill_price = 0.089
+        fill_fee = 0.01
+
+        new_state, actions = transition(
+            state,
+            RecoveryFillEvent(
+                recovery_id=recovery.recovery_id,
+                txid="REC-FILL-A",
+                side=recovery.side,
+                price=fill_price,
+                volume=recovery.volume,
+                fee=fill_fee,
+                timestamp=1110.0,
+            ),
+            cfg,
+            ORDER_SIZE_USD,
+        )
+
+        book = _only_action(actions, BookCycleAction)
+        expected_gross = (recovery.entry_price - fill_price) * recovery.volume
+        expected_fees = recovery.entry_fee + fill_fee
+        expected_net = expected_gross - expected_fees
+        assert book.from_recovery is True
+        assert book.gross_profit == pytest.approx(expected_gross, rel=1e-9)
+        assert book.fees == pytest.approx(expected_fees, rel=1e-9)
+        assert book.net_profit == pytest.approx(expected_net, rel=1e-9)
+        assert new_state.total_profit == pytest.approx(expected_net, rel=1e-9)
+        assert len(new_state.recovery_orders) == 0
+        assert len(new_state.completed_cycles) == 1
+        assert new_state.completed_cycles[0].from_recovery is True
+
+    def test_recovery_fill_companion_order_is_correct_side(self):
