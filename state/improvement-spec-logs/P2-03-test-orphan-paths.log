+
+
+ORDER_SIZE_USD = 2.0
+
+
+def _run(coro):
+    loop = asyncio.new_event_loop()
+    try:
+        return loop.run_until_complete(coro)
+    finally:
+        loop.close()
+
+
+class _CommentatorStub:
+    def push_event(self, *_args, **_kwargs):
+        return None
+
+
+def _make_engine_config(**overrides) -> EngineConfig:
+    defaults = dict(
+        entry_pct=0.20,
+        profit_pct=1.0,
+        refresh_pct=1.0,
+        order_size_usd=ORDER_SIZE_USD,
+        price_decimals=6,
+        volume_decimals=0,
+        min_volume=13.0,
+        maker_fee_pct=0.25,
+        stale_price_max_age_sec=1000.0,
+        s1_orphan_after_sec=60.0,
+        s2_orphan_after_sec=90.0,
+        max_recovery_slots=2,
+        sticky_mode_enabled=False,
+    )
+    defaults.update(overrides)
+    return EngineConfig(**defaults)
+
+
+def _make_bootstrapped_state(
+    cfg: EngineConfig,
+    *,
+    market_price: float = 0.09,
+    now: float = 1000.0,
+) -> PairState:
+    state = PairState(
+        market_price=market_price,
+        now=now,
+        last_price_update_at=now,
+    )
+    state, _, orders = bootstrap_orders(state, cfg, ORDER_SIZE_USD)
+    return replace(state, orders=orders)
+
+
+def _fill_fee(price: float, volume: float, cfg: EngineConfig) -> float:
+    return price * volume * cfg.maker_fee_pct / 100.0
+
+
+def _advance_to_s1a(cfg: EngineConfig) -> PairState:
+    state = _make_bootstrapped_state(cfg)
+    sell_entry = next(
+        order for order in state.orders
+        if order.role == "entry" and order.trade_id == "A"
+    )
+    fill = FillEvent(
+        order_local_id=sell_entry.local_id,
+        txid="FILL-A",
+        side=sell_entry.side,
+        price=sell_entry.price,
+        volume=sell_entry.volume,
+        fee=_fill_fee(sell_entry.price, sell_entry.volume, cfg),
+        timestamp=state.now + 1.0,
+    )
+    state, _ = transition(state, fill, cfg, ORDER_SIZE_USD)
+    return state
+
+
+def _advance_to_s1b(cfg: EngineConfig) -> PairState:
+    state = _make_bootstrapped_state(cfg)
+    buy_entry = next(
+        order for order in state.orders
+        if order.role == "entry" and order.trade_id == "B"
+    )
+    fill = FillEvent(
+        order_local_id=buy_entry.local_id,
+        txid="FILL-B",
+        side=buy_entry.side,
+        price=buy_entry.price,
+        volume=buy_entry.volume,
+        fee=_fill_fee(buy_entry.price, buy_entry.volume, cfg),
+        timestamp=state.now + 1.0,
+    )
+    state, _ = transition(state, fill, cfg, ORDER_SIZE_USD)
+    return state
+
+
+def _advance_to_s2(cfg: EngineConfig) -> PairState:
+    state = _make_bootstrapped_state(cfg)
+    for entry in tuple(order for order in state.orders if order.role == "entry"):
+        fill = FillEvent(
+            order_local_id=entry.local_id,
+            txid=f"FILL-{entry.trade_id}",
+            side=entry.side,
+            price=entry.price,
+            volume=entry.volume,
+            fee=_fill_fee(entry.price, entry.volume, cfg),
+            timestamp=state.now + 1.0,
+        )
+        state, _ = transition(state, fill, cfg, ORDER_SIZE_USD)
+    return state
+
+
+def _orphan_on_timer(state: PairState, cfg: EngineConfig, *, at: float = 1100.0):
+    return transition(state, TimerTick(timestamp=at), cfg, ORDER_SIZE_USD)
+
+
+def _only_action(actions: list, action_type):
+    matches = [action for action in actions if isinstance(action, action_type)]
+    assert len(matches) == 1
+    return matches[0]
+
+
+def _orphaned_s1a_state(cfg: EngineConfig, *, at: float = 1100.0) -> PairState:
+    state = _advance_to_s1a(cfg)
+    state, _ = _orphan_on_timer(state, cfg, at=at)
+    return state
+
+
+def _orphaned_s1b_state(cfg: EngineConfig, *, at: float = 1100.0) -> PairState:
+    state = _advance_to_s1b(cfg)
+    state, _ = _orphan_on_timer(state, cfg, at=at)
+    return state
+
+
+def _make_recovery_cancel_fixture():
