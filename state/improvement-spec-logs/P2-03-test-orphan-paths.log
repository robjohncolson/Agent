+        new_state, actions = _orphan_on_timer(state, cfg)
+
+        assert not any(isinstance(action, CancelOrderAction) for action in actions)
+        assert companion_entry in new_state.orders
+        assert not any(order.local_id == stale_exit.local_id for order in new_state.orders)
+        recovery = new_state.recovery_orders[0]
+        assert recovery.side == stale_exit.side
+        assert recovery.price == stale_exit.price
+        assert recovery.volume == stale_exit.volume
+        assert recovery.trade_id == stale_exit.trade_id
+        assert recovery.entry_price == stale_exit.entry_price
+
+    def test_orphan_promotes_live_exit_to_recovery_with_same_txid(self):
+        cfg = _make_engine_config()
+        state = _advance_to_s1b(cfg)
+        patched_orders = []
+        stale_exit = None
+        for order in state.orders:
+            if order.role == "exit":
+                stale_exit = replace(order, txid="EXIT-B-1")
+                patched_orders.append(stale_exit)
+            else:
+                patched_orders.append(order)
+        assert stale_exit is not None
+        state = replace(state, orders=tuple(patched_orders))
+
+        new_state, _ = _orphan_on_timer(state, cfg)
+
+        recovery = new_state.recovery_orders[0]
+        assert recovery.txid == "EXIT-B-1"
+        assert recovery.price == stale_exit.price
+        assert recovery.side == stale_exit.side
+        assert recovery.trade_id == stale_exit.trade_id
+
+    def test_orphan_transitions_back_to_s0_and_rebootstraps_missing_entry(self):
+        cfg = _make_engine_config()
+        state = _advance_to_s1a(cfg)
+
+        new_state, actions = _orphan_on_timer(state, cfg)
+
+        entry_action = _only_action(actions, PlaceOrderAction)
+        assert derive_phase(new_state) == "S0"
+        assert entry_action.role == "entry"
+        assert entry_action.side == "sell"
+        assert entry_action.trade_id == "A"
+        assert entry_action.reason == "orphan_A"
+        assert {order.trade_id for order in new_state.orders if order.role == "entry"} == {"A", "B"}
