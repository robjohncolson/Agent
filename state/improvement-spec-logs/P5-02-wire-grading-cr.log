-    let jsonStr = text.match(/\{[\s\S]*\}/)?.[0];
-    if (jsonStr) {
-      // Fix smart quotes: " " → "
-      jsonStr = jsonStr.replace(/[\u201C\u201D]/g, '"');
-      // Fix smart single quotes: ' ' → '
