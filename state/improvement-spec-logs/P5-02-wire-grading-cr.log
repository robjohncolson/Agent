-          await this.delay(waitTime);
-        }
-
-        // Execute the task
-        this.lastRequestTime = Date.now();
-        this.requestsThisMinute++;
-        const result = await task();
-        resolve(result);
-
-      } catch (error) {
-        // Check if it's a rate limit error (429)
