-// Groq rate limits: 30 RPM for free tier, be conservative
-const GROQ_RATE_LIMIT = {
-  maxRequestsPerMinute: 25,  // Stay under 30 RPM limit
-  minDelayBetweenRequests: 2500  // 2.5 seconds between requests
