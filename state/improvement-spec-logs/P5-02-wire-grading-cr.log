+const GRADING_PROXY = process.env.GRADING_PROXY_URL || 'http://localhost:3002';
+const GRADING_PROXY_TIMEOUT_MS = 35000;
+
+async function parseProxyResponse(response) {
+  const text = await response.text();
+  if (!text) {
+    return {};
+  }
+
+  try {
+    return JSON.parse(text);
