-          this.requestsThisMinute = 0;
-          this.minuteStart = now;
-        }
-
-        // Wait if we've hit the per-minute limit
-        if (this.requestsThisMinute >= GROQ_RATE_LIMIT.maxRequestsPerMinute) {
