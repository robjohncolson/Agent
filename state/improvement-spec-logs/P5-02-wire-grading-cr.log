-    if (scoreMatch) {
-      return {
-        score: scoreMatch[1].toUpperCase(),
-        feedback: feedbackMatch ? feedbackMatch[1] : ''
-      };
-    }
-  } catch (e) { /* give up */ }
-
-  return null;
-}
