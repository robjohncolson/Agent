import assert from 'node:assert/strict';
import fs from 'node:fs';
import path from 'node:path';
import vm from 'node:vm';

const repoRoot = process.cwd();
const serverSource = fs.readFileSync(path.join(repoRoot, 'railway-server/server.js'), 'utf8');
const gradingEngineSource = fs.readFileSync(path.join(repoRoot, 'js/grading/grading-engine.js'), 'utf8');
const gradingRulesSource = fs.readFileSync(path.join(repoRoot, 'js/grading/frq-grading-rules.js'), 'utf8');

function extractBetween(source, startMarker, endMarker) {
  const start = source.indexOf(startMarker);
  const end = source.indexOf(endMarker, start);
  if (start === -1 || end === -1) {
    throw new Error("'`Could not extract source between ${startMarker} and ${endMarker}`);
  }
  return source.slice(start, end).trim();
}

const proxySource = extractBetween(serverSource, '"'const GRADING_PROXY =', '// Get server statistics');

function createServerHarness() {
  const routes = new Map();
  const queuedResponses = [];
  const fetchCalls = [];
  const sandbox = {
    process: { env: { GRADING_PROXY_URL: 'https://shared-grading-proxy.example.com' } },
    AbortSignal: { timeout(ms) { return { timeoutMs: ms }; } },
    fetch: async (url, options = {}) => {
      fetchCalls.push({ url, body: options.body ? JSON.parse(options.body) : undefined });
      const next = queuedResponses.shift();
      if (next instanceof Error) throw next;
      return {
        ok: next?.ok ?? true,
        status: next?.status ?? 200,
        async text() { return JSON.stringify(next?.body ?? {}); }
      };
    },
    app: {
      get(route, handler) { routes.set("'`GET ${route}`, handler); },
      post(route, handler) { routes.set(`POST ${route}`, handler); }
    },
    console,
    JSON,
    Object
  };
  vm.createContext(sandbox);
  vm.runInContext(proxySource, sandbox, { filename: '"'server-ai-proxy.js' });
  return {
    fetchCalls,
    queue(value) { queuedResponses.push(value); },
    async invoke(method, route, body) {
      const handler = routes.get("'`${method} ${route}`);
      let statusCode = 200;
      let payload;
      const res = {
        status(code) { statusCode = code; return this; },
        json(data) { payload = data; return this; }
      };
      await handler({ body }, res);
      return { status: statusCode, payload };
    }
  };
}

function createBrowserHarness(fetchImpl) {
  const sandbox = {
    window: {},
    fetch: fetchImpl,
    console,
    AbortController,
    setTimeout,
    clearTimeout
  };
  sandbox.window = sandbox;
  sandbox.window.RAILWAY_SERVER_URL = '"'https://test-server.example.com';
  vm.createContext(sandbox);
  vm.runInContext(gradingRulesSource, sandbox, { filename: 'frq-grading-rules.js' });
  vm.runInContext(gradingEngineSource, sandbox, { filename: 'grading-engine.js' });
  return new sandbox.window.GradingEngine({ serverUrl: 'https://test-server.example.com' });
}

const server = createServerHarness();
server.queue(new Error('proxy down'));
const gradeFallback = await server.invoke('POST', '/api/ai/grade', { keywordScore: 'P' });
assert.equal(gradeFallback.payload.score, 'P');

server.queue(new Error('proxy down'));
const appealFallback = await server.invoke('POST', '/api/ai/appeal', { currentScore: 'E' });
assert.equal(appealFallback.payload.score, 'E');

const browserFetch = async () => ({
  ok: true,
  status: 200,
  async json() {
    return { score: 'P', feedback: 'Lower proxy score.' };
  }
});
const engine = createBrowserHarness(browserFetch);
const appealResult = await engine.submitAppeal(
  'Simulation uses repeated random trials.',
  'I still think the original answer was strong.',
  { score: 'E', feedback: 'Full credit already awarded.' },
  {
    questionId: 'U4-L2-Q01',
    topic: 'AP Statistics',
    prompt: 'Explain how simulation estimates probability.',
    questionType: 'free-response'
  }
);
assert.equal(appealResult.score, 'E');
assert.equal(appealResult._downgradeBlocked, true);

const forwardServer = createServerHarness();
forwardServer.queue({ body: { score: 'E', feedback: 'Proxy result.' } });
await forwardServer.invoke('POST', '/api/ai/grade', {
  scenario: { questionId: 'U1-L1-Q01' },
  answers: { answer: 'test' },
  keywordScore: 'I'
});
assert.equal(forwardServer.fetchCalls[0].url, 'https://shared-grading-proxy.example.com/grade');
assert.equal(forwardServer.fetchCalls[0].body.keywordScore, 'I');

