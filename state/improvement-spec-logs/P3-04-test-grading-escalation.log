import assert from 'node:assert/strict';
import { readFileSync } from 'node:fs';
import path from 'node:path';
import vm from 'node:vm';
import { buildFrameworkContext, getFrameworkForQuestion } from './railway-server/frameworks.js';

const repoRoot = process.cwd();
const gradingEngineSource = readFileSync(path.join(repoRoot, 'js/grading/grading-engine.js'), 'utf8');
const gradingRulesSource = readFileSync(path.join(repoRoot, 'js/grading/frq-grading-rules.js'), 'utf8');
const serverSource = readFileSync(path.join(repoRoot, 'railway-server/server.js'), 'utf8');

function extractBetween(source, startMarker, endMarker) {
  const start = source.indexOf(startMarker);
  const end = source.indexOf(endMarker, start);
  if (start === -1 || end === -1) throw new Error("'`Missing markers: ${startMarker} -> ${endMarker}`);
  return source.slice(start, end).trim();
}

const gradeRouteSource = extractBetween(serverSource, "app.post('"'/api/ai/grade'\", '// Call Groq API with llama-3.3-70b-versatile');
const appealRouteSource = extractBetween(serverSource, \"app.post('/api/ai/appeal'\", '// Build appeal prompt - different from regular grading prompt');
const buildAppealPromptSource = extractBetween(serverSource, 'function buildAppealPrompt', '// Get server statistics');

function clone(value) {
  return value === undefined ? undefined : JSON.parse(JSON.stringify(value));
}

function createBrowserHarness(options = {}) {
  const sandbox = {
    window: {},
    fetch: options.fetchImpl,
    console,
    AbortController,
    setTimeout: options.setTimeoutImpl || setTimeout,
    clearTimeout: options.clearTimeoutImpl || clearTimeout
  };
  sandbox.window = sandbox;
  sandbox.window.RAILWAY_SERVER_URL = 'https://test-server.example.com';
  vm.createContext(sandbox);
  vm.runInContext(gradingRulesSource, sandbox);
  vm.runInContext(gradingEngineSource, sandbox);
  return {
    engine: new sandbox.window.GradingEngine({ serverUrl: 'https://test-server.example.com' }),
    rules: sandbox.window.FRQGradingRules
  };
}

function createServerHarness() {
  const routes = new Map();
  const prompts = [];
  const queued = [];
  const sandbox = {
    app: { post(route, handler) { routes.set(route, handler); } },
    gradingQueue: { getQueueLength() { return 0; }, async add(task) { return task(); } },
    callGroq: async (prompt) => {
      prompts.push(prompt);
      if (queued.length === 0) throw new Error('No queued Groq response');
      return clone(queued.shift());
    },
    GROQ_API_KEY: 'test-key',
    GROQ_MODEL: 'llama-3.3-70b-versatile',
    getFrameworkForQuestion,
    buildFrameworkContext,
    console,
    Object
  };
  vm.createContext(sandbox);
  vm.runInContext("'`${gradeRouteSource}'"\\n\\n"'${buildAppealPromptSource}'"\\n\\n"'${appealRouteSource}`, sandbox);
  return {
    prompts,
    queue(response) { queued.push(response); },
    async invoke(route, body) {
      let status = 200;
      let payload;
      await routes.get(route)({ body }, {
        status(code) { status = code; return this; },
        json(data) { payload = data; return this; }
      });
      return { status, ok: status >= 200 && status < 300, payload };
    }
  };
}

function createRouteFetch(server) {
  return async (url, options = {}) => {
    const pathname = new URL(url, '"'https://test-server.example.com').pathname;
    const result = await server.invoke(pathname, options.body ? JSON.parse(options.body) : undefined);
    return {
      ok: result.ok,
      status: result.status,
      async json() { return result.payload; }
    };
  };
}

const socsContext = {
  questionId: 'U4-L2-Q01',
  partId: 'answer',
  topic: 'AP Statistics',
  prompt: 'Describe the distribution of the exam scores.',
  variable: 'scores'
};

const server = createServerHarness();
server.queue({ score: 'P', feedback: 'partial understanding' });
server.queue({ score: 'E', feedback: 'appeal upgrade', appealGranted: true, appealResponse: 'upgraded' });
const browser = createBrowserHarness({ fetchImpl: createRouteFetch(server) });

const keyword = browser.engine.gradeRegex('The scores are skewed right.', browser.rules.describeDistributionSOCS, socsContext);
assert.equal(keyword.score, 'I');

const aiResult = await browser.engine.gradeDual('The scores are skewed right.', browser.rules.describeDistributionSOCS, socsContext);
assert.equal(aiResult.score, 'P');
assert.equal(aiResult._regexScore, 'I');

const appeal = await browser.engine.submitAppeal(
  'The scores are skewed right.',
  'I explained long-run probability through repeated simulation trials and relative frequency.',
  aiResult,
  {
    questionId: 'U4-L2-Q01',
    topic: 'AP Statistics',
    prompt: 'Explain how simulation estimates probability.',
    questionType: 'free-response'
  }
);
assert.equal(appeal.score, 'E');
assert.equal(appeal.upgraded, true);

const downgradeServer = createServerHarness();
downgradeServer.queue({ score: 'I', feedback: 'should be blocked', appealGranted: false });
const downgrade = await downgradeServer.invoke('/api/ai/appeal', {
  scenario: {
    questionId: 'U4-L2-Q01',
    topic: 'AP Statistics',
    prompt: 'Explain how simulation estimates probability.',
    questionType: 'free-response'
  },
  answers: { answer: 'Simulation uses repeated random trials.' },
  appealText: 'Please reconsider.',
  previousResults: { answer: { score: 'P', feedback: 'previous partial' } }
});
assert.equal(downgrade.payload.score, 'P');
assert.equal(downgrade.payload._downgradeBlocked, true);

const mcqServer = createServerHarness();
mcqServer.queue({ score: 'E', feedback: 'too generous' });
const mcq = await mcqServer.invoke('/api/ai/grade', {
  scenario: {
    questionId: 'U4-L2-Q01',
    topic: 'AP Statistics',
    questionType: 'multiple-choice',
    correctAnswer: 'A'
  },
  answers: { answer: 'B' },
  prompt: 'Grade this MCQ.'
});
assert.equal(mcq.payload.score, 'P');
assert.equal(mcq.payload._scoreCapped, true);

const promptServer = createServerHarness();
promptServer.queue({ score: 'P', feedback: 'capture prompt', appealGranted: false });
await promptServer.invoke('/api/ai/appeal', {
  scenario: {
    questionId: 'U4-L2-Q01',
    topic: 'AP Statistics',
    prompt: 'Explain how simulation estimates probability.',
    questionType: 'free-response'
  },
  answers: { answer: 'Simulation uses random outcomes.' },
  appealText: 'I referenced relative frequency and the long run.',
  previousResults: { answer: { score: 'P', feedback: 'needs more detail' } }
});
assert.match(promptServer.prompts[0], /Estimate probabilities using simulation/);
assert.match(promptServer.prompts[0], /relative frequency/i);
assert.doesNotMatch(promptServer.prompts[0], /UNC-2\\.A/);

