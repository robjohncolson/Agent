+          return this;
+        },
+        json(data) {
+          payload = data;
+          return this;
+        }
+      };
+
+      await handler({ body }, res);
+
+      return {
+        ok: statusCode >= 200 && statusCode < 300,
+        status: statusCode,
+        payload
+      };
+    }
+  };
