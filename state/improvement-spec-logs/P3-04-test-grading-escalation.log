+function createBrowserHarness(options = {}) {
+  const {
+    fetchImpl = vi.fn(),
+    setTimeoutImpl = setTimeout,
+    clearTimeoutImpl = clearTimeout,
+    serverUrl = 'https://test-server.example.com'
+  } = options;
+
+  const sandbox = {
