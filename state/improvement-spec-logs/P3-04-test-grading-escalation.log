+      }
+    );
+
+    expect(result.success).toBe(true);
+    expect(result.score).toBe('P');
+    expect(result.upgraded).toBe(false);
+  });
+
+  test('appeal injects AP framework context', async () => {
+    const server = createServerHarness();
+    server.queueGroqResponse({
+      score: 'P',
+      feedback: 'Prompt captured for inspection.',
+      appealGranted: false
+    });
+
+    await server.invoke('/api/ai/appeal', {
+      scenario: {
+        questionId: 'U4-L2-Q01',
+        topic: 'AP Statistics',
+        prompt: 'Explain how simulation estimates probability.',
+        questionType: 'free-response'
+      },
+      answers: {
+        answer: 'Simulation uses random outcomes.'
+      },
+      appealText: 'I also described relative frequency and long-run behavior.',
+      previousResults: {
+        answer: {
+          score: 'P',
+          feedback: 'Needs more lesson vocabulary.'
+        }
+      }
+    });
+
+    expect(server.prompts).toHaveLength(1);
+    expect(server.prompts[0]).toContain('## AP Statistics Framework Context');
+    expect(server.prompts[0]).toContain('Estimate probabilities using simulation');
+    expect(server.prompts[0]).toContain('The relative frequency of an outcome or event');
+    expect(server.prompts[0]).toContain('law of large numbers');
+    expect(server.prompts[0]).not.toContain('**UNC-2.A:');
+    expect(server.prompts[0]).not.toContain('UNC-2.A.1:');
+  });
+});
+
+describe('Invariant: Score Can Only Go Up', () => {
+  test('full escalation chain: I -> P (AI) -> E (appeal)', async () => {
+    const server = createServerHarness();
+    server.queueGroqResponse({
+      score: 'P',
+      feedback: 'The AI recognized partial understanding.'
+    });
+    server.queueGroqResponse({
