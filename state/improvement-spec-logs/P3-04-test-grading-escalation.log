+      prompts.push(prompt);
+
+      if (queuedResponses.length === 0) {
+        throw new Error(`No queued Groq response for prompt: ${prompt.slice(0, 80)}`);
+      }
+
+      return clone(queuedResponses.shift());
+    }),
