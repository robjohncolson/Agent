+  let data = {};
+
+  try {
+    data = responseText ? JSON.parse(responseText) : {};
+  } catch (err) {
+    throw new Error(responseText || `Invalid grading proxy response (${response.status})`);
+  }
+
+  if (!response.ok) {
+    throw new Error(data.error || `Grading proxy request failed (${response.status})`);
+  }
+
+  return data;
+}
