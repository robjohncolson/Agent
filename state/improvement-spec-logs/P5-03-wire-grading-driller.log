+    : Object.entries(fieldResults)
+      .map(([fieldId, result]) => `${fieldId}: ${result.feedback}`)
+      .join(' ');
+
+  return {
+    ...fieldResults,
+    ...summarizeProxyMetadata(proxyResults),
+    appealResponse: feedbackSummary,
+    feedback: feedbackSummary
+  };
+}
