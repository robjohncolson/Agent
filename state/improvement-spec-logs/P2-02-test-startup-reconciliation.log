+    )
+    return {
+        "engine": engine,
+        "ledger": ledger,
+        "slot": slot,
+        "recovery": recovery,
+    }
+
+
+def _build_restored_recovery_env(root, *, recovery: RecoveryOrder):
+    live = _build_recovery_env(root, recovery=recovery)
+    state_path, restored_engine, restored_ledger = _restore_from_disk(
+        root,
+        live["engine"],
+        live["ledger"],
+    )
+    restored_slot = _first_slot(restored_engine)
