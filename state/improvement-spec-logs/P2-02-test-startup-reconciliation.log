from __future__ import annotations

import asyncio
from dataclasses import replace
import json
import time

import pytest

import slot_engine as slot_engine_module
from bot_types import GovernorActions, PlaceOrderAction, RecoveryOrder
from ledger import Ledger
from main import poll_fills, reconcile_recovery_orders
from server import CommentatorEngine
from slot_engine import SlotEngine
from state_machine import derive_phase
from tests.conftest import (
    MockExchangeAdapter,
    make_engine_config as _make_engine_config,
    make_pair_state as _make_pair_state,
    make_slot_runtime as _make_slot_runtime,
)


@pytest.fixture
def mock_adapter() -> MockExchangeAdapter:
    return MockExchangeAdapter()


@pytest.fixture
def make_pair_state():
    return _make_pair_state


@pytest.fixture
def make_engine_config():
    return _make_engine_config


@pytest.fixture
def make_slot():
    return _make_slot_runtime


def _run(coro):
    loop = asyncio.new_event_loop()
    try:
        return loop.run_until_complete(coro)
    finally:
        loop.close()


def _first_slot(engine: SlotEngine):
    return next(iter(engine.all_slots().values()))


def _find_order(slot, *, role: str, side: str | None = None,
                txid: str | None = None, trade_id: str | None = None):
    for order in slot.state.orders:
        if order.role != role:
            continue
        if side is not None and order.side != side:
            continue
        if txid is not None and order.txid != txid:
            continue
        if trade_id is not None and order.trade_id != trade_id:
            continue
        return order
    raise AssertionError(f"Could not find order role={role!r} side={side!r} txid={txid!r}")


def _find_recovery(slot, txid: str):
    for recovery in slot.state.recovery_orders:
        if recovery.txid == txid:
            return recovery
    raise AssertionError(f"Could not find recovery txid={txid!r}")


def _place_live_orders(engine: SlotEngine, adapter: MockExchangeAdapter) -> None:
    for slot in engine.all_slots().values():
        place_actions = [
            PlaceOrderAction(
                local_id=order.local_id,
                side=order.side,
                role=order.role,
                price=order.price,
                volume=order.volume,
                trade_id=order.trade_id,
                cycle=order.cycle,
                post_only=True,
            )
            for order in slot.state.orders
            if not order.txid
        ]
        if place_actions:
            _run(engine.execute_actions(slot, place_actions, adapter))


def _restore_from_disk(root, engine: SlotEngine, ledger: Ledger):
    state_path = root / "state.json"
    engine.save_to_file(str(state_path))
    ledger.save()

    restored_engine = SlotEngine(initial_slots=0)
    assert restored_engine.load_from_file(str(state_path)) is True

    restored_ledger = Ledger(ledger_file=str(root / "ledger.jsonl"))
    restored_ledger.load()
    for slot in restored_engine.all_slots().values():
        slot.account = restored_ledger.get_slot_account(slot.slot_id)

    return state_path, restored_engine, restored_ledger


def _build_active_entry_env(root, adapter: MockExchangeAdapter, *,
                            profit_pct_runtime: float | None = None,
                            target_side: str = "buy"):
    ledger = Ledger(ledger_file=str(root / "ledger.jsonl"))
    engine = SlotEngine(initial_slots=1, initial_sticky_ratio=1.0)
    engine.initialize(market_price=0.09, order_size_usd=2.0)
    slot = _first_slot(engine)
    if profit_pct_runtime is not None:
        slot.state = replace(slot.state, profit_pct_runtime=float(profit_pct_runtime))
    _place_live_orders(engine, adapter)
    entry = _find_order(slot, role="entry", side=target_side)
    return {
        "engine": engine,
        "ledger": ledger,
        "slot": slot,
        "entry": entry,
    }


def _build_restored_active_entry_env(root, adapter: MockExchangeAdapter, *,
                                     profit_pct_runtime: float | None = None,
                                     target_side: str = "buy"):
    live = _build_active_entry_env(
        root,
        adapter,
        profit_pct_runtime=profit_pct_runtime,
        target_side=target_side,
    )
    state_path, restored_engine, restored_ledger = _restore_from_disk(
        root,
        live["engine"],
        live["ledger"],
    )
    restored_slot = _first_slot(restored_engine)
    restored_entry = _find_order(
        restored_slot,
        role="entry",
        txid=live["entry"].txid,
    )
    return {
        **live,
        "state_path": state_path,
        "restored_engine": restored_engine,
        "restored_ledger": restored_ledger,
        "restored_slot": restored_slot,
        "restored_entry": restored_entry,
    }


def _build_restored_open_exit_env(root, adapter: MockExchangeAdapter, *,
                                  profit_pct_runtime: float | None = None,
                                  target_side: str = "buy",
                                  entry_fee: float = 0.0):
    env = _build_active_entry_env(
        root,
        adapter,
        profit_pct_runtime=profit_pct_runtime,
        target_side=target_side,
    )
    entry = env["entry"]
    adapter.simulate_fill(
        entry.txid,
        price=entry.price,
        volume=entry.volume,
        fee=entry_fee,
    )
    had_fill = _run(poll_fills(
        adapter=adapter,
        slot_engine=env["engine"],
        ledger=env["ledger"],
        commentator=CommentatorEngine(),
        governor_actions=GovernorActions(),
    ))
    assert had_fill is True

    live_slot = env["slot"]
    open_exit = _find_order(live_slot, role="exit", trade_id=entry.trade_id)
    state_path, restored_engine, restored_ledger = _restore_from_disk(
        root,
        env["engine"],
        env["ledger"],
    )
    restored_slot = _first_slot(restored_engine)
    restored_exit = _find_order(restored_slot, role="exit", txid=open_exit.txid)
    return {
        **env,
        "state_path": state_path,
        "open_exit": open_exit,
        "restored_engine": restored_engine,
        "restored_ledger": restored_ledger,
        "restored_slot": restored_slot,
        "restored_exit": restored_exit,
    }


def _build_recovery_env(root, *, recovery: RecoveryOrder):
    ledger = Ledger(ledger_file=str(root / "ledger.jsonl"))
    engine = SlotEngine(initial_slots=0)
    slot = engine.add_slot(sticky=True)
    assert slot is not None
    slot.state = replace(
        slot.state,
        market_price=0.091,
        orders=(),
        recovery_orders=(recovery,),
        next_recovery_id=recovery.recovery_id + 1,
    )
    return {
        "engine": engine,
        "ledger": ledger,
        "slot": slot,
        "recovery": recovery,
    }


def _build_restored_recovery_env(root, *, recovery: RecoveryOrder):
    live = _build_recovery_env(root, recovery=recovery)
    state_path, restored_engine, restored_ledger = _restore_from_disk(
        root,
        live["engine"],
        live["ledger"],
    )
    restored_slot = _first_slot(restored_engine)
    restored_recovery = _find_recovery(restored_slot, recovery.txid)
    return {
        **live,
        "state_path": state_path,
        "restored_engine": restored_engine,
        "restored_ledger": restored_ledger,
        "restored_slot": restored_slot,
        "restored_recovery": restored_recovery,
    }


def _complete_cycle_from_entry(engine: SlotEngine, ledger: Ledger,
                               adapter: MockExchangeAdapter, *,
                               entry_txid: str,
                               entry_fee: float,
                               exit_fee: float):
    commentator = CommentatorEngine()
    slot = _first_slot(engine)
    entry = _find_order(slot, role="entry", txid=entry_txid)
    adapter.simulate_fill(
        entry.txid,
        price=entry.price,
        volume=entry.volume,
        fee=entry_fee,
    )
    assert _run(poll_fills(
        adapter=adapter,
        slot_engine=engine,
        ledger=ledger,
        commentator=commentator,
        governor_actions=GovernorActions(),
    )) is True

    exit_order = _find_order(slot, role="exit", trade_id=entry.trade_id)
    adapter.simulate_fill(
        exit_order.txid,
        price=exit_order.price,
        volume=exit_order.volume,
        fee=exit_fee,
    )
    assert _run(poll_fills(
        adapter=adapter,
        slot_engine=engine,
        ledger=ledger,
        commentator=commentator,
        governor_actions=GovernorActions(),
    )) is True

    cycle = slot.state.completed_cycles[-1]
    account = ledger.get_slot_account(slot.slot_id)
    return {
        "exit_price": exit_order.price,
        "net_profit": cycle.net_profit,
        "fees": cycle.fees,
        "ledger_profit": account.total_profit_usd,
        "ledger_fees": account.total_fees_usd,
    }


class TestStartupStateLoad:
    """State loading from persisted files."""

    def test_loads_slot_state_from_json(self, tmp_path, mock_adapter):
        env = _build_restored_open_exit_env(
            tmp_path / "startup-load",
            mock_adapter,
            profit_pct_runtime=1.7,
            entry_fee=0.01,
        )

        live_slot = env["slot"]
        restored_slot = env["restored_slot"]

        assert env["state_path"].exists()
        assert restored_slot.slot_id == live_slot.slot_id
        assert derive_phase(restored_slot.state) == derive_phase(live_slot.state)
        assert restored_slot.state.profit_pct_runtime == pytest.approx(1.7)
        assert {order.txid for order in restored_slot.state.orders} == {
            order.txid for order in live_slot.state.orders
        }

    def test_replays_ledger_to_current_state(self, tmp_path, make_slot, make_pair_state):
        slot = make_slot(
            slot_id=3,
            sticky=True,
            state=make_pair_state(market_price=0.09, now=1_700_000_000.0),
        )
        engine = SlotEngine(initial_slots=0)
        engine._slots = {slot.slot_id: slot}
        engine._next_slot_id = slot.slot_id + 1
        state_path = tmp_path / "state.json"
        engine.save_to_file(str(state_path))

        ledger = Ledger(ledger_file=str(tmp_path / "ledger.jsonl"))
        ledger.record_entry_fill(
            slot_id=3,
            trade_id="B",
            cycle=1,
            side="buy",
            price=0.09,
            volume=100.0,
            fee=0.01,
            txid="ENTRY-3",
        )
        ledger.record_exit_fill(
            slot_id=3,
            trade_id="B",
            cycle=1,
            side="sell",
            price=0.091,
            volume=100.0,
            fee=0.01,
            txid="EXIT-3",
            entry_price=0.09,
        )
        ledger.book_cycle_profit(
            slot_id=3,
            trade_id="B",
            cycle=1,
            entry_price=0.09,
            exit_price=0.091,
            volume=100.0,
            fees=0.02,
        )
        ledger.save()

        restored_engine = SlotEngine(initial_slots=0)
        assert restored_engine.load_from_file(str(state_path)) is True
        restored_ledger = Ledger(ledger_file=str(tmp_path / "ledger.jsonl"))
        restored_ledger.load()
        restored_slot = restored_engine.get_slot(3)
        assert restored_slot is not None
        restored_slot.account = restored_ledger.get_slot_account(3)

        assert restored_slot.account.total_profit_usd == pytest.approx(0.08)
        assert restored_slot.account.total_fees_usd == pytest.approx(0.01091)
        assert restored_slot.account.round_trips == 1
        assert restored_ledger.earliest_entry_ts > 0.0

    def test_handles_missing_state_file_gracefully(self, tmp_path):
        engine = SlotEngine(initial_slots=0)
        assert engine.load_from_file(str(tmp_path / "missing-state.json")) is False
        assert engine.slot_count() == 0

    @pytest.mark.xfail(
        raises=json.JSONDecodeError,
        reason="startup restore still propagates partial state.json writes",
    )
    def test_handles_corrupted_state_file(self, tmp_path):
        path = tmp_path / "state.json"
        path.write_text('{"slots": ', encoding="utf-8")
        SlotEngine(initial_slots=0).load_from_file(str(path))


class TestStartupReconciliation:
    """Reconciliation between persisted state and exchange."""

    def test_detects_orders_filled_while_offline(self, tmp_path, mock_adapter):
        env = _build_restored_open_exit_env(
            tmp_path / "offline-fill",
            mock_adapter,
            profit_pct_runtime=1.7,
            entry_fee=0.01,
        )
        restored_slot = env["restored_slot"]
        exit_order = env["restored_exit"]

        mock_adapter.simulate_fill(
            exit_order.txid,
            price=exit_order.price,
            volume=exit_order.volume,
            fee=0.02,
        )
        had_fill = _run(poll_fills(
            adapter=mock_adapter,
            slot_engine=env["restored_engine"],
            ledger=env["restored_ledger"],
            commentator=CommentatorEngine(),
            governor_actions=GovernorActions(),
        ))

        assert had_fill is True
        assert len(restored_slot.state.completed_cycles) == 1
        assert any(
            entry.entry_type == "CYCLE_PROFIT" and entry.trade_id == exit_order.trade_id
            for entry in env["restored_ledger"].recent_entries(limit=50)
        )
        assert any(
            entry.entry_type in ("BUY_EXIT", "SELL_EXIT") and entry.txid == exit_order.txid
            for entry in env["restored_ledger"].recent_entries(limit=50)
        )

    def test_reconciliation_uses_same_transition_as_normal_fill(self, tmp_path, monkeypatch):
        recovery = RecoveryOrder(
            recovery_id=21,
            side="sell",
            price=0.092,
            volume=100.0,
            trade_id="B",
            cycle=2,
            entry_price=0.09,
            orphaned_at=time.time() - 300,
            txid="REC-SAME-PATH",
        )
        live_env = _build_recovery_env(tmp_path / "normal", recovery=recovery)
        startup_env = _build_restored_recovery_env(tmp_path / "startup", recovery=recovery)

        live_adapter = MockExchangeAdapter()
        startup_adapter = MockExchangeAdapter()
        live_adapter._closed_orders[recovery.txid] = {
            "status": "closed",
            "vol_exec": str(recovery.volume),
            "price": str(recovery.price),
            "fee": "0.01",
        }
        startup_adapter._closed_orders[recovery.txid] = dict(live_adapter._closed_orders[recovery.txid])

        captured: list[dict] = []
        original_transition = slot_engine_module.transition

        def _spy_transition(state, event, cfg, order_size_usd, order_sizes=None):
            if type(event).__name__ == "RecoveryFillEvent":
                captured.append({
                    "event_type": type(event).__name__,
                    "recovery_id": int(event.recovery_id),
                    "txid": str(event.txid),
                    "side": str(event.side),
                    "price": float(event.price),
                    "volume": float(event.volume),
                    "fee": float(event.fee),
                    "state_profit_pct_runtime": float(state.profit_pct_runtime),
                    "cfg_entry_pct": float(cfg.entry_pct),
                    "cfg_profit_pct": float(cfg.profit_pct),
                    "cfg_maker_fee_pct": float(cfg.maker_fee_pct),
                    "order_size_usd": float(order_size_usd),
                    "order_sizes": dict(order_sizes or {}),
                })
            return original_transition(state, event, cfg, order_size_usd, order_sizes)

        monkeypatch.setattr(slot_engine_module, "transition", _spy_transition)

        _run(poll_fills(
            adapter=live_adapter,
            slot_engine=live_env["engine"],
            ledger=live_env["ledger"],
            commentator=CommentatorEngine(),
            governor_actions=GovernorActions(),
        ))
        normal_call = captured.pop()

        _run(reconcile_recovery_orders(
            adapter=startup_adapter,
            slot_engine=startup_env["restored_engine"],
            ledger=startup_env["restored_ledger"],
            commentator=CommentatorEngine(),
            governor_actions=GovernorActions(),
        ))
        startup_call = captured.pop()

        assert startup_call == normal_call

    def test_reconciliation_handles_cancelled_orders(self, tmp_path, mock_adapter):
        recovery = RecoveryOrder(
            recovery_id=22,
            side="buy",
            price=0.088,
            volume=100.0,
            trade_id="A",
            cycle=5,
            entry_price=0.09,
            orphaned_at=time.time() - 400,
            txid="REC-CANCELLED",
        )
        env = _build_restored_recovery_env(tmp_path / "cancelled-recovery", recovery=recovery)
        mock_adapter._closed_orders[recovery.txid] = {
            "status": "canceled",
            "vol_exec": "0.0",
            "price": str(recovery.price),
            "fee": "0.0",
        }

        _run(reconcile_recovery_orders(
            adapter=mock_adapter,
            slot_engine=env["restored_engine"],
            ledger=env["restored_ledger"],
            commentator=CommentatorEngine(),
            governor_actions=GovernorActions(),
        ))

        assert len(env["restored_slot"].state.recovery_orders) == 0
        assert any(
            entry.entry_type == "WRITE_OFF"
            for entry in env["restored_ledger"].recent_entries(limit=50)
        )
        assert env["restored_slot"].account.total_write_offs_usd == pytest.approx(
            env["restored_ledger"].get_slot_account(env["restored_slot"].slot_id).total_write_offs_usd
        )

    def test_slot_phase_consistent_after_reconciliation(self, tmp_path, mock_adapter):
        env = _build_restored_open_exit_env(
            tmp_path / "phase-consistency",
            mock_adapter,
            profit_pct_runtime=1.7,
            entry_fee=0.01,
        )
        exit_order = env["restored_exit"]

        mock_adapter.simulate_fill(
            exit_order.txid,
            price=exit_order.price,
            volume=exit_order.volume,
            fee=0.02,
        )
        _run(poll_fills(
            adapter=mock_adapter,
            slot_engine=env["restored_engine"],
            ledger=env["restored_ledger"],
            commentator=CommentatorEngine(),
            governor_actions=GovernorActions(),
        ))

        assert derive_phase(env["restored_slot"].state) == "S0"


class TestStartupFeeConsistency:
    """Fee calculation must be identical at startup and during normal operation."""

    def test_startup_fee_path_matches_normal_fee_path(self, tmp_path):
        live_adapter = MockExchangeAdapter()
        startup_adapter = MockExchangeAdapter()

        live_env = _build_active_entry_env(
            tmp_path / "live-cycle",
            live_adapter,
            profit_pct_runtime=1.7,
            target_side="buy",
        )
        startup_env = _build_restored_active_entry_env(
            tmp_path / "startup-cycle",
            startup_adapter,
            profit_pct_runtime=1.7,
            target_side="buy",
        )

        live_result = _complete_cycle_from_entry(
            live_env["engine"],
            live_env["ledger"],
            live_adapter,
            entry_txid=live_env["entry"].txid,
            entry_fee=0.01,
            exit_fee=0.02,
        )
        startup_result = _complete_cycle_from_entry(
            startup_env["restored_engine"],
