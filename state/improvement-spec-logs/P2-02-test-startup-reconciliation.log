+        orders=(),
+        recovery_orders=(recovery,),
+        next_recovery_id=recovery.recovery_id + 1,
+    )
+    return {
+        "engine": engine,
+        "ledger": ledger,
+        "slot": slot,
+        "recovery": recovery,
+    }
