+  }
+
+  const requestedModeId = getModeId(requestedModeNumber);
+  if (!requestedModeId) {
+    return defaultModeId;
+  }
+
+  const state = platform.gameEngine.getState();
+  const firstIncompletePrerequisite = findFirstIncompletePrerequisite(requestedModeNumber, state);
+
+  return firstIncompletePrerequisite ?? requestedModeId;
+}
