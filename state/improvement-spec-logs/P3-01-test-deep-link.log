+  );
+
+  for (const modeNumber of completedModes) {
+    const requiredGold = getRequiredGoldForMode(modeNumber + 1);
+    setModeGold(engine, modeNumber, requiredGold);
+    engine.starCounts.gold += requiredGold;
+  }
+
+  engine.unlockedTiers = [];
