+      manifest: {
+        ...manifest,
+        meta: {
+          ...manifest.meta,
+          id: cartridgeId
+        }
+      },
+      gradingRules: {
+        gradeField: vi.fn(() => ({ score: 'E', feedback: 'Correct' }))
+      }
+    })),
+    getModes: vi.fn(() => manifest.modes),
+    getMode: vi.fn((modeId) => manifest.modes.find((mode) => mode.id === modeId)),
+    generateProblem: vi.fn(async (modeId) => ({
+      context: { modeId },
+      answers: {},
+      scenario: `Problem for ${modeId}`,
+      graphConfig: null
+    }))
+  };
+}
+
+function parseQueryParams(search) {
+  const params = new URLSearchParams(search);
+  const rawMode = params.get('mode');
+
+  return {
+    cartridge: params.get('cartridge'),
+    mode: rawMode ? Number.parseInt(rawMode, 10) : null
+  };
+}
+
+function findFirstIncompletePrerequisite(modeNumber, state) {
+  for (let currentModeNumber = 1; currentModeNumber < modeNumber; currentModeNumber++) {
+    const currentModeId = getModeId(currentModeNumber);
+    const requiredGold = getRequiredGoldForMode(currentModeNumber + 1);
+    const earnedGold = state.starsPerMode?.[currentModeId]?.gold ?? 0;
+
+    if (earnedGold < requiredGold) {
+      return currentModeId;
+    }
+  }
+
+  return null;
+}
+
+function resolveRequestedModeId(requestedModeNumber, platform) {
+  const defaultModeId = platform.currentMode ?? getModeId(1);
+
+  if (!requestedModeNumber) {
