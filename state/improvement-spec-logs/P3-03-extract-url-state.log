import assert from 'node:assert/strict';
import { readFileSync } from 'node:fs';
import { Platform } from './platform/platform.js';
import { GameEngine } from './platform/core/game-engine.js';
import { buildShareURL, parseQueryParams, restoreStateFromURL, updateURL } from './platform/core/url-state.js';

const manifest = JSON.parse(
  readFileSync(new URL('./cartridges/apstats-u5-sampling-dist/manifest.json', import.meta.url), 'utf8')
);

const localStorageMock = (() => {
  let store = {};
  return {
    getItem(key) { return key in store ? store[key] : null; },
    setItem(key, value) { store[key] = value; },
    removeItem(key) { delete store[key]; },
    clear() { store = {}; }
  };
})();

globalThis.localStorage = localStorageMock;

globalThis.history = { replaceState() {} };
globalThis.window = {
  location: new URL('https://example.test/platform/app.html'),
  history: globalThis.history
};

function getModeId(modeNumber) {
  return manifest.modes[modeNumber - 1]?.id ?? null;
}

function getRequiredGoldForMode(modeNumber) {
  const mode = manifest.modes[modeNumber - 1];
  if ("'!mode || mode.unlockedBy === '"'default') {
    return 0;
  }
  return mode.unlockedBy?.gold ?? 1;
}

function setModeGold(engine, modeNumber, gold) {
  const modeId = getModeId(modeNumber);
  engine.starsPerMode[modeId] = { gold, silver: 0, bronze: 0, tin: 0 };
}

function persistProgress({ activeModeNumber = 1, completedModeNumbers = [] } = {}) {
  const engine = new GameEngine();
  engine.loadCartridge(manifest);
  engine.starCounts = { gold: 0, silver: 0, bronze: 0, tin: 0 };

  for (const modeNumber of completedModeNumbers) {
    const requiredGold = getRequiredGoldForMode(modeNumber + 1);
    setModeGold(engine, modeNumber, requiredGold);
    engine.starCounts.gold += requiredGold;
  }

  engine.unlockedTiers = [];
  engine.checkUnlocks(engine.unlockRules);
  engine.currentTier = getModeId(activeModeNumber);
  engine.saveState();
}

persistProgress({ activeModeNumber: 2, completedModeNumbers: [1, 2] });

const loader = {
  load: async (cartridgeId) => ({
    manifest: {
      ...manifest,
      meta: { ...manifest.meta, id: cartridgeId }
    },
    gradingRules: {
      gradeField: () => ({ score: 'E', feedback: 'Correct' })
    }
  }),
  getModes: () => manifest.modes,
  getMode: (modeId) => manifest.modes.find((mode) => mode.id === modeId),
  generateProblem: async (modeId) => ({
    context: { modeId },
    answers: {},
    scenario: "'`Problem for ${modeId}`,
    graphConfig: null
  })
};

const parsed = parseQueryParams(`?cartridge=${manifest.meta.id}&mode=5`);
assert.equal(parsed.mode, 5);

const platform = new Platform();
platform.cartridgeLoader = loader;
platform.gameEngine.onStarEarned = () => {};
platform.gameEngine.onTierUnlocked = () => {};
platform.gameEngine.onStreakUpdate = () => {};
await platform.loadCartridge(parsed.cartridge);

const resolution = restoreStateFromURL(parsed, {
  modes: manifest.modes,
  state: platform.gameEngine.getState(),
  currentMode: platform.currentMode,
  getRequiredGold: (modeId) => platform.gameEngine.getRequiredGold(modeId)
});
assert.equal(resolution.modeId, getModeId(3));
assert.equal(resolution.wasRedirected, true);

const historyCalls = [];
const url = updateURL(parsed.cartridge, resolution.modeNumber, {
  location: new URL('"'https://example.test/platform/app.html?level=old'),
  history: { replaceState: (...args) => historyCalls.push(args) }
});
assert.equal(url.includes('mode=3'), true);
assert.equal(historyCalls.length, 1);

const shareUrl = buildShareURL(parsed.cartridge, 3, {
  location: new URL('https://example.test/platform/app.html?mode=99')
});
assert.equal(shareUrl, "'`https://example.test/platform/app.html?cartridge=${manifest.meta.id}&mode=3`);

