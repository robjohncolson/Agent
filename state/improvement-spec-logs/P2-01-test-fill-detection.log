+        ))
+
+        assert derive_phase(slot.state) == "S0"
+        assert len(slot.state.recovery_orders) == 0
+        assert slot.state.completed_cycles[-1].from_recovery is True
+        assert {order.trade_id for order in slot.state.orders if order.role == "entry"} == {"A", "B"}
+        assert any(entry.entry_type == "RECOVERY_FILL" for entry in ledger.recent_entries(limit=20))
+
+    def test_startup_reconcile_clears_canceled_recovery_as_write_off(
+        self,
+        tmp_path,
+        mock_adapter,
+        make_pair_state,
+        make_engine_config,
+    ):
+        """Bug class: startup cancel detection must write off stale recovery risk immediately."""
+        state, _, recovery, _ = _make_orphaned_recovery_state(
+            make_pair_state,
+            make_engine_config,
+            trade_id="B",
+        )
+        engine, slot, ledger, commentator = _make_runtime(tmp_path, state, sticky=False)
+        live_entry_ids = {order.local_id for order in slot.state.orders if order.role == "entry"}
+        mock_adapter._closed_orders[recovery.txid] = {
+            "status": "canceled",
+            "vol_exec": 0.0,
+            "price": recovery.price,
+            "fee": 0.0,
+        }
+
+        _run(reconcile_recovery_orders(
+            adapter=mock_adapter,
+            slot_engine=engine,
+            ledger=ledger,
+            commentator=commentator,
+            governor_actions=GovernorActions(),
+        ))
+
+        assert len(slot.state.recovery_orders) == 0
+        assert {order.local_id for order in slot.state.orders if order.role == "entry"} == live_entry_ids
+        assert derive_phase(slot.state) == "S0"
+        assert any(entry.entry_type == "WRITE_OFF" for entry in ledger.recent_entries(limit=20))
+
