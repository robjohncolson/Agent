+class TestPath4RecoveryCancel:
+    """PATH 4: Recovery-order cancel/expiry handling."""
+
+    def test_recovery_cancel_removes_only_the_recovery_and_keeps_live_entries(
+        self,
+        make_pair_state,
+        make_engine_config,
+    ):
+        """Bug class: recovery cancel must not mutate the live ladder around it."""
+        state, _, recovery, _ = _make_orphaned_recovery_state(
+            make_pair_state,
+            make_engine_config,
+            trade_id="A",
+        )
+        engine = SlotEngine(initial_slots=0)
