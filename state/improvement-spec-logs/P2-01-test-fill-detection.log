+    state: PairState,
+    *,
+    cfg: EngineConfig,
+    side: str,
+    order_size_usd: float,
+) -> PairState:
+    entry = next(
+        order for order in state.orders
+        if order.role == "entry" and order.side == side
+    )
+    filled, _ = transition(
+        state,
+        FillEvent(
+            order_local_id=entry.local_id,
+            txid=entry.txid or f"FILL-{entry.local_id}",
+            side=entry.side,
+            price=entry.price,
+            volume=entry.volume,
+            fee=_fill_fee(entry.price, entry.volume, cfg),
+            timestamp=state.now + 1.0,
+        ),
+        cfg,
+        order_size_usd,
+    )
+    return filled
+
