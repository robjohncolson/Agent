+                order_size_usd=order_size_usd,
+            )
+        elif phase == "S1a_short_only":
+            state = replace(
+                state,
+                orders=tuple(order for order in state.orders if order.side == "sell"),
+                long_only=False,
+                short_only=True,
+                mode_source="balance",
+            )
+            state = _fill_entry_for_phase(
+                state,
+                cfg=cfg,
+                side="sell",
+                order_size_usd=order_size_usd,
+            )
+        elif phase == "S1b_long_only":
+            state = replace(
+                state,
+                orders=tuple(order for order in state.orders if order.side == "buy"),
+                long_only=True,
+                short_only=False,
+                mode_source="balance",
+            )
+            state = _fill_entry_for_phase(
+                state,
+                cfg=cfg,
+                side="buy",
+                order_size_usd=order_size_usd,
+            )
+        elif phase != "S0":
+            raise ValueError(f"Unsupported phase for test fixture: {phase}")
+
+        if bind_txids:
+            state = _bind_order_txids(state, txid_prefix)
+        if overrides:
+            state = replace(state, **overrides)
+        return state
+
+    return _factory
+
+
+@pytest.fixture
+def make_slot(make_pair_state):
+    """Factory for SlotRuntime with customizable state and phase."""
+
+    def _factory(
+        *,
+        slot_id: int = 1,
+        sticky: bool = True,
+        phase: str = "S0",
+        state: PairState | None = None,
+        paused: bool = False,
+        alias: str | None = None,
+        created_at: float | None = None,
+        **state_kwargs,
+    ) -> SlotRuntime:
+        runtime_state = state or make_pair_state(
