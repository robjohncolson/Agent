+            sticky=sticky,
+            **state_kwargs,
+        )
+        return SlotRuntime(
+            slot_id=slot_id,
+            state=runtime_state,
+            sticky=sticky,
+            alias=alias or f"Slot {slot_id}",
+            account=SlotAccount(slot_id=slot_id),
+            created_at=float(time.time() if created_at is None else created_at),
+            paused=paused,
+        )
+
+    return _factory
+
