+from __future__ import annotations
+
+import asyncio
+from dataclasses import replace
+
+import pytest
+
+from bot_types import (
+    BookCycleAction,
+    GovernorActions,
+    PlaceOrderAction,
+    PriceTick,
+    RecoveryCancelEvent,
+    RecoveryFillEvent,
+    TimerTick,
+    derive_phase,
+    transition,
+)
+from ledger import Ledger
+from main import poll_fills, reconcile_recovery_orders
+from server import CommentatorEngine
+from slot_engine import SlotEngine
+
+
+def _run(coro):
+    loop = asyncio.new_event_loop()
+    try:
+        return loop.run_until_complete(coro)
+    finally:
+        loop.close()
+
+
+def _make_runtime(tmp_path, state, *, sticky: bool = True):
+    engine = SlotEngine(initial_slots=0)
+    slot = engine.add_slot(sticky=sticky)
+    assert slot is not None
+    slot.state = state
+    ledger = Ledger(str(tmp_path / "fill-path-ledger.jsonl"))
+    commentator = CommentatorEngine()
+    return engine, slot, ledger, commentator
+
+
+def _bind_live_orders(engine: SlotEngine, slot, adapter) -> None:
+    actions = [
+        PlaceOrderAction(
+            local_id=order.local_id,
+            side=order.side,
+            role=order.role,
+            price=order.price,
+            volume=order.volume,
+            trade_id=order.trade_id,
+            cycle=order.cycle,
+            post_only=True,
+            reason="test_bind",
+        )
+        for order in slot.state.orders
+        if not order.txid
+    ]
+    if actions:
+        _run(engine.execute_actions(slot, actions, adapter, governor_actions=GovernorActions()))
+
+
+def _make_orphaned_recovery_state(make_pair_state, make_engine_config, *, trade_id: str):
+    cfg = make_engine_config(
+        sticky_mode_enabled=False,
+        refresh_pct=float("inf"),
+        s1_orphan_after_sec=60.0,
+    )
+    phase = "S1a" if trade_id == "A" else "S1b"
+    state = make_pair_state(
+        phase=phase,
+        sticky=False,
+        bind_txids=True,
+        txid_prefix=f"REC-{trade_id}",
+    )
+    exit_order = next(
+        order
+        for order in state.orders
+        if order.role == "exit" and order.trade_id == trade_id
+    )
+    moved_price = exit_order.price + 0.01 if exit_order.side == "buy" else max(0.000001, exit_order.price - 0.01)
+    state = replace(
+        state,
+        market_price=moved_price,
+        last_price_update_at=state.now,
+        orders=tuple(
+            replace(
+                order,
+                entry_filled_at=(state.now - 180.0 if order.local_id == exit_order.local_id else order.entry_filled_at),
+                placed_at=(state.now - 180.0 if order.local_id == exit_order.local_id else order.placed_at),
+            )
+            for order in state.orders
+        ),
+    )
+    state, _ = transition(
+        state,
+        PriceTick(price=moved_price, timestamp=state.now),
+        cfg,
+        cfg.order_size_usd,
+    )
+    state, actions = transition(
+        state,
+        TimerTick(timestamp=state.now + 120.0),
+        cfg,
+        cfg.order_size_usd,
+    )
+    assert state.recovery_orders
+    return state, cfg, state.recovery_orders[0], actions
+
+
+class TestPath1NormalPollFill:
+    """PATH 1: Normal fill detection through tracked active-order polling."""
+
+    def test_poll_detects_buy_entry_fill_and_transitions_to_s1b(
+        self,
+        tmp_path,
+        mock_adapter,
+        make_pair_state,
+    ):
+        """Bug class: normal poll once left filled buy entries stranded in S0."""
+        state = make_pair_state(phase="S0", with_entry_orders=True)
+        engine, slot, ledger, commentator = _make_runtime(tmp_path, state)
+        _bind_live_orders(engine, slot, mock_adapter)
+
+        entry = next(order for order in slot.state.orders if order.role == "entry" and order.side == "buy")
+        mock_adapter.simulate_fill(entry.txid, price=entry.price, volume=entry.volume, fee=0.0)
+
+        had_fill = _run(poll_fills(
+            adapter=mock_adapter,
+            slot_engine=engine,
+            ledger=ledger,
+            commentator=commentator,
+            governor_actions=GovernorActions(),
+        ))
+
+        assert had_fill is True
+        assert derive_phase(slot.state) == "S1b"
+        assert any(order.role == "exit" and order.side == "sell" and order.trade_id == "B" for order in slot.state.orders)
+        assert any(order.role == "entry" and order.side == "sell" and order.trade_id == "A" for order in slot.state.orders)
+
+    def test_poll_detects_sell_entry_fill_and_transitions_to_s1a(
+        self,
+        tmp_path,
+        mock_adapter,
+        make_pair_state,
+    ):
+        """Bug class: normal poll once missed filled sell entries after price spikes."""
+        state = make_pair_state(phase="S0", with_entry_orders=True)
+        engine, slot, ledger, commentator = _make_runtime(tmp_path, state)
+        _bind_live_orders(engine, slot, mock_adapter)
+
+        entry = next(order for order in slot.state.orders if order.role == "entry" and order.side == "sell")
+        mock_adapter.simulate_fill(entry.txid, price=entry.price, volume=entry.volume, fee=0.0)
+
+        had_fill = _run(poll_fills(
+            adapter=mock_adapter,
+            slot_engine=engine,
+            ledger=ledger,
+            commentator=commentator,
+            governor_actions=GovernorActions(),
+        ))
+
+        assert had_fill is True
+        assert derive_phase(slot.state) == "S1a"
+        assert any(order.role == "exit" and order.side == "buy" and order.trade_id == "A" for order in slot.state.orders)
+        assert any(order.role == "entry" and order.side == "buy" and order.trade_id == "B" for order in slot.state.orders)
+
+    def test_poll_exit_fill_books_cycle_and_reseeds_back_to_s0(
+        self,
+        tmp_path,
+        mock_adapter,
+        make_pair_state,
+    ):
+        """Bug class: exit fills must book PnL and immediately restore the completed side."""
+        state = make_pair_state(phase="S1a")
+        engine, slot, ledger, commentator = _make_runtime(tmp_path, state)
+        _bind_live_orders(engine, slot, mock_adapter)
+
+        exit_order = next(order for order in slot.state.orders if order.role == "exit" and order.trade_id == "A")
+        fill_price = exit_order.price
+        exit_fee = 0.02
+        mock_adapter.simulate_fill(exit_order.txid, price=fill_price, volume=exit_order.volume, fee=exit_fee)
+
+        had_fill = _run(poll_fills(
+            adapter=mock_adapter,
+            slot_engine=engine,
+            ledger=ledger,
+            commentator=commentator,
+            governor_actions=GovernorActions(),
+        ))
+
+        cycle = slot.state.completed_cycles[-1]
+        expected_gross = (exit_order.entry_price - fill_price) * exit_order.volume
+        expected_net = expected_gross - exit_order.entry_fee - exit_fee
+
+        assert had_fill is True
+        assert derive_phase(slot.state) == "S0"
+        assert cycle.trade_id == "A"
+        assert cycle.gross_profit == pytest.approx(expected_gross)
+        assert cycle.net_profit == pytest.approx(expected_net)
+        assert {order.trade_id for order in slot.state.orders if order.role == "entry"} == {"A", "B"}
+        assert any(entry.entry_type == "CYCLE_PROFIT" for entry in ledger.recent_entries(limit=20))
+
+    def test_exit_fill_fee_deduction_uses_entry_and_exit_fees(
+        self,
+        make_pair_state,
+        make_fill_event,
+        make_engine_config,
+    ):
+        """Bug class: fee tracing must subtract both sides of the round trip."""
+        cfg = make_engine_config(maker_fee_pct=0.25)
+        state = make_pair_state(phase="S1a")
+        exit_order = next(order for order in state.orders if order.role == "exit" and order.trade_id == "A")
+        fill_fee = 0.02
+        fill = make_fill_event(
+            order=exit_order,
+            price=exit_order.price,
+            fee=fill_fee,
+            timestamp=state.now + 30.0,
+        )
+
+        new_state, actions = transition(state, fill, cfg, cfg.order_size_usd)
+        book = next(action for action in actions if isinstance(action, BookCycleAction))
+        expected_fees = exit_order.entry_fee + fill_fee
+
+        assert book.fees == pytest.approx(expected_fees)
+        assert book.net_profit == pytest.approx(book.gross_profit - expected_fees)
+        assert new_state.completed_cycles[-1].fees == pytest.approx(expected_fees)
+        assert new_state.total_profit == pytest.approx(book.net_profit)
+
+
+class TestPath2StartupReconciliation:
+    """PATH 2: Startup-only reconciliation of tracked recovery txids."""
+
+    def test_startup_reconcile_processes_filled_recovery_before_loop(
+        self,
+        tmp_path,
+        mock_adapter,
+        make_pair_state,
+        make_engine_config,
+    ):
+        """Bug class: offline fills on startup previously survived into governor evaluation."""
+        state, _, recovery, _ = _make_orphaned_recovery_state(
+            make_pair_state,
+            make_engine_config,
+            trade_id="A",
+        )
+        engine, slot, ledger, commentator = _make_runtime(tmp_path, state, sticky=False)
+        mock_adapter._closed_orders[recovery.txid] = {
+            "status": "closed",
+            "vol_exec": recovery.volume,
+            "price": recovery.price,
+            "fee": 0.0,
+        }
+
+        _run(reconcile_recovery_orders(
+            adapter=mock_adapter,
+            slot_engine=engine,
+            ledger=ledger,
+            commentator=commentator,
+            governor_actions=GovernorActions(),
+        ))
+
+        assert derive_phase(slot.state) == "S0"
+        assert len(slot.state.recovery_orders) == 0
+        assert slot.state.completed_cycles[-1].from_recovery is True
+        assert {order.trade_id for order in slot.state.orders if order.role == "entry"} == {"A", "B"}
+        assert any(entry.entry_type == "RECOVERY_FILL" for entry in ledger.recent_entries(limit=20))
+
+    def test_startup_reconcile_clears_canceled_recovery_as_write_off(
+        self,
+        tmp_path,
+        mock_adapter,
+        make_pair_state,
+        make_engine_config,
+    ):
+        """Bug class: startup cancel detection must write off stale recovery risk immediately."""
+        state, _, recovery, _ = _make_orphaned_recovery_state(
+            make_pair_state,
+            make_engine_config,
+            trade_id="B",
+        )
+        engine, slot, ledger, commentator = _make_runtime(tmp_path, state, sticky=False)
+        live_entry_ids = {order.local_id for order in slot.state.orders if order.role == "entry"}
+        mock_adapter._closed_orders[recovery.txid] = {
+            "status": "canceled",
+            "vol_exec": 0.0,
+            "price": recovery.price,
+            "fee": 0.0,
+        }
+
+        _run(reconcile_recovery_orders(
+            adapter=mock_adapter,
+            slot_engine=engine,
+            ledger=ledger,
+            commentator=commentator,
+            governor_actions=GovernorActions(),
+        ))
+
+        assert len(slot.state.recovery_orders) == 0
+        assert {order.local_id for order in slot.state.orders if order.role == "entry"} == live_entry_ids
+        assert derive_phase(slot.state) == "S0"
+        assert any(entry.entry_type == "WRITE_OFF" for entry in ledger.recent_entries(limit=20))
+
