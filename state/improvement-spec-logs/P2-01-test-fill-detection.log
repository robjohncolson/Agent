+from tests.conftest import MockExchangeAdapter, make_engine_config as _base_make_engine_config
+
+
+ROOT = Path(__file__).resolve().parent
+ROOT_STR = str(ROOT)
+if ROOT_STR not in sys.path:
+    sys.path.insert(0, ROOT_STR)
+
+
+def _fill_fee(price: float, volume: float, cfg: EngineConfig) -> float:
+    return float(price) * float(volume) * float(cfg.maker_fee_pct) / 100.0
+
+
+def _bind_order_txids(state: PairState, prefix: str) -> PairState:
+    return replace(
+        state,
+        orders=tuple(
+            replace(order, txid=(order.txid or f"{prefix}-{order.local_id}"))
+            for order in state.orders
+        ),
+    )
+
+
+def _bootstrap_state(
+    *,
+    cfg: EngineConfig,
+    market_price: float,
+    now: float,
+    order_size_usd: float,
+) -> PairState:
+    state = PairState(market_price=market_price, now=now)
+    state, _, orders = bootstrap_orders(state, cfg, order_size_usd)
+    return replace(state, orders=orders)
+
+
+def _fill_entry_for_phase(
+    state: PairState,
+    *,
+    cfg: EngineConfig,
+    side: str,
+    order_size_usd: float,
+) -> PairState:
+    entry = next(
+        order for order in state.orders
+        if order.role == "entry" and order.side == side
+    )
+    filled, _ = transition(
+        state,
+        FillEvent(
+            order_local_id=entry.local_id,
+            txid=entry.txid or f"FILL-{entry.local_id}",
+            side=entry.side,
+            price=entry.price,
+            volume=entry.volume,
+            fee=_fill_fee(entry.price, entry.volume, cfg),
+            timestamp=state.now + 1.0,
+        ),
+        cfg,
+        order_size_usd,
+    )
+    return filled
+
+
+@pytest.fixture
+def mock_adapter() -> MockExchangeAdapter:
+    """Mock Kraken-style adapter with configurable query_orders responses."""
+    return MockExchangeAdapter()
+
