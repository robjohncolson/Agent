+@pytest.fixture
+def make_fill_event():
+    """Factory for FillEvent that can derive defaults from an existing order."""
+
+    def _factory(
+        *,
+        order=None,
+        order_local_id: int | None = None,
+        txid: str | None = None,
+        side: str | None = None,
+        price: float | None = None,
+        volume: float | None = None,
+        fee: float = 0.0,
+        timestamp: float | None = None,
+    ) -> FillEvent:
+        if order is not None:
+            if order_local_id is None:
+                order_local_id = int(order.local_id)
+            if txid is None:
+                txid = str(order.txid or f"FILL-{order.local_id}")
+            if side is None:
+                side = str(order.side)
+            if price is None:
+                price = float(order.price)
+            if volume is None:
+                volume = float(order.volume)
+
+        if order_local_id is None:
+            raise ValueError("order_local_id is required when order is not supplied")
+        if txid is None:
+            txid = f"FILL-{order_local_id}"
+        if side is None:
+            raise ValueError("side is required when order is not supplied")
+        if price is None:
+            raise ValueError("price is required when order is not supplied")
+        if volume is None:
+            raise ValueError("volume is required when order is not supplied")
+
+        return FillEvent(
+            order_local_id=int(order_local_id),
+            txid=str(txid),
+            side=str(side),
+            price=float(price),
+            volume=float(volume),
+            fee=float(fee),
+            timestamp=float(time.time() if timestamp is None else timestamp),
+        )
+
+    return _factory
