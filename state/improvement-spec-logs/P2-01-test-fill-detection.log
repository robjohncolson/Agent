+class TestPath3RecoveryFill:
+    """PATH 3: Recovery-order fills after a timeout orphan is on the book."""
+
+    def test_recovery_fill_does_not_place_an_extra_companion_order(
+        self,
+        make_pair_state,
+        make_engine_config,
+    ):
+        """Bug class: recovery fills once spawned the wrong companion order after repricing."""
+        state, _, recovery, orphan_actions = _make_orphaned_recovery_state(
+            make_pair_state,
+            make_engine_config,
+            trade_id="A",
+        )
+        engine = SlotEngine(initial_slots=0)
+        slot = engine.add_slot(sticky=False)
+        assert slot is not None
+        slot.state = state
+        before_entries = tuple((order.local_id, order.side, order.trade_id) for order in slot.state.orders)
+
+        actions = engine.process_recovery_fill(
+            slot,
+            RecoveryFillEvent(
+                recovery_id=recovery.recovery_id,
+                txid=recovery.txid,
+                side=recovery.side,
+                price=recovery.price,
+                volume=recovery.volume,
+                fee=0.0,
+                timestamp=slot.state.now + 1.0,
+            ),
+            GovernorActions(),
+        )
+
+        assert orphan_actions
+        assert len([action for action in actions if isinstance(action, BookCycleAction)]) == 1
+        assert not any(isinstance(action, PlaceOrderAction) for action in actions)
+        assert len(slot.state.recovery_orders) == 0
+        assert tuple((order.local_id, order.side, order.trade_id) for order in slot.state.orders) == before_entries
+        assert derive_phase(slot.state) == "S0"
+
+    def test_recovery_fill_books_cycle_as_from_recovery_for_trade_b(
+        self,
+        make_pair_state,
+        make_engine_config,
+    ):
+        """Bug class: recovery fills must preserve the recovery provenance in cycle bookkeeping."""
+        state, _, recovery, _ = _make_orphaned_recovery_state(
+            make_pair_state,
+            make_engine_config,
+            trade_id="B",
+        )
+        engine = SlotEngine(initial_slots=0)
+        slot = engine.add_slot(sticky=False)
+        assert slot is not None
+        slot.state = state
+
+        actions = engine.process_recovery_fill(
+            slot,
+            RecoveryFillEvent(
+                recovery_id=recovery.recovery_id,
+                txid=recovery.txid,
+                side=recovery.side,
+                price=recovery.price,
+                volume=recovery.volume,
+                fee=0.0,
+                timestamp=slot.state.now + 1.0,
+            ),
+            GovernorActions(),
+        )
+
+        book = next(action for action in actions if isinstance(action, BookCycleAction))
+        assert book.from_recovery is True
+        assert book.trade_id == "B"
+        assert slot.state.completed_cycles[-1].from_recovery is True
+        assert slot.state.completed_cycles[-1].trade_id == "B"
