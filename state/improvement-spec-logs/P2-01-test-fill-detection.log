+    ) -> PairState:
+        ts = float(time.time() if now is None else now)
+        cfg = make_engine_config(sticky_mode_enabled=sticky)
+
+        if phase == "S0" and not with_entry_orders:
+            state = PairState(market_price=market_price, now=ts)
+        else:
+            state = _bootstrap_state(
+                cfg=cfg,
+                market_price=market_price,
+                now=ts,
+                order_size_usd=order_size_usd,
+            )
+
+        if phase == "S0_long_only":
+            state = replace(
+                state,
+                orders=tuple(order for order in state.orders if order.side == "buy"),
+                long_only=True,
+                short_only=False,
+                mode_source="balance",
+            )
+        elif phase == "S0_short_only":
+            state = replace(
+                state,
+                orders=tuple(order for order in state.orders if order.side == "sell"),
+                long_only=False,
+                short_only=True,
+                mode_source="balance",
+            )
+        elif phase == "S1a":
+            state = _fill_entry_for_phase(
+                state,
+                cfg=cfg,
+                side="sell",
+                order_size_usd=order_size_usd,
+            )
+        elif phase == "S1b":
+            state = _fill_entry_for_phase(
+                state,
+                cfg=cfg,
+                side="buy",
+                order_size_usd=order_size_usd,
+            )
+        elif phase == "S2":
+            state = _fill_entry_for_phase(
+                state,
+                cfg=cfg,
+                side="sell",
+                order_size_usd=order_size_usd,
+            )
+            state = _fill_entry_for_phase(
+                state,
+                cfg=cfg,
+                side="buy",
+                order_size_usd=order_size_usd,
+            )
+        elif phase == "S1a_short_only":
+            state = replace(
+                state,
+                orders=tuple(order for order in state.orders if order.side == "sell"),
+                long_only=False,
+                short_only=True,
+                mode_source="balance",
+            )
+            state = _fill_entry_for_phase(
+                state,
+                cfg=cfg,
+                side="sell",
+                order_size_usd=order_size_usd,
+            )
+        elif phase == "S1b_long_only":
+            state = replace(
+                state,
+                orders=tuple(order for order in state.orders if order.side == "buy"),
+                long_only=True,
+                short_only=False,
+                mode_source="balance",
+            )
+            state = _fill_entry_for_phase(
+                state,
+                cfg=cfg,
+                side="buy",
+                order_size_usd=order_size_usd,
+            )
+        elif phase != "S0":
+            raise ValueError(f"Unsupported phase for test fixture: {phase}")
+
+        if bind_txids:
+            state = _bind_order_txids(state, txid_prefix)
+        if overrides:
+            state = replace(state, **overrides)
+        return state
+
+    return _factory
+
